      "cell_type": "code",
      "source": [
        "@torch.compile(dynamic=False)\n",
        "def hist_update_v7_fast_bwd_mod_2_noslices_max_non_buffered(\n",
        "    hist: torch.Tensor,          # [P, bs, h]\n",
        "    p_reset: torch.Tensor,       # [bs, h]\n",
        "    p_inc: torch.Tensor,         # [bs, h]\n",
        "    p_dec: torch.Tensor,         # [bs, h]\n",
        "    p_keep: torch.Tensor,        # [bs, h]\n",
        "    p_copy: torch.Tensor|None,   # [P+1, bs, h] or [bs, h, P+1]\n",
        "    eps: float,\n",
        "    gamma: torch.Tensor|float,   # scalar or [h] (broadcast ok)\n",
        "    power: bool = True,\n",
        "):\n",
        "    P, bs, h = hist.shape\n",
        "    # one = torch.ones_like(p_reset)\n",
        "    one = 1.0\n",
        "\n",
        "    # ---------- Compute weights in parallel --------------------------\n",
        "    inv_r = one - p_reset\n",
        "    # Stack weights together in a single tensor to parallelize multiplication\n",
        "    weights = torch.stack([p_inc, p_dec, p_keep], dim=0) * inv_r  # Shape: [3, bs, h]\n",
        "\n",
        "    # Unsqueeze hist and weights to align shapes for broadcasting\n",
        "    hist_unsqueezed = hist.unsqueeze(0)  # Shape: [1, P, bs, h]\n",
        "    weights_unsqueezed = weights.unsqueeze(1)  # Shape: [3, 1, bs, h]\n",
        "\n",
        "    # Perform parallel multiplication for hist\n",
        "    hist_updates = hist_unsqueezed * weights_unsqueezed  # Shape: [3, P, bs, h]\n",
        "\n",
        "    hist_inc, hist_dec, hist_keep = hist_updates.unbind(0)\n",
        "\n",
        "    # ---------- Build INC & DEC shifts (no slice-writes) --------------------\n",
        "    zero_row = torch.zeros(1, bs, h, device=hist.device, dtype=hist.dtype)\n",
        "\n",
        "    # t → t+1 (prepend 0-row, drop last) + \"overflow stays\" add-in\n",
        "    # inc_shift = torch.cat([zero_row, hist_inc[:-1]], dim=0) + torch.cat([torch.zeros_like(hist_inc[:-1]), hist_inc[-1:]], dim=0)\n",
        "\n",
        "    # t → t-1 (append 0-row, drop first) + \"underflow stays\" add-in\n",
        "    # dec_shift = torch.cat([hist_dec[1:], zero_row], dim=0) + torch.cat([hist_dec[:1], torch.zeros_like(hist_dec[1:])], dim=0)\n",
        "\n",
        "    # ---------- Base accumulation ------------------------------------------\n",
        "    out = hist_keep + (torch.cat([zero_row, hist_inc[:-1]], dim=0) + torch.cat([torch.zeros_like(hist_inc[:-1]), hist_inc[-1:]], dim=0)) + (torch.cat([hist_dec[1:], zero_row], dim=0) + torch.cat([hist_dec[:1], torch.zeros_like(hist_dec[1:])], dim=0))  # [P,bs,h]\n",
        "    # out = hist_keep + inc_shift + dec_shift  # [P,bs,h]\n",
        "\n",
        "    # ---------- Reset branches (build as tensor, add once) ------------------\n",
        "    total = 1.0  # hist.sum(0) [bs,h]\n",
        "\n",
        "    reset_block = torch.cat([\n",
        "        (total * p_reset * (p_dec + p_keep)).unsqueeze(0),  # row-0\n",
        "        (total * p_reset * p_inc).unsqueeze(0),  # row-1\n",
        "        torch.zeros(P - 2, bs, h, device=hist.device, dtype=hist.dtype)\n",
        "    ], dim=0)\n",
        "\n",
        "    out = out + reset_block\n",
        "\n",
        "    # ---------- Copy branch (if p_copy is not None and Position_Copying_Enabled) -------------------\n",
        "    # If p_copy is defined, apply position copying logic (currently commented out)\n",
        "    # if p_copy is not None and Position_Copying_Enabled:\n",
        "    #     if p_copy.shape[0] != P + 1:  # allow [bs,h,P+1]\n",
        "    #         p_copy = p_copy.permute(2, 0, 1)  # → [P+1,bs,h]\n",
        "    #     pos_cols, no_copy = p_copy[:-1], p_copy[-1]  # [P,bs,h]  [bs,h]\n",
        "    #     out = out * no_copy.unsqueeze(0) + total.unsqueeze(0) * pos_cols\n",
        "\n",
        "    # ---------- Sharpen + Renormalize -------------------------------------------\n",
        "    if power:\n",
        "        out = (out + eps).pow_(gamma)\n",
        "    out = (out + eps).div_(out.sum(0, keepdim=True).add_(eps))\n",
        "\n",
        "    return out\n"
      ],
      "metadata": {
        "id": "MzCMoHSY59xE",
        "trusted": true,
