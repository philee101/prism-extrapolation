        "\n",
        "        #     out = torch.stack(out_list, dim=0)\n",
        "        #     latentFor_gamma_proj_full = torch.stack(out_list_latent_for_gamma_proj, dim=0)\n",
        "        # else:\n",
        "        #     latentFor_gamma_proj_full = latentFor_gamma_proj\n",
        "\n",
        "        # --- NEW (vectorized, no data-dependent Python branching on tensors) ---\n",
        "        # if True:\n",
        "        #     num_ops = self.num_operators\n",
        "        #     gates   = MERGED_GATE_MLP_NUM_GATES\n",
        "        #     bs, seq_len = embeddings.shape[:2]\n",
        "        #     d = self.intermediate_dim\n",
        "\n",
        "        #     # Full outputs: start filled with the fixed value, then overwrite learnables\n",
        "        #     out_full = out.new_full((num_ops, bs, seq_len, gates), self.output_value_for_fixed_gates)\n",
        "        #     if self.learnable_idx.numel() > 0:\n",
        "        #         out_full.index_copy_(0, self.learnable_idx, out)\n",
        "\n",
        "        #     # Full latents: fixed rows = ones, learnable rows = computed latents\n",
        "        #     latent_full = latentFor_gamma_proj.new_zeros((num_ops, bs, seq_len, d))\n",
        "        #     if self.fixed_idx.numel() > 0:\n",
        "        #         ones_fixed = latentFor_gamma_proj.new_ones((self.fixed_idx.numel(), bs, seq_len, d))\n",
        "        #         latent_full.index_copy_(0, self.fixed_idx, ones_fixed)\n",
        "        #     if self.learnable_idx.numel() > 0:\n",
        "        #         latent_full.index_copy_(0, self.learnable_idx, latentFor_gamma_proj)\n",
        "\n",
        "        #     out = out_full\n",
        "        #     latentFor_gamma_proj_full = latent_full\n",
        "        \"\"\"\n",
        "        New code\n",
        "        \"\"\"\n",
        "        # --- Rebuild [num_operators, B, S, *] using lists + stack (no index_copy/scatter) ---\n",
        "        O = self.num_operators\n",
        "        B, S = bs, seq_len\n",
        "        G = MERGED_GATE_MLP_NUM_GATES\n",
        "        D = self.intermediate_dim\n",
        "\n",
        "        # Learnable slices come in order 0..N-1 along dim 0\n",
        "        learn_out_list = list(out.unbind(0))                       # N × [B, S, G]\n",
        "\n",
        "        if not USE_SEPARATE_LINEAR_PROJ_FOR_INPT_DPDNT_GAMMA_LATENTS:\n",
        "            learn_lat_list = list(latentFor_gamma_proj.unbind(0))      # N × [B, S, D]\n",
        "        else:\n",
        "            # Use self.separate_linear_proj_gamma_latent,\n",
        "            # inited with shape (self.num_operators, self.input_dim, self.intermediate_dim)\n",
        "            initial_inputs_ln = F.layer_norm(initial_inputs, normalized_shape=initial_inputs.shape[-1:])\n",
        "\n",
        "            # Bias initialized with shape (self.num_operators, 1, self.intermediate_dim)\n",
        "            latentFor_gamma_proj_full = torch.einsum(\"bsd,ndf->nbsf\", initial_inputs_ln, self.separate_linear_proj_gamma_latent) + self.separate_linear_bias_gamma_latent.unsqueeze(-2)\n",
        "\n",
        "\n",
        "        li = 0  # index into learnable lists\n",
        "\n",
        "        # Fixed-row templates (shared tensors; stacking will materialize copies)\n",
        "        fixed_out_template = out.new_full((B, S, G), self.output_value_for_fixed_gates)\n",
        "        fixed_lat_template = latentFor_gamma_proj.new_ones((B, S, D))\n",
        "\n",
        "        out_slots: list[torch.Tensor] = []\n",
        "        if not USE_SEPARATE_LINEAR_PROJ_FOR_INPT_DPDNT_GAMMA_LATENTS:\n",
        "            lat_slots: list[torch.Tensor] = []\n",
        "\n",
        "        # Iterate over operator slots using Python booleans (no Tensor-based branching)\n",
        "        for is_fixed in self._slot_is_fixed:\n",
        "            if is_fixed:\n",
        "                out_slots.append(fixed_out_template)\n",
        "                if not USE_SEPARATE_LINEAR_PROJ_FOR_INPT_DPDNT_GAMMA_LATENTS:\n",
        "                    lat_slots.append(fixed_lat_template)\n",
        "            else:\n",
        "                out_slots.append(learn_out_list[li])\n",
        "                if not USE_SEPARATE_LINEAR_PROJ_FOR_INPT_DPDNT_GAMMA_LATENTS:\n",
        "                    lat_slots.append(learn_lat_list[li])\n",
        "                li += 1\n",
        "\n",
        "        # Stack back into the original operator order\n",
        "        out = torch.stack(out_slots, dim=0)                        # [O, B, S, G]\n",
        "        if not USE_SEPARATE_LINEAR_PROJ_FOR_INPT_DPDNT_GAMMA_LATENTS:\n",
        "            latentFor_gamma_proj_full = torch.stack(lat_slots, dim=0)  # [O, B, S, D]\n",
        "\n",
        "\n",
        "        # cache outputs if needed\n",
        "        if not self.training:\n",
        "            with torch.no_grad():\n",
        "                self.latest_scalar_outputs.append(out.clone())\n",
        "\n",
        "        assert latentFor_gamma_proj_full.shape == (self.num_operators, bs, seq_len, self.intermediate_dim)\n",
        "        return out, latentFor_gamma_proj_full  # ([num_ops, batch, seq, 4])\n",
        "\n"
      ],
