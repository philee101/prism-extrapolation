    {
      "cell_type": "markdown",
      "source": [
        "## Pretty Printing/Aligning Predicted Outputs"
      ],
      "metadata": {
        "id": "YwkmxXYAr2yu"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "def split_problem(problem_str):\n",
        "    \"\"\"\n",
        "    Splits a multiplication problem string of the form:\n",
        "      <prefix>[<summand1>+<summand2>+ ... +<summandN>]\n",
        "    into the prefix (everything up to the '[') and a list of summands.\n",
        "    If no '[' is found, returns the entire string as the prefix and an empty list.\n",
        "    \"\"\"\n",
        "    open_bracket = problem_str.find('[')\n",
        "    if open_bracket == -1:\n",
        "        return problem_str, []\n",
        "    close_bracket = problem_str.rfind(']')\n",
        "    prefix = problem_str[:open_bracket+1]  # include the '['\n",
        "    summands_str = problem_str[open_bracket+1:close_bracket]\n",
        "    # Split summands on the plus sign.\n",
        "    summands = summands_str.split('+')\n",
        "    return prefix, summands\n",
        "\n",
        "def pretty_print_alignment(predicted, expected):\n",
        "    \"\"\"\n",
        "    Pretty-prints the predicted and expected multiplication problems,\n",
        "    grouping the summands (i.e. the tokens inside the square brackets) by the digit\n",
        "    of the right multiplicand.\n",
        "\n",
        "    Example output:\n",
        "\n",
        "      Problem:\n",
        "         Predicted prefix:  97308943x15852979=97308943x[\n",
        "         Expected prefix:   97308943x15852979=97308943x[\n",
        "      ---------------------------------------------------------------\n",
        "      Digit      | Predicted                                     | Expected\n",
        "      ---------------------------------------------------------------\n",
        "      Digit 1:   | 1*(1->1)(5->0)(8->0)(5->0)(2->0)(9->0)(7->0)(9->0) | 1*(1->1)(5->0)(8->0)(5->0)(2->0)(9->0)(7->0)(9->0)\n",
        "      Digit 2:   | 5*(5->1)(8->0)(5->0)(2->0)(9->0)(7->0)(9->0)      | 5*(5->1)(8->0)(5->0)(2->0)(9->0)(7->0)(9->0)\n",
        "      ...\n",
        "      correct = 0\n",
        "    \"\"\"\n",
        "    pred_prefix, pred_summands = split_problem(predicted)\n",
        "    exp_prefix, exp_summands = split_problem(expected)\n",
        "\n",
        "    print(\"Problem:\")\n",
        "    print(\" Predicted prefix: \", pred_prefix)\n",
        "    print(\" Expected prefix:  \", exp_prefix)\n",
        "    print(\"-\" * 80)\n",
        "\n",
        "    # Determine the number of summands (digits) to display\n",
        "    n = max(len(pred_summands), len(exp_summands))\n",
        "\n",
        "    # Print header row\n",
        "    header = \"{:<10s} | {:<60s} | {:<60s}\".format(\"Digit\", \"Predicted\", \"Expected\")\n",
        "    print(header)\n",
        "    print(\"-\" * len(header))\n",
        "\n",
        "    for i in range(n):\n",
        "        pred_token = pred_summands[i] if i < len(pred_summands) else \"\"\n",
        "        exp_token = exp_summands[i] if i < len(exp_summands) else \"\"\n",
        "        line = \"{:<10s} | {:<60s} | {:<60s}\".format(f\"Digit {i+1}:\", pred_token, exp_token)\n",
        "        print(line)\n",
        "\n",
        "    correct = predicted == expected\n",
        "    print(\"correct =\", int(correct))\n",
        "\n",
        "\n",
        "# # --- Example usage:\n",
        "\n",
        "# # These are example strings for predicted and expected outputs.\n",
        "# predicted_str = \"97308943x[8*(1->1)(5->0)(9->0)(1->0)(1->0)++(5->0)+5*(5->1)(9->0)(9->0)(9->0)(3->0)+++8*(8->1)(9->0)(9->0)(9->0)+(5->0)+5*(5->1)(9->0)(9->0)+++2*(2->1)(9->0)(7->0)++9*(9->1)(7->0)(5->0)+7*(7->1)(9->0)+9*(9->1)]\"\n",
        "# expected_str  = \"97308943x[1*(1->1)(5->0)(8->0)(5->0)(2->0)(9->0)(7->0)(9->0)+5*(5->1)(8->0)(5->0)(2->0)(9->0)(7->0)(9->0)+8*(8->1)(5->0)(2->0)(9->0)(7->0)(9->0)+5*(5->1)(2->0)(9->0)(7->0)(9->0)+2*(2->1)(9->0)(7->0)(9->0)+9*(9->1)(7->0)(9->0)+7*(7->1)(9->0)+9*(9->1)]\"\n",
        "\n",
        "# pretty_print_alignment(predicted_str, expected_str)\n"
      ],
      "metadata": {
        "id": "a_JiCbHqr6Ab",
        "scrolled": true,
        "trusted": true,
        "execution": {
          "iopub.status.busy": "2025-09-17T19:06:52.741044Z",
          "iopub.execute_input": "2025-09-17T19:06:52.741263Z",
          "iopub.status.idle": "2025-09-17T19:06:52.759851Z",
          "shell.execute_reply.started": "2025-09-17T19:06:52.741246Z",
