      "metadata": {
        "id": "ugydMr69xDn2"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "if model_rse is not None and hasattr(model_rse.relative_encodings[0], 'cached_attention_matrices'):\n",
        "    for i,rse in enumerate(model_rse.relative_encodings):\n",
        "\n",
        "        # print(model_rse.relative_encodings[0].cached_attention_matrices.shape) # Expected Shape: torch.Size([1, num operators/2, seq_len, seq_len+1])\n",
        "        # cam = model_rse.relative_encodings[0].cached_attention_matrices\n",
        "        if rse is None:\n",
        "            continue\n",
        "        cam = rse.cached_attention_matrices\n",
        "        print('===' * 30)\n",
        "        print('===' + f'RSE layer {i+1}' + '===')\n",
        "        print('===' * 30)\n",
        "        total_count_max = 0\n",
        "        total_count_gr_than_06 = 0\n",
        "        # print the first matrix:\n",
        "        # print(model_rse.relative_encodings[0].cached_attention_matrices[0, 0])\n",
        "        for op_idx in range(cam.shape[1]):\n",
        "            print(f'---' * 10)\n",
        "            print(f'Operator {op_idx}')\n",
        "            # print(cam[0, op_idx])\n",
        "            prob_hist = cam[0, op_idx]\n",
        "            seq_len = prob_hist.shape[0]\n",
        "            assert prob_hist.shape == (seq_len, seq_len + 1)\n",
        "            # prob_hist = prob_hist[:,:-1]\n",
        "            # assert prob_hist.shape == (seq_len, seq_len)\n",
        "            print(f'prob_hist.shape = {prob_hist.shape}')\n",
        "\n",
        "            # Print the index of maximum in dim=-1 of prob_hist instead of the above commented out statement:\n",
        "            count_max = 0\n",
        "            count_prob_gr_than_06 = 0\n",
        "            for i in range(prob_hist.shape[0]):\n",
        "              if prob_hist[i].argmax() != prob_hist.shape[-1]-1:\n",
        "                  print(f'{i}: Max={prob_hist[i].max()}, index of max={prob_hist[i].argmax()}, second highest={prob_hist[i][prob_hist[i] != prob_hist[i].max()].max()}, index of second highest={prob_hist[i][prob_hist[i] != prob_hist[i].max()].argmax()}')\n",
        "                  count_max += 1\n",
        "                  if prob_hist[i].max() > 0.6:\n",
        "                      count_prob_gr_than_06 += 1\n",
        "                      total_count_gr_than_06 += 1\n",
        "\n",
        "                  total_count_max += 1\n",
        "            print(f'count_max = {count_max}, count_prob_gr_than_06 = {count_prob_gr_than_06}')\n",
        "\n",
        "        print(f'total_count_max = {total_count_max}, total_count_gr_than_06 = {total_count_gr_than_06}')\n"
      ],
