    {
      "cell_type": "code",
      "source": [
        "import torch\n",
        "\n",
        "@torch.compile(dynamic=False)\n",
        "def hist_update_v7_fast_bwd_mod_2_fused(\n",
        "    hist:    torch.Tensor,          # [P, bs, h]\n",
        "    p_reset: torch.Tensor,          # [bs, h]\n",
        "    p_inc:    torch.Tensor,         # [bs, h]\n",
        "    p_dec:    torch.Tensor,         # [bs, h]\n",
        "    p_keep:   torch.Tensor,         # [bs, h]\n",
        "    p_copy:   torch.Tensor|None,    # [P+1, bs, h] or None\n",
        "    eps:      float,\n",
        "    gamma:    torch.Tensor|float,   # scalar or [h]\n",
        "    power:    bool = True,\n",
        ") -> torch.Tensor:\n",
        "    P, bs, h = hist.shape\n",
        "\n",
        "    # just make everything contiguous\n",
        "    hist    = hist.contiguous()\n",
        "    p_reset = p_reset.contiguous()\n",
        "    p_inc   = p_inc.contiguous()\n",
        "    p_dec   = p_dec.contiguous()\n",
        "    p_keep  = p_keep.contiguous()\n",
        "    if p_copy is not None:\n",
        "        p_copy = p_copy.contiguous()\n",
        "\n",
        "    # 1) build prev/next via in-place slicing (2 kernels)\n",
        "    hist_prev = torch.empty_like(hist)\n",
        "    hist_next = torch.empty_like(hist)\n",
        "    hist_prev[1:].copy_(hist[:-1])\n",
        "    hist_prev[0].zero_()\n",
        "    hist_next[:-1].copy_(hist[1:])\n",
        "    hist_next[-1].zero_()\n",
        "\n",
        "    # 2) weight vectors [bs,h] → broadcast-ready\n",
        "    inv_r = 1.0 - p_reset               # [bs,h]\n",
        "    w_inc  = (inv_r * p_inc)[None]      # [1,bs,h]\n",
        "    w_keep = (inv_r * p_keep)[None]\n",
        "    w_dec  = (inv_r * p_dec)[None]\n",
        "\n",
        "    # 3) stack the three “taps” + apply weights in one fused multiply+sum\n",
        "    hist_keep = hist * w_keep\n",
        "    taps = torch.stack([\n",
        "        hist_prev * w_inc,\n",
        "        hist_keep,\n",
        "        hist_next * w_dec\n",
        "    ], dim=-1)                         # [P,bs,h,3]\n",
        "    out = taps.sum(dim=-1)             # [P,bs,h] — one big fused kernel\n",
        "\n",
        "    # 4) reset branch\n",
        "    total = hist.sum(0, keepdim=True)  # [1,bs,h]\n",
        "    out[0] += (total * p_reset * (p_dec + p_keep)).squeeze(0)\n",
        "    if P > 1:\n",
        "        out[1] += (total * p_reset * p_inc).squeeze(0)\n",
        "\n",
        "    # 5) copy branch\n",
        "    if p_copy is not None:\n",
        "        if p_copy.shape[0] != P+1:\n",
        "            p_copy = p_copy.permute(2,0,1)\n",
        "        pos_cols = p_copy[:-1]           # [P,bs,h]\n",
        "        no_copy  = p_copy[-1].unsqueeze(0)# [1,bs,h]\n",
        "        out = out * no_copy + total * pos_cols\n",
        "\n",
        "    # 6) sharpen + renorm\n",
        "    if power:\n",
        "        out = (out + eps).pow(gamma)\n",
        "    out = (out + eps) / (out.sum(0, keepdim=True) + eps)\n",
        "\n",
        "    return out\n",
        "\n",
        "# compile for best fusion\n",
        "# compiled_fused = torch.compile(\n",
        "#     hist_update_v7_fast_bwd_mod_2_fused,\n",
        "#     backend='inductor'\n",
        "# )\n"
      ],
