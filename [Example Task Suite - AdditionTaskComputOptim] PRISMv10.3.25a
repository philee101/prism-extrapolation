    },
    {
      "cell_type": "code",
      "source": [
        "# Print average operator norms of layer.ff for each layer\n",
        "for i,layer in enumerate(model_rse.layers):\n",
        "    # print(f'Layer {i} norm: {torch.norm(layer.ff[0].weight, p=2)}, shape: {layer.ff[0].weight.shape}')\n",
        "    # Use frobenius norm:\n",
        "    print(f'Layer {i} norm: {torch.norm(layer.ff[0].weight, p=\"fro\")}, shape: {layer.ff[0].weight.shape}')\n",
        "    print(f'\\tdownProjection norm: {torch.norm(layer.ff[2].weight, p=\"fro\")}, shape: {layer.ff[2].weight.shape}')\n",
        "    # Print operator norms, i.e. max eigvals:\n",
        "    print(f'Layer {i} operator norms: {torch.linalg.svdvals(layer.ff[0].weight).max()}, {torch.linalg.svdvals(layer.ff[2].weight).max()}')\n",
        "    print(f'\\tDownProjection operator norms: {torch.linalg.svdvals(layer.ff[2].weight).max()}')\n",
        "    # Print max column norms:\n",
        "    print(f'\\tLayer {i} max column norms: {torch.norm(layer.ff[0].weight, p=2, dim=-1).max()}, {torch.norm(layer.ff[2].weight, p=2, dim=-1).max()}')\n",
        "    print('---'*50)"
      ],
      "metadata": {
        "id": "uvf8MiH3vmqi"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# Print output vector norms of model_rse.fc_out\n",
        "print(f'Shape of model_rse.fc_out.weight: {model_rse.fc_out.weight.shape}') # Expected: [VOCAB_SIZE, VOCAB_N_DIM]\n",
        "for i in range(VOCAB_SIZE):\n",
        "    print(f'Norm of row {i}: {torch.norm(model_rse.fc_out.weight[i], p=2)}')\n",
        "\n",
        "# Print norm of bias vector:\n",
        "# print(f'Norm of model_rse.fc_out.bias: {torch.norm(model_rse.fc_out.bias, p=2)}')"
      ],
      "metadata": {
        "id": "jm0PJ5llvV4i"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# Print the rank and condition number of the feedforward and v_linear layers:\n",
        "for i,layer in enumerate(model_rse.layers):\n",
        "    print(f'Layer {i} feedforward inputProj rank: {torch.linalg.matrix_rank(layer.ff[0].weight)}, condition number: {torch.linalg.cond(layer.ff[0].weight)}')\n",
        "    print(f'Layer {i} feedforward downProj rank: {torch.linalg.matrix_rank(layer.ff[2].weight)}, condition number: {torch.linalg.cond(layer.ff[2].weight)}')\n",
        "    print(f'Layer {i} v_linear inputProj rank: {torch.linalg.matrix_rank(layer.self_attn.v_linear.weight)}, condition number: {torch.linalg.cond(layer.self_attn.v_linear.weight)}')\n",
        "    print(f'---')"
      ],
      "metadata": {
        "id": "tHemgYWLTzwl"
      },
      "execution_count": null,
      "outputs": []
    },
