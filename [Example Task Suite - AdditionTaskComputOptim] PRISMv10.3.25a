      },
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "markdown",
      "source": [
        "## Plot the histogram to viz. the distribution of rpe.latest_scalar_outputs:\n"
      ],
      "metadata": {
        "id": "swdaRWxjWUk8"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Plot the histogram to viz. the distribution of rpe.latest_scalar_outputs:\n",
        "for i, rpe in enumerate(model_rse.relative_encodings):\n",
        "    plt.figure(figsize=(10, 6))\n",
        "    # plt.hist(rpe.latest_scalar_outputs.detach().cpu().numpy(), bins=50)\n",
        "\n",
        "    for gate in [rpe.reset_gate, rpe.output_gate]:\n",
        "        list_of_outputs = gate.latest_scalar_outputs\n",
        "\n",
        "        # Each elem is a tensor - flatten it and add to list:\n",
        "        for elem in list_of_outputs:\n",
        "\n",
        "            for operator in range(elem.shape[0]):\n",
        "                flattened_list = elem[operator].flatten().tolist()\n",
        "\n",
        "                plt.hist(flattened_list, bins=50)\n",
        "                plt.title(f'Distribution of latest_scalar_outputs for gate {operator}, type={\"reset\" if gate is rpe.reset_gate else \"output\"}')\n",
        "                plt.xlabel('Value')\n",
        "                plt.ylabel('Frequency')\n",
        "                plt.show()\n",
        "\n",
        "\n"
      ],
      "metadata": {
        "id": "UR6JzRGEVb6h",
        "scrolled": true,
        "trusted": true
      },
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "markdown",
      "source": [
        "## # Print {postSoftmaxScalingFactors_K, postSoftmaxScalingFactors_Q} for each MHA:\n"
      ],
      "metadata": {
        "id": "O7Nml6gE2Rsc"
      }
    },
    {
      "cell_type": "code",
      "source": [],
      "metadata": {
        "id": "XD0tFT89RS7b",
        "scrolled": true,
        "trusted": true
      },
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "code",
      "source": [],
      "metadata": {
        "id": "zO3oiTHbNRDv",
        "scrolled": true,
        "trusted": true
      },
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "code",
      "source": [],
      "metadata": {
        "id": "wcwYEvFU0L9a",
        "scrolled": true,
        "trusted": true
      },
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "code",
      "source": [],
      "metadata": {
        "id": "s47UTBMMYadP",
        "scrolled": true,
        "trusted": true
      },
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "code",
      "source": [],
      "metadata": {
        "id": "mN9Tk2_iwxOQ",
        "scrolled": true,
        "trusted": true
      },
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "code",
      "source": [
        "# Print {post_scaling_factors_QK, post_scaling_factors_QK} for each MHA:\n",
        "for layer, decoder_layer in enumerate(model_rse.layers):\n",
        "    for head_idx in range(decoder_layer.self_attn.num_heads):\n",
        "        # self.pos_coeffs_Q = nn.Parameter(torch.abs(torch.randn(num_heads, half_ops) / half_ops))\n",
        "        print(f'---' * 10)\n",
        "        print(f'Layer {layer}, head {head_idx}')\n",
        "\n",
        "        # post_scaling_factors_QK => nn.Parameter(torch.ones(num_heads, new_half_ops) / POST_QK_SCALING_FACTORS_MULTIPLIER)\n",
        "        post_scaling_factors_QK = decoder_layer.self_attn.post_scaling_factors_QK[head_idx]\n",
        "\n",
        "\n",
        "        # Mult by COEFFS_Q_MULTIPLIER:\n",
        "        post_scaling_factors_QK = post_scaling_factors_QK * POST_QK_SCALING_FACTORS_MULTIPLIER\n",
        "\n",
        "        print(f'post_scaling_factors_QK = {post_scaling_factors_QK}')\n",
        "        # Print max:\n",
        "        # print(f'max pos_coeffs_Q = {torch.max(decoder_layer.self_attn.pos_coeffs_Q[head_idx])}')\n",
        "        print(f'max post_scaling_factors_QK = {torch.max(post_scaling_factors_QK.abs())}')\n",
        "        # Print sum over half_ops:\n",
        "        # print(f'sum pos_coeffs_Q = {torch.sum(decoder_layer.self_attn.pos_coeffs_Q[head_idx])}')\n",
        "        # print(f'sum abs(post_scaling_factors_QK) = {torch.sum(post_scaling_factors_QK.abs())}')\n",
        "        print(f'norm(post_scaling_factors_QK) = {torch.norm(post_scaling_factors_QK)}')\n",
        "        # print(f'pos_coeffs_K = {decoder_layer.self_attn.pos_coeffs_K[head_idx]}')\n",
        "        print(decoder_layer.self_attn.abs_enc.device)\n",
        "        # Print mha expScaling factors QK:\n",
        "        # print(f'mha_expScalingFactors_QK = {decoder_layer.self_attn.exp_scaling_factors_QK[head_idx]}')\n",
        "        #\n",
        "\n",
        "        print('---' * 10)\n",
        "\n"
      ],
      "metadata": {
        "id": "uqdAu92vOy6c",
        "scrolled": true,
        "trusted": true
      },
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "code",
      "source": [
        "print(optimizers_dict)"
