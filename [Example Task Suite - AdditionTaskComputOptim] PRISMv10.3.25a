          "iopub.status.idle": "2025-09-17T19:06:59.795702Z",
          "shell.execute_reply.started": "2025-09-17T19:06:59.779816Z",
          "shell.execute_reply": "2025-09-17T19:06:59.795011Z"
        }
      },
      "outputs": [],
      "execution_count": null
