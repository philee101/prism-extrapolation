        "#     reset_vals   = total.unsqueeze(0) * p_reset.unsqueeze(0) * reset_coeffs  # [2, bs, h]\n",
        "\n",
        "#     next_hist = hist.new_zeros((P, bs, h))\n",
        "#     next_hist[0], next_hist[1] = reset_vals[0], reset_vals[1]\n",
        "\n",
        "#     # ③ fused weight-apply for keep, inc, dec\n",
        "#     # stack weights → [3, bs, h], then broadcast-multiply over hist → [3, P, bs, h]\n",
        "#     weights_stack = torch.stack([w_keep, w_inc, w_dec], dim=0)       # [3, bs, h]\n",
        "#     bases         = hist.unsqueeze(0) * weights_stack.unsqueeze(1)  # [3, P, bs, h]\n",
        "#     base_keep, base_inc, base_dec = bases.unbind(0)                 # each [P, bs, h]\n",
        "\n",
        "#     # inc-branch: shift up, clamp overflow\n",
        "#     inc_roll = torch.cat([\n",
        "#         hist.new_zeros(1, bs, h),\n",
        "#         base_inc[:-1]\n",
        "#     ], dim=0)\n",
        "#     inc_roll[-1].add_(base_inc[-1])\n",
        "\n",
        "#     # dec-branch: shift down, clamp underflow\n",
        "#     dec_roll = torch.cat([\n",
        "#         base_dec[1:],\n",
        "#         hist.new_zeros(1, bs, h)\n",
        "#     ], dim=0)\n",
        "#     dec_roll[0].add_(base_dec[0])\n",
        "\n",
        "#     next_hist.add_(base_keep).add_(inc_roll).add_(dec_roll)\n",
        "\n",
        "#     # ④ copy-branch\n",
        "#     if p_copy is not None:\n",
        "#         if p_copy.dim() == 3 and p_copy.size(0) != P_hist + 1:\n",
        "#             p_copy = p_copy.permute(2, 0, 1)\n",
        "#         pos_cols = p_copy[:P_hist]           # [P_hist, bs, h]\n",
        "#         no_copy  = p_copy[P_hist]            # [bs, h]\n",
        "#         next_hist.mul_(no_copy.unsqueeze(0))\n",
        "#         next_hist.add_(total.unsqueeze(0) * pos_cols)\n",
        "\n",
        "#     # ⑤ sharpening + renormalize\n",
        "#     if power_sharpen:\n",
        "#         next_hist = (next_hist + eps).pow(gamma.view(h) if type(gamma) is Tensor else gamma)\n",
        "#     # denom = next_hist.sum(0).add_(eps)       # [bs, h]\n",
        "#     # next_hist.div_(denom.unsqueeze(0))\n",
        "#     next_hist.div_(next_hist.sum(0).add(eps).unsqueeze(0))\n",
        "\n",
        "\n",
        "#     if cached_hists_qk_fordebug is not None and not DISABLE_POSITION_CACHING:\n",
        "#         cached_hists_qk_fordebug.append(next_hist)\n",
        "\n",
        "#     return next_hist\n",
        "\n",
        "\n",
        "import torch.nn.functional as F\n",
        "\n",
        "@torch.compile(dynamic=False)\n",
        "def histogram_update_learnable_sharpened_copy_pos_convolve(\n",
        "    hist: Tensor,                    # [P, bs, h]\n",
        "    p_reset: Tensor,                 # [bs, h]\n",
        "    p_incr: Tensor,                  # [bs, h]\n",
        "    p_decr: Tensor,                  # [bs, h]\n",
        "    p_keep: Tensor,                  # [bs, h]\n",
        "    p_copy: Optional[Tensor],        # None or [P+1, bs, h] / [bs, h, P+1]\n",
        "    eps: float,\n",
        "    gamma: Tensor,                   # [h] or scalar\n",
        "    power_sharpen: bool,\n",
        "    next_hist: Tensor,               # [P, bs, h] pre-allocated\n",
        "    inc_roll: Tensor = None,                # [P, bs, h] pre-allocated\n",
        "    dec_roll: Tensor = None,                # [P, bs, h] pre-allocated\n",
        ") -> Tensor:\n",
        "    P, bs, h = hist.shape\n",
        "\n",
        "    # --- 1) reset injection as before ---\n",
        "    total = hist.sum(0)                             # [bs,h]\n",
        "    # next_hist = torch.zeros_like(hist)\n",
        "\n",
        "    next_hist[0].add_( total * p_reset * (p_decr+p_keep) )\n",
        "    next_hist[1].add_( total * p_reset * p_incr )\n",
        "\n",
        "    # --- 2) conv for inc/keep/dec all at once ---\n",
        "    # reshape → [1, bs*h, P]\n",
        "    x = hist.permute(1,2,0).reshape(1, bs*h, P)\n",
        "    # kernel per–(batch×head): shape [bs*h, 1, 3]\n",
        "    nr = (1.0 - p_reset)\n",
        "    kernel = torch.stack([nr*p_decr, nr*p_keep, nr*p_incr], dim=2)  # [bs,h,3]\n",
        "    kernel = kernel.reshape(bs*h, 1, 3)\n",
        "    # do grouped conv1d with padding=1\n",
        "    y = F.conv1d(x, kernel, padding=1, groups=bs*h)\n",
        "    flow = y.reshape(bs,h,P).permute(2,0,1)  # [P, bs, h]\n",
        "\n",
        "    next_hist = next_hist.add_(flow)\n",
        "\n",
        "    # --- 3) copy branch + sharpen + norm as before ---\n",
        "    if p_copy is not None:\n",
        "        if p_copy.dim()==3 and p_copy.size(0)!=P+1:\n",
        "            p_copy = p_copy.permute(2,0,1)\n",
        "        pos_cols = p_copy[:P]; no_copy = p_copy[P]\n",
        "        next_hist.mul_(no_copy.unsqueeze(0))\n",
        "        next_hist.add_( total.unsqueeze(0) * pos_cols )\n",
        "\n",
        "    if power_sharpen:\n",
        "        next_hist = (next_hist + eps).pow(gamma.view(h) if type(gamma) is Tensor else gamma)\n",
        "\n",
        "    den = next_hist.sum(0).add_(eps)\n",
        "    return next_hist.div(den.unsqueeze(0))\n",
        "\n",
        "\n",
        "\n",
        "# def histogram_update_learnable_sharpened_copy_pos_optim_v4_prealloced_buffers_(\n",
