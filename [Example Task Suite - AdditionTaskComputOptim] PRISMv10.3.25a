        "#             # print(f'len(recurrent_array_entry) = {len(recurrent_array_entry)}')\n",
        "\n",
        "#             e = recurrent_array_entry[r]\n",
        "#             aw = e[0][head_idx]\n",
        "#             if isinstance(aw, torch.Tensor):\n",
        "#                 aw = aw.detach().cpu().numpy()\n",
        "\n",
        "#             sns.heatmap(aw,\n",
        "#                         cmap='viridis', cbar=True)\n",
        "#             plt.title(f'Self-Attention Weights - Layer {layer_num_}, Array Entry Index = {r}, Head {head_idx}, Example {visualize_attn_example_index}')\n",
        "#             plt.xlabel('Input Sequence')\n",
        "#             plt.ylabel('Output Sequence')\n",
        "#             plt.show()\n",
        "#             plt.show()\n",
        "#             if r > 0:\n",
        "#               torch.set_printoptions(threshold=10000000000)\n",
        "#               # print(aw.detach())\n",
        "#     print('visualize_attn(): num layers = ', len(attn_weights_dict))\n",
        "#     for i in range(0, len(attn_weights_dict), 1):\n",
        "#         if visualize_attn_layer_indices is not None:\n",
        "#             if i not in visualize_attn_layer_indices:\n",
        "#                 continue\n",
        "#         print(f'visualize_attn(): layer = {i}')\n",
        "#         for j in range(NUM_HEADS):  # TODO: hard coded num heads == 2\n",
        "#             _visualize(i, j)\n",
        "\n",
        "import numpy as np\n",
        "import torch\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "def visualize_attention(attn_weights_dict,\n",
        "                        visualize_attn_example_index,\n",
        "                        visualize_attn_layer_skip=1,\n",
        "                        visualize_attn_layer_indices=None,\n",
        "                        kind=\"pos\",                    # [ADD - RSEv0.99999-bench-v3.1]]  \"pos\" | \"content\"\n",
        "                        num_heads_override=None):      # [ADD - RSEv0.99999-bench-v3.1]]  optionally override head count\n",
        "    \"\"\"\n",
        "    Visualizes attention weights. Now supports:\n",
        "      - positional heads (\"pos\") from MultiHeadAttention_ScalarPos\n",
        "      - content heads (\"content\") from MultiHeadAttention (when present)\n",
        "\n",
        "    `attn_weights_dict[layer_idx]` can be:\n",
        "      - a list (legacy: positional-only), or\n",
        "      - a dict {\"pos\": [...], \"content\": [...]} (new).\n",
        "    \"\"\"\n",
        "\n",
        "    def _pick_array_for_kind(layer_entry):\n",
        "        # legacy: just a list → treat as 'pos'\n",
        "        if isinstance(layer_entry, list):\n",
        "            return layer_entry\n",
        "        # new: dict holding both streams\n",
        "        if isinstance(layer_entry, dict):\n",
        "            return layer_entry.get(kind, [])\n",
        "        return []\n",
        "\n",
        "    def _infer_num_heads(entry_list):\n",
        "        # entry_list is a list of per-forward numpy/tensors with shape [B, H, S, S]\n",
        "        if not entry_list:\n",
        "            return 0\n",
        "        e0 = entry_list[0]\n",
        "        # unify to numpy and read H\n",
        "        if isinstance(e0, torch.Tensor):\n",
        "            e0 = e0.detach().cpu().numpy()\n",
        "        try:\n",
        "            return int(e0.shape[1])  # [B, H, S, S]\n",
        "        except Exception:\n",
        "            return 0\n",
        "\n",
        "    def _visualize(layer_num, head_idx, arr_list):\n",
        "        print(f'Layer {layer_num}, head {head_idx}, entries = {len(arr_list)}')\n",
        "        for r in range(0, len(arr_list), visualize_attn_layer_skip):\n",
        "            e = arr_list[r]\n",
        "            if isinstance(e, torch.Tensor):\n",
        "                e = e.detach().cpu()\n",
        "            # e: [B, H, S, S]; pick example, then head\n",
        "            aw = e[visualize_attn_example_index % e.shape[0], head_idx]  # [S, S]\n",
        "            mat = aw.detach().cpu().float().numpy() if isinstance(aw, torch.Tensor) else np.asarray(aw, dtype=float)\n",
        "\n",
        "            fig, ax = plt.subplots(figsize=(5, 4), dpi=150) # <viz. attn dpi>\n",
        "            im = ax.imshow(mat, cmap='viridis', interpolation='nearest', aspect='auto')\n",
        "            fig.colorbar(im, ax=ax)\n",
        "            ax.set(title=f'[{kind}] Layer {layer_num}  Entry {r}  Head {head_idx}  Ex {visualize_attn_example_index}',\n",
        "                   xlabel='Input Sequence', ylabel='Output Sequence')\n",
        "            plt.tight_layout()\n",
        "            plt.show()\n",
        "\n",
        "    num_layers = len(attn_weights_dict)\n",
        "    print(f'---\\nvisualize_attention(kind=\"{kind}\"): num layers = {num_layers}')\n",
        "\n",
        "    for layer in range(num_layers):\n",
        "        if visualize_attn_layer_indices is not None and layer not in visualize_attn_layer_indices:\n",
        "            continue\n",
        "\n",
        "        arr = _pick_array_for_kind(attn_weights_dict[layer])\n",
        "        n_heads = num_heads_override if num_heads_override is not None else _infer_num_heads(arr)\n",
        "        if n_heads == 0 or not arr:\n",
        "            print(f'Layer {layer}: no \"{kind}\" attention cached.')\n",
        "            continue\n",
        "\n",
        "        for head in range(n_heads):\n",
        "            _visualize(layer, head, arr)\n"
      ],
      "metadata": {
