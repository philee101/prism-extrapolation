      }
    },
    {
      "cell_type": "code",
      "source": [
        "save_ckpt('backup before profiling SCAN.pth', model_rse)"
      ],
      "metadata": {
        "id": "z0B-QImu1kfL",
        "trusted": true
      },
      "outputs": [],
