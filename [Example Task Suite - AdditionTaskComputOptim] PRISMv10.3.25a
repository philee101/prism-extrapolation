    {
      "cell_type": "markdown",
      "source": [
        "## histogram update - non-vjp based backward, triton fwd"
      ],
      "metadata": {
        "id": "2nXRwIkjz3iy"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "def histogram_update_dummy_nontrivial_grad(\n",
        "    hist: torch.Tensor,               # [P, bs, h]\n",
        "    p_reset: torch.Tensor,            # [bs, h]\n",
        "    p_incr: torch.Tensor,             # [bs, h]\n",
        "    p_decr: torch.Tensor,             # [bs, h]\n",
        "    p_keep: torch.Tensor,             # [bs, h]\n",
        "    p_copy: Optional[torch.Tensor],   # unused if DISABLE_COPY_POS=True\n",
        "    eps: float,\n",
        "    gamma: float,\n",
        "    power_sharpen: bool,\n",
        "    # buf: torch.Tensor,                # [P, bs, h]  (pre-allocated, will not be written here)\n",
        "    buf: Optional[torch.Tensor] = None,\n",
        "    inc_buf: Optional[torch.Tensor] = None,\n",
        "    dec_buf: Optional[torch.Tensor] = None\n",
        ") -> torch.Tensor:\n",
        "\n",
        "\n",
        "    \"\"\" base_dec, base_keep, base_inc => combined.unbind(0) \"\"\"\n",
        "\n",
        "    buf = (p_incr * p_decr * p_keep).unsqueeze(0) + hist\n",
        "    return buf\n"
      ],
      "metadata": {
        "id": "I8YxduS9rLI3",
        "trusted": true,
        "execution": {
          "iopub.status.busy": "2025-09-17T19:06:51.717683Z",
