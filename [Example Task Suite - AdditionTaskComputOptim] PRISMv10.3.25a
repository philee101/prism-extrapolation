      }
    },
    {
      "cell_type": "code",
      "source": [
        "TRAIN_BASELINE_TRANSFORMER = False\n",
        "NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE = 96\n",
        "NUM_LAYERS = 6\n",
        "\n",
        "assert NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE % 2 == 0, f'NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE ({NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE}) must be divisible by 2'\n",
        "# MARK: GroupedQKHeadsToOperators:\n",
        "NUM_QK_OPERATOR_PAIRS_PER_HEAD = 2 # Num {q,k} operators per head\n",
        "\n",
        "re_range_list_mask = torch.zeros(NUM_LAYERS, dtype=torch.bool)\n",
        "re_range_list_mask[0] = torch.tensor(True)\n",
        "re_range_list_mask[3] = torch.tensor(True)\n",
        "total_num_re_layers = re_range_list_mask.sum().item()\n",
        "\n",
        "\n",
        "\"\"\"\n",
        "v9.23.25b:\n",
        "<perOperatorAttnHeads>: - If True, then each attn head\n",
        "is associated with exactly <NUM_QK_OPERATOR_PAIRS_PER_HEAD> * 2 operators, and the number of attn heads is:\n",
        "((NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE // 2) // NUM_QK_OPERATOR_PAIRS_PER_HEAD) // NUM_LAYERS\n",
        "Only makes a difference if NUM_LAYERS > 1.\n",
        "\n",
        "- If False, at each layer, the same head index is associated with the same operator indices,\n",
        "and the number of attn heads is (NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE // 2) // NUM_QK_OPERATOR_PAIRS_PER_HEAD\n",
        "\"\"\"\n",
        "perOperatorAttnHeads = True\n",
        "TOTAL_NUM_OPERATORS = None\n",
        "\n",
        "if not TRAIN_BASELINE_TRANSFORMER:\n",
        "    if not perOperatorAttnHeads:\n",
        "        assert (NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE // 2) % NUM_QK_OPERATOR_PAIRS_PER_HEAD == 0, f'NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE // 2 ({NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE // 2}) must be divisible by NUM_QK_OPERATOR_PAIRS_PER_HEAD ({NUM_QK_OPERATOR_PAIRS_PER_HEAD})'\n",
        "        assert NUM_QK_OPERATOR_PAIRS_PER_HEAD <= (NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE // 2)\n",
        "        NUM_HEADS = (NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE // 2) // NUM_QK_OPERATOR_PAIRS_PER_HEAD\n",
        "    else:\n",
        "        FIX_NUM_OPERATORS_PER_ENCODING_MODULE_IF_NEEDED = True\n",
        "        def _check_num_heads():\n",
        "            global TOTAL_NUM_OPERATORS, NUM_HEADS, num_op_pairs_per_head_for_per_operator_sa, NUM_OPERATORS_PER_SA_LAYER\n",
        "            TOTAL_NUM_OPERATORS = NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE * total_num_re_layers\n",
        "            yn = (TOTAL_NUM_OPERATORS) % (NUM_QK_OPERATOR_PAIRS_PER_HEAD * NUM_LAYERS) == 0, f'NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE // 2 ({NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE // 2}) must be divisible by NUM_QK_OPERATOR_PAIRS_PER_HEAD * NUM_LAYERS ({NUM_QK_OPERATOR_PAIRS_PER_HEAD * NUM_LAYERS})'\n",
        "            NUM_HEADS = (NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE * total_num_re_layers) // (NUM_QK_OPERATOR_PAIRS_PER_HEAD * 2 * NUM_LAYERS)\n",
        "            _NUM_OPERATORS_PER_SA_LAYER = ((NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE * total_num_re_layers) // NUM_LAYERS)\n",
        "            num_ops_per_head = (_NUM_OPERATORS_PER_SA_LAYER // (2 * NUM_HEADS))\n",
        "            even = (_NUM_OPERATORS_PER_SA_LAYER // NUM_QK_OPERATOR_PAIRS_PER_HEAD) % 2 == 0\n",
        "            yn = yn and even\n",
        "            yn = yn and _NUM_OPERATORS_PER_SA_LAYER % 2 == 0\n",
        "            yn = (_NUM_OPERATORS_PER_SA_LAYER // 2) % NUM_HEADS == 0 and yn\n",
        "\n",
        "            return yn, NUM_HEADS, num_ops_per_head, _NUM_OPERATORS_PER_SA_LAYER\n",
        "\n",
        "        yn, NUM_HEADS, num_op_pairs_per_head_for_per_operator_sa, NUM_OPERATORS_PER_SA_LAYER = _check_num_heads()\n",
        "\n",
        "        if not FIX_NUM_OPERATORS_PER_ENCODING_MODULE_IF_NEEDED:\n",
        "            assert yn\n",
        "            yn, NUM_HEADS, num_op_pairs_per_head_for_per_operator_sa, NUM_OPERATORS_PER_SA_LAYER = _check_num_heads()\n",
        "            assert num_op_pairs_per_head_for_per_operator_sa > 0, f'num_ops_per_head must be > 0'\n",
        "            assert NUM_HEADS > 0, f'NUM_HEADS must be > 0'\n",
        "            assert NUM_OPERATORS_PER_SA_LAYER % 2 == 0 and NUM_OPERATORS_PER_SA_LAYER > 0, f'NUM_OPERATORS_PER_SA_LAYER must be > 0 and divisible by 2'\n",
        "            assert (NUM_OPERATORS_PER_SA_LAYER // 2) // NUM_HEADS > 0, f'(NUM_OPERATORS_PER_SA_LAYER // 2) // NUM_HEADS must be > 0'\n",
        "            assert num_op_pairs_per_head_for_per_operator_sa == NUM_QK_OPERATOR_PAIRS_PER_HEAD, f'num_op_pairs_per_head_for_per_operator_sa must be {NUM_QK_OPERATOR_PAIRS_PER_HEAD}'\n",
        "        else:\n",
        "            while (not yn or NUM_HEADS <= 0 or num_op_pairs_per_head_for_per_operator_sa <= 0 or NUM_OPERATORS_PER_SA_LAYER % 2 != 0):\n",
        "                NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE += 1\n",
        "                yn, NUM_HEADS, num_op_pairs_per_head_for_per_operator_sa, NUM_OPERATORS_PER_SA_LAYER = _check_num_heads()\n",
        "                print(f'Warning: invalid NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE for <perOperatorAttnHeads=T>, fixing automatically by raising NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE to {NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE}')\n",
        "        print(f'Set final NUM_HEADS = {NUM_HEADS} for <perOperatorAttnHeads=T>, NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE = {NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE}')\n",
        "        print(f'Resulting num_ops_per_head = {num_op_pairs_per_head_for_per_operator_sa}')\n",
        "        assert num_op_pairs_per_head_for_per_operator_sa == NUM_QK_OPERATOR_PAIRS_PER_HEAD, f'num_op_pairs_per_head_for_per_operator_sa must be {NUM_QK_OPERATOR_PAIRS_PER_HEAD}, got {num_op_pairs_per_head_for_per_operator_sa}'\n",
        "\n",
        "        # NUM_OPERATORS_PER_SA_LAYER = ((NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE) // (NUM_HEADS * 2)) // NUM_LAYERS\n",
        "\n",
        "        assert NUM_OPERATORS_PER_SA_LAYER > 0 and NUM_OPERATORS_PER_SA_LAYER % 2 == 0, f'NUM_OPERATORS_PER_SA_LAYER ({NUM_OPERATORS_PER_SA_LAYER}) must be > 0 and divisible by 2'\n",
        "elif TRAIN_BASELINE_TRANSFORMER:\n",
        "    NUM_HEADS = 65\n",
        "    perOperatorAttnHeads = False # Not applicable\n",
        "\n"
      ],
      "metadata": {
        "id": "VyMFYHfmV82p"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "\n",
        "# Define constants\n",
        "MAX_DIGITS = 20\n",
        "# VOCAB_SIZE = len(vocab)\n",
        "VOCAB_SIZE = len(vocab_tokens)\n",
        "# NUM_HEADS = 3\n",
        "BATCH_SIZE = 1500  # Increased batch size\n",
        "EPOCHS = 100\n",
        "\n",
        "examples_persequence = 1\n",
        "\n",
        "TRAIN_SEQ_LEN = 5  # Default max length for training sequences for token copying\n",
        "TEST_SEQ_LEN = 7  # Default max length for test sequences for token copying\n",
        "\n",
        "GRAD_ACCUMULATION_STEPS = 1\n",
        "\n",
        "##########################################\n",
        "# RSE-Relevant HParams:\n",
        "##########################################\n",
        "ALLOW_X_SHIFT = True\n",
        "\n",
        "\"\"\"\n",
        "EMBED_SIZE_: Dimension of the full (not low-rank) position encoding if TRAIN_BASELINE_TRANSFORMER == True\n",
        ", else the dimensionality of the vocab and position encoding if TRAIN_BASELINE_TRANSFORMER == True\n",
        "\"\"\"\n",
        "EMBED_SIZE_ = 768\n",
        "\n",
        "use_lowRank_pe = not TRAIN_BASELINE_TRANSFORMER\n",
        "\n",
        "\"\"\"\n",
        "USE_SINUSOIDAL_PE: If False, use scalar PE and use the smooth approximation to PE inner product via double_exp_closed_form, which is currently deprecated since it is too slow for lots of coefficients/linear combinations of sinusoidal encodings\n",
        "\"\"\"\n",
        "USE_SINUSOIDAL_PE = True\n",
        "\n",
        "\"\"\"\n",
        "MARK: lowRank_pe:\n",
        "- Warning: EMBED_SIZE is updated later if TRAIN_BASELINE_TRANSFORMER == False and use_lowRank_pe == True\n",
        "\"\"\"\n",
        "EMBED_SIZE = EMBED_SIZE_  # If TRAIN_BASELINE_TRANSFORMER\n",
        "\n",
        "\n",
        "# Define enum for {use_transformer, gru, None} for layers preceding RelativeEncoding:\n",
        "# Enum:\n",
        "from enum import Enum\n",
        "\n",
        "class PRE_RELATIVE_ENCODING_LAYER_OPTIONS(Enum):\n",
        "    use_transformer = 1\n",
        "    gru = 2\n",
        "    none = 3\n",
        "\n",
        "pre_relative_encoding_layer_options = PRE_RELATIVE_ENCODING_LAYER_OPTIONS.gru\n",
        "\n",
        "\n",
        "\n",
        "VALUE_VECTORS_USE_HEAD_DIM_CONCATENATION_TO_MATCH_VOCAB_DIM = True\n",
        "VOCAB_N_DIM = 385 # Output embed dim for the value projections for self-attn\n",
        "VOCAB_N_DIM_ = VOCAB_N_DIM # Embed dim for feedforward token embeddings\n",
        "\n",
        "if VALUE_VECTORS_USE_HEAD_DIM_CONCATENATION_TO_MATCH_VOCAB_DIM:\n",
        "    while VOCAB_N_DIM_ % NUM_HEADS != 0:\n",
        "        VOCAB_N_DIM_ += 1\n",
        "    VOCAB_N_DIM = VOCAB_N_DIM_\n",
        "\n",
        "if TRAIN_BASELINE_TRANSFORMER:\n",
        "    VOCAB_N_DIM = EMBED_SIZE\n",
        "    VOCAB_N_DIM_ = VOCAB_N_DIM\n",
        "\n",
        "if use_lowRank_pe and not TRAIN_BASELINE_TRANSFORMER:\n",
        "    print(f'WARNING: Content embedding latent dimension was changed and <use_lowRank_pe> == True. You must call _update_asymptotically_correct_pe_approx() or the PE latent dimension will be incorrect.')\n",
        "\n",
        "MAX_SEQ_LEN = 2048\n",
        "SINUSOIDAL_ENC_SEQ_LENGTH_PADDING = 4 # To prevent out of bounds exceptions in the context of x shift and negative position values, which are shifted to MAX_SEQ_LEN // 2 + 1 for the zeroth integer position\n",
        "assert (MAX_SEQ_LEN + SINUSOIDAL_ENC_SEQ_LENGTH_PADDING) % 2 == 0, f'MAX_SEQ_LEN + SINUSOIDAL_ENC_SEQ_LENGTH_PADDING ({MAX_SEQ_LEN + SINUSOIDAL_ENC_SEQ_LENGTH_PADDING}) must be divisible by 2'\n",
        "\n",
        "\"\"\"\n",
        "For a basic looped-transformer style recurrence from mapping outputs back to inputs the specified number of times\n",
        "\"\"\"\n",
        "N_RECURRENT_STEPS = 1\n",
        "\n",
        "MHA_USE_CUSTOM_LN = 0\n",
        "NUM_LAYERS_PER_RE_GATE = 2\n",
        "\n",
        "# <Input-Dependent Gamma+Alpha Coeffs>\n",
        "Input_Dependent_Gamma_Exponents = True\n",
        "DISABLE_POSITION_CACHING = False\n",
        "\n",
        "# ablateSharedMGMLP: reduce NUM_SHARED_MGMLP_LAYERS from 3 to 0\n",
        "NUM_SHARED_MGMLP_LAYERS = 0\n",
        "ABLATE_LSTM_IN_OUT_PROJ = False\n",
        "\n",
        "# MARK: addInputProjectionBeforeLSTM\n",
        "addInputProjectionBeforeLSTM = not ABLATE_LSTM_IN_OUT_PROJ\n",
        "USE_G_PARAM_REGULARIZER = False\n",
        "\n",
        "removeRSE_LN = False # To try preserving scale for reasoning in latent space using the RSE positional encodings, which are latent representations, c.f. main paper HMM interpretation at https://www.alphaxiv.org/overview/2506.00920v1\n",
        "ReplaceLNWithSmoothCapIfRemoveRSE_LN = False\n",
        "\n",
        "if ReplaceLNWithSmoothCapIfRemoveRSE_LN:\n",
        "    assert removeRSE_LN, \"ReplaceLNWithSmoothCapIfRemoveRSE_LN must be True if removeRSE_LN is True\"\n",
        "\n",
        "ResidualStreamLN = False #not removeRSE_LN # Experimental: A more aggressive LN to balance features across tokens, since norms were found to be very imbalanced across tokens with standard transformer LN. Implements residual stream normalization as of the form mha(ln_0(x)) + ln_1(<orig_x>). For RSE version 9.11.25a\n",
        "                        # Also applies to some ffn and residual layers used for RelativePositionEncoding and MGMLP\n",
        "if ResidualStreamLN:\n",
        "    assert not removeRSE_LN and not ReplaceLNWithSmoothCapIfRemoveRSE_LN, \"ResidualStreamLN must be False if removeRSE_LN or ReplaceLNWithSmoothCapIfRemoveRSE_LN is True\"\n",
        "\n",
        "ADD_FINAL_LOGITS_LN = True\n",
        "sandwichLN = False\n",
        "if sandwichLN:\n",
        "    assert not removeRSE_LN and not ReplaceLNWithSmoothCapIfRemoveRSE_LN and not ResidualStreamLN, \"sandwichLN must be False if removeRSE_LN or ReplaceLNWithSmoothCapIfRemoveRSE_LN or ResidualStreamLN is True\"\n",
        "\n",
        "\"\"\"\n",
        "v9.15.25b addendum <resetGateOversmoothingFix>:\n",
        "Reset gate probabilities above ~0.1 multiplicatively \"dampen\" the probability of other histogram bins too quickly, particularly for consecutive time steps where this is the case.\n",
        "- Reset probabilities also accumulate mass quickly since the prob. mass of *all* bins contribute to the histogram probability at time to corresponding to the reset position. This is whereas e.g. the top-k bins lose mass in the presence of 1-reset_prob for multiple timesteps.\n",
        "- Therefore,\n",
        "setting this option to True prevents this geometric dampening via:\n",
        "(a) preserving the unnormalized probabilities via *not* multiplying non-reset bins by 1-reset_prob\n",
        "(b) adding a normalization before the gamma sharpening step so that the probabilities sum to 1\n",
        "(c) in order to allow for the possibility that histogram[t] at the reset position to remain sharp, the maximum reset transition \"probability\" (before normalizing the histogram bins at time t) is 2.0 instead of 1.0.\n",
        "\"\"\"\n",
        "USE_RESET_GATE_OVERSMOOTHING_FIXES = True\n",
        "\n",
        "ATTN_FF_OUTPUT_DROPOUT = 0.0\n",
        "\n",
        "LINEAR_MODULE_SPECTRAL_NORM = False\n",
        "VALUE_VECTOR_LNORM = False\n",
        "assert not (LINEAR_MODULE_SPECTRAL_NORM and VALUE_VECTOR_LNORM), \"LINEAR_MODULE_SPECTRAL_NORM and VALUE_VECTOR_LNORM cannot both be True\"\n",
        "\n"
      ],
      "metadata": {
        "id": "yumKCKp5-CTI",
