      "cell_type": "markdown",
      "source": [
        "#### hist_update_step_conv"
      ],
      "metadata": {
        "id": "j2eICp5caG_T"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# torch._inductor.config.triton.cudagraph_skip_dynamic_graphs=True"
      ],
      "metadata": {
        "id": "XMfbGyMsPiGj",
        "trusted": true,
        "execution": {
          "iopub.status.busy": "2025-09-17T19:06:51.312428Z",
          "iopub.execute_input": "2025-09-17T19:06:51.312635Z",
          "iopub.status.idle": "2025-09-17T19:06:51.326777Z",
          "shell.execute_reply.started": "2025-09-17T19:06:51.312619Z",
          "shell.execute_reply": "2025-09-17T19:06:51.326114Z"
        }
      },
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "code",
      "source": [
        "import torch\n",
        "import torch.nn.functional as F\n",
        "from typing import Optional\n",
        "\n",
        "@torch.jit.script\n",
        "def hist_update_prepare(\n",
        "    p_reset: torch.Tensor,  # [bs, h]\n",
        "    p_inc:   torch.Tensor,  # [bs, h]\n",
        "    p_dec:   torch.Tensor,  # [bs, h]\n",
        "    p_keep:  torch.Tensor,  # [bs, h]\n",
        ") -> torch.Tensor:\n",
        "    \"\"\"\n",
        "    Build the grouped‐conv1d kernel for one histogram step.\n",
        "\n",
        "    Returns w_kernel of shape [bs*h, 1, 3], where each channel\n",
        "    implements the dec/keep/inc weighted shift with zero‐padding.\n",
        "    \"\"\"\n",
        "    bs, h = p_reset.shape\n",
        "    # (1 - reset) × [dec, keep, inc] → [bs, h, 3]\n",
        "    inv_r   = (1.0 - p_reset).unsqueeze(-1)         # [bs, h, 1]\n",
        "    dp = torch.stack([p_dec, p_keep, p_inc], dim=-1)  # [bs, h, 3]\n",
        "    w       = inv_r * dp                      # [bs, h, 3]\n",
        "    w_kernel = w.reshape(bs * h, 1, 3)              # [bs*h, 1, 3]\n",
        "    # assert w_kernel.shape == (bs*h, 1, 3), \\\n",
        "    #     f\"hist_update_prepare: expected [(bs*h),1,3], got {tuple(w_kernel.shape)}\"\n",
        "    return w_kernel\n",
        "\n",
        "\n",
        "@torch.compile(dynamic=False)\n",
        "def hist_update_step_conv(\n",
        "    x:        torch.Tensor,           # [P, bs, h]\n",
        "    w_kernel: torch.Tensor,           # [bs*h, 1, 3]\n",
        "    p_reset:  torch.Tensor,           # [bs, h]\n",
        "    p_inc:    torch.Tensor,           # [bs, h]\n",
        "    p_dec:    torch.Tensor,           # [bs, h]\n",
        "    p_keep:   torch.Tensor,           # [bs, h]\n",
        "    p_copy:   Optional[torch.Tensor], # [P+1, bs, h] or None\n",
        "    eps:      float,\n",
        "    gamma:    torch.Tensor|float,     # scalar or [h]\n",
        ") -> torch.Tensor:\n",
        "    # w_kernel = torch.randn(bs*h, 1, 3, device=x.device)\n",
        "    w_kernel : torch.Tensor = hist_update_prepare(p_reset, p_inc, p_dec, p_keep)\n",
        "    # Annotate as shape (bs*h, 1, 3) for jit:\n",
        "    # w_kernel  = torch.jit.annotate(torch.Tensor, hist_update_prepare(p_reset, p_inc, p_dec, p_keep))\n",
        "    # w_kernel = hist_update_prepare(p_reset, p_inc, p_dec, p_keep)\n",
        "\n",
        "    return _hist_update_step_conv(x, w_kernel, p_reset, p_inc, p_dec, p_keep, p_copy, eps, gamma)\n",
        "\n",
        "\n",
        "@torch.compile(dynamic=False)\n",
        "@torch.jit.script\n",
        "def _hist_update_step_conv(\n",
        "    x:        torch.Tensor,           # [P, bs, h]\n",
        "    w_kernel: torch.Tensor,           # [bs*h, 1, 3]\n",
        "    p_reset:  torch.Tensor,           # [bs, h]\n",
        "    p_inc:    torch.Tensor,           # [bs, h]\n",
        "    p_dec:    torch.Tensor,           # [bs, h]\n",
        "    p_keep:   torch.Tensor,           # [bs, h]\n",
        "    p_copy:   Optional[torch.Tensor], # [P+1, bs, h] or None\n",
        "    eps:      float,\n",
        "    gamma:    torch.Tensor #|float,     # scalar or [h]\n",
        ") -> torch.Tensor:\n",
        "    \"\"\"\n",
        "    Perform one histogram‐update step:\n",
        "     1) fused shift+multiply via grouped conv1d using w_kernel\n",
        "     2) reset branch\n",
        "     3) optional copy branch\n",
        "     4) sharpen + renorm\n",
        "    \"\"\"\n",
        "    P, bs, h = x.shape\n",
        "    # 1) conv‐fused shifts & weights\n",
        "    hist_flat = x.permute(1,2,0).reshape(1, bs*h, P)  # [1,bs*h,P]\n",
        "    out_flat  = F.conv1d(hist_flat, w_kernel, padding=1, groups=bs*h)\n",
        "    out = out_flat.reshape(bs, h, P).permute(2,0,1)   # [P,bs,h]\n",
        "\n",
        "    # 2) reset\n",
        "    total = 1.0 #x.sum(dim=0, keepdim=True)               # [1,bs,h]\n",
        "    r0    = total * p_reset * (p_dec + p_keep)       # [1,bs,h]\n",
        "    r1    = total * p_reset * p_inc                  # [1,bs,h]\n",
        "    out[0] += r0.squeeze(0)\n",
        "    if P > 1:\n",
        "        out[1] += r1.squeeze(0)\n",
        "\n",
        "    # 3) copy\n",
        "    if p_copy is not None:\n",
        "        # assume p_copy is already [P+1, bs, h]\n",
        "        pos_cols = p_copy[:-1]                       # [P,bs,h]\n",
        "        no_copy  = p_copy[-1].unsqueeze(0)           # [1,bs,h]\n",
        "        out = out * no_copy + total * pos_cols\n",
        "\n",
        "    # 4) sharpen + renorm\n",
        "    # out = (out + eps).pow(gamma)\n",
        "    out = torch.pow(out + eps, gamma)\n",
        "    out = (out + eps) / (out.sum(dim=0, keepdim=True) + eps)\n",
        "\n",
        "    return out\n"
      ],
      "metadata": {
