    },
    {
      "cell_type": "code",
      "source": [
        "from torch.profiler import profile, record_function, ProfilerActivity, schedule, tensorboard_trace_handler\n",
        "\n",
        "debug_profile = True\n",
        "# if you only want to profile for a few iterations:\n",
        "if debug_profile:\n",
        "    prof = profile(\n",
        "        activities=[ProfilerActivity.CPU, ProfilerActivity.CUDA],\n",
        "        # schedule=schedule(wait=1, warmup=1, active=3, repeat=1),\n",
        "        on_trace_ready=tensorboard_trace_handler(\"./runs/test\"),\n",
        "        record_shapes=True,\n",
        "        profile_memory=True,\n",
        "        with_stack=False,\n",
        "        use_cuda=True\n",
        "    )\n",
        "    prof.__enter__()\n",
        "\n",
        "for i in range(6):\n",
        "    print(ALLOW_X_SHIFT)\n",
        "    ALLOW_X_SHIFT = DEFAULT_ALLOWS_X_SHIFT\n",
        "    BATCH_SIZE    = 35\n",
        "    continue_training(num_epochs=1, optimizers_dict=optimizers_dict,\n",
        "                              min_seq_len_for_dataset=15,\n",
        "                      max_seq_len_for_dataset=15,\n",
        "                                dataset_init_seed=None ,\n",
        "\n",
        "                      num_examples_per_batched_data = 1,\n",
        "\n",
        "                              task='copy_hold_n_sparse',\n",
        "                                examples_per_sequence=1,\n",
        "                              turn_off_aux_losses=False, # Set this to True only when debugging gradients for token losses\n",
        "                              min_digits_arithmetic=1,\n",
        "                              max_digits_arithmetic=3\n",
        "                   af   ,\n",
        "                      hold_n_for_repeat_n_copy=3\n",
        "\n",
        "                              )\n",
        "    if debug_profile:\n",
        "        prof.step()\n"
      ],
      "metadata": {
        "id": "vasy-GAU_mG_",
        "trusted": true
      },
      "outputs": [],
      "execution_count": null
    },
