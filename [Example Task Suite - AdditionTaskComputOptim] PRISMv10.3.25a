    {
      "cell_type": "markdown",
      "source": [
        "## GRUWithFrobeniusGain"
      ],
      "metadata": {
        "id": "WGwZnh51f71O"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import torch\n",
        "import torch.nn as nn\n",
        "import torch.nn.functional as F\n",
        "from typing import Tuple\n",
        "\n",
        "class GRUWithFrobeniusGain(nn.Module):\n",
        "    \"\"\"\n",
        "    Wraps an existing nn.GRU, normalizing each recurrent weight_hh_l* by its Frobenius norm\n",
        "    and scaling by a learned or fixed gain.\n",
        "    \"\"\"\n",
        "    def __init__(\n",
        "        self,\n",
        "        gru: nn.GRU,\n",
        "        learned_gain: bool = True,\n",
        "        eps: float = 1e-12\n",
        "    ):\n",
        "        super().__init__()\n",
        "        self.gru = gru\n",
        "        self.eps = eps\n",
        "\n",
        "        # Find and re‐register all weight_hh parameters as \"raw\"\n",
        "        self._hh_names = []\n",
        "        for name in self.gru._flat_weights_names:\n",
        "            if name.startswith(\"weight_hh\"):\n",
        "                self._hh_names.append(name)\n",
        "                # extract the Parameter, remove it from the GRU\n",
        "                raw_param = getattr(self.gru, name)\n",
        "                del self.gru._parameters[name]\n",
        "                # register under our wrapper\n",
        "                self.register_parameter(f\"{name}_raw\", raw_param)\n",
        "\n",
        "        # set up a single gain parameter (shared across layers)\n",
        "        if learned_gain:\n",
        "            # initialize so softplus(g_param) = 1.0\n",
        "            init_val = 1.0\n",
        "            g0 = torch.log(torch.exp(torch.tensor(init_val)) - 1.0)\n",
        "            self.g_param = nn.Parameter(g0)\n",
        "        else:\n",
        "            # no grad, just use gain = 1.0\n",
        "            self.register_parameter(\"g_param\", None)\n",
        "\n",
        "    def forward(\n",
        "        self,\n",
        "        input: torch.Tensor,\n",
        "        hx: torch.Tensor = None\n",
        "    ) -> Tuple[torch.Tensor, torch.Tensor]:\n",
        "        # compute gain\n",
        "        if self.g_param is not None:\n",
        "            g = F.softplus(self.g_param)\n",
        "        else:\n",
        "            g = None\n",
        "\n",
        "        # for each recurrent weight, normalize & reassign\n",
        "        for name in self._hh_names:\n",
        "            raw = getattr(self, f\"{name}_raw\")      # shape (3*hidden, hidden)\n",
        "            norm = raw.norm(p=\"fro\")                # Frobenius norm\n",
        "            if g is not None:\n",
        "                W = g * (raw / (norm + self.eps))\n",
        "            else:\n",
        "                W = raw\n",
        "            # assign into the GRU (overwriting the attribute)\n",
        "            setattr(self.gru, name, W)\n",
        "\n",
        "        # delegate to the underlying GRU\n",
        "        return self.gru(input, hx)\n"
      ],
      "metadata": {
        "id": "MJFqTsuif6sC",
        "trusted": true,
        "execution": {
          "iopub.status.busy": "2025-09-17T19:06:51.767860Z",
          "iopub.execute_input": "2025-09-17T19:06:51.768064Z",
          "iopub.status.idle": "2025-09-17T19:06:51.782526Z",
          "shell.execute_reply.started": "2025-09-17T19:06:51.768048Z",
          "shell.execute_reply": "2025-09-17T19:06:51.781951Z"
        }
      },
      "outputs": [],
      "execution_count": null
