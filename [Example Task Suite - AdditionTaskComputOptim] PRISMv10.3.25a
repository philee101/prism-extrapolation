    },
    {
      "cell_type": "code",
      "source": [],
      "metadata": {
        "id": "NkeWJJwfmA5N",
        "trusted": true
      },
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "code",
      "source": [
        "import torch\n",
        "import torch.profiler\n",
        "import gc\n",
        "\n",
        "# Clear Python garbage and CUDA cache (for debugging)\n",
        "gc.collect()\n",
        "torch.cuda.empty_cache()\n",
        "\n",
        "BATCH_SIZE = 50\n",
        "max_seq_len = 9999\n",
        "idx = 0\n",
        "best_results_scan = {}\n",
        "\n",
        "# Example: using PyTorch's profiler with a schedule\n",
        "# - wait=1: skip profiling the first 1 iteration(s)\n",
        "# - warmup=1: then warm up on the next 1 iteration(s)\n",
        "# - active=2: and finally profile the next 2 iteration(s)\n",
        "# This repeats if we call 'prof.step()' in a loop.\n",
        "# Adjust these as needed for your scenario.\n",
        "profiler_schedule = torch.profiler.schedule(wait=1, warmup=1, active=2, repeat=1)\n",
        "\n",
        "# Define where to save trace events for TensorBoard:\n",
        "# You can later run: tensorboard --logdir=./log\n",
        "# trace_handler = torch.profiler.tensorboard_trace_handler('./log')\n",
        "\n",
        "# Create the profiler\n",
        "with torch.profiler.profile(\n",
        "    activities=[\n",
        "        torch.profiler.ProfilerActivity.CPU,\n",
        "        torch.profiler.ProfilerActivity.CUDA,\n",
        "    ],\n",
        "    schedule=profiler_schedule,\n",
        "    # on_trace_ready=trace_handler,\n",
        "    on_trace_ready=torch.profiler.tensorboard_trace_handler(\"./runs/test\"),\n",
        "    record_shapes=True,      # record shape info\n",
        "    profile_memory=True,     # track tensor memory usage\n",
        "    with_stack=False          # include Python stack traces with events\n",
        ") as prof:\n",
        "\n",
        "    for i_ in range(3):\n",
        "        # --------------------------------------------------------------------\n",
        "        # Call your training function here\n",
        "        # --------------------------------------------------------------------\n",
        "        continue_training(\n",
        "            num_epochs=1,\n",
        "            optimizers_dict=optimizers_dict,\n",
        "            max_seq_len_for_dataset=9999,\n",
        "            examples_per_sequence=1,\n",
        "            task='scan_dataset'\n",
        "        )\n",
        "        idx += 1\n",
        "\n",
        "        # Step the profiler at each iteration\n",
        "        prof.step()\n",
        "\n",
        "        # --------------------------------------------------------------------\n",
        "        # Periodically evaluate the model\n",
        "        # --------------------------------------------------------------------\n",
        "        if idx % 1000 == 0:\n",
        "            print('Evaluating...')\n",
        "            acc = test_extrapolation_SCAN(\n",
        "                extrapolation_len=9999,\n",
        "                for_model='rse' if model_to_use.model_is_rse else 'baseline',\n",
        "                printOutputsAndTargets=True,\n",
        "                visualize_attn_weights=0,\n",
        "                n_total_examples=1000\n",
        "            )\n",
        "\n",
        "            best_results_scan[idx] = acc\n",
        "            print(f'Final acc={acc}, best acc={max(best_results_scan.values())}')\n",
        "\n",
        "            # Save checkpoint\n",
        "            save_ckpt(f'[SCAN] Model RSE iterIdx={idx}, acc={acc}.pth', for_model=model_to_use)\n",
        "\n",
        "        # --------------------------------------------------------------------\n",
        "        # (Optional) Check memory usage at intervals\n",
        "        # --------------------------------------------------------------------\n",
        "        if idx % 100 == 0:\n",
        "            print(torch.cuda.memory_summary())  # Summaries all memory usage\n",
        "            # Or: print(torch.cuda.mem_get_info(device=0))\n",
        "            # to get (free, total) memory in bytes\n"
      ],
      "metadata": {
        "id": "rmL59QSk25gk",
        "trusted": true
      },
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "code",
