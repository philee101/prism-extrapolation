      "source": [
        "## Init losses dict"
      ],
      "metadata": {
        "id": "XNXK3NOndT9c"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# General Losses dict structure:\n",
        "# Allows to Retrieve for each of train/val:\n",
        "    # - Each list is A list of tuples\n",
        "    # - Losses: indexes the iteration index of each epoch, along with the loss, of the form [(iteration index, epoch, loss)]\n",
        "    # - extra_info_*: a list of tuples where each tuples contains an extra\n",
        "    #   info dictionary. Of the same length as train_losses_*, though also of the form\n",
        "    #   also as [(<iteration index>, <dictionary at iteration index>)]\n",
        "# Init empty list\n",
        "losses_dict = {\n",
        "    'train_losses_rse': [],\n",
        "    'val_losses_rse': [],\n",
        "    'train_losses_baseline': [],\n",
        "    'val_losses_baseline': [],\n",
        "    'wall_clock_time_rse': [],  # Wall-clock time for Rotated Adam\n",
        "    'wall_clock_time_baseline': [],       # Wall-clock time for Baseline\n",
        "    'extra_info_rse' : [],\n",
        "    'extra_info_baseline' : []\n",
        "    }\n",
        "global num_invocations_continue_training\n",
        "global_iter = 0\n",
        "num_invocations_continue_training = 0\n"
      ],
      "metadata": {
        "id": "NhirEZ8KwHz2",
        "trusted": true,
        "execution": {
