    {
      "cell_type": "code",
      "source": [
        "def _ablateREGPUStorageIfApplcbl():\n",
        "    MOVE_RE_CLASS_TO_CPU_IF_APPLICABLE = False\n",
        "    if not ABLATE_REL_ENC_ENTIRE_CLASS and MOVE_RE_CLASS_TO_CPU_IF_APPLICABLE:\n",
        "        for re in model_rse.relative_encodings:\n",
        "            if re is None: continue\n",
