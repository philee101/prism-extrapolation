    {
      "cell_type": "code",
      "source": [
        "# prompt: Add Cosine Annealing scheduler to optimizers_dict for each model\n",
        "import math\n",
        "ABLATE_RSE_SPECIFIC_OPTIMIZER = False\n",
        "\n",
        "def reinitOptimizers(\n",
        "    wgt_decay=wgt_decay,\n",
        "    learn_r=1e-4,\n",
        "    ignore_wd_for_relative_encodings=False,\n",
        "    adam_eps=1e-9,\n",
        "    freeze_mha_pos_biases=False,   # NEW: pass-through to get_optimizer_RSE\n",
        "    attn_bias_lr=None,             # NEW: pass-through to get_optimizer_RSE (overrides freeze when > 0)\n",
        "):\n",
        "    \"\"\"\n",
        "    (Re)initialize optimizers for RSE and baseline models.\n",
        "\n",
        "    - RSE side calls your custom get_optimizer_RSE(...) and forwards:\n",
        "        freeze_mha_pos_biases, attn_bias_lr\n",
        "    - Baseline stays on AdamW.\n",
        "\n",
        "    Returns:\n",
        "        {\n",
        "          'rse': {'main': AdamWAdaptiveEpsilon(...)} or None,\n",
        "          'baseline': torch.optim.Optimizer or None\n",
        "        }\n",
        "    \"\"\"\n",
        "    # ---- RSE optimizer ----\n",
        "    if model_rse is not None:\n",
        "        if not ABLATE_RSE_SPECIFIC_OPTIMIZER:\n",
        "            optimizer_RSE_ = get_optimizer_RSE(\n",
        "                model_rse,\n",
        "                weight_decay=wgt_decay,\n",
        "                lr=learn_r,\n",
        "                ignore_wd_for_relative_encodings=ignore_wd_for_relative_encodings,\n",
        "                adam_eps=adam_eps,\n",
        "                freeze_mha_pos_biases=freeze_mha_pos_biases,  # <-- pass-through\n",
        "                attn_bias_lr=attn_bias_lr,                    # <-- pass-through\n",
        "            )\n",
        "        else:\n",
        "            # Fallback simple Adam if you ablate the custom grouping (kept as-is)\n",
        "            param_list = [p for _, p in model_rse.named_parameters()]\n",
        "            optimizer_RSE_ = torch.optim.Adam(\n",
        "                param_list,\n",
        "                lr=learn_r,\n",
        "                eps=2e-8,\n",
        "                betas=(0.9, 0.995),\n",
        "                fused=True\n",
        "            )\n",
        "    else:\n",
        "        optimizer_RSE_ = None\n",
        "\n",
        "    # ---- Baseline optimizer ----\n",
        "    if model_baseline is not None:\n",
        "        optimizer_baseline_ = torch.optim.AdamW(\n",
        "            model_baseline.parameters(),\n",
        "            lr=learn_r,\n",
        "            eps=2e-8,\n",
        "            betas=(0.9, 0.997),\n",
        "            weight_decay=wgt_decay\n",
        "        )\n",
        "    else:\n",
        "        optimizer_baseline_ = None\n",
        "\n",
        "    # ---- Package and return ----\n",
        "    optimizers_dict_ = {\n",
        "        'rse': optimizer_RSE_,        # note: dict with {'main': ...} if using get_optimizer_RSE\n",
        "        'baseline': optimizer_baseline_\n",
        "    }\n",
        "    return optimizers_dict_\n",
        "\n",
        "\n",
        "def reinit_schedulers():\n",
        "\n",
        "    for model_type, optimizer in optimizers_dict.items():\n",
        "        if optimizer is not None:\n",
        "            sch = torch.optim.lr_scheduler.CosineAnnealingWarmRestarts(optimizer, T_0=100, T_mult=1, eta_min=0, last_epoch=-1)\n",
        "            optimizer.scheduler = sch\n",
        "\n",
        "# reinit_schedulers()"
      ],
      "metadata": {
        "id": "9wAR705KkbPm",
        "scrolled": true,
        "trusted": true,
        "execution": {
          "iopub.status.busy": "2025-09-17T19:06:59.383340Z",
