      "cell_type": "code",
      "source": [
        "import torch\n",
        "\n",
        "@torch.compile(dynamic=False)\n",
        "def hist_update_v7_fast_bwd_mod_2_noslices_symmetric_padstrided_fma_v2(\n",
        "    hist:   torch.Tensor,         # [2*seq_len+1, bs, h]\n",
        "    p_reset: torch.Tensor,        # [bs, h]\n",
        "    p_inc:   torch.Tensor,        # [bs, h]\n",
        "    p_dec:   torch.Tensor,        # [bs, h]\n",
        "    p_keep:  torch.Tensor,        # [bs, h]\n",
        "    eps:     float,\n",
        "    gamma:   torch.Tensor|float,  # scalar or [h]\n",
        "    power:   bool,\n",
        "    seq_len: int,\n",
        "    p_copy:  torch.Tensor|None = None,         # [2*seq_len+2, bs, h] or None\n",
        "    *,\n",
        "    pad_buf: torch.Tensor|None = None,         # optional (L+2,bs,h) prealloc\n",
        "):\n",
        "    L, bs, h = hist.shape\n",
        "    mid = seq_len\n",
        "\n",
        "    # ---- per-(b,h) weights (no L indexing) -----------------------------------\n",
        "    inv_r  = 1.0 - p_reset\n",
        "    w_inc  = inv_r * p_inc\n",
        "    w_dec  = inv_r * p_dec\n",
        "    w_keep = inv_r * p_keep\n",
        "    w_dec_u  = w_dec.unsqueeze(0)   # [1,bs,h]\n",
        "    w_keep_u = w_keep.unsqueeze(0)\n",
        "    w_inc_u  = w_inc.unsqueeze(0)\n",
        "\n",
        "    # ---- zero-padded staging (reusing user buffer if given) -------------------\n",
        "    if pad_buf is None:\n",
        "        pad = hist.new_zeros((L + 2, bs, h))\n",
        "    else:\n",
        "        pad = pad_buf\n",
        "        pad.zero_()\n",
        "\n",
        "    # place hist and boundary carries without slicing the hot inputs\n",
        "    pad.narrow(0, 1, L).copy_(hist)  # hist → pad[1:1+L]\n",
        "    pad[0].add_(hist[0])             # dec carry\n",
        "    pad[L + 1].add_(hist[L - 1])     # inc carry\n",
        "\n",
        "    # three neighbor views (no data movement)\n",
        "    prev = pad.narrow(0, 0, L)       # hist[i-1] with boundary carry\n",
        "    curr = pad.narrow(0, 1, L)       # hist[i]\n",
        "    nxt  = pad.narrow(0, 2, L)       # hist[i+1] with boundary carry\n",
        "\n",
        "    # ---- fused 3-tap mix (one large pointwise kernel under Inductor) ----------\n",
        "    out = curr * w_keep_u\n",
        "    out = out.addcmul(prev, w_dec_u)     # out += prev * w_dec\n",
        "    out = out.addcmul(nxt,  w_inc_u)     # out += next * w_inc\n",
        "\n",
        "    # ---- reset triad (three fixed rows; tiny) ---------------------------------\n",
        "    pr = p_reset\n",
        "    out[mid    ].add_(pr * p_keep)\n",
        "    if mid + 1 < L: out[mid + 1].add_(pr * p_inc)\n",
        "    if mid - 1 >= 0: out[mid - 1].add_(pr * p_dec)\n",
        "\n",
        "    # ---- optional copy blend --------------------------------------------------\n",
        "    if p_copy is not None:\n",
        "        pos_cols, no_copy = p_copy.split([L, 1], dim=0)  # views\n",
        "        out = out * no_copy + pos_cols\n",
        "\n",
        "    # ---- γ-sharpen ------------------------------------------------------------\n",
        "    if power:\n",
        "        # per-head broadcast (safe for TorchDynamo)\n",
        "        if isinstance(gamma, torch.Tensor) and gamma.numel() == h:\n",
        "            g = gamma.to(device=hist.device, dtype=hist.dtype).view(1,1,h)\n",
        "            out = (out + eps).pow(g)\n",
        "        else:\n",
        "            out = (out + eps).pow(float(gamma))\n",
        "        # full normalize (sum really changes under pow)\n",
        "        denom = out.sum(0, keepdim=True).add_(eps)\n",
        "        out = out / denom\n",
        "        return out\n",
        "\n",
        "    # ---- no-pow path: mass is exactly 1 → skip reduction ----------------------\n",
        "    # In this branch the update is linear and mass-preserving even with copy;\n",
        "    # original code divides by (1+eps). We do the same but **without** a reduction.\n",
        "    inv_1peps = 1.0 / (1.0 + eps)\n",
        "    out.mul_(inv_1peps)\n",
        "    return out\n"
      ],
