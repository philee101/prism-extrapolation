    {
      "cell_type": "code",
      "source": [
        "import torch\n",
        "import numpy as np\n",
        "\n",
        "ABLATE_REDUCED_DIM = False\n",
        "\n",
        "def construct_sinusoidal_pe_with_asymptotic_correctness(d_model, max_seq_len):\n",
        "    max_seq_len = max_seq_len + SINUSOIDAL_ENC_SEQ_LENGTH_PADDING\n",
        "    true_spe = positional_encoding_1d(d_model, max_seq_len, use_asymptotically_correct_approx=False)\n",
        "    if ABLATE_REDUCED_DIM:\n",
        "        true_spe = true_spe[:, :]\n",
        "        return true_spe, true_spe.shape[-1]\n",
        "\n",
        "\n",
        "    assert true_spe.shape == (max_seq_len, d_model), f'true_spe.shape = {true_spe.shape}, expected {(max_seq_len, d_model)}'\n",
        "    U, S, Vt = torch.linalg.svd(true_spe, full_matrices=False)\n",
        "    # a) variance explained up to d\n",
        "\n",
        "    variance_explained = torch.cumsum(S**2, dim=0) / torch.sum(S**2)\n",
        "    # 3) find smallest d for 99%\n",
        "    if 'cpu' in str(device):\n",
        "        desired_percentage = 0.9999999\n",
        "    else:\n",
        "        desired_percentage = 0.9999999\n",
        "\n",
        "    d_99 = (variance_explained >= desired_percentage).nonzero()[0].item() + 1\n",
        "    if d_99 % 2 != 0:\n",
        "        d_99 += 1\n",
        "\n",
        "    print(f\"Need d={d_99} to capture {desired_percentage*100:.2f}% of the variance\")\n",
        "\n",
        "    # b) projection matrix for top-d components\n",
        "    Vd = Vt[:d_model]                    # [d, D]\n",
        "    # E_reduced = E @ Vd.T           # [L, d]\n",
        "    # print(f'S shape: {S.shape}, Vd shape: {Vd.shape}')\n",
        "    # print(f'E shape: {E.shape}, E_reduced shape: {E_reduced.shape}')\n",
        "    E_reduced = (U[:,:d_99] @ torch.diag(S[:d_99]))\n",
        "    assert E_reduced.shape == (max_seq_len, d_99), f\"E_reduced.shape = {E_reduced.shape}, expected {(L, d_model)}\"\n",
        "\n",
        "    # 5) Sample random position pairs for evaluation\n",
        "    M = 5000\n",
        "    idx_i = torch.randint(0, max_seq_len, (M,))\n",
        "    idx_j = torch.randint(0, max_seq_len, (M,))\n",
        "    true_ips = (true_spe[idx_i] * true_spe[idx_j]).sum(axis=1)\n",
        "\n",
        "    # c) compute inner-product matrix for error analysis/sanity check\n",
        "    approx_ips = (E_reduced[idx_i] * E_reduced[idx_j]).sum(axis=1)\n",
        "\n",
        "    # d) compute metrics\n",
        "    # mse = float(np.mean((approx_ips - true_ips)**2))\n",
        "    corr = float(np.corrcoef(true_ips, approx_ips)[0,1])\n",
        "    mse = torch.mean((approx_ips - true_ips)**2)\n",
        "    # corr = torch.corrcoef(true_ips, approx_ips)[0,1]\n",
        "\n",
        "    print(f'MSE of inner-products: {mse}, Pearson r: {corr}')\n",
        "\n",
        "    # Normalize PE to norm 0.7071 * (d99 ** 0.5), in line with original sinusoidal encoding empirical vector norms of a given dimension:\n",
        "    E_reduced = (E_reduced / E_reduced.norm(dim=1, keepdim=True)) * sinusoidal_encoding_vector_norm_vs_d_model(EMBED_SIZE_)\n",
        "    assert torch.allclose(E_reduced.norm(dim=1), torch.ones(max_seq_len) * sinusoidal_encoding_vector_norm_vs_d_model(EMBED_SIZE_)), f'E_reduced.norm(dim=1) = {E_reduced.norm(dim=1)}'\n",
        "\n",
        "    asymptotically_correct_pe_approx = E_reduced\n",
        "\n",
        "    return E_reduced, d_99\n",
        "\n",
        "def _update_asymptotically_correct_pe_approx():\n",
        "    global asymptotically_correct_pe_approx, d_99, EMBED_SIZE_, EMBED_SIZE\n",
        "\n",
        "    lr_pe, d_99 = construct_sinusoidal_pe_with_asymptotic_correctness(EMBED_SIZE_, MAX_SEQ_LEN)\n",
        "    if not TRAIN_BASELINE_TRANSFORMER and use_lowRank_pe and (asymptotically_correct_pe_approx is None or asymptotically_correct_pe_approx.shape != lr_pe.shape or asymptotically_correct_pe_approx.shape[-1] != EMBED_SIZE):\n",
        "        print(f'lr_pe shape: {lr_pe.shape}')\n",
        "        print(f'[lr_pe] WARNING: Updated EMBED_SIZE from {EMBED_SIZE} to {d_99}')\n",
        "        EMBED_SIZE = d_99\n",
        "        asymptotically_correct_pe_approx = lr_pe\n",
        "\n",
        "_update_asymptotically_correct_pe_approx()"
      ],
      "metadata": {
        "id": "FUf6DJs0C6-0",
        "trusted": true,
        "execution": {
          "iopub.status.busy": "2025-09-17T19:06:50.730387Z",
          "iopub.execute_input": "2025-09-17T19:06:50.730655Z",
          "iopub.status.idle": "2025-09-17T19:06:50.948769Z",
          "shell.execute_reply.started": "2025-09-17T19:06:50.730628Z",
          "shell.execute_reply": "2025-09-17T19:06:50.947982Z"
        }
      },
