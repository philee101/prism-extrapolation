      "cell_type": "markdown",
      "source": [
        "### v7 kernel optim jul 3 2025"
      ],
      "metadata": {
        "id": "uHvKBPZV6sMR"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "@torch.compile(dynamic=False)\n",
        "def histogram_update_learnable_sharpened_copy_pos_optim_v7_fix_autograd_mod_4(\n",
        "\n",
        "    hist: torch.Tensor,             # [P, bs, h]\n",
        "    p_reset: torch.Tensor,          # [bs, h]\n",
        "    p_incr: torch.Tensor,           # [bs, h]\n",
        "    p_decr: torch.Tensor,           # [bs, h]\n",
        "    p_keep: torch.Tensor,           # [bs, h]\n",
        "    p_copy: Optional[torch.Tensor], # [P+1, bs, h] or [bs, h, P+1]\n",
        "    eps: float,\n",
        "    gamma: torch.Tensor,            # scalar or [h]\n",
        "    power_sharpen: bool,\n",
        "    buf: torch.Tensor = None,              # [P, bs, h]  (pre-allocated)\n",
        "    inc_buf: torch.Tensor = None,          # [P, bs, h]  (pre-allocated)\n",
        "    dec_buf: torch.Tensor = None,          # [P, bs, h]  (pre-allocated)\n",
        "    ) -> torch.Tensor:\n",
        "\n",
        "    P, bs, h = hist.shape\n",
        "\n",
        "    # 1) total & no-reset weights\n",
        "    # total = hist.sum(0)                    # [bs, h]\n",
        "    total = 1.0\n",
        "    nr    = 1.0 - p_reset                  # [bs, h]\n",
        "    w_inc = nr * p_incr                    # [bs, h]\n",
        "    w_dec = nr * p_decr\n",
        "    w_k   = nr * p_keep\n",
        "\n",
        "    # w_dki_tensor = torch.stack([nr*p_decr, nr*p_keep, nr*p_incr], dim=0)\n",
        "\n",
        "\n",
        "    # 3) compute base flows\n",
        "    hc = hist\n",
        "    base_keep = hc * w_k.unsqueeze(0)    # [P, bs, h]\n",
        "    base_inc  = hc * w_inc.unsqueeze(0)\n",
        "    base_dec  = hc * w_dec.unsqueeze(0)\n",
        "\n",
        "    # 4) inc-roll into inc_buf\n",
        "    # if inc_buf is None:\n",
        "    #     inc_buf = torch.zeros_like(base_inc)\n",
        "    # inc_buf[1:].copy_( base_inc[:-1] )\n",
        "    inc_buf = torch.cat([ torch.zeros(1,bs,h, device=hist.device),\n",
        "                           base_inc[:-1] ], dim=0)\n",
        "    inc_buf[-1].add_( base_inc[-1] )\n",
        "\n",
        "\n",
        "    # # 5) dec-roll into dec_buf\n",
        "    # if dec_buf is None:\n",
        "    #     dec_buf = torch.zeros_like(base_dec)\n",
        "    # dec_buf[:-1].copy_( base_dec[1:] )\n",
        "    dec_buf = torch.cat([ base_dec[1:], torch.zeros(1,bs,h, device=hist.device) ], dim=0)\n",
        "    dec_buf[0].add_( base_dec[0] )\n",
        "\n",
        "    # 6) accumulate no-copy branches\n",
        "    buf = base_keep + inc_buf + dec_buf\n",
        "    # buf = base_keep.add_( inc_buf).add_( dec_buf )\n",
        "    buf[1] = buf[1].add( total * p_reset * p_incr )               # to bin 1\n",
        "    buf[0] = buf[0].add( total * p_reset * (p_decr + p_keep) )     # to bin 0\n",
        "\n",
        "    # 7) copy branch\n",
        "    # if p_copy is not None and Position_Copying_Enabled:\n",
        "    #     # accept either [bs,h,P+1] or [P+1,bs,h]\n",
        "    #     if p_copy.dim() == 3 and p_copy.size(0) != P+1:\n",
        "    #         p_copy = p_copy.permute(2, 0, 1)\n",
        "    #     pos_cols = p_copy[:-1]              # [P, bs, h]\n",
        "    #     no_copy  = p_copy[-1]               # [bs, h]\n",
        "\n",
        "    #     buf.mul_( no_copy.unsqueeze(0) )    # scale normal flows\n",
        "    #     buf.add_( total.unsqueeze(0) * pos_cols )  # jump mass\n",
        "\n",
        "    # 8) sharpening & normalize\n",
        "    if True:\n",
        "        # In-place:\n",
        "        if True:\n",
        "            buf = buf.add(eps).pow_(gamma)\n",
        "            # torch.pow(buf.add(eps), gamma, out=buf\n",
        "        else:\n",
        "            buf = (buf + eps).pow(gamma)\n",
        "\n",
        "    buf = buf.div( buf.sum(0, keepdim=True).add_(eps))\n",
        "\n",
        "    return buf"
      ],
      "metadata": {
        "id": "q3n88CD06eXE",
        "trusted": true,
        "execution": {
          "iopub.status.busy": "2025-09-17T19:06:51.166031Z",
          "iopub.execute_input": "2025-09-17T19:06:51.166361Z",
          "iopub.status.idle": "2025-09-17T19:06:51.184634Z",
          "shell.execute_reply.started": "2025-09-17T19:06:51.166338Z",
          "shell.execute_reply": "2025-09-17T19:06:51.183930Z"
        }
      },
