        "\n",
        "#     return next_hist\n",
        "\n",
        "\n",
        "def histogram_update_learnable_sharpened_copy_pos_optim_v4_prealloced_buffers(\n",
        "    hist: Tensor,           # [P_hist, bs, h]\n",
        "    p_reset: Tensor,        # [bs, h]\n",
        "    p_incr: Tensor,         # [bs, h]\n",
        "    p_decr: Tensor,         # [bs, h]\n",
        "    p_keep: Tensor,         # [bs, h]\n",
        "    p_copy: Optional[Tensor],\n",
        "    eps: float,\n",
        "    gamma: Tensor,          # scalar or [h]\n",
        "    power_sharpen: bool,\n",
        "    # these buffers are mutated in-place to provide zeros:\n",
        "    next_hist_buf: Tensor,  # [P_hist, bs, h]\n",
        "    roll_buf: Tensor,       # [P_hist, bs, h]\n",
        ") -> Tensor:\n",
        "    P, bs, h = hist.shape\n",
        "\n",
        "    # 1) no-reset weights\n",
        "    total = hist.sum(0)                  # [bs,h]\n",
        "    nr    = (1.0 - p_reset)              # [bs,h]\n",
        "    w_inc = nr * p_incr                  # [bs,h]\n",
        "    w_dec = nr * p_decr\n",
        "    w_k   = nr * p_keep\n",
        "\n",
        "    # 2) reset-branch contributions\n",
        "    reset0 = (total * p_reset * (p_decr + p_keep)).unsqueeze(0)   # [1,bs,h]\n",
        "    reset1 = (total * p_reset * p_incr).unsqueeze(0)              # [1,bs,h]\n",
        "    # zero out the tail of next_hist_buf[2:] and concat\n",
        "    next_hist_buf[2:].zero_()                                    # zeros for positions 2…P-1\n",
        "    reset_branch = torch.cat([reset0, reset1, next_hist_buf[2:]], dim=0)  # [P,bs,h]\n",
        "\n",
        "    # 3) keep / inc / dec branches\n",
        "    base_keep = hist * w_k.unsqueeze(0)                           # [P,bs,h]\n",
        "    base_inc  = hist * w_inc.unsqueeze(0)\n",
        "    base_dec = hist * w_dec.unsqueeze(0)\n",
        "\n",
        "    # inc: roll up by 1\n",
        "    # use roll_buf[0:1] as a 1×bs×h zero‐row\n",
        "    roll_buf[0:1].zero_()\n",
        "    inc_roll = torch.cat([roll_buf[0:1], base_inc[:-1]], dim=0)    # [P,bs,h]\n",
        "    # clamp overflow from last bin back into it\n",
        "    inc_roll = inc_roll + base_inc[-1:].clone()\n",
        "\n",
        "    # dec: roll down by 1\n",
        "    roll_buf[0:1].zero_()\n",
        "    dec_roll = torch.cat([base_dec[1:], roll_buf[0:1]], dim=0)    # [P,bs,h]\n",
        "    # clamp underflow from first bin back into it\n",
        "    dec_roll = dec_roll + base_dec[:1].clone()\n",
        "\n",
        "    # sum all contributions\n",
        "    next_hist = reset_branch + base_keep + inc_roll + dec_roll    # [P,bs,h]\n",
        "\n",
        "    # 4) copy-branch\n",
        "    if p_copy is not None:\n",
        "        if p_copy.dim()==3 and p_copy.size(0)!=P+1:\n",
        "            p_copy = p_copy.permute(2,0,1)\n",
        "        pos_cols = p_copy[:P]             # [P,bs,h]\n",
        "        no_copy  = p_copy[P]              # [bs,h]\n",
        "        next_hist = next_hist * no_copy.unsqueeze(0) \\\n",
        "                   + total.unsqueeze(0) * pos_cols\n",
        "\n",
        "    # 5) sharpen & normalize\n",
        "    if power_sharpen:\n",
        "        next_hist = (next_hist + eps).pow(gamma)\n",
        "    next_hist = next_hist / (next_hist.sum(0) + eps)\n",
        "\n",
        "    return next_hist\n",
        "\n",
        "import torch\n",
        "import torch.nn.functional as F\n",
        "from typing import Optional\n",
        "\n",
        "\"\"\"\n",
        "Brings significant efficiency improvements\n",
        "See companion notebook https://colab.research.google.com/drive/1jDZ4iKe0yBNhROxI96qVhn9hRS6vvb4Z?usp=sharing\n",
        "for unit tests of the below kernel version:\n",
        "\"\"\"\n",
        "@torch.compile(dynamic=False)\n",
        "def histogram_update_learnable_sharpened_copy_pos_optim_v4_prealloced_buffers_conv(\n",
        "    hist: torch.Tensor,           # [P, bs, h]\n",
        "    p_reset: torch.Tensor,        # [bs, h]\n",
        "    p_incr: torch.Tensor,         # [bs, h]\n",
        "    p_decr: torch.Tensor,         # [bs, h]\n",
        "    p_keep: torch.Tensor,         # [bs, h]\n",
        "    p_copy: Optional[torch.Tensor],\n",
        "    eps: float,\n",
        "    gamma: torch.Tensor,          # scalar or [h]\n",
        "    power_sharpen: bool,\n",
        "    next_hist_buf: torch.Tensor,  # [P, bs, h]\n",
        "    roll_buf: torch.Tensor = None,       # [P, bs, h]\n",
        ") -> torch.Tensor:\n",
        "    P, bs, h = hist.shape\n",
        "\n",
        "    # 1) no-reset weights\n",
        "    total = hist.sum(0)                    # [bs,h]\n",
        "    nr    = (1.0 - p_reset)                # [bs,h]\n",
        "    w_inc = nr * p_incr                    # [bs,h]\n",
        "    w_dec = nr * p_decr\n",
        "    w_k   = nr * p_keep\n",
        "\n",
        "    # 2) reset-branch\n",
        "    reset0 = (total * p_reset * (p_decr + p_keep)).unsqueeze(0)  # [1,bs,h]\n",
        "    reset1 = (total * p_reset * p_incr).unsqueeze(0)             # [1,bs,h]\n",
        "    next_hist_buf[2:].zero_()                                   # clear tail\n",
        "    reset_branch = torch.cat([reset0, reset1, next_hist_buf[2:]], dim=0)  # [P,bs,h]\n",
        "\n",
        "    # 3) keep / inc / dec bases\n",
        "    base_keep = hist * w_k.unsqueeze(0)    # [P,bs,h]\n",
        "    base_inc  = hist * w_inc.unsqueeze(0)\n",
        "    base_dec  = hist * w_dec.unsqueeze(0)\n",
        "\n",
        "    # 3a) inc-roll via pad+slice along P\n",
        "    # reshape to [bs*h, 1, P]\n",
        "    bh = bs * h\n",
        "    inc_flat = base_inc.permute(1,2,0).reshape(bh,1,P)\n",
        "    # pad on left, then drop final element\n",
        "    inc_padded = F.pad(inc_flat, (1,0))    # [bh,1,P+1]\n",
        "    inc_shift = inc_padded[:, :, :-1]      # [bh,1,P]\n",
        "    inc_roll = inc_shift.reshape(bs,h,P).permute(2,0,1)  # [P,bs,h]\n",
        "    # clamp overflow\n",
        "    inc_roll[-1].add_(base_inc[-1])\n",
        "\n",
        "    # 3b) dec-roll via pad+slice on right\n",
        "    dec_flat = base_dec.permute(1,2,0).reshape(bh,1,P)\n",
        "    dec_padded = F.pad(dec_flat, (0,1))    # [bh,1,P+1]\n",
        "    dec_shift = dec_padded[:, :, 1:]       # drop first → [bh,1,P]\n",
        "    dec_roll = dec_shift.reshape(bs,h,P).permute(2,0,1)  # [P,bs,h]\n",
        "    # clamp underflow\n",
        "    dec_roll[0].add_(base_dec[0])\n",
        "\n",
        "    # 4) sum all three non-reset branches\n",
        "    non_reset = base_keep + inc_roll + dec_roll\n",
        "\n",
        "    # 5) combine reset + non-reset\n",
        "    next_hist = reset_branch + non_reset    # [P,bs,h]\n",
        "\n",
        "    # 6) copy-branch\n",
        "    if p_copy is not None:\n",
        "        if p_copy.dim()==3 and p_copy.size(0)!=P+1:\n",
        "            p_copy = p_copy.permute(2,0,1)\n",
        "        pos_cols = p_copy[:P]                # [P,bs,h]\n",
        "        no_copy  = p_copy[P]                 # [bs,h]\n",
        "        next_hist = next_hist * no_copy.unsqueeze(0) \\\n",
        "                   + total.unsqueeze(0) * pos_cols\n",
        "\n",
        "    # 7) sharpen & normalize\n",
        "    if power_sharpen:\n",
        "        next_hist = (next_hist + eps).pow(gamma)\n",
        "    next_hist = next_hist / (next_hist.sum(0) + eps)\n",
        "\n",
        "    return next_hist\n"
      ],
