        "                                  #     gamma: float,\n",
        "                                  #     power_sharpen: bool,\n",
        "                                  #     reset_buf: torch.Tensor,    # [P, bs, h]\n",
        "                                  #     inc_buf:   torch.Tensor,    # [P, bs, h]\n",
        "                                  #     dec_buf:   torch.Tensor,    # [P, bs, h]\n",
        "                                  #     out_buf:   torch.Tensor,    # [P, bs, h]\n",
        "                                  #     gates_buf: torch.Tensor,    # [3, bs, h]\n",
        "                                  # ):\n",
        "                                  # out_buf = torch.zeros_like(hist)\n",
        "                                  gates_buf = torch.zeros(3,bs,h,device=dev)\n",
        "                                  hist_next = histogram_update_learnable_sharpened_copy_pos_optim_v12(\n",
        "                                      hist,\n",
        "                                      reset_probs_t,\n",
        "                                      p_incr_t,\n",
        "                                      p_decr_t,\n",
        "                                      p_keep_t,\n",
