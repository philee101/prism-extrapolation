      "source": [
        "VERBOSE_LOGGING = 1\n",
        "evaluate_extrapolation_odds_first(for_model='rse', min_seq_len_for_dataset=30,\n",
        "                                   max_seq_len_for_dataset=30,\n",
        "                                   printOutputsAndTargets=True,\n",
        "                                  visualize_attn_weights=0, n_total_examples=1)"
      ],
