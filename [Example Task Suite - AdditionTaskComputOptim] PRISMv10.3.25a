      "source": [
        "import torch\n",
        "\n",
        "@torch.compile(dynamic=False)\n",
        "def hist_update_v7_fast_bwd_mod_2_noslices_symmetric_split_rowadd_fma(\n",
        "    hist:   torch.Tensor,         # [2*seq_len+1, bs, h]\n",
        "    p_reset: torch.Tensor,        # [bs, h]\n",
        "    p_inc:   torch.Tensor,        # [bs, h]\n",
        "    p_dec:   torch.Tensor,        # [bs, h]\n",
        "    p_keep:  torch.Tensor,        # [bs, h]\n",
        "    eps:     float,\n",
        "    gamma:   torch.Tensor|float,  # scalar or [h]\n",
        "    power:   bool,\n",
        "    seq_len: int,\n",
        "    p_copy:  torch.Tensor|None = None,   # [2*seq_len+2, bs, h] or None\n",
        "):\n",
        "    L, bs, h = hist.shape\n",
        "    mid = seq_len\n",
        "\n",
        "    one   = torch.ones_like(p_reset)\n",
        "    inv_r = one - p_reset\n",
        "    w_inc, w_dec, w_keep = inv_r * p_inc, inv_r * p_dec, inv_r * p_keep\n",
        "\n",
        "    # --- base output (keep) ---\n",
        "    out = hist * w_keep.unsqueeze(0)                      # [L,bs,h]\n",
        "\n",
        "    # --- +1 shift (one cat + one row add; no index tensors) ---\n",
        "    zero_row = torch.zeros(1, bs, h, device=hist.device, dtype=hist.dtype)\n",
        "    hist_main, hist_last = hist.split([L-1, 1], dim=0)    # views\n",
        "    inc_shift = torch.cat([zero_row, hist_main], dim=0)   # [L,bs,h]\n",
        "    out = out + inc_shift * w_inc.unsqueeze(0)\n",
        "    out[-1] = out[-1] + hist_last.squeeze(0) * w_inc      # carry to last row\n",
        "\n",
        "    # --- -1 shift (one cat + one row add) ---\n",
        "    hist_first, hist_rest = hist.split([1, L-1], dim=0)   # views\n",
        "    dec_shift = torch.cat([hist_rest, zero_row], dim=0)   # [L,bs,h]\n",
        "    out = out + dec_shift * w_dec.unsqueeze(0)\n",
        "    out[0] = out[0] + hist_first.squeeze(0) * w_dec       # carry to first row\n",
        "\n",
        "    # --- reset triad (constant row writes; no big buffer) ---\n",
        "    out[mid] = out[mid] + (p_reset * p_keep)\n",
        "    if mid + 1 < L:\n",
        "        out[mid + 1] = out[mid + 1] + (p_reset * p_inc)\n",
        "    if mid - 1 >= 0:\n",
        "        out[mid - 1] = out[mid - 1] + (p_reset * p_dec)\n",
        "\n",
        "    # --- optional position-copy (split; no tensor indexing) ---\n",
        "    if p_copy is not None:\n",
        "        pos_cols, no_copy = p_copy.split([L, 1], dim=0)   # [L,bs,h], [1,bs,h]\n",
        "        out = out * no_copy + pos_cols\n",
        "\n",
        "    # --- sharpen + normalize ---\n",
        "    if power:\n",
        "        # original power path (fast when fused); supports scalar or per-head gamma\n",
        "        if isinstance(gamma, torch.Tensor) and gamma.numel() == h:\n",
        "            g = gamma.to(device=hist.device, dtype=hist.dtype).view(1, 1, h)\n",
        "        else:\n",
        "            g = torch.as_tensor(gamma, device=hist.device, dtype=hist.dtype).view(1, 1, 1)\n",
        "        out = (out + eps).pow(g)\n",
        "        out = out / (out.sum(0, keepdim=True) + eps)\n",
        "    else:\n",
        "        out = out / (out.sum(0, keepdim=True) + eps)\n",
        "\n",
        "    return out\n"
      ],
