    {
      "cell_type": "markdown",
      "source": [
        "### Regularizers"
      ],
      "metadata": {
        "id": "qf_qnYF9zmgn"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "from torch.nn import Linear\n",
        "\n",
        "# For <LINEAR_MODULE_SPECTRAL_NORM>\n",
        "@torch.no_grad()\n",
        "def spectral_clip_(linear, s_max: float,\n",
        "                   iters:int=3,   # PI steps before first scale\n",
        "                   rechecks:int=2,# how many recheck/rescale rounds\n",
        "                   tol:float=1e-3,# allow +0.1% slack\n",
        "                   safety:float=0.01, # 1% extra shrink to counter underest.\n",
        "                   eps:float=1e-6):\n",
        "    if isinstance(linear, torch.nn.Linear):\n",
        "        W = linear.weight\n",
        "    else:\n",
        "        W = linear\n",
        "        assert isinstance(W, torch.nn.parameter.Parameter)\n",
        "\n",
        "    Wf = W.float()  # do PI in fp32\n",
        "\n",
        "    # fresh u,v\n",
        "    u = torch.randn(Wf.size(0), device=W.device)\n",
        "    v = torch.randn(Wf.size(1), device=W.device)\n",
        "    u = u / (u.norm() + eps); v = v / (v.norm() + eps)\n",
        "\n",
        "    # initial PI\n",
        "    for _ in range(iters):\n",
        "        v = (Wf.t() @ u); v = v / (v.norm() + eps)\n",
        "        u = (Wf @ v);     u = u / (u.norm() + eps)\n",
        "    sigma = (u @ (Wf @ v)).abs().item()\n",
        "\n",
        "    # if sigma <= s_max * (1 + tol):\n",
        "    #     return sigma\n",
        "\n",
        "    # scale + recheck loop\n",
        "    for _ in range(rechecks):\n",
        "        # extra safety factor (1 - safety) guards against \\hatσ < σ\n",
        "        W.mul_( (s_max / (sigma + 1e-12)) * (1.0 - safety) )\n",
        "\n",
        "        # one warm-started PI step on the *scaled* W\n",
        "        Wf = W.float()\n",
        "        v = (Wf.t() @ u); v = v / (v.norm() + eps)\n",
        "        u = (Wf @ v);     u = u / (u.norm() + eps)\n",
        "        sigma = (u @ (Wf @ v)).abs().item()\n",
        "\n",
        "        # if sigma <= s_max * (1 + tol):\n",
        "        #     break\n",
        "\n",
        "    return sigma\n",
        "\n",
        "def project_mats_(model):\n",
        "    for layer in model.layers:\n",
        "        # Attention out-proj and V\n",
        "        if USE_HIGH_DIMENSIONAL_OUTPUT_PROJECTION:\n",
        "            spectral_clip_(layer.self_attn.head_projections, s_max=3.0, iters=3)\n",
        "        spectral_clip_(layer.self_attn.v_linear, s_max=3.0, iters=3)\n",
        "\n",
        "        # FFN: W2 is the expanding map; W1 can be column-clipped\n",
        "        spectral_clip_(layer.ff[2], s_max=3.0, iters=3)\n",
        "        spectral_clip_(layer.ff[0], s_max=3.0, iters=3)"
      ],
      "metadata": {
        "id": "k0iQ0t70d8AU"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "import torch\n",
        "import torch.nn.functional as F\n",
        "\n",
        "def _ortho_penalty_linear(linear: torch.nn.Linear, *, only_offdiag=False):\n",
        "    # compute in fp32 for stability even under AMP\n",
        "    W = linear.weight.float()\n",
        "    out, in_ = W.shape\n",
        "    if out >= in_:   # columns can be orthonormal\n",
        "        G = W.T @ W                    # [in, in]\n",
        "        I = torch.eye(in_, device=W.device, dtype=W.dtype)\n",
        "    else:            # rows can be orthonormal\n",
        "        G = W @ W.T                    # [out, out]\n",
        "        I = torch.eye(out, device=W.device, dtype=W.dtype)\n",
        "\n",
        "    if only_offdiag:\n",
        "        G = G - torch.diag_embed(torch.diagonal(G))\n",
        "        I = I.zero_()                  # no unit-norm pressure, just de-correlate\n",
        "\n",
        "    # Frobenius MSE; normalize by matrix size to keep the scale predictable\n",
        "    return F.mse_loss(G, I, reduction='sum') / G.numel()\n",
        "\n",
        "def orthogonal_regularizer_linear_modules(model, lambda_v=1e-4, lambda_ff=1e-4, only_offdiag=False):\n",
        "    reg = 0.0\n",
        "    for layer in model.layers:  # adjust to your module structure\n",
        "        reg = reg + lambda_v * _ortho_penalty_linear(layer.self_attn.v_linear, only_offdiag=only_offdiag)\n",
        "        reg = reg + lambda_ff * _ortho_penalty_linear(layer.ff[0],                  only_offdiag=only_offdiag)\n",
        "        reg = reg + lambda_ff * _ortho_penalty_linear(layer.ff[2],                  only_offdiag=only_offdiag)\n",
        "    return reg"
      ],
      "metadata": {
        "id": "r3K1yqu0qSiI",
        "scrolled": true,
        "trusted": true,
        "execution": {
          "iopub.status.busy": "2025-09-17T19:06:57.930706Z",
          "iopub.execute_input": "2025-09-17T19:06:57.930908Z",
          "iopub.status.idle": "2025-09-17T19:06:57.946563Z",
          "shell.execute_reply.started": "2025-09-17T19:06:57.930891Z",
          "shell.execute_reply": "2025-09-17T19:06:57.946009Z"
        }
      },
