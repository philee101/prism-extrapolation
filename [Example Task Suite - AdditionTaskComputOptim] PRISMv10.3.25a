      "cell_type": "markdown",
      "source": [
        "## Histogram_update_main_kernel"
      ],
      "metadata": {
        "id": "37n71YKSnl-A"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "from torch import Tensor\n",
        "from typing import Optional, List\n",
        "\n",
        "\"\"\"\n",
        "    - Same as histogram_update_learnable_sharpened_copy_pos_optim_v4(), except using jit.script\n",
        "    - Unit test at: https://colab.research.google.com/drive/1MSeX1edeCEJbhds8iZWjqGHfGmrNxP84#scrollTo=PYM_QHazEheH\n",
        "\"\"\"\n",
        "\n",
        "def histogram_update_learnable_sharpened_copy_pos_optim_v4_jit_script(\n",
        "    hist: Tensor,                            # [P, bs, h]\n",
        "    p_reset: Tensor,                         # [bs, h]\n",
        "    p_incr: Tensor,                          # [bs, h]\n",
        "    p_decr: Tensor,                          # [bs, h]\n",
        "    p_keep: Tensor,                          # [bs, h]\n",
        "    P_hist: int,                             # int\n",
        "    p_copy: Optional[Tensor],                # either None or [bs, h, P_hist+1] or [P_hist+1, bs, h]\n",
        "    eps: float,\n",
        "    # gamma: float,\n",
        "    gamma: Tensor,                           # [1,1,h]\n",
        "    power_sharpen: bool,\n",
        "    cached_hists_qk_fordebug: Optional[List[Tensor]],    # if provided, we .append to it\n",
        ") -> Tensor:\n",
        "    # extract dynamic sizes\n",
        "    P = hist.size(0)\n",
        "    h = hist.size(2)\n",
        "    bs = hist.size(1)\n",
        "    # ① compute no-reset weights\n",
        "    total = hist.sum(0)                      # [bs, h]\n",
        "    one   = torch.ones((), device=hist.device)\n",
        "    w_inc  = (one - p_reset) * p_incr        # [bs, h]\n",
        "    w_dec  = (one - p_reset) * p_decr\n",
        "    w_keep = (one - p_reset) * p_keep\n",
        "\n",
        "    # ② reset‐branch\n",
        "    next_hist = torch.zeros_like(hist)       # [P, bs, h]\n",
        "    next_hist[1] = next_hist[1] + total * p_reset * p_incr\n",
        "    next_hist[0] = next_hist[0] + total * p_reset * (p_decr + p_keep)\n",
        "\n",
        "    # ③ fused inc/keep/dec via pure slicing\n",
        "    base_keep = hist * w_keep.unsqueeze(0)   # [P, bs, h]\n",
        "\n",
        "    # inc-branch: shift up by 1, clamp overflow\n",
        "    base_inc = hist * w_inc.unsqueeze(0)\n",
        "    inc_roll = torch.zeros_like(base_inc)\n",
        "    inc_roll[1:] = base_inc[:-1]\n",
        "    # clamp spill from last bin back into it\n",
        "    inc_roll[-1] = inc_roll[-1] + base_inc[-1]\n",
        "\n",
        "    # dec-branch: shift down by 1, clamp underflow\n",
        "    base_dec = hist * w_dec.unsqueeze(0)\n",
        "    dec_roll = torch.zeros_like(base_dec)\n",
        "    dec_roll[:-1] = base_dec[1:]\n",
        "    # clamp spill from first bin back into it\n",
        "    dec_roll[0] = dec_roll[0] + base_dec[0]\n",
        "\n",
        "    next_hist = next_hist + base_keep + inc_roll + dec_roll\n",
        "\n",
        "    # ④ copy‐branch\n",
        "    if p_copy is not None:\n",
        "\n",
        "        # bring into shape [P_hist+1, bs, h]\n",
        "        if p_copy.dim() == 3 and p_copy.size(0) != P_hist + 1:\n",
        "            # assume [bs,h,P_hist+1] → permute\n",
        "            assert False, \"Not implemented\"\n",
        "            p_copy = p_copy.permute(2, 0, 1)\n",
        "\n",
        "        # now must be [P_hist+1, bs, h]\n",
        "        # assert p_copy.shape == (P_hist + 1, hist.shape[1], hist.shape[2])\n",
        "        # split into copy-to-pos and no-copy\n",
        "        pos_cols = p_copy[:P_hist]              # [P_hist, bs, h]\n",
        "        no_copy  = p_copy[P_hist]               # [bs, h]\n",
        "        # down‐scale normal flow\n",
        "        next_hist = next_hist * no_copy.unsqueeze(0)\n",
        "        # add jump mass\n",
        "        next_hist = next_hist + total.unsqueeze(0) * pos_cols\n",
        "\n",
        "\n",
        "     # ⑤ sharpening + renormalize with learned gamma\n",
        "    if power_sharpen:\n",
        "        next_hist = (next_hist + eps).pow(gamma.view(h) if type(gamma) is Tensor else gamma)\n",
        "\n",
        "    # now normalize\n",
        "    denom = next_hist.sum(0) + eps       # shape [bs, h]\n",
        "    next_hist = next_hist / denom.unsqueeze(0)\n",
        "\n",
        "    # optional debug cache\n",
        "    if cached_hists_qk_fordebug is not None and not DISABLE_POSITION_CACHING:\n",
        "        cached_hists_qk_fordebug.append(next_hist)\n",
        "\n",
        "    return next_hist\n",
        "\n",
        "from torch import Tensor\n",
        "from typing import Optional, List\n",
        "import torch\n",
        "\n",
        "from torch import Tensor\n",
        "from typing import Optional, List\n",
        "import torch\n",
        "\n",
        "import torch\n",
        "from torch import Tensor\n",
        "from typing import Optional, List\n",
        "\n",
        "\n",
        "# def histogram_update_learnable_sharpened_copy_pos_optim_v4_jit_script_fused_lines(\n",
        "#     hist: Tensor,                            # [P, bs, h]\n",
        "#     p_reset: Tensor,                         # [bs, h]\n",
        "#     p_incr: Tensor,                          # [bs, h]\n",
        "#     p_decr: Tensor,                          # [bs, h]\n",
        "#     p_keep: Tensor,                          # [bs, h]\n",
        "#     P_hist: int,                             # int\n",
        "#     p_copy: Optional[Tensor],                # either None or [bs, h, P_hist+1] or [P_hist+1, bs, h]\n",
        "#     eps: float,\n",
        "#     gamma: Tensor,                           # [1,1,h]\n",
        "#     power_sharpen: bool,\n",
        "#     cached_hists_qk_fordebug: Optional[List[Tensor]],\n",
        "# ) -> Tensor:\n",
