    {
      "cell_type": "code",
      "source": [
        "#@torch.compiler.disable()\n",
        "def _softmax_without_torch_compiler(logits, dim=-1):\n",
        "    return F.softmax(logits, dim=dim)\n",
        "\n",
        "\"\"\"\n",
        "- Avoids issue: `W1001 04:16:04.239000 360 torch/_inductor/utils.py:1436] [3/0] Not enough SMs to use max_autotune_gemm mode\n",
        "/usr/local/lib/python3.12/dist-packages/torch/_inductor/lowering.py:7095: UserWarning:\n",
        "Online softmax is disabled on the fly since Inductor decides to\n",
        "split the reduction. Cut an issue to PyTorch if this is an\n",
        "important use case and you want to speed it up with online\n",
        "softmax.`\n",
        "- Mathematically identical to F.softmax(x, dim)\n",
        "\"\"\"\n",
        "def softmax_lse(x, dim=-1):\n",
        "    # mathematically identical to F.softmax(x, dim)\n",
        "    return (x - x.logsumexp(dim, keepdim=True)).exp()\n"
      ],
      "metadata": {
        "id": "z2MeXOPJqVbr"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "from logging import DEBUG\n",
        "import torch.nn.functional as F\n",
        "from functools import partial\n",
        "\n",
        "# import opt einsum\n",
        "from opt_einsum import contract\n",
        "import math\n",
        "# Import torch scan func:\n",
        "# from torch_xla.experimental.scan import scan\n",
        "\n",
        "USE_LSTM_FOR_RE_CELLS = True # Otherwise use GRU\n",
        "# USE_LINEAR_LAYER_INSTEAD_OF_LN_FOR_INPUT_PROJ = True\n",
        "USE_RMS_NORM_LSTM = False\n",
        "\n",
        "\n",
        "\"\"\" <copyProbsSigmoidGateForNull>\n",
        "If True, use a sigmoid gate isntead of softmax to compute no-copy. Only affects cases where <Position_Copying_Enabled>=T\n",
        "\"\"\"\n",
        "USE_SIGMOID_GATE_FOR_NO_COPY_BRANCH = True\n",
        "copyRelViaAbsPos = False and Position_Copying_Enabled\n",
        "\n",
        "USE_ARGMAX_OVER_TOPK = True # If BW == 1, use argmax\n",
        "ResetGateBranching = True # Use branching at each time t for reset gate instead of multiplying the relative position at time t. Num branches per position is at least 2\n",
        "stochasticMatrixForResetPosBr = True\n",
        "\n",
        "\n",
        "# MARK RelativeEncodingLSTMHiddenOutputsRelevanceEncoding:\n",
        "lstm_latent_dim_for_RPE_forward_return = 1\n",
        "RelativeEncodingLSTMHiddenOutputsRelevanceEncoding_IS_ENABLED = False\n",
        "LSTM_OUTPUT_QK_N_DIM = 128\n",
        "RelativeEncodingLSTMHiddenOutputs_Use_Higher_Dim_Embeds = lstm_latent_dim_for_RPE_forward_return > 1\n",
        "\n",
        "\n",
        "MIN_POSITION = 0.0\n",
        "NUM_LSTM_CELLS = 1\n",
        "\n",
        "\n",
        "\n",
        "MultiplyWithCustomGrad_NORMALIZED_GRAD_VALUE = 1.0\n",
        "increment_scale = 1.0 #1.0 / (self.max_len - 1)  # e.g., 1/2047\n",
        "NULL_CANDIDATE_SENTINAL_SCALAR_POSITION_VALUE = 0.0\n",
        "\n",
        "# MARK: replaceSigmoidReForGumbel\n",
        "replaceSigmoidReForGumbel = True\n",
        "# BRANCHING_FACTOR_FOR_RE_POS = 5\n",
        "LOGIT_LOSS_RSE_COPY_PROBS = False\n",
        "RSE_COPY_PROBS_USE_MARGIN_REG = False           # hinge on logit margin\n",
        "TEST_ABLATE_COPYPROBS = False\n",
        "PREALLOCED_HISTOGRAM_TENSORS = False\n",
        "USE_PREALLOCED_STATE_POS_BASE = True\n",
        "\n",
        "ABLATE_PROC_QK = False\n",
        "PERMUTE_TIME_IDX_TO_DIM_0 = True\n",
        "SEPARATE_GATE_PROBS_TO_LISTS_BEFORE_TIMESLICES = True\n",
        "\n",
        "# <negativePosViaSymmUpdate>:\n",
        "# Unit test notebook: https://colab.research.google.com/drive/13BJ2kZCX3RQvKF0D6zlXYTFhAeGTPBhe#scrollTo=8B4BJQdlsiTm\n",
        "SYMMETRIC_UPDATE_FN = True # Allows negative positions for symmetry about the position axis\n",
        "MGMLP_BROADCAST_INSTEAD_OF_EXPAND = True # For performance related reasons only - don't expand tensors sent to mgmlp, does not affect mathematics of the model\n",
        "RSE_LSTM_USE_RESIDUAL_CONNECTION = True\n",
        "\n",
        "\n",
        "class RelativePositionEncoding(nn.Module):\n",
        "\n",
        "    # MARK: RSPE.init()\n",
        "    def __init__(self, max_len, num_operators, num_layers_per_gate=3,\n",
        "                 intermediate_dim=40,\n",
        "                 use_lstm=True,\n",
        "                 fixed_output_gates=True,\n",
        "                 fixed_reset_gates=False,\n",
        "                 jump_gate_head_dim_per_operator=20, # Also denoted the 'copy-position' gates\n",
        "\n",
        "                 path_for_rotation_matrices=None,\n",
        "                  override_rotation_matrices=None,\n",
        "                 fixed_gate_mask = None\n",
        "                 ):\n",
        "\n",
        "        \"\"\"\n",
        "        A vectorized implementation of Relative Position Encoding with parallel multi-operator support.\n",
        "\n",
        "        Args:\n",
        "            max_len (int): Maximum sequence length.\n",
        "            num_operators (int): Number of operators to process in parallel.\n",
        "            num_layers_per_gate (int): Number of layers for the gate MLPs.\n",
        "            intermediate_dim (int): Intermediate hidden dimension for the MLPs.\n",
        "            fixed_gate_mask: See MARK: fixedOutput+ResetGates for >= 1 keyOperators\n",
        "        \"\"\"\n",
        "        global NUM_FIXED_KEY_RE\n",
        "        super().__init__()\n",
        "        assert not (fixed_output_gates and fixed_reset_gates), \"Cannot have both fixed_output_gates and fixed_reset_gates set to True\"\n",
        "        assert num_operators > 0, \"Number of operators must be greater than 0\"\n",
        "\n",
        "        # MARK: fixedOutput+ResetGates for >= 1 keyOperators\n",
        "        # - Purpose: used in the context of RelPositionAddressCopying_IS_Enabled == True so to copy key positions as ABSOLUTE\n",
        "        # positions, NOT RELATIVE positions\n",
        "        # Save the user’s specified range for key operators that must forcibly increment:\n",
        "        if fixed_gate_mask is None:\n",
        "            fixed_gate_mask = torch.zeros(num_operators, dtype=torch.bool)\n",
        "\n",
        "        self.register_buffer('fixed_gate_mask', torch.tensor(fixed_gate_mask, dtype=torch.bool))\n",
        "        # For <addPosCopyingForHMM>: only allow copying the absolute positions from a past key rel. position to any query relative position\n",
        "        self.copy_from_fixed_absolute_enc_key_gates_only = True and (NUM_FIXED_KEY_RE is None or NUM_FIXED_KEY_RE <= 0)\n",
        "        if sum(self.fixed_gate_mask) <= 0:\n",
        "            self.copy_from_fixed_absolute_enc_key_gates_only = False\n",
        "        print(f'[RelativePositionEncoding.init()] self.copy_from_fixed_absolute_enc_key_gates_only = {self.copy_from_fixed_absolute_enc_key_gates_only}')\n",
        "\n",
        "        self.beam_width = 1\n",
        "        self.intermediate_dim_for_gate_mlp = intermediate_dim\n",
        "        self.jump_gate_head_dim_per_operator = jump_gate_head_dim_per_operator\n",
        "\n",
        "        if Input_Dependent_Gamma_Exponents:\n",
        "            # self.gamma_proj = nn.Linear(VOCAB_N_DIM, num_operators, bias=True) # Replaced by einsum map below\n",
        "            # nn.init.xavier_uniform_(self.gamma_proj.weight)\n",
        "\n",
        "            # <gamma_proj_proj_per_operator_to_scalar>: New per-opeator map from R^(bs x seq_len x num_operators x VOCAB_N_DIM) to R^(bs x seq_len x num_operators) using einsum:\n",
        "            param_tensor_for_gamma_per_operator_proj = torch.randn(num_operators, self.intermediate_dim_for_gate_mlp)\n",
        "\n",
        "            # Normalize each parameter vector to unit norm:\n",
        "            for param in range(param_tensor_for_gamma_per_operator_proj.shape[0]):\n",
        "                param_tensor_for_gamma_per_operator_proj[param] /= param_tensor_for_gamma_per_operator_proj[param].norm()\n",
        "                #  *= math.sqrt(param_tensor_for_gamma_per_operator_proj[param].shape[0])):\n",
        "                # param_tensor_for_gamma_per_operator_proj[param] *= math.sqrt(param_tensor_for_gamma_per_operator_proj[param].shape[0])\n",
        "\n",
        "\n",
        "            self._gamma_proj_proj_per_operator_to_scalar = nn.Parameter(param_tensor_for_gamma_per_operator_proj)\n",
        "            _gamma_proj_bias = torch.ones(num_operators, self.intermediate_dim_for_gate_mlp)\n",
        "            # Make _gamma_proj_bias sum to 0.7:\n",
        "            _gamma_proj_bias = (_gamma_proj_bias / _gamma_proj_bias.sum(dim=-1, keepdim=True)) * 0.6\n",
        "            # assert equal to 0.7:\n",
        "            # assert torch.allclose(_gamma_proj_bias.sum(dim=-1), torch.ones(num_operators)\n",
        "            self._gamma_proj_bias = nn.Parameter(_gamma_proj_bias)\n",
        "\n",
        "\n",
        "        self.max_len = max_len\n",
        "        self.num_operators = num_operators\n",
        "        # assert self.sinusoidal_encoding.is_contiguous(), f'self.sinusoidal_encoding.is_contiguous(): {self.sinusoidal_encoding.is_contiguous()}'\n",
        "\n",
        "        # Initialize sinusoidal encoding\n",
        "\n",
        "        # For <SharpenHistUpdate>\n",
        "        # one γ per operator, but expressed in unconstrained space θ\n",
        "        γ_init = 2.0\n",
        "        # theta0 = torch.log(torch.exp(torch.tensor(γ_init-1.)) - 1.)\n",
        "        theta0 = torch.log(torch.tensor(γ_init - 1.0))\n",
        "        self._theta_gamma = nn.Parameter(\n",
        "            theta0.repeat(self.num_operators)   # shape [h]\n",
        "        )\n",
        "\n",
        "        # Learnable projections for queries and keys, similar to SA layers\n",
        "        # For MARK: RelPositionAddressCopying\n",
        "        if True:\n",
        "\n",
        "            if USE_ESCAPE_GATE_FOR_RELPOS_COPY:\n",
        "                self.escape_gate = nn.Sequential(\n",
        "                nn.Linear(self.jump_gate_head_dim_per_operator, self.jump_gate_head_dim_per_operator // 2),\n",
        "\n",
        "                nn.GELU(),\n",
        "                # nn.Linear(VOCAB_N_DIM // 2, 1)\n",
        "                nn.Linear(self.jump_gate_head_dim_per_operator // 2, 1)\n",
        "                )\n",
        "                for layer in self.escape_gate:\n",
        "                    if isinstance(layer, nn.Linear):\n",
        "                        nn.init.xavier_uniform_(layer.weight)\n",
        "\n",
        "                # self.escape_gate_bias = nn.Parameter(torch.tensor([-3.0]))  # negative bias strongly discourages consecutive copying\n",
        "\n",
        "                self.escape_gate_bias_ = nn.Parameter(torch.torch.ones(self.num_operators // 2, 1, 1) * -3.0)\n",
        "\n",
        "            half_ops = num_operators // 2\n",
        "            self.W_q_ = nn.Parameter(torch.randn(half_ops, VOCAB_N_DIM, jump_gate_head_dim_per_operator))  # Per-operator\n",
        "            self.W_k_ = nn.Parameter(torch.randn(half_ops, VOCAB_N_DIM, jump_gate_head_dim_per_operator))  # Per-operator\n",
        "            half_ops = num_operators // 2\n",
        "\n",
        "\n",
        "            self.W_null_q = nn.Parameter(torch.randn(half_ops, VOCAB_N_DIM, jump_gate_head_dim_per_operator ))\n",
        "            self.W_null_k = nn.Parameter(torch.randn(half_ops, VOCAB_N_DIM, jump_gate_head_dim_per_operator))\n",
        "\n",
        "            # bias parameters for null embeddings (optional but recommended)\n",
        "            self.q_bias = nn.Parameter(torch.zeros(half_ops, 1, jump_gate_head_dim_per_operator))\n",
        "            self.k_bias = nn.Parameter(torch.zeros(half_ops, 1, jump_gate_head_dim_per_operator))\n",
        "            self.null_q_bias = nn.Parameter(torch.zeros(half_ops, 1, jump_gate_head_dim_per_operator))\n",
        "            self.null_k_bias = nn.Parameter(torch.zeros(half_ops, 1, jump_gate_head_dim_per_operator))\n",
        "\n",
        "            # re-initialize properly (e.g., Xavier uniform):\n",
        "            for param in [self.W_null_q, self.W_null_k]:\n",
        "                nn.init.xavier_uniform_(param.transpose(-2, -1))\n",
        "\n",
        "            # Use xavier init for W_q, W_k, null_key\n",
        "            to_init_norm = [self.W_q_, self.W_k_] #, self.null_key]\n",
        "            for param in to_init_norm:\n",
        "                nn.init.xavier_uniform_(param.T)\n",
        "\n",
        "            # # assert VOCAB_N_DIM % 2 == 0, f'VOCAB_N_DIM: {VOCAB_N_DIM} not divisible by 2'\n",
        "            self.layer_norm_for_addr_copy_func__ = nn.LayerNorm(VOCAB_N_DIM, elementwise_affine=False)\n",
        "\n",
        "\n",
        "        else:\n",
        "            self.W_q_ = None\n",
        "            self.W_k_ = None\n",
        "\n",
        "\n",
        "        self.use_lstm = use_lstm\n",
        "\n",
        "        # Create shared parameters for the first two layers\n",
        "\n",
        "        ABLATE_MERGED_GMLP = False\n",
        "\n",
        "        if not ABLATE_MERGED_GMLP:\n",
        "            self._merged_gate_mlp = MergedGateMLP_Residual(intermediate_dim, intermediate_dim, num_operators, num_layers=num_layers_per_gate,\n",
        "                                                final_gate_bias=0, fixed_gate_mask=fixed_gate_mask,\n",
        "                                                output_value_for_fixed_gates=1)\n",
        "            self._mgmlpInputProj = nn.Linear(VOCAB_N_DIM, intermediate_dim, bias=True)\n",
        "            nn.init.xavier_uniform_(self._mgmlpInputProj.weight)\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "        # self.initial_state = torch.nn.Parameter(torch.ones(num_operators, 1) * -0.4, requires_grad=True)\n",
        "\n",
        "        self.layer_norm = nn.LayerNorm(VOCAB_N_DIM_, elementwise_affine=0) if not ReplaceLNWithSmoothCapIfRemoveRSE_LN else SoftCapLNorm()\n",
        "        self.lstm_post_norm = nn.LayerNorm(VOCAB_N_DIM, elementwise_affine=0) if not ReplaceLNWithSmoothCapIfRemoveRSE_LN else SoftCapLNorm()\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "        # assert self.rotation_matrices.shape[0] == 1 #self.num_operators, f'self.rotation_matrices.shape[0]: {self.rotation_matrices.shape[0]} != self.num_operators: {self.num_operators}'\n",
        "        self.output_gate_sigmoid_activation_values_for_logging = []\n",
        "        self.reset_gate_sigmoid_activation_values_for_logging = []\n",
        "        self.decrement_gat_sigmoid_activation_values_for_logging = []\n",
        "        self.latest_cached_real_positions = None\n",
        "        self.addInputProjectionBeforeLSTM = addInputProjectionBeforeLSTM\n",
        "        self.residual_lstm_output_norm = nn.LayerNorm(VOCAB_N_DIM) if not ReplaceLNWithSmoothCapIfRemoveRSE_LN else SoftCapLNorm()\n",
        "        self.cached_hists_q_fordebug = []; self.cached_hists_k_fordebug = []          # will grow to length T at inference\n",
        "\n",
        "        if self.use_lstm:\n",
        "            lstm_hidden_dim = 384\n",
        "            if ABLATE_LSTM_IN_OUT_PROJ:\n",
        "                lstm_hidden_dim = VOCAB_N_DIM\n",
        "            self.lstm_hidden_dim = lstm_hidden_dim\n",
        "\n",
        "            self.lstm_input_size = VOCAB_N_DIM if not addInputProjectionBeforeLSTM else VOCAB_N_DIM\n",
        "            if addInputProjectionBeforeLSTM:\n",
        "                self.post_input_proj_layer_norm = nn.LayerNorm(VOCAB_N_DIM, elementwise_affine=0) if not ReplaceLNWithSmoothCapIfRemoveRSE_LN else SoftCapLNorm()\n",
        "\n",
        "            num_lstm_cells = NUM_LSTM_CELLS\n",
        "\n",
        "            if not USE_LSTM_FOR_RE_CELLS:\n",
        "                self.lstm_cells = nn.ModuleList([\n",
        "\n",
        "                  # CustomGRU(self.lstm_input_size, self.lstm_hidden_dim,\n",
        "                  #           num_layers=1, batch_first=True) for _ in range(num_lstm_cells)\n",
        "                  nn.GRU(self.lstm_input_size, self.lstm_hidden_dim,\n",
        "                          num_layers=1, batch_first=True) for _ in range(num_lstm_cells)\n",
        "                ])\n",
        "            else:\n",
        "                if not USE_RMS_NORM_LSTM:\n",
        "                    self.lstm_cells = nn.ModuleList([\n",
        "                        nn.LSTM(self.lstm_input_size, self.lstm_hidden_dim,\n",
        "                                num_layers=1, batch_first=True)\n",
        "                        for _ in range(num_lstm_cells)\n",
        "                    ])\n",
        "                else:\n",
        "                    self.lstm_cells = nn.ModuleList([\n",
        "                        RMSNormLSTM(input_size=self.lstm_input_size, hidden_size=self.lstm_hidden_dim, batch_first=True)\n",
        "                        for _ in range(num_lstm_cells)\n",
        "                    ])\n",
        "\n",
        "            # self.rnn_wrappers_frobenius_gain = [\n",
        "            #     GRUWithFrobeniusGain(nnGRU, learned_gain=True) for nnGRU in self.lstm_cells\n",
        "            # ]\n",
        "            if USE_G_PARAM_REGULARIZER:\n",
        "                self.rnn_wrappers_frobenius_gain = nn.ModuleList([\n",
        "                    GRUWithFrobeniusGain(nnGRU, learned_gain=True) for nnGRU in self.lstm_cells\n",
        "                ])\n",
        "            else:\n",
        "                self.rnn_wrappers_frobenius_gain = self.lstm_cells\n",
        "\n",
        "            self.lstm_out_proj = nn.Parameter(torch.randn(NUM_LSTM_CELLS, self.lstm_hidden_dim, VOCAB_N_DIM))\n",
        "            self.lstm_out_bias = nn.Parameter(torch.zeros(NUM_LSTM_CELLS, VOCAB_N_DIM))\n",
        "\n",
        "            if RelativeEncodingLSTMHiddenOutputsRelevanceEncoding_IS_ENABLED:\n",
        "\n",
        "                self.lstm_out_proj_for_relevance_entity_encoding = nn.Parameter(torch.randn(self.num_operators, self.lstm_hidden_dim, VOCAB_N_DIM))\n",
        "                self.lstm_out_bias_for_relevance_entity_encoding = nn.Parameter(torch.zeros(self.num_operators, VOCAB_N_DIM))\n",
        "                self.lstm_output_proj_for_forward_return = nn.Parameter(torch.randn(self.num_operators, VOCAB_N_DIM, lstm_latent_dim_for_RPE_forward_return))\n",
        "                self.lstm_output_bias_for_forward_return = nn.Parameter(torch.zeros(self.num_operators, lstm_latent_dim_for_RPE_forward_return))\n",
        "                self.lstm_output_reproj_for_forward_return = nn.Parameter(torch.randn(self.num_operators, lstm_latent_dim_for_RPE_forward_return, LSTM_OUTPUT_QK_N_DIM))\n",
        "                self.lstm_output_bias_for_forward_return_reproj = nn.Parameter(torch.zeros(self.num_operators, LSTM_OUTPUT_QK_N_DIM))\n",
        "\n",
        "                self.lstm_cells_for_relevance_entity_encoding = nn.ModuleList([\n",
        "                    nn.LSTM(VOCAB_N_DIM, self.lstm_hidden_dim,\n",
        "                            num_layers=1, batch_first=True)\n",
        "                    for _ in range(num_operators)\n",
        "                ])\n",
        "\n",
        "                for i in range(NUM_LSTM_CELLS):\n",
        "                    nn.init.xavier_uniform_(self.lstm_output_proj_for_forward_return[i].T)\n",
        "                    nn.init.xavier_uniform_(self.lstm_output_reproj_for_forward_return[i].T)\n",
        "                    nn.init.xavier_uniform_(self.lstm_out_proj_for_relevance_entity_encoding[i].T)\n",
        "\n",
        "\n",
        "\n",
        "                # MARK: RelativeEncodingLSTMHiddenOutputsRelevanceEncoding\n",
        "                # self.sigmoid_gate_for_relevance_encoding = _RelevanceSigmoidGate(VOCAB_N_DIM)\n",
        "\n",
        "\n",
        "\n",
        "            for i in range(NUM_LSTM_CELLS):\n",
        "                nn.init.xavier_uniform_(self.lstm_out_proj[i].T)\n",
        "\n",
        "\n",
        "            # Initialize LSTM parameters with orthogonal matrices\n",
        "            def _init_lstm_params(lstm):\n",
        "                 for name, param in lstm.named_parameters():\n",
        "                    if \"weight_ih\" in name or \"weight_hh\" in name:\n",
        "                        W = param\n",
        "                        hidden_dim = W.shape[1]\n",
        "                        W_split = torch.chunk(W, chunks=4, dim=0)\n",
        "                        for W_gate in W_split:\n",
        "                            nn.init.orthogonal_(W_gate)\n",
        "\n",
        "\n",
        "\n",
        "            # _init_lstm_params(self.lstm_cells)\n",
        "            if RelativeEncodingLSTMHiddenOutputsRelevanceEncoding_IS_ENABLED:\n",
        "                _init_lstm_params(self.lstm_cells_for_relevance_entity_encoding)\n",
        "\n",
        "\n",
        "            if addInputProjectionBeforeLSTM:\n",
        "                self.input_projection_before_lstm = nn.Parameter(torch.empty(NUM_LSTM_CELLS, VOCAB_N_DIM_, VOCAB_N_DIM))\n",
        "                for i in range(NUM_LSTM_CELLS):\n",
        "                    nn.init.xavier_uniform_(self.input_projection_before_lstm[i].T)\n",
        "                self.input_bias_before_lstm = nn.Parameter(torch.zeros(NUM_LSTM_CELLS, VOCAB_N_DIM))\n",
        "\n",
        "\n",
        "    # For <SharpenHistUpdate>\n",
        "    def _current_gamma(self, *, keys: bool = False, half_ops: int = None) -> torch.Tensor:\n",
        "        \"\"\"\n",
        "        Returns γ with shape [1, 1, h] so it broadcasts against next_hist.\n",
        "        The first `half_ops` indices are for queries, the remainder for keys.\n",
        "        \"\"\"\n",
        "        import torch.nn.functional as F\n",
        "        gamma_full = 1. + torch.exp(self._theta_gamma)      # [h*2]\n",
        "\n",
        "        # DELIBERATELY_ADD_OVERSMOOTHING = False\n",
        "        # if DELIBERATELY_ADD_OVERSMOOTHING:\n",
        "        #     gamma_full = gamma_full / 1.5\n",
        "        #     print(f'[WARNING] DELIBERATELY_ADD_OVERSMOOTHING: gamma_full = {gamma_full}')\n",
        "\n",
        "        if half_ops is None:\n",
        "            half_ops = self.num_operators // 2\n",
        "\n",
        "        if keys:\n",
        "            gamma_h = gamma_full[half_ops:]                   # keys slice\n",
        "        else:\n",
        "            gamma_h = gamma_full[:half_ops]                   # queries slice\n",
        "        return gamma_h.view(1, 1, -1)                         # [1,1,h]\n",
        "\n",
        "    @torch._dynamo.disable\n",
        "    def _rnn_fwd(self, inputs, rnn):\n",
        "        return rnn(inputs)\n",
        "\n",
        "    # @torch.compile(dynamic=False)\n",
        "    def _parallel_lstm_cells_forward(self, embeddings):\n",
        "        \"\"\"\n",
        "        Runs `num cells` LSTM cells in parallel over the sequence length.\n",
        "\n",
        "        Args:\n",
        "            embeddings (Tensor): Input tensor of shape [batch_size, seq_len, <intermed dim>].\n",
        "\n",
        "        Returns:\n",
        "            Tensor: Output tensor of shape [batch_size, num cells, seq_len, intermed dim].\n",
        "        \"\"\"\n",
        "        # return embeddings.unsqueeze(1).expand(-1, self.num_operators, -1, -1)\n",
        "        batch_size, seq_len, _ = embeddings.shape\n",
        "        assert embeddings.shape == (batch_size, seq_len, VOCAB_N_DIM_), f\"Expected shape {(batch_size, seq_len, VOCAB_N_DIM_)}, but got {embeddings.shape}\"\n",
        "        lstm_outputs = []; lstm_outputs_for_relevance_entity_encoding = []\n",
        "\n",
        "        if addInputProjectionBeforeLSTM:\n",
        "            assert self.input_projection_before_lstm.shape == (NUM_LSTM_CELLS, VOCAB_N_DIM_, VOCAB_N_DIM)\n",
        "            embeddings_proj = torch.einsum(\"bsd,nde->bnse\", embeddings, self.input_projection_before_lstm)\n",
        "            assert self.input_bias_before_lstm.shape == (NUM_LSTM_CELLS, VOCAB_N_DIM)\n",
        "            embeddings_proj = embeddings_proj + self.input_bias_before_lstm.unsqueeze(0).unsqueeze(-2)\n",
        "            assert embeddings_proj.shape == (batch_size, NUM_LSTM_CELLS, seq_len, VOCAB_N_DIM)\n",
        "            if embeddings.shape[-1] == embeddings_proj.shape[-1]:\n",
        "                embeddings = embeddings_proj + embeddings.unsqueeze(1).expand(-1, NUM_LSTM_CELLS, -1, -1)\n",
        "            else:\n",
        "                embeddings = embeddings_proj\n",
        "            assert embeddings.shape == (batch_size, NUM_LSTM_CELLS, seq_len, VOCAB_N_DIM)\n",
        "            # if self.post_input_proj_layer_norm is not None:\n",
        "            if not removeRSE_LN or ReplaceLNWithSmoothCapIfRemoveRSE_LN:\n",
        "                embeddings = self.post_input_proj_layer_norm(embeddings) #* (3 ** 0.5) * ((self.lstm_hidden/VOCAB_N_DIM)**0.5)\n",
        "\n",
        "        if VERBOSE_LOGGING:\n",
        "            print(f'AVG LSTM input norm: {torch.mean(torch.norm(embeddings, dim=-1))}, min norm: {torch.min(torch.norm(embeddings, dim=-1))}, max norm: {torch.max(torch.norm(embeddings, dim=-1))}')\n",
        "\n",
        "\n",
        "        # Run each LSTM cell separately and collect all hidden states\n",
        "        for i in range(len(self.lstm_cells)):\n",
        "\n",
        "            if not addInputProjectionBeforeLSTM:\n",
        "                # lstm_out, _ = self.rnn_wrappers_frobenius_gain[i](embeddings)  # lstm_out: [batch_size, seq_len, intermed dim]\n",
        "                lstm_out, _ = self._rnn_fwd(embeddings, self.lstm_cells[i])\n",
        "            else:\n",
        "                # lstm_out, _ = self.rnn_wrappers_frobenius_gain[i](embeddings[:, i, :, :])\n",
        "                lstm_out, _ = self._rnn_fwd(embeddings[:, i, :, :], self.lstm_cells[i])\n",
        "\n",
        "            assert lstm_out.shape == (batch_size, seq_len, self.lstm_hidden_dim), f\"Expected shape {(batch_size, seq_len, self.lstm_hidden_dim)}, but got {lstm_out.shape}\"\n",
        "            lstm_outputs.append(lstm_out)  # Collect the entire sequence output\n",
        "\n",
        "            if RelativeEncodingLSTMHiddenOutputsRelevanceEncoding_IS_ENABLED:\n",
        "                lstm_out_for_relevance_entity_encoding, _ = self.lstm_cells_for_relevance_entity_encoding[i](embeddings)\n",
        "                lstm_outputs_for_relevance_entity_encoding.append(lstm_out_for_relevance_entity_encoding)\n",
        "            else:\n",
        "                lstm_out_for_relevance_entity_encoding, _ = torch.zeros_like(lstm_out), torch.zeros_like(lstm_out)\n",
        "                lstm_outputs_for_relevance_entity_encoding.append(lstm_out_for_relevance_entity_encoding)\n",
        "\n",
        "\n",
        "        assert len(lstm_outputs) == NUM_LSTM_CELLS, f\"Expected {NUM_LSTM_CELLS} LSTM outputs, but got {len(lstm_outputs)}\"\n",
        "        lstm_outputs = torch.stack(lstm_outputs, dim=1)  # [batch_size, num_operators, seq_len, lstm hidden dim]\n",
        "\n",
        "        if RelativeEncodingLSTMHiddenOutputsRelevanceEncoding_IS_ENABLED:\n",
        "            lstm_outputs_for_relevance_entity_encoding = torch.stack(lstm_outputs_for_relevance_entity_encoding, dim=1)\n",
        "            assert lstm_outputs.shape == (batch_size, NUM_LSTM_CELLS, seq_len, self.lstm_hidden_dim), f\"Expected shape {(batch_size, NUM_LSTM_CELLS, seq_len, self.lstm_hidden_dim)}, but got {lstm_outputs.shape}\"\n",
        "\n",
        "            assert lstm_outputs_for_relevance_entity_encoding.shape == (batch_size, NUM_LSTM_CELLS, seq_len, self.lstm_hidden_dim)\n",
        "\n",
        "\n",
        "        if VERBOSE_LOGGING:\n",
        "            with torch.no_grad():\n",
        "                print(f'[LSTM Output] AVG lstm outputs norm: {torch.mean(torch.norm(lstm_outputs, dim=-1))}, avg norm of last vector = {torch.mean(torch.norm(lstm_outputs[:, -1, :], dim=-1))}, avg norm of first vector = {torch.mean(torch.norm(lstm_outputs[:, 0, :], dim=-1))}')\n",
        "                # Print min and max norm for each lstm cell:\n",
        "                # print(f'[LSTM Output] MIN lstm outputs norm: {torch.min(torch.norm(lstm_outputs, dim=-1))}, MAX lstm outputs norm: {torch.max(torch.norm(lstm_outputs, dim=-1))}')\n",
        "                for i in range(NUM_LSTM_CELLS):\n",
        "                    print(f'[LSTM Cell {i}] MIN lstm outputs norm: {torch.min(torch.norm(lstm_outputs[:, i, :], dim=-1))}, MAX lstm outputs norm: {torch.max(torch.norm(lstm_outputs[:, i, :], dim=-1))}')\n",
        "\n",
        "\n",
        "\n",
        "        if not ABLATE_LSTM_IN_OUT_PROJ:\n",
        "            # final output shape must be: [batch_size, num lstm cells, seq_len, VOCAB_N_DIM]\n",
        "            lstm_outputs = torch.einsum(\"bnto,nof->bntf\", lstm_outputs, self.lstm_out_proj)\n",
        "\n",
        "        assert lstm_outputs.shape == (batch_size, NUM_LSTM_CELLS, seq_len, VOCAB_N_DIM), \\\n",
        "                    f\"Expected shape {(batch_size, NUM_LSTM_CELLS, seq_len, VOCAB_N_DIM)}, but got {lstm_outputs.shape}\"\n",
        "\n",
        "        if RelativeEncodingLSTMHiddenOutputsRelevanceEncoding_IS_ENABLED:\n",
        "            lstm_outputs_for_relevance_entity_encoding = torch.einsum(\"bnto,nof->bntf\", lstm_outputs_for_relevance_entity_encoding, self.lstm_out_proj_for_relevance_entity_encoding)\n",
        "        else:\n",
        "            lstm_outputs_for_relevance_entity_encoding = torch.zeros_like(lstm_outputs)\n",
        "        assert lstm_outputs_for_relevance_entity_encoding.shape == lstm_outputs.shape\n",
        "\n",
        "        lstm_out_bias = self.lstm_out_bias.unsqueeze(0).unsqueeze(-2)\n",
        "        assert lstm_out_bias.shape == (1,          NUM_LSTM_CELLS, 1,      VOCAB_N_DIM), f'lstm_out_bias.shape: {lstm_out_bias.shape}'\n",
        "        assert lstm_outputs.shape ==  (batch_size, NUM_LSTM_CELLS, seq_len, VOCAB_N_DIM), f'lstm_outputs.shape: {lstm_outputs.shape}'\n",
        "        lstm_outputs = lstm_outputs + lstm_out_bias\n",
        "\n",
        "        if RelativeEncodingLSTMHiddenOutputsRelevanceEncoding_IS_ENABLED:\n",
        "            lstm_out_bias_for_relevance_entity_encoding = self.lstm_out_bias_for_relevance_entity_encoding.unsqueeze(0).unsqueeze(-2)\n",
        "            lstm_outputs_for_relevance_entity_encoding = lstm_outputs_for_relevance_entity_encoding + lstm_out_bias_for_relevance_entity_encoding\n",
        "\n",
        "        # if self.training:\n",
        "        #     assert lstm_outputs.requires_grad, \"[DEBUG] lstm_outputs still requires grad after bias addition\"\n",
        "\n",
        "\n",
        "        if VERBOSE_LOGGING:\n",
        "            print(f'[LSTM Output] AVG lstm outputs norm: {torch.mean(torch.norm(lstm_outputs, dim=-1))}, avg norm of last vector = {torch.mean(torch.norm(lstm_outputs[:, -1, :], dim=-1))}, avg norm of first vector = {torch.mean(torch.norm(lstm_outputs[:, 0, :], dim=-1))}')\n",
        "        #     # Print min and max norm:\n",
        "        #     print(f'[LSTM Output] MIN lstm outputs norm: {torch.min(torch.norm(lstm_outputs, dim=-1))}, MAX lstm outputs norm: {torch.max(torch.norm(lstm_outputs, dim=-1))}')\n",
        "\n",
        "\n",
        "\n",
        "        return lstm_outputs, lstm_outputs_for_relevance_entity_encoding\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "    def visualize_cached_attention(self, sample_idx=0, operator_idx=0, unnormed_logits=False):\n",
        "        \"\"\"\n",
        "        Visualizes the cached attention matrices for position_copying_enabled=True for a single sample and operator.\n",
        "        \"\"\"\n",
        "        if not hasattr(self, 'cached_attention_matrices'):\n",
        "            raise ValueError(\"No cached attention matrices found. Run forward pass first.\")\n",
        "\n",
        "        # pull out the tensor (shape [seq_len, seq_len+1])\n",
        "        if unnormed_logits:\n",
        "            assert self.unnormed_candidate_logits_for_position_copying.shape == (self.unnormed_candidate_logits_for_position_copying.shape[0], self.num_operators // 2, self.unnormed_candidate_logits_for_position_copying.shape[-2], self.unnormed_candidate_logits_for_position_copying.shape[-1]), f'self.unnormed_candidate_logits_for_position_copying.shape: {self.unnormed_candidate_logits_for_position_copying.shape}, expected: {(self.unnormed_candidate_logits_for_position_copying.shape[0], self.num_operators // 2, self.unnormed_candidate_logits_for_position_copying.shape[-2], self.unnormed_candidate_logits_for_position_copying.shape[-1])}'\n",
        "            attn = self.unnormed_candidate_logits_for_position_copying[sample_idx, operator_idx]\n",
        "        else:\n",
        "            attn = self.cached_attention_matrices[sample_idx, operator_idx]\n",
        "\n",
        "\n",
        "\n",
        "        # convert to a clean numpy float array:\n",
        "        if isinstance(attn, torch.Tensor):\n",
        "            mat = attn.detach().cpu().float().numpy()\n",
        "        else:\n",
        "            mat = np.asarray(attn, dtype=float)\n",
        "\n",
        "        fig, ax = plt.subplots(figsize=(6, 6), dpi=80)\n",
        "        im = ax.imshow(mat,\n",
        "                      cmap='Blues',\n",
        "                      interpolation='nearest',\n",
        "                      aspect='auto')\n",
        "        fig.colorbar(im, ax=ax)\n",
        "        ax.set(xlabel='Positions (with null)',\n",
        "              ylabel='Query token (time step)',\n",
        "              title=f'Attention – Sample {sample_idx}, Op {operator_idx}')\n",
        "        plt.tight_layout()\n",
        "        plt.show()\n",
        "\n",
        "\n",
        "    import matplotlib.pyplot as plt\n",
        "    import seaborn as sns\n",
        "\n",
        "    def visualize_candidate_scores_for_main_re_gates_slow(self, sample_idx=0, operator_idx=0, visualize_unnorm_logits=False):\n",
        "        \"\"\"\n",
        "        Visualizes candidate scores (or probabilities) for the 4 discrete choices\n",
        "        (reset, increment, decrement, keep same) for each time step for a single sample\n",
        "        and operator.\n",
        "\n",
        "        Args:\n",
        "            sample_idx (int): Index of the sample within the batch.\n",
        "            operator_idx (int): Index of the operator (e.g., 0 to half_ops-1) to visualize.\n",
        "\n",
        "        Assumes that self.cached_candidate_probabilities exists and has shape\n",
        "        [batch_size, num_operators, seq_len, 4].\n",
        "        \"\"\"\n",
        "        if not hasattr(self, 'cached_candidate_probabilities_for_main_re'):\n",
        "            print(\"No cached_candidate_probabilities_for_main_re found. \"\n",
        "                            \"Make sure to run a forward pass that caches them.\")\n",
        "            return\n",
        "\n",
        "        # candidate_scores: shape [seq_len, 4] for the given sample and operator.\n",
        "\n",
        "        cached_candidate_probabilities_for_main_re = self.cached_candidate_probabilities_for_main_re.cpu().numpy()\n",
        "        if visualize_unnorm_logits:\n",
        "            cached_candidate_probabilities_for_main_re = self.cached_candidate_logits_for_main_re.cpu().numpy()\n",
        "        # assert cached_candidate_probabilities_for_main_re.shape == (bs, self.num_operators, seq_len, 4)\n",
        "        candidate_scores = cached_candidate_probabilities_for_main_re[sample_idx, operator_idx]\n",
        "\n",
        "\n",
        "        plt.figure(figsize=(12, 8))\n",
        "        sns.heatmap(candidate_scores, annot=True, cmap='viridis', cbar=True, fmt=\".5f\")\n",
        "        plt.xlabel(\"Candidate Choice (0: reset, 1: increment, 2: decrement, 3: keep)\")\n",
        "        plt.ylabel(\"Time step\")\n",
        "        plt.title(f\"Candidate Scores for Sample {sample_idx}, Operator {operator_idx}\")\n",
        "        plt.tight_layout()\n",
        "        plt.show()\n",
        "\n",
        "\n",
        "    import matplotlib.pyplot as plt\n",
        "\n",
        "    # Faster implementation:\n",
        "    def visualize_candidate_scores_for_main_re_gates(self,\n",
        "                                                    sample_idx=0,\n",
        "                                                    operator_idx=0,\n",
        "                                                    visualize_unnorm_logits=False,\n",
        "                                                    annotate=True):\n",
        "        \"\"\"\n",
        "        Visualizes candidate scores (or probabilities) for the 4 discrete choices\n",
        "        (reset, increment, decrement, keep same) for each time step for a single sample\n",
        "        and operator, using fast imshow rendering.\n",
        "\n",
        "        Args:\n",
        "            sample_idx (int): Index of the sample within the batch.\n",
        "            operator_idx (int): Index of the operator to visualize.\n",
        "            visualize_unnorm_logits (bool): If True, plot unnormalized logits instead of probabilities.\n",
        "            annotate (bool): Whether to annotate cell values (slow for large matrices).\n",
        "        \"\"\"\n",
        "        # check we have the data\n",
        "        if not hasattr(self, 'cached_candidate_probabilities_for_main_re'):\n",
        "            print(\"No cached_candidate_probabilities_for_main_re found. \"\n",
        "                  \"Make sure to run a forward pass that caches them.\")\n",
        "            return\n",
        "\n",
        "        # pull out the right array, move to CPU and numpy\n",
        "        if visualize_unnorm_logits:\n",
        "            arr = self.cached_candidate_logits_for_main_re\n",
        "        else:\n",
        "            arr = self.cached_candidate_probabilities_for_main_re\n",
        "\n",
        "        # [batch, ops, seq_len, 4] → [seq_len, 4]\n",
        "        # detach and convert to float32 numpy\n",
        "        if isinstance(arr, torch.Tensor):\n",
        "            full_np = arr.detach().cpu().float().numpy()\n",
        "        else:\n",
        "            full_np = np.asarray(arr, dtype=float)\n",
        "\n",
        "        candidate_scores = full_np[sample_idx, operator_idx]  # shape [seq_len, 4]\n",
        "\n",
        "        # now plot\n",
        "        fig, ax = plt.subplots(figsize=(12, 8), dpi=80)\n",
        "        im = ax.imshow(candidate_scores,\n",
        "                      cmap='viridis',\n",
        "                      interpolation='nearest',\n",
        "                      aspect='auto')\n",
        "        cbar = fig.colorbar(im, ax=ax)\n",
        "\n",
        "        # optional annotations\n",
        "        if annotate:\n",
        "            # annotate each cell with 5-digit precision\n",
        "            for i in range(candidate_scores.shape[0]):\n",
        "                for j in range(candidate_scores.shape[1]):\n",
        "                    ax.text(j, i,\n",
        "                            f\"{candidate_scores[i, j]:.5f}\",\n",
        "                            ha='center', va='center', fontsize=6,\n",
        "                            color='white' if candidate_scores[i,j] < 0.5 else 'black')\n",
        "\n",
        "        # ax.set_xlabel(\"Candidate Choice (0: reset, 1: increment, 2: decrement, 3: keep)\")\n",
        "        # Increment, decrement, keep, reset:\n",
        "        ax.set_xlabel(\"Candidate Choice (0: increment, 1: decrement, 2: keep, 3: reset)\")\n",
        "        ax.set_ylabel(\"Time step\")\n",
        "        title_type = \"Logits\" if visualize_unnorm_logits else \"Probabilities\"\n",
        "        ax.set_title(f\"{title_type} for Sample {sample_idx}, Operator {operator_idx}\")\n",
        "        plt.tight_layout()\n",
        "        plt.show()\n",
        "\n",
        "\n",
        "    import torch.nn.functional as F\n",
        "\n",
        "    def compute_candidate_relative_positions_timewise_null_weight_for_qk_token_copy(\n",
        "        self,\n",
        "        embeddings,\n",
        "        key_rel_positions_for_addr_copy,\n",
        "        positions_x_shift_relative=None,\n",
        "        copyingFromKeysToQueries=RelPosCopyRoute.KEYS_TO_QUERIES,\n",
        "        ):\n",
        "        \"\"\"\n",
        "        For each query operator (first half_ops) and for all time steps t,\n",
        "        compute candidate relative positions. The real candidates come from the learned logits\n",
        "        + dot products, the null candidate has learned logits as well, but after the softmax\n",
        "        we add 0.20 probability to the null candidate and re‐normalize.\n",
        "        \"\"\"\n",
        "        assert copyingFromKeysToQueries == RelPosCopyRoute.KEYS_TO_QUERIES or RelPosCopyRoute.NoCopy, f'copyingFromKeysToQueries: {copyingFromKeysToQueries}'\n",
        "\n",
        "        bs, seq_len, embed_dim = embeddings.shape\n",
        "        num_operators = self.num_operators\n",
        "        device = embeddings.device\n",
        "        half_ops = num_operators // 2\n",
        "\n",
        "        # Optional: LN for address copying\n",
        "        embeddings = self.layer_norm_for_addr_copy_func__(embeddings)\n",
        "\n",
        "        # --- Step 1: Q, K from learned projections\n",
        "        # Q = torch.einsum(\"bhtd,hde->bhte\", embeddings[:, :half_ops] + self.q_bias, self.W_q_)\n",
        "        # K = torch.einsum(\"bhtd,hde->bhte\", embeddings[:, half_ops:] + self.k_bias, self.W_k_) #/ (embed_dim ** 0.5)\n",
        "        assert embeddings.shape[-1] == VOCAB_N_DIM, f'embeddings.shape[-1]: {embeddings.shape[-1]}, VOCAB_N_DIM: {VOCAB_N_DIM}'\n",
        "        Q = torch.einsum(\"btd,hde->bhte\", embeddings, self.W_q_)\n",
        "        Q = Q + self.q_bias\n",
        "        K = torch.einsum(\"btd,hde->bhte\", embeddings, self.W_k_)\n",
        "        K = K + self.k_bias\n",
        "        # => [bs, half_ops, seq_len, intermed dim]\n",
        "\n",
        "        \"\"\"Null candidate logits (learnable)\"\"\"\n",
        "\n",
        "        NULL_BIAS_AFTER_SOFTMAX = False and not USE_SIGMOID_GATE_FOR_NO_COPY_BRANCH\n",
        "        emb_null_q = torch.einsum(\"btd,hde->bhte\", embeddings, self.W_null_q)\n",
        "        emb_null_q = emb_null_q + self.null_q_bias\n",
        "        emb_null_k = torch.einsum(\"btd,hde->bhte\", embeddings, self.W_null_k)\n",
        "        emb_null_k = emb_null_k + self.null_k_bias\n",
        "\n",
        "        dot_product_divisor_null_gate = emb_null_q.shape[-1] ** 0.5\n",
        "\n",
        "        # Normalize over last dimension:\n",
        "        Q = F.layer_norm(Q, Q.shape[-1:])\n",
        "        K = F.layer_norm(K, K.shape[-1:])\n",
        "        NORM_FOR_SIGMOID_GATE = None\n",
        "        if not USE_SIGMOID_GATE_FOR_NO_COPY_BRANCH: # i.e. null weights/embeds\n",
        "            emb_null_q = F.layer_norm(emb_null_q, emb_null_q.shape[-1:])\n",
        "            emb_null_k = F.layer_norm(emb_null_k, emb_null_k.shape[-1:])\n",
        "        # <copyProbsSigmoidGateForNull>:\n",
        "        elif USE_SIGMOID_GATE_FOR_NO_COPY_BRANCH:\n",
        "            NORM_FOR_SIGMOID_GATE = 2.5\n",
        "            emb_null_q = emb_null_q * NORM_FOR_SIGMOID_GATE/emb_null_q.norm(dim=-1, keepdim=True)\n",
        "            emb_null_k = emb_null_k * NORM_FOR_SIGMOID_GATE/emb_null_k.norm(dim=-1, keepdim=True)\n",
        "            dot_product_divisor_null_gate = 1.0\n",
        "\n",
        "        # --- Step 3: Dot-product logits for real keys\n",
        "        # => [bs, half_ops, seq_len, seq_len]\n",
        "        dot_product_divisor = Q.shape[-1] ** 0.5\n",
        "        logits_real = torch.einsum(\"bhtd,bhsd->bhts\",\n",
        "                                   Q, K) / dot_product_divisor\n",
        "        assert logits_real.shape == (bs, half_ops, seq_len, seq_len)\n",
        "\n",
        "        # Compute null_logits from self-interactions:\n",
        "        null_logits = torch.einsum(\n",
        "            \"bhtd,bhtd->bht\",\n",
        "            emb_null_q,  # [bs, half_ops, seq_len, embed_dim]\n",
        "            emb_null_k   # [bs, half_ops, seq_len, embed_dim]\n",
        "        ) / dot_product_divisor_null_gate\n",
        "\n",
        "        # null_logits = torch.abs(null_logits)\n",
        "\n",
        "        # unsqueeze to match your previous code:\n",
        "        null_logits = null_logits.unsqueeze(-1)  # [bs, half_ops, seq_len, 1]\n",
        "\n",
        "        assert null_logits.shape == (bs, half_ops, seq_len, 1)\n",
        "        SOFTMAX_TEMP_GUMBEL_LIKE = 1.0\n",
        "        null_prob_for_sigmoid_gate = None\n",
        "        if not NULL_BIAS_AFTER_SOFTMAX:\n",
        "\n",
        "            if not USE_SIGMOID_GATE_FOR_NO_COPY_BRANCH:\n",
        "                # NULL_BIAS_LOGITS = 1.2\n",
        "                # Make NULL_BIAS_LOGITS equal to half of the expected value E[<I.P.>] of the inner product of\n",
        "                # two random vectors of dimension n = null_logits.shape[-1]\n",
        "                # and for vectors of norm r = sqrt(n). Expected value IP given by formula:\n",
        "                # E[I.P.(x,y)] = r**2 * sqrt(2/(pi*n))\n",
        "                n = embed_dim #null_logits.shape[-1]\n",
        "                r = n ** 0.5\n",
        "                expected_inner_product = r**2 * (2/(math.pi * n)) ** 0.5\n",
        "                NULL_BIAS_LOGITS = expected_inner_product / 1.0\n",
        "                if VERBOSE_LOGGING:\n",
        "                    print(f'[DEBUG RSE.copyCandLogits] NULL_BIAS_LOGITS: {NULL_BIAS_LOGITS}, expected_inner_product: {expected_inner_product}')\n",
        "\n",
        "                # null_logits = null_logits + NULL_BIAS_LOGITS # shape [bs, half_ops, seq_len]\n",
        "                # Apply -NULL_BIAS_LOGITS to real_logits:\n",
        "\n",
        "                logits_real = logits_real - NULL_BIAS_LOGITS/1.0\n",
        "            elif USE_SIGMOID_GATE_FOR_NO_COPY_BRANCH:\n",
        "                NULL_BIAS_LOGITS = NORM_FOR_SIGMOID_GATE\n",
        "\n",
        "            null_logits = null_logits + NULL_BIAS_LOGITS/1.0\n",
        "\n",
        "        if USE_SIGMOID_GATE_FOR_NO_COPY_BRANCH:\n",
        "            null_prob_for_sigmoid_gate = torch.sigmoid(null_logits / SOFTMAX_TEMP_GUMBEL_LIKE)\n",
        "\n",
        "\n",
        "        \"\"\"End compute null candidate logits (learnable)\"\"\"\n",
        "\n",
        "        # 3) CAUSAL MASK immediately (so the actual argmax sees only valid tokens)\n",
        "        causal_mask = torch.tril(torch.ones(seq_len, seq_len, device=device)).unsqueeze(0).unsqueeze(0)\n",
        "        logits_real = logits_real.masked_fill(causal_mask == 0, float('-inf'))\n",
        "\n",
        "        # --- optionally restrict copying to only FIXED key heads ---\n",
        "        # If copy_from_fixed_absolute_enc_key_gates_only == True, then only allow copying the absolute positions from a past key rel. position to any query relative position\n",
        "        if getattr(self, \"copy_from_fixed_absolute_enc_key_gates_only\", False):\n",
        "            # self.fixed_gate_mask is length num_operators;\n",
        "            # the key‐heads are at positions [half_ops:].\n",
        "            assert self.fixed_gate_mask.shape == (self.num_operators,)\n",
        "            key_mask = self.fixed_gate_mask[half_ops:]               # shape: [half_ops]\n",
        "            # reshape to broadcast over (bs,half_ops,seq,seq)\n",
        "            key_mask = key_mask.view(1, half_ops, 1, 1)              # [1,h,1,1]\n",
        "            assert logits_real.shape == (bs, half_ops, seq_len, seq_len)\n",
        "            # for any key‐head where mask==False, zero out ALL its real‐copy logits:\n",
        "            if not USE_SIGMOID_GATE_FOR_NO_COPY_BRANCH:\n",
        "                logits_real = logits_real.masked_fill(~key_mask, float(\"-inf\"))\n",
        "            elif USE_SIGMOID_GATE_FOR_NO_COPY_BRANCH:\n",
        "                logits_real = logits_real.masked_fill(~key_mask, float(\"0\"))\n",
        "                null_prob_for_sigmoid_gate = null_prob_for_sigmoid_gate.masked_fill(~key_mask, 1.0)\n",
        "            # print(f'[DEBUG, copy_from_fixed_absolute_enc_key_gates_only] key_mask.shape: {key_mask.shape}, logits_real.shape: {logits_real.shape}')\n",
        "\n",
        "\n",
        "        # 4) Combine real + null => candidate_logits => softmax\n",
        "        if not USE_SIGMOID_GATE_FOR_NO_COPY_BRANCH:\n",
        "            candidate_logits = torch.cat([logits_real, null_logits], dim=-1)\n",
        "        else:\n",
        "            candidate_logits = logits_real\n",
        "\n",
        "        ABLATE_LOGIT_SUPPRESSION = True\n",
        "\n",
        "        # Apply logit suppression after any copy operation:\n",
        "        if USE_ESCAPE_GATE_FOR_RELPOS_COPY and not ABLATE_LOGIT_SUPPRESSION:\n",
        "            candidate_probs = gumbel_softmax_STE(candidate_logits, tau=5.0, max_ste=False, alpha=0.99)\n",
        "\n",
        "            # We do a first pass to see which token is \"selected\" at each time step\n",
        "            # using a straight-through one-hot => 'one_hot_sel[t]'.\n",
        "            # Then we see if the last index => null or not => triggers cooldown next step or not.\n",
        "\n",
        "            # We'll store shape => [bs, half_ops, seq_len, 1] for each time step's cooldown\n",
        "\n",
        "            cooldown_states_list = []\n",
        "            # Start not in cooldown\n",
        "            cooldown_state_current = torch.zeros(bs, half_ops, 1, 1, dtype=torch.bool, device=device)\n",
        "            escape_gate_probs_list = []\n",
        "            # Evaluate \"escape gate\"\n",
        "            emb_esc = embeddings[:, :half_ops, :, :]#.unsqueeze(2)\n",
        "            escape_gate_logits = self.escape_gate(emb_esc)\n",
        "            assert escape_gate_logits.shape == (bs, half_ops, seq_len, 1), f'escape_gate_logits.shape: {escape_gate_logits.shape}'\n",
        "\n",
        "            assert self.escape_gate_bias_.shape == (half_ops, 1, 1)\n",
        "            escape_gate_probs  = torch.sigmoid(escape_gate_logits + self.escape_gate_bias_)\n",
        "            # escape_gate_probs_list.append(escape_gate_probs)\n",
        "            escape_hard_gate   = HardResetGate.apply(escape_gate_probs)\n",
        "            assert escape_hard_gate.shape == (bs, half_ops, seq_len, 1)\n",
        "\n",
        "            # cooldown_states = torch.empty(bs, half_ops, seq_len, 1, dtype=torch.bool, device=device)\n",
        "\n",
        "            # We'll build an array of (time, index) one-hot selections to see if it's real vs null\n",
        "            # but we only need it for logic below. So let's do the loop.\n",
        "            ASSRT_SHAPES = False\n",
        "            for t in range(seq_len):\n",
        "                # (a) candidate_probs[t] => shape [bs, half_ops, seq_len+1]\n",
        "                cand_probs_t = candidate_probs[:, :, t, :]\n",
        "\n",
        "                # (b) straight-through one-hot => one_hot_sel[t]\n",
        "                #     shape => [bs, half_ops, seq_len+1]\n",
        "                one_hot_sel_t = straight_through_probs_regular_argmax(cand_probs_t)\n",
        "                if ASSRT_SHAPES:\n",
        "                    assert one_hot_sel_t.shape == (bs, half_ops, seq_len+1)\n",
        "\n",
        "                # Check if last index is selected => null?\n",
        "                # shape => [bs, half_ops], True if null\n",
        "                selected_null_t = (one_hot_sel_t[..., -1] == 1)\n",
        "                if ASSRT_SHAPES:\n",
        "                    assert selected_null_t.shape == (bs, half_ops)\n",
        "\n",
        "                escape_hard_gate_t = escape_hard_gate[:, :, t, :]  # => [bs, half_ops, 1]\n",
        "\n",
        "\n",
        "\n",
        "                if ASSRT_SHAPES:\n",
        "                    assert escape_hard_gate_t.shape == (bs, half_ops, 1), f'escape_hard_gate_t.shape: {escape_hard_gate_t.shape}'\n",
        "                escape_hard_gate_t = escape_hard_gate_t.unsqueeze(-1)  # => [bs, half_ops, 1, 1]\n",
        "                ABLATE_ESCAPE_GATE = True\n",
        "                if ABLATE_ESCAPE_GATE:\n",
        "                    escape_hard_gate_t = torch.zeros_like(escape_hard_gate_t)\n",
        "\n",
        "\n",
        "                assert cooldown_state_current.shape == (bs, half_ops, 1, 1)\n",
        "\n",
        "                # If in cooldown => can exit if escape=1\n",
        "                # We'll do that for the next step\n",
        "                cooldown_state_next = cooldown_state_current.clone()\n",
        "                exit_mask = (cooldown_state_current == True) & (escape_hard_gate_t.bool())\n",
        "\n",
        "\n",
        "                cooldown_state_next = torch.where(exit_mask,\n",
        "                                                  torch.zeros_like(cooldown_state_current),\n",
        "                                                  cooldown_state_next)\n",
        "\n",
        "                # If not in cooldown, real is chosen => means we want to start cooldown next step\n",
        "                real_sel_t = (~selected_null_t).unsqueeze(-1).unsqueeze(-1)  # => [bs, half_ops,1,1]\n",
        "                if ASSRT_SHAPES:\n",
        "                    assert real_sel_t.shape == (bs, half_ops, 1, 1)\n",
        "                not_in_cd = (cooldown_state_current == False)\n",
        "                new_cd_mask = not_in_cd & real_sel_t.bool()\n",
        "                cooldown_state_next = torch.where(\n",
        "                    new_cd_mask,\n",
        "                    torch.ones_like(cooldown_state_current),\n",
        "                    cooldown_state_next\n",
        "                )\n",
        "\n",
        "                # real_sel_t_count = sum(real_sel_t.view(-1).tolist())\n",
        "                # if real_sel_t_count > 0:\n",
        "                #     print(f'[DEBUG] real_sel_t_count = {real_sel_t_count}')\n",
        "\n",
        "\n",
        "                # This step's cooldown state is what we store\n",
        "                cooldown_states_list.append(cooldown_state_current.clone())\n",
        "                # cooldown_states[:, :, t, 0] = cooldown_state_current.squeeze(-1).squeeze(-1)\n",
        "\n",
        "\n",
        "                # Finally, set current=next\n",
        "                cooldown_state_current = cooldown_state_next\n",
        "\n",
        "            escape_gate_probs_list = escape_gate_probs.detach().cpu() #torch.cat(escape_gate_probs_list, dim=2).detach().cpu()\n",
        "            if VERBOSE_LOGGING:\n",
        "                print(f'[DEBUG] escape_gate_probs_list avg = {torch.mean(escape_gate_probs_list)}, min = {torch.min(escape_gate_probs_list)}, max = {torch.max(escape_gate_probs_list)}')\n",
        "\n",
        "\n",
        "            # Now we have a list of length seq_len => each [bs, half_ops, 1,1].\n",
        "            # We want => [bs, half_ops, seq_len,1].\n",
        "\n",
        "            cooldown_states = torch.cat(cooldown_states_list, dim=-2)\n",
        "\n",
        "            assert  cooldown_states.shape == (bs, half_ops, seq_len, 1), f'cooldown_states.shape: {cooldown_states.shape}'\n",
        "\n",
        "            # negative offsets\n",
        "            SUPPRESSION_IF_COOLDOWN = -50.0\n",
        "            SUPPRESSION_IF_NO_COPY  = -1.0\n",
        "\n",
        "            # shape => [bs, half_ops, seq_len, 1]\n",
        "            assert logits_real.shape ==     (bs, half_ops, seq_len, seq_len), f'logits_real.shape: {logits_real.shape}, cooldown_states.shape: {cooldown_states.shape}'\n",
        "            assert cooldown_states.shape == (bs, half_ops, seq_len, 1), f'cooldown_states.shape: {cooldown_states.shape}'\n",
        "\n",
        "            # # --We want cooldown_states to broadcast across the last dimension of size seq_len\n",
        "            # #    so that each query time t can produce a mask for the entire real-keys dimension s\n",
        "            # #    We'll expand from shape [b, h, t, 1] -> [b, h, t, t]\n",
        "            # cooldown_mask_2d = cooldown_states.expand(-1, -1, -1, logits_real.shape[-1])\n",
        "            # # cooldown_mask_2d now has shape [b, h, t, s], same as logits_real\n",
        "\n",
        "            final_suppression = torch.where(\n",
        "                cooldown_states.bool(),\n",
        "                torch.full_like(logits_real, SUPPRESSION_IF_COOLDOWN),\n",
        "                torch.full_like(logits_real, SUPPRESSION_IF_NO_COPY)\n",
        "            )\n",
        "            assert final_suppression.shape == (bs, half_ops, seq_len, seq_len)\n",
        "            # print(f'[DEBUG] cooldown_states count = {torch.sum(cooldown_states)}, total elements = {torch.numel(cooldown_states)}')\n",
        "            # apply to the \"real\" portion\n",
        "            logits_real = logits_real + final_suppression\n",
        "\n",
        "        # Causal mask: only s <= t\n",
        "        causal_mask = torch.tril(torch.ones(seq_len, seq_len, device=device)).unsqueeze(0).unsqueeze(0)\n",
        "        logits_real = logits_real.masked_fill(causal_mask == 0, -float('inf'))\n",
        "\n",
        "        # --- Step 4: Concatenate to get final logits for all candidates\n",
        "        # => shape [bs, half_ops, seq_len, seq_len+1]\n",
        "        if not USE_SIGMOID_GATE_FOR_NO_COPY_BRANCH:\n",
        "            candidate_logits = torch.cat([logits_real, null_logits], dim=-1)\n",
        "        else:\n",
        "            candidate_logits = logits_real\n",
        "\n",
        "        # Print mean, min, max of candidate_logits WITHOUT the -inf masked out part:\n",
        "        if VERBOSE_LOGGING:\n",
        "            candidate_logits_for_print = candidate_logits.masked_fill(candidate_logits == -float('inf'), 0.0)\n",
        "            print(f'[DEBUG] candidate_logits min = {torch.min(candidate_logits_for_print)}, max = {torch.max(candidate_logits_for_print)}, mean = {torch.mean(candidate_logits_for_print)}, numel = {torch.numel(candidate_logits_for_print)}')\n",
        "        if USE_SIGMOID_GATE_FOR_NO_COPY_BRANCH:\n",
        "\n",
        "            assert candidate_logits.shape == (bs, half_ops, seq_len, seq_len), f'candidate_logits.shape: {candidate_logits.shape}'\n",
        "        else:\n",
        "            assert candidate_logits.shape == (bs, half_ops, seq_len, seq_len+1), f'candidate_logits.shape: {candidate_logits.shape}'\n",
        "\n",
        "        # --- Step 5: Normal softmax over the entire set\n",
        "        SOFTMAX_TEMP = 2.5\n",
        "        candidate_logits = candidate_logits * SOFTMAX_TEMP\n",
        "        candidate_probs_ = gumbel_softmax_STE(candidate_logits, tau=6.0, max_ste=False, alpha=0.98)\n",
        "        # candidate_probs_unnorm = torch.softmax(candidate_logits, dim=-1)\n",
        "\n",
        "        assert candidate_probs_.shape == ((bs, half_ops, seq_len, seq_len+1) if not USE_SIGMOID_GATE_FOR_NO_COPY_BRANCH else (bs, half_ops, seq_len, seq_len)), f'candidate_probs_.shape: {candidate_probs_.shape}'\n",
        "\n",
        "        if NULL_BIAS_AFTER_SOFTMAX and not USE_SIGMOID_GATE_FOR_NO_COPY_BRANCH:\n",
        "            candidate_probs_ = candidate_probs_.clone()  # <-- add clone here\n",
        "            candidate_probs_[..., -1] = candidate_probs_[..., -1] + 0.30;\n",
        "            sum_probs = candidate_probs_.sum(dim=-1, keepdim=True)\n",
        "            candidate_probs = candidate_probs_ / (sum_probs + 1e-9)\n",
        "        else:\n",
        "            candidate_probs = candidate_probs_\n",
        "            if USE_SIGMOID_GATE_FOR_NO_COPY_BRANCH:\n",
        "                assert null_prob_for_sigmoid_gate is not None\n",
        "                assert candidate_probs.shape == (bs, half_ops, seq_len, seq_len)\n",
        "                assert null_prob_for_sigmoid_gate.shape == (bs, half_ops, seq_len, 1)\n",
        "                candidate_probs *= (1-null_prob_for_sigmoid_gate)\n",
        "                candidate_probs = torch.cat([candidate_probs, null_prob_for_sigmoid_gate], dim=-1)\n",
        "                if VERBOSE_LOGGING and not self.training:\n",
        "                    for i in range(half_ops):\n",
        "\n",
        "                        neg_inf = getattr(self, \"copy_from_fixed_absolute_enc_key_gates_only\", False)\n",
        "                        key_mask = self.fixed_gate_mask[half_ops:] if neg_inf else None              # shape: [half_ops]\n",
        "                        if (key_mask is not None and key_mask[i*2] == True) or not neg_inf:\n",
        "                            assert torch.allclose(candidate_probs[:, i, :, :].sum(dim=-1), torch.ones_like(candidate_probs[:, i, :, :].sum(dim=-1)))\n",
        "\n",
        "\n",
        "        if self.training and VERBOSE_LOGGING:\n",
        "\n",
        "            def create_named_hook(name):\n",
        "                def hook(grad):\n",
        "                  if grad is not None:\n",
        "                      print(f\"[relPosCopy] Hook '{name}' triggered, avg grad: {torch.mean(grad.abs())}, min grad: {torch.min(grad)}, max grad: {torch.max(grad)}\")\n",
        "                  else:\n",
        "                      print(f\"[relPosCopy] Hook '{name}' triggered, grad is None\")\n",
        "                return hook\n",
        "\n",
        "            candidate_probs.register_hook(create_named_hook(\"candidate_probs\"))\n",
        "            candidate_logits.register_hook(create_named_hook(\"candidate_logits\"))\n",
        "            logits_real.register_hook(create_named_hook(\"logits_real\"))\n",
        "\n",
        "\n",
        "        # --- Step 8: Weighted sum for cand_enc_soft, discrete for cand_enc_hard\n",
        "        assert candidate_probs.shape == (bs, half_ops, seq_len, seq_len+1)\n",
        "\n",
        "        if not self.training:\n",
        "            with torch.no_grad():\n",
        "                self.cached_attention_matrices = candidate_probs.detach().cpu()\n",
        "                if USE_SIGMOID_GATE_FOR_NO_COPY_BRANCH:\n",
        "                    candidate_logits_ = torch.cat([logits_real, null_logits], dim=-1)\n",
        "                self.unnormed_candidate_logits_for_position_copying = candidate_logits_.detach().cpu()\n",
        "\n",
        "\n",
        "        return None, candidate_probs, None, None #, Q, K\n",
        "\n",
        "    ###@torch.compile(dynamic=False)\n",
        "    def histogram_update_learnable_sharpened_copy_pos_optim_v3_5(\n",
        "        self,\n",
        "        hist = None,          # [P,bs,h]\n",
        "        p_reset = None,       # [bs,h]\n",
        "        p_incr  = None,       # [bs,h]\n",
        "        p_decr  = None,       # [bs,h]\n",
        "        p_keep  = None,       # [bs,h]\n",
        "        P_hist: int = None,\n",
        "        keys = False,\n",
        "\n",
        "        p_copy=None,   # [P_hist+1, bs,h]  (last elem of dim 0 = no-copy)\n",
        "\n",
        "        eps       : float = 1e-8,\n",
        "        gamma     : float = 1.0,\n",
        "        power_sharpen : bool = True,\n",
        "        cached_hists_qk_fordebug : list[torch.Tensor] = None,\n",
        "    ):\n",
        "\n",
        "        P, bs, h = hist.shape\n",
        "        one      = torch.ones((), device=hist.device)\n",
        "\n",
        "        # ①  flows ----------------------------------------------------\n",
        "        total   = hist.sum(0)                       # [bs,h]\n",
        "        w_inc   = (one-p_reset) * p_incr\n",
        "        w_dec   = (one-p_reset) * p_decr\n",
        "        w_keep  = (one-p_reset) * p_keep\n",
        "\n",
        "        # 1) allocate and add the “reset” branch\n",
        "        next_hist = torch.zeros_like(hist)\n",
        "        next_hist[1] += total * p_reset * p_incr\n",
        "        next_hist[0] += total * p_reset * p_decr + total * p_reset * p_keep\n",
        "\n",
        "        # 2) compute the “keep”, “inc”, “dec” flows\n",
        "        hist_keep = hist * w_keep.unsqueeze(0)\n",
        "        hist_inc  = hist * w_inc .unsqueeze(0)\n",
        "        hist_dec  = hist * w_dec .unsqueeze(0)\n",
        "\n",
        "        # (a) keep branch is trivial: same row\n",
        "        next_hist += hist_keep\n",
        "\n",
        "        # (b) increment branch: shift everything up one row, clamp the last\n",
        "        next_hist[1:]   += hist_inc[:-1]\n",
        "        next_hist[-1]   += hist_inc[-1]     # clamp from out-of-bounds\n",
        "\n",
        "        # (c) decrement branch: shift everything down one row, clamp the first\n",
        "        next_hist[:-1]  += hist_dec[1:]\n",
        "        next_hist[0]    += hist_dec[0]\n",
        "\n",
        "\n",
        "        # ②  copy branch ---------------------------------------------\n",
        "        if p_copy is not None:\n",
        "            # assert p_copy.shape == (bs,h,P_hist+1)\n",
        "            assert p_copy.shape == (P_hist+1, bs, h)\n",
        "            # copy_pos, p_no_copy = p_copy[..., :-1], p_copy[..., -1]\n",
        "            copy_pos, p_no_copy = p_copy[:-1, ...], p_copy[-1, ...]\n",
        "            assert  copy_pos.shape == (P_hist, bs, h)\n",
        "\n",
        "            next_hist.mul_(p_no_copy.unsqueeze(0))                        # scale\n",
        "            # next_hist += total.unsqueeze(0) * copy_pos.permute(2,0,1)     # jump\n",
        "            next_hist.add_(total.unsqueeze(0) * copy_pos)\n",
        "\n",
        "        # ③  sharpening & normalise ----------------------------------\n",
        "        gamma = 2.0\n",
        "        next_hist = (next_hist + eps).pow(gamma)\n",
        "        next_hist = next_hist / (next_hist.sum(0, keepdim=True) + eps)\n",
        "        if cached_hists_qk_fordebug is not None:\n",
        "            cached_hists_qk_fordebug.append(next_hist)\n",
        "        return next_hist\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "    import torch.nn.functional as F\n",
        "\n",
        "\n",
        "\n",
        "    \"\"\" Unit test at: https://colab.research.google.com/drive/1MSeX1edeCEJbhds8iZWjqGHfGmrNxP84#scrollTo=PYM_QHazEheH \"\"\"\n",
        "    ##@torch.compile(dynamic=False)\n",
        "    def histogram_update_learnable_sharpened_copy_pos_optim_v4(\n",
        "        self,\n",
        "        hist: torch.Tensor,            # [P, bs, h]\n",
        "        p_reset: torch.Tensor,         # [bs, h]\n",
        "        p_incr: torch.Tensor,          # [bs, h]\n",
        "        p_decr: torch.Tensor,          # [bs, h]\n",
        "        p_keep: torch.Tensor,          # [bs, h]\n",
        "        P_hist: int,\n",
        "        *,\n",
        "        keys: bool = False,\n",
        "        p_copy: torch.Tensor = None,   # either [bs, h, P_hist+1] or [P_hist+1, bs, h]\n",
        "        eps: float = 1e-8,\n",
        "        gamma: float = 1.0,\n",
        "        power_sharpen: bool = True,\n",
        "        cached_hists_qk_fordebug: list[torch.Tensor] = None,\n",
        "    ) -> torch.Tensor:\n",
        "\n",
        "        P, bs, h = hist.shape\n",
        "        one = torch.ones((), device=hist.device)\n",
        "\n",
        "        # ① compute no-reset weights\n",
        "        total  = hist.sum(0)               # [bs, h]\n",
        "        w_inc  = (one - p_reset) * p_incr  # [bs, h]\n",
        "        w_dec  = (one - p_reset) * p_decr\n",
        "        w_keep = (one - p_reset) * p_keep\n",
        "\n",
        "        # ② reset‐branch\n",
        "        next_hist = torch.zeros_like(hist)   # [P, bs, h]\n",
        "        next_hist[1] += total * p_reset * p_incr\n",
        "        next_hist[0] += total * p_reset * (p_decr + p_keep)\n",
        "\n",
        "        # ③ fused inc/keep/dec via slicing instead of roll\n",
        "        base_keep = hist * w_keep.unsqueeze(0)  # [P, bs, h]\n",
        "\n",
        "        # — inc branch: shift up 1, clamp ends\n",
        "        base_inc = hist * w_inc.unsqueeze(0)    # [P, bs, h]\n",
        "        inc_roll = torch.zeros_like(base_inc)\n",
        "        # t→t+1 for t=0…P-2\n",
        "        inc_roll[1:] = base_inc[:-1]\n",
        "        # clamp last row: any spill from P-1 stays at P-1\n",
        "        inc_roll[-1] += base_inc[-1]\n",
        "\n",
        "        # — dec branch: shift down 1, clamp ends\n",
        "        base_dec = hist * w_dec.unsqueeze(0)\n",
        "        dec_roll = torch.zeros_like(base_dec)\n",
        "        # t→t-1 for t=1…P-1\n",
        "        dec_roll[:-1] = base_dec[1:]\n",
        "        # clamp first row: any spill from 0 stays at 0\n",
        "        dec_roll[0] += base_dec[0]\n",
        "\n",
        "        # accumulate all three in one pass\n",
        "        next_hist += base_keep\n",
        "        next_hist += inc_roll\n",
        "        next_hist += dec_roll\n",
        "\n",
        "        # ④ copy‐branch\n",
        "        if p_copy is not None:\n",
        "            # normalize to [P_hist+1, bs, h]\n",
        "            if p_copy.shape == (bs, h, P_hist+1):\n",
        "                p_copy = p_copy.permute(2, 0, 1)\n",
        "            assert p_copy.shape == (P_hist+1, bs, h)\n",
        "\n",
        "            pos_cols, no_copy = p_copy[:-1], p_copy[-1]   # [P_hist, bs, h], [bs, h]\n",
        "            next_hist.mul_(no_copy.unsqueeze(0))         # scale normal flows\n",
        "            next_hist.add_(total.unsqueeze(0) * pos_cols)  # jump copy flows\n",
        "\n",
        "        # ⑤ sharpening + renormalize\n",
        "        if power_sharpen:\n",
        "            next_hist = (next_hist + eps).pow(2.0)\n",
        "        next_hist = next_hist / (next_hist.sum(0, keepdim=True) + eps)\n",
        "\n",
        "        if cached_hists_qk_fordebug is not None:\n",
        "            cached_hists_qk_fordebug.append(next_hist)\n",
        "\n",
        "        return next_hist\n",
        "\n",
        "\n",
        "\n",
        "    ###@torch.compile(dynamic=False)\n",
        "    def histogram_update_learnable_sharpened_copy_pos_optim_v3(\n",
        "        self,\n",
        "        hist = None,          # [P,bs,h]\n",
        "        p_reset = None,       # [bs,h]\n",
        "        p_incr  = None,       # [bs,h]\n",
        "        p_decr  = None,       # [bs,h]\n",
        "        p_keep  = None,       # [bs,h]\n",
        "        P_hist: int = None,\n",
        "        keys = False,\n",
        "\n",
        "        p_copy=None,   # [P_hist+1, bs,h]  (last elem of dim 0 = no-copy)\n",
        "\n",
        "        eps       : float = 1e-8,\n",
        "        gamma     : float = 1.0,\n",
        "        power_sharpen : bool = True,\n",
        "        cached_hists_qk_fordebug : list[torch.Tensor] = None,\n",
        "    ):\n",
        "\n",
        "        P, bs, h = hist.shape\n",
        "        one      = torch.ones((), device=hist.device)\n",
        "\n",
        "        # ①  flows ----------------------------------------------------\n",
        "        total   = hist.sum(0)                       # [bs,h]\n",
        "        w_inc   = (one-p_reset) * p_incr\n",
        "        w_dec   = (one-p_reset) * p_decr\n",
        "        w_keep  = (one-p_reset) * p_keep\n",
        "\n",
        "        # 1) allocate and add the “reset” branch\n",
        "        next_hist = torch.zeros_like(hist)\n",
        "        next_hist[1] += total * p_reset * p_incr\n",
        "        next_hist[0] += total * p_reset * p_decr + total * p_reset * p_keep\n",
        "\n",
        "        # 2) compute the “keep”, “inc”, “dec” flows\n",
        "        hist_keep = hist * w_keep.unsqueeze(0)\n",
        "        hist_inc  = hist * w_inc .unsqueeze(0)\n",
        "        hist_dec  = hist * w_dec .unsqueeze(0)\n",
        "\n",
        "        # (a) keep branch is trivial: same row\n",
        "        next_hist += hist_keep\n",
        "\n",
        "        # (b) increment branch: shift everything up one row, clamp the last\n",
        "        next_hist[1:]   += hist_inc[:-1]\n",
        "        next_hist[-1]   += hist_inc[-1]     # clamp from out-of-bounds\n",
        "\n",
        "        # (c) decrement branch: shift everything down one row, clamp the first\n",
        "        next_hist[:-1]  += hist_dec[1:]\n",
        "        next_hist[0]    += hist_dec[0]\n",
        "\n",
        "\n",
        "        # ②  copy branch ---------------------------------------------\n",
        "        if p_copy is not None:\n",
        "            # assert p_copy.shape == (bs,h,P_hist+1)\n",
        "            assert p_copy.shape == (P_hist+1, bs, h)\n",
        "            # copy_pos, p_no_copy = p_copy[..., :-1], p_copy[..., -1]\n",
        "            copy_pos, p_no_copy = p_copy[:-1, ...], p_copy[-1, ...]\n",
        "            assert  copy_pos.shape == (P_hist, bs, h)\n",
        "\n",
        "            next_hist.mul_(p_no_copy.unsqueeze(0))                        # scale\n",
        "            # next_hist += total.unsqueeze(0) * copy_pos.permute(2,0,1)     # jump\n",
        "            next_hist.add_(total.unsqueeze(0) * copy_pos)\n",
        "\n",
        "        # ③  sharpening & normalise ----------------------------------\n",
        "        gamma = 2.0\n",
        "        next_hist = (next_hist + eps).pow(gamma)\n",
        "        next_hist = next_hist / (next_hist.sum(0, keepdim=True) + eps)\n",
        "        if cached_hists_qk_fordebug is not None:\n",
        "            cached_hists_qk_fordebug.append(next_hist)\n",
        "        return next_hist\n",
        "\n",
        "\n",
        "    \"\"\" The kernel code of the relative position algorithm:\n",
        "    # --- define vectorized histogram update as an efficient stochastic matrix of order O(T) per step instead of T^2 for matrix-vector ---------------------------\n",
        "    # For <stochasticMatrixForResetPosBr> in _processQueriesOrKeys_AllBranches()\n",
        "    # Unit Test: https://colab.research.google.com/drive/1MSeX1edeCEJbhds8iZWjqGHfGmrNxP84#scrollTo=0Oi72Jy08Qtx\n",
        "    # <statePosSTEFix v2>\n",
        "    \"\"\"\n",
        "    ###@torch.compile(dynamic=False)\n",
        "    def histogram_update_learnable_sharpened_copy_pos(\n",
        "        self,\n",
        "        hist      : torch.Tensor,   # [P, bs, h]\n",
        "        p_reset   : torch.Tensor,   # [bs, h]\n",
        "        p_incr    : torch.Tensor,   # [bs, h]\n",
        "        p_decr    : torch.Tensor,   # [bs, h]\n",
        "        p_keep    : torch.Tensor,   # [bs, h]\n",
        "        P_hist    : int = None,\n",
        "        keys = False,\n",
        "        p_copy    : torch.Tensor = None,   #  *** NEW ***\n",
        "        power_sharpen : bool = True,\n",
        "        eps       : float = 1e-8,\n",
        "        gamma     : float = 1.0,\n",
        "        cached_hists_qk_fordebug : list[torch.Tensor] = None,\n",
        "\n",
        "    ) -> torch.Tensor:\n",
        "        \"\"\"\n",
        "        If `p_copy` is provided it must have shape [ P_hist+1, bs, h].\n",
        "        The last column is P(no-copy); columns 0…P_hist−1 are\n",
        "        P(copy → absolute position s).\n",
        "        All rows must sum to 1.\n",
        "        \"\"\"\n",
        "\n",
        "        P, bs, h = hist.shape\n",
        "        device   = hist.device\n",
        "        one      = torch.ones((), device=device)\n",
        "\n",
        "        # ------------------------------------------------------------------ ①\n",
        "        true_inc, true_dec, true_keep = p_incr, p_decr, p_keep              # [bs,h]\n",
        "\n",
        "        # ------------------------------------------------------------------ ②   (reset path)\n",
        "        total   = hist.sum(0)                                               # [bs,h]\n",
        "        r_inc   = total * p_reset * true_inc\n",
        "        r_dec   = total * p_reset * true_dec\n",
        "        r_keep  = total * p_reset * true_keep\n",
        "\n",
        "        # ------------------------------------------------------------------ ③   (no-reset weights)\n",
        "        p_no    = one - p_reset\n",
        "        w_inc   = p_no * true_inc\n",
        "        w_dec   = p_no * true_dec\n",
        "        w_keep  = p_no * true_keep\n",
        "\n",
        "        # ------------------------------------------------------------------ ④   (split old hist)\n",
        "        hist_inc   = hist * w_inc .unsqueeze(0)\n",
        "        hist_dec   = hist * w_dec .unsqueeze(0)\n",
        "        hist_keep  = hist * w_keep.unsqueeze(0)\n",
        "\n",
        "        # ------------------------------------------------------------------ ⑤   (scatter targets)\n",
        "        idx       = torch.arange(P, device=device).view(P,1,1)\n",
        "        tgt_keep  = idx.expand_as(hist)\n",
        "        tgt_inc   = (idx+1).clamp_max(P-1).expand_as(hist)\n",
        "        tgt_dec   = (idx-1).clamp_min(0) .expand_as(hist)\n",
        "\n",
        "        # ------------------------------------------------------------------ ⑥   (accumulate)\n",
        "        next_hist = torch.zeros_like(hist)\n",
        "        next_hist[1] += r_inc\n",
        "        next_hist[0] += r_keep + r_dec\n",
        "        next_hist.scatter_add_(0, tgt_keep, hist_keep)\n",
        "        next_hist.scatter_add_(0, tgt_inc,  hist_inc)\n",
        "        next_hist.scatter_add_(0, tgt_dec,  hist_dec)\n",
        "\n",
        "        ASSERT_SUMS = False\n",
        "        with torch.no_grad():\n",
        "            if ASSERT_SUMS:\n",
        "                assert torch.allclose(total, torch.ones_like(total), atol=1e-3)\n",
        "                assert torch.allclose(next_hist.sum(0), torch.ones_like(total), atol=1e-3)\n",
        "\n",
        "\n",
        "        # ------------------------------------------------------------------ ⑥-b  *** COPY BRANCH ***\n",
        "        if p_copy is not None:                                             # [bs,h,P+1]\n",
        "\n",
        "            assert  p_copy.shape == (P_hist+1, bs, h), f'p_copy.shape: {p_copy.shape}, expected: {P_hist+1, bs, h}'\n",
        "            if ASSERT_SUMS:\n",
        "                assert torch.allclose(p_copy.sum(dim=0), torch.ones_like(p_copy.sum(dim=0)), atol=1e-3)\n",
        "            # p_copy_pos = p_copy[..., :-1]           # copy → s\n",
        "            # p_no_copy  = p_copy[..., -1]            # stay in normal branches\n",
        "            p_copy_pos = p_copy[:-1, ...]           # copy → s\n",
        "            p_no_copy  = p_copy[-1, ...]            # stay in normal branches\n",
        "            assert p_no_copy.shape == (bs, h)\n",
        "            # with torch.no_grad():\n",
        "            #     if TEST_ABLATE_COPYPROBS:\n",
        "            #         assert torch.allclose(p_copy_pos, torch.zeros_like(p_copy_pos), atol=1e-8)\n",
        "            #         assert torch.allclose(p_no_copy, torch.ones_like(p_no_copy), atol=1e-8)\n",
        "\n",
        "\n",
        "            # (i) down-scale all normal flows by P(no-copy)\n",
        "            scale = p_no_copy\n",
        "\n",
        "            # next_hist shape: (P, bs, h)\n",
        "            next_hist.mul_(scale.unsqueeze(0))      # broadcast to [P,bs,h]\n",
        "\n",
        "            # (ii) add mass that jumps directly to absolute s\n",
        "            # mass_copy = total.unsqueeze(0) * p_copy_pos.permute(2,0,1)  # [P,bs,h]\n",
        "            # mass_copy = torch.einsum('bh, bhp -> pbh', total, p_copy_pos)\n",
        "            assert p_copy_pos.shape == (P_hist, bs, h) == next_hist.shape\n",
        "            mass_copy = p_copy_pos\n",
        "            # next_hist += mass_copy\n",
        "            # In-place add:\n",
        "            next_hist.add_(mass_copy)\n",
        "\n",
        "            with torch.no_grad():\n",
        "                if ASSERT_SUMS:\n",
        "                    assert torch.allclose(next_hist.sum(0), torch.ones_like(total), atol=1e-6)\n",
        "\n",
        "        # ------------------------------------------------------------------ ⑦   (optional sharpening)\n",
        "        if power_sharpen:\n",
        "            gamma = self._current_gamma(keys=keys, half_ops=h)             # [1,1,h]\n",
        "            assert gamma.shape == (1,1,h)\n",
        "            if self.training:\n",
        "                next_hist = (next_hist + eps).pow(gamma)\n",
        "            else:                                                          # eval → full γ\n",
        "                next_hist = (next_hist + eps).pow(gamma)\n",
        "            next_hist = next_hist / (next_hist.sum(0, keepdim=True))\n",
        "\n",
        "        with torch.no_grad():\n",
        "            if cached_hists_qk_fordebug is not None:\n",
        "                cached_hists_qk_fordebug.append(next_hist.detach().cpu())\n",
        "\n",
        "        return next_hist\n",
        "\n",
        "    # @torch.compile(dynamic=False)\n",
        "    def _calc_input_dependent_gammas(self, embeddings=None, bs=None, T=None, for_keys=False):\n",
        "\n",
        "          _, _, _, latent_dim = embeddings.shape\n",
        "          assert embeddings.shape == (\n",
        "              self.num_operators, bs, T, self._gamma_proj_proj_per_operator_to_scalar.shape[-1]\n",
        "          ), f'embeddings.shape: {embeddings.shape}'\n",
        "\n",
        "          # ① collapse batch & time, keep operator axis\n",
        "          ctx = (\n",
        "              embeddings\n",
        "              .permute(1, 2, 0, 3)            # [bs, T, n_ops, d]\n",
        "              .reshape(bs * T, self.num_operators, latent_dim)\n",
        "          )\n",
        "          assert ctx.shape == (bs*T, self.num_operators, latent_dim), f'ctx.shape: {ctx.shape}'\n",
        "\n",
        "          # ---- NEW: norm-target so that max inner product ≡ 2.5 ----\n",
        "          # If ||w|| = ||x|| = (effective) sqrt(2.5), then max <w,x> = 2.5 (when aligned).\n",
        "          NORM_TARGET = math.sqrt(1.4)\n",
        "\n",
        "          # (a) normalize inputs per vector to ||x|| = sqrt(2.5)\n",
        "          ctx = F.normalize(ctx, dim=-1, eps=1e-12) * NORM_TARGET\n",
        "\n",
        "          # (b) normalize operator parameters per vector to ||w|| = sqrt(2.5)\n",
        "          #     (do NOT modify the parameter in-place; use a normalized view)\n",
        "          w_normed = F.normalize(self._gamma_proj_proj_per_operator_to_scalar, dim=-1, eps=1e-12) * NORM_TARGET\n",
        "          assert w_normed.shape == (self.num_operators, latent_dim)\n",
        "\n",
        "          # ② inner products (bounded in [-2.5, 2.5] before bias)\n",
        "          theta = torch.einsum('lnd,nd->ln', ctx, w_normed)       # [bs*T, n_ops]\n",
        "          # assert theta.shape == (bs*T, self.num_operators)\n",
        "          # # Add bias for _gamma_proj_bias, of shape (num_operators, self.intermediate_dim_for_gate_mlp)\n",
        "          theta = softplus_cap_at_bounds(torch.abs(theta) + softplus_cap_at_bounds(torch.abs(self._gamma_proj_bias.sum(dim=-1))), bounds=0.8)\n",
        "          assert theta.shape == (bs*T, self.num_operators)\n",
        "\n",
        "          # theta = theta + self._theta_gamma.unsqueeze(0)      # broadcast → [bs*T, num_ops]\n",
        "          # theta = torch.ones_like(theta) * 0.8\n",
        "          gamma_full = 1.2 + (theta)\n",
        "          if VERBOSE_LOGGING:\n",
        "              print(f'[RSE inputDependentGammaProjection] gamma_full avg={gamma_full.mean():.3e}  min={gamma_full.min():.20e}  max={gamma_full.max():.10e},  std={gamma_full.std():.3e}, median={torch.median(gamma_full):.3e}')\n",
        "\n",
        "\n",
        "          # ③ slice queries vs. keys\n",
        "          half = self.num_operators // 2\n",
        "          gamma_qk = gamma_full[:, :half] if not for_keys else gamma_full[:, half:]\n",
        "          # gamma_qk = torch.clamp(gamma_qk, 1.0, 2.0)\n",
        "          # now [bs*T, h_ops]\n",
        "\n",
        "          # ④ reshape back\n",
        "          gammas_all = gamma_qk.view(bs, T, half)             # <-- half = self.num_operators//2\n",
        "          return gammas_all\n",
        "\n",
        "\n",
        "\n",
        "    # V3: Fixes state_prob and state_pos ste to include all branches\n",
        "    # @torch.compile(dynamic=False)\n",
        "    def _processQueriesOrKeys_AllBranches(self, batch_size=None, embeddings=None, reset_probs=None, incr_decr_action_probabilities=None,\n",
        "                                          reset_logits=None,\n",
        "                                          cached_hists_q_fordebug=None,\n",
        "                                          cached_hists_k_fordebug=None,\n",
        "                                          seq_len=None,\n",
        "\n",
        "                                          # Main params:\n",
        "                                          for_keys = True, half_ops=None,\n",
        "                                          all_scalar_position_probabilities_for_copy=None,\n",
        "                                          all_scalar_histogram_rel_positions_for_copy=None,\n",
        "                                          all_abs_positions_for_copy=None,\n",
        "                                          copyProbs=None,):\n",
        "\n",
        "            \"\"\"\n",
        "            Vectorised, memory-frugal beam filter.\n",
        "            Parameters:\n",
        "              keys: determining key positions or otherwise query positions\n",
        "              half_ops: number of operators for the queries and keys == self.num_operators // 2\n",
        "              all_scalar_position_probabilities_for_copy: (bs, half_ops, seq_len, histogram size)\n",
        "              all_scalar_histogram_rel_positions_for_copy:  (bs, half_ops, seq_len, seq_len+1)\n",
        "              copyProbs: shape (bs, half_ops, seq_len, seq_len+1) # <-- Where copyProbs[..., -1] is prob that no copy is performed.\n",
        "              # copy_bool_mask: shape = copyProbs.shape\n",
        "\n",
        "            Returns\n",
        "            -------\n",
        "            enc_final : (half_ops, bs, seq_len, branches)\n",
        "            best_pos  : [half_ops, bs, seq_len]     (debug only)\n",
        "            \"\"\"\n",
        "\n",
        "\n",
        "            BW        = self.beam_width            # beam width\n",
        "            bs        = batch_size                 # comes from caller’s scope\n",
        "            h         = half_ops\n",
        "            dev       = reset_probs.device\n",
        "            T         = seq_len\n",
        "\n",
        "\n",
        "            # --- initialize histogram at t=0 ----------------------------\n",
        "            # For <stochasticMatrixForResetPosBr>\n",
        "            # max discrete position we track = sequence length\n",
        "            # ─── histogram size and init ──────────────────────────────────────\n",
        "            if SYMMETRIC_UPDATE_FN:\n",
        "                # symmetric range [-T…+T] → length 2*T+1, with index T ↔ position=0\n",
        "                P_hist = 2 * T + 1\n",
        "            else:\n",
        "                # one-sided [0…T] → length T+1, with index 0 ↔ position=0\n",
        "                P_hist = T + 1\n",
        "\n",
        "            # copy‐matrix buffer (last row = “no copy”)\n",
        "            # p_copy_dense = torch.zeros(\n",
        "            #     P_hist + 1, bs, h,\n",
        "            #     dtype=torch.float,\n",
        "            #     device=dev,\n",
        "            # )\n",
        "\n",
        "            # initialize histogram: delta at “zero” bin\n",
        "            hist = torch.zeros(P_hist, bs, h, device=dev)\n",
        "            if SYMMETRIC_UPDATE_FN:\n",
        "                # zero at middle index\n",
        "                hist[T].fill_(1.0)\n",
        "            else:\n",
        "                # zero at start\n",
        "                hist[0].fill_(1.0)\n",
        "\n",
        "            # ─── preallocate base‐positions for visualization/top-k ─────────────\n",
        "            if USE_PREALLOCED_STATE_POS_BASE:\n",
        "                # indices 0…P_hist-1 → broadcast as [P_hist, bs, h]\n",
        "                state_pos_base_buf = torch.arange(P_hist, device=dev) \\\n",
        "                                        .view(P_hist, 1, 1) \\\n",
        "                                        .expand(P_hist, bs, h)\n",
        "                # unbind into a list of length T for time-major indexing\n",
        "                state_pos_base_buf = state_pos_base_buf \\\n",
        "                                        .unsqueeze(0).expand(T, -1, -1, -1) \\\n",
        "                                        .unbind(0)\n",
        "\n",
        "            if PREALLOCED_HISTOGRAM_TENSORS:\n",
        "                # after you compute P_hist, bs, h, T, dev, etc.\n",
        "\n",
        "                # 1️⃣ pre-allocate the per-timestep next_hist stack\n",
        "                _hist_buf = torch.zeros(T, P_hist, bs, h, device=dev)\n",
        "                _inc_buf  = torch.zeros_like(_hist_buf)\n",
        "                _dec_buf  = torch.zeros_like(_hist_buf)\n",
        "                _roll_buf = torch.zeros(T, P_hist, bs, h, device=dev)   # single shared roll buffer per t\n",
        "                _reset_buf = torch.zeros(T, P_hist, bs, h, device=dev) # single shared reset buffer per t\n",
        "\n",
        "\n",
        "            prealloc_gate_probs_stack = False\n",
        "            BRANCH_FACTOR = None #shifts.shape[0]\n",
        "\n",
        "            # ------------------------------------------------------------------ #\n",
        "            #  initial beam state\n",
        "            # ------------------------------------------------------------------ #\n",
        "            state_pos  = torch.zeros(BW, bs, h, device=dev, dtype=torch.float)\n",
        "            state_pos_base = None\n",
        "            state_prob = torch.ones(BW, bs, h, device=dev, dtype=torch.float)\n",
        "            state_prob = state_prob / state_prob.sum(0, keepdim=True)\n",
        "\n",
        "            # running sum for the output encoding  (bs,h,T,d)\n",
        "\n",
        "            best_pos_list = []                     # debug only\n",
        "\n",
        "            # incr/decr/keep:\n",
        "            assert incr_decr_action_probabilities.shape == (self.num_operators, bs, seq_len, MERGED_GATE_MLP_NUM_GATES-1, 1), f'incr_decr_action_probabilities shape: {incr_decr_action_probabilities.shape}'\n",
        "            incrDecrAsIndependentAdditiveGates = False\n",
        "\n",
        "            if SEPARATE_GATE_PROBS_TO_LISTS_BEFORE_TIMESLICES:\n",
        "                # assert permute to time idx 0:\n",
        "                assert PERMUTE_TIME_IDX_TO_DIM_0, f'PERMUTE_TIME_IDX_TO_DIM_0: {PERMUTE_TIME_IDX_TO_DIM_0}'\n",
        "                num_ops, bs, T, _, _ = incr_decr_action_probabilities.shape\n",
        "                half_ops = num_ops // 2                      # if you need it\n",
        "\n",
        "                # 1) pick the YES-branch for each gate → shape [3, num_ops, bs, T]\n",
        "                #    ( NO-branch is all zeros so we drop it )\n",
        "                # gate_all = incr_decr_action_probabilities[..., 0]\n",
        "                diff_squeezed = incr_decr_action_probabilities.squeeze(-1)\n",
        "                assert diff_squeezed.shape == (num_ops, bs, T, MERGED_GATE_MLP_NUM_GATES-1), f'diff_squeezed.shape: {diff_squeezed.shape}'\n",
        "                diff_squeezed_unbinded = diff_squeezed.unbind(dim=0); assert len(diff_squeezed) == self.num_operators, f'len(diff_squeezed): {len(diff_squeezed)}'\n",
        "                ##gate_all = gate_all[:half_ops] if not for_keys else gate_all[half_ops:]\n",
        "                gate_all = diff_squeezed_unbinded[:half_ops] if not for_keys else diff_squeezed_unbinded[half_ops:]\n",
        "                gate_all = torch.stack(gate_all, dim=0)\n",
        "                assert gate_all.shape == (half_ops, bs, T, MERGED_GATE_MLP_NUM_GATES-1), f'gate_all.shape: {gate_all.shape}'\n",
        "\n",
        "                # 2) permute to TIME-MAJOR and materialise once\n",
        "                #    new shape → [T, MERGED_GATE_MLP_NUM_GATES-1, bs, half_ops]  (contiguous)\n",
        "                gate_all_tm = gate_all.permute(2, 3, 1, 0).contiguous()\n",
        "                assert gate_all_tm.shape == (T, MERGED_GATE_MLP_NUM_GATES-1, bs, half_ops), f'gate_all_tm.shape: {gate_all_tm.shape}'\n",
        "\n",
        "                # 3) split the gate dimension so we get three tensors time-major\n",
        "                #    each element is [num_ops, bs]\n",
        "                # 4) build Python lists of [bs, h] tensors *per timestep*\n",
        "                p_incr_tm, p_decr_tm, p_keep_tm = gate_all_tm.unbind(dim=1)   # list length = 3\n",
        "                assert p_incr_tm.shape == (T, bs, half_ops) == p_decr_tm.shape == p_keep_tm.shape, f'p_incr_tm.shape: {p_incr_tm.shape}, expected: {T, bs, half_ops}'\n",
        "\n",
        "\n",
        "                p_incr_list = p_incr_tm.clone().unbind(dim=0)\n",
        "                p_decr_list = p_decr_tm.clone().unbind(dim=0)\n",
        "                p_keep_list = p_keep_tm.clone().unbind(dim=0)\n",
        "\n",
        "            # First dim: {incr, decr}\n",
        "            elif not SEPARATE_GATE_PROBS_TO_LISTS_BEFORE_TIMESLICES:\n",
        "                p_id = incr_decr_action_probabilities.permute(3, 4, 1, 0, 2)  # [MERGED_GATE_MLP_NUM_GATES, 2, bs, ops, T]\n",
        "                assert p_id.shape == (MERGED_GATE_MLP_NUM_GATES-1, 1, bs, self.num_operators, T), f'p_id.shape: {p_id.shape}'\n",
        "                p_id_h = p_id[:, :, :, :h, :] if not for_keys else p_id[:, :, :, h:, :]\n",
        "                assert p_id_h.shape == (MERGED_GATE_MLP_NUM_GATES-1, 1, bs, h, T), f'p_id_h.shape: {p_id_h.shape}'\n",
        "                if PERMUTE_TIME_IDX_TO_DIM_0:\n",
        "                    p_id_h = p_id_h.permute(4, 0, 1, 2, 3)\n",
        "                    assert p_id_h.shape == (T, MERGED_GATE_MLP_NUM_GATES-1, 1, bs, h), f'p_id_h.shape: {p_id_h.shape}'\n",
        "                    p_id_h = p_id_h.contiguous()\n",
        "                    # assert p_id_h.is_contiguous(), f'p_id_h.is_contiguous(): {p_id_h.is_contiguous()}'\n",
        "\n",
        "\n",
        "            if reset_probs is not None:\n",
        "                assert reset_probs.shape == (self.num_operators, bs, seq_len, 2), f'reset_probs_T.shape: {reset_probs.shape}'\n",
        "                reset_probs_T = reset_probs.permute(3, 1, 0, 2)\n",
        "                assert reset_probs_T.shape == (2, bs, self.num_operators, T), f'reset_probs_T.shape: {reset_probs_T.shape}'\n",
        "                reset_probs_T = reset_probs_T[0, :, :, :]\n",
        "                assert reset_probs_T.shape == (bs, h*2, T), f'reset_probs_T.shape: {reset_probs_T.shape}'\n",
        "                reset_probs_T = (reset_probs_T[:, :h, :] if not for_keys else reset_probs_T[:, h:, :])\n",
        "                # reset_probs_T = HardResetGate.apply(reset_probs_T) # Quantize in {0, 1}\n",
        "                assert reset_probs_T.shape == (bs, h, T), f'reset_probs_T.shape: {reset_probs_T.shape}'\n",
        "                if PERMUTE_TIME_IDX_TO_DIM_0:\n",
        "                    reset_probs_T = reset_probs_T.permute(2, 0, 1)\n",
        "                    assert reset_probs_T.shape == (T, bs, h), f'reset_probs_T.shape: {reset_probs_T.shape}'\n",
        "                    reset_probs_T = reset_probs_T.contiguous()\n",
        "                    if SEPARATE_GATE_PROBS_TO_LISTS_BEFORE_TIMESLICES:\n",
        "                        reset_probs_list = reset_probs_T.clone().unbind(dim=0)\n",
        "            else:\n",
        "                assert False, 'Unsupported/code path removed as of v0.660+'\n",
        "\n",
        "            if prealloc_gate_probs_stack:\n",
        "                  assert False, 'Unsupported/code path removed as of v0.660+'\n",
        "\n",
        "\n",
        "            BRANCH_FACTOR = 1\n",
        "            if stochasticMatrixForResetPosBr:\n",
        "                # two branches: [reset, no‐reset]\n",
        "                BRANCH_FACTOR = P_hist if stochasticMatrixForResetPosBr else 2\n",
        "            else:\n",
        "                assert False, 'Unsupported/code path removed as of v0.660+'\n",
        "\n",
        "\n",
        "\n",
        "            if incrDecrAsIndependentAdditiveGates:\n",
        "                assert False, \"Unsupported as of 0.660+\"\n",
        "\n",
        "            # p_res  = reset_probs.permute(1,0,2,3)                      # [bs, ops, T, 2]\n",
        "            # assert p_res.shape == (bs, self.num_operators, T, 2), f'p_res.shape: {p_res.shape}'\n",
        "\n",
        "            ASSERT_CORRECT_SHAPES = 0\n",
        "\n",
        "            # Precompute branch shifts & reset mask\n",
        "            # ─── VARS for FUSED candidate generation option ─────────────────────────── #\n",
        "            # First two: for reset; last four: non-reset branch\n",
        "            branches  = BRANCH_FACTOR * BW                     # reset/¬reset × (k,i,d)\n",
        "\n",
        "            # ─── END VARS for FUSED candidate generation option ─────────────────────────── #\n",
        "\n",
        "            # with torch.cuda.graph(graph):\n",
        "\n",
        "            USE_PREALLOC_SCALAR_BUFFER = False\n",
        "\n",
        "            if USE_PREALLOC_SCALAR_BUFFER:\n",
        "                pos_t_stack  = torch.zeros(T, branches, bs, h, device=dev)\n",
        "                prob_t_stack = torch.zeros(T, branches, bs, h, device=dev)\n",
        "            else:\n",
        "                pos_t_list = []\n",
        "                prob_t_list = []\n",
        "\n",
        "            # self.register_buffer('hard_mask', torch.zeros(self.branches, self.batch_size, self.half_ops, dtype=torch.float))\n",
        "            hard_mask_ = torch.zeros(branches, bs, half_ops, device=dev)\n",
        "            prealloc_incr_ste_terms = False\n",
        "\n",
        "            if prealloc_incr_ste_terms or incrDecrAsIndependentAdditiveGates:\n",
        "                assert False, \"Unsupported / code path removed as of v0.660+\"\n",
        "\n",
        "            COUNT_UPDATE_FN_TOTAL_RUNTIME = ENABLE_CUDA_SYNCHRONIZE_TIMING_STATISTICS;\n",
        "            if COUNT_UPDATE_FN_TOTAL_RUNTIME:\n",
        "                GRANULAR_PROFILE = False\n",
        "                UPDATE_FN_TOTAL_RUNTIME = 0.0\n",
        "                UPDATE_FN_TOTAL_ITER_COUNT = 0\n",
        "\n",
        "                if COUNT_UPDATE_FN_TOTAL_RUNTIME:\n",
        "                    start = torch.cuda.Event(enable_timing=True)\n",
        "                    end   = torch.cuda.Event(enable_timing=True)\n",
        "\n",
        "                    torch.cuda.synchronize()\n",
        "                    start.record()\n",
        "\n",
        "            # ——— Precompute time-varying gammas in one shot ———\n",
        "            if Input_Dependent_Gamma_Exponents:\n",
        "                # ——— Precompute all per-timestep γ’s in parallel ———\n",
        "\n",
        "                gammas_all = self._calc_input_dependent_gammas(embeddings, bs, T, for_keys=for_keys)\n",
        "\n",
        "\n",
        "                # ——————————————————————————————————————————————————————\n",
        "            elif not Input_Dependent_Gamma_Exponents:\n",
        "                gammas_all = self._current_gamma(keys=for_keys, half_ops=h).view(half_ops,)\n",
        "\n",
        "\n",
        "            kernel_is_jit_scriptfunc = type(histogram_kernel_to_use) == torch.jit.ScriptFunction\n",
        "            kernel_name = histogram_kernel_to_use.__name__ if histogram_kernel_to_use is not None and not kernel_is_jit_scriptfunc else (histogram_kernel_to_use._torchdynamo_inline.__name__ if kernel_is_jit_scriptfunc else None)\n",
        "            if VERBOSE_LOGGING:\n",
        "                print('[RSE] using kernel name:', kernel_name)\n",
        "\n",
        "            # v0.660+ <addPosCopyingForHMM>:\n",
        "            if Position_Copying_Enabled:\n",
        "\n",
        "                # RSEv9.29.25b: For efficiency, add a precomputation pass for all p_copy_t (BEFORE the time loop):\n",
        "                if all_scalar_position_probabilities_for_copy is not None:\n",
        "\n",
        "                    histogram_size_for_prob_dist = T + 1 if not SYMMETRIC_UPDATE_FN else 2 * T + 1\n",
        "                    assert all_scalar_position_probabilities_for_copy.shape == (bs, h, T, histogram_size_for_prob_dist), f'all_scalar_position_probabilities_for_copy.shape: {all_scalar_position_probabilities_for_copy.shape}'\n",
        "                    all_scalar_position_probabilities_for_copy = all_scalar_position_probabilities_for_copy.permute(2, 0, 1, 3)\n",
        "                    assert all_scalar_position_probabilities_for_copy.shape == (T, bs, h, histogram_size_for_prob_dist), f'all_scalar_position_probabilities_for_copy.shape: {all_scalar_position_probabilities_for_copy.shape}'\n",
        "\n",
        "                    assert copyProbs.shape == (bs, h, T, T+1), f'copyProbs.shape: {copyProbs.shape}'\n",
        "                    copyProbs = copyProbs.permute(3, 0, 1, 2)   # -> [T+1, bs, h, T]\n",
        "                    copy_probs = copyProbs\n",
        "                    assert copy_probs.shape == (T+1, bs, h, T), f'copy_probs.shape: {copy_probs.shape}'\n",
        "                    if SEPARATE_GATE_PROBS_TO_LISTS_BEFORE_TIMESLICES:\n",
        "                        copy_probs_list = copy_probs.clone().unbind(dim=-1)\n",
        "\n",
        "                    # --- NEW: for effiency, precompute p_copy for all timesteps (no sequential dependency, VECTORIZED) ---\n",
        "                    precomputed_p_copy_list = None\n",
        "\n",
        "                    if all_scalar_position_probabilities_for_copy is not None:\n",
        "                        pos_candidates = all_scalar_position_probabilities_for_copy\n",
        "                        assert pos_candidates.shape == (T, bs, h, histogram_size_for_prob_dist), f'pos_candidates.shape: {pos_candidates.shape}'\n",
        "                        assert P_hist == histogram_size_for_prob_dist, f'P_hist: {P_hist}, histogram_size_for_prob_dist: {histogram_size_for_prob_dist}'\n",
        "\n",
        "                        # We will use the contiguous 4D copy_probs tensor for vectorization,\n",
        "                        # regardless of whether a per-t list (copy_probs_list) also exists.\n",
        "                        # copy_probs: [T+1, bs, h, T]  (0..T-1 = copy-from positions, last = no-copy)\n",
        "\n",
        "                        assert copy_probs.shape == (T + 1, bs, h, T), f'copy_probs.shape: {copy_probs.shape}'\n",
        "\n",
        "                        # Split: [T, bs, h, T] for copy-only, and [bs, h, T] for no-copy\n",
        "                        n_pos_candidates_per_timestep = copy_probs.shape[0] - 1\n",
        "                        prob_copy_only_all = copy_probs[:-1, ...]     # [T, bs, h, T]\n",
        "                        prob_no_copy_all   = copy_probs[-1,  ...]     # [bs, h, T]\n",
        "                        assert prob_copy_only_all.shape == (n_pos_candidates_per_timestep, bs, h, T), f'prob_copy_only_all.shape: {prob_copy_only_all.shape}'\n",
        "                        assert prob_no_copy_all.shape   == (bs, h, T), f'prob_no_copy_all.shape: {prob_no_copy_all.shape}'\n",
        "\n",
        "                        # Prepare a dense buffer for ALL timesteps in one shot:\n",
        "                        # p_copy_dense_all: [P_hist+1, bs, h, T]   (last row = \"no copy\")\n",
        "                        \"\"\"\n",
        "                        For adding the copy gate probs to final histogram: must add the same size tensors\n",
        "                        <floatRelPositionsForPosCopy>\n",
        "                        \"\"\"\n",
        "                        p_copy_dense_all = hist.new_zeros(P_hist + 1, bs, h, T)\n",
        "\n",
        "                        # \"Superpose\" relative positions via linear combination of the probability histograms\n",
        "                        # p_copy_dense_all[:-1, ...] = torch.einsum('tbhp,sbht->pbhs', pos_candidates, prob_copy_only_all)\n",
        "                        p_copy_dense_all[:-1, ...] = torch.einsum('tbhp,tbhs->pbhs', pos_candidates, prob_copy_only_all)\n",
        "                        if VERBOSE_LOGGING and not self.training:\n",
        "\n",
        "                            assert torch.allclose(copy_probs.sum(dim=0), torch.ones_like(copy_probs.sum(dim=0))), f'copy_probs.sum(dim=0): {copy_probs.sum(dim=0)}'\n",
        "                            assert torch.allclose(pos_candidates.sum(dim=-1), torch.ones_like(pos_candidates.sum(dim=-1))), f'pos_candidates.sum(dim=-1): {pos_candidates.sum(dim=-1)}'\n",
        "\n",
        "                            prob_copy_only_all = prob_copy_only_all+1e-20\n",
        "                            copy_probs_normed = (prob_copy_only_all) / (prob_copy_only_all.sum(dim=0, keepdim=True))\n",
        "                            assert torch.allclose(copy_probs_normed.sum(dim=0), torch.ones_like(copy_probs_normed.sum(dim=0))), f'copy_probs_normed.sum(dim=0): {copy_probs_normed.sum(dim=0)}'\n",
        "                            normed_p_copy_dense = torch.einsum('tbhp,tbhs->pbhs', pos_candidates, copy_probs_normed)\n",
        "\n",
        "                            assert torch.allclose(normed_p_copy_dense.sum(dim=0), torch.ones_like(normed_p_copy_dense.sum(dim=0))), f'normed_p_copy_dense.sum(dim=0): {normed_p_copy_dense.sum(dim=0)}'\n",
        "\n",
        "                        # Fill the “no-copy’’ row (row index = P_hist)\n",
        "                        p_copy_dense_all[-1, ...] = prob_no_copy_all  # broadcast to [bs, h, T]\n",
        "\n",
        "                        # Normalize across the histogram row dimension for numerical safety\n",
        "                        denom = p_copy_dense_all.sum(0, keepdim=True) + 1e-9         # [1, bs, h, T]\n",
        "                        p_copy_dense_all = p_copy_dense_all / denom\n",
        "\n",
        "                        # For easy retrieval inside the time loop:\n",
        "                        precomputed_p_copy_list = list(p_copy_dense_all.unbind(-1))   # length T, each [P_hist+1, bs, h]\n",
        "\n",
        "            # Small helper to retrieve precomputed p_copy at time t\n",
        "            def _p_copy_at(t_idx: int):\n",
        "                return None if precomputed_p_copy_list is None else precomputed_p_copy_list[t_idx]\n",
        "\n",
        "            if True:\n",
        "                \"\"\"\n",
        "                Activation checkpointing\n",
        "                \"\"\"\n",
        "                # Toggle here if you want to test perf vs memory\n",
        "                ENABLE_RSE_UPDATE_CHECKPOINT = False  # set False to disable\n",
        "                if ENABLE_RSE_UPDATE_CHECKPOINT:\n",
        "                    # ---- CHECKPOINT WRAPPER (stateless; captures only small scalars) ----\n",
        "                    # We param-bind the bool/int to avoid retracing; tensors are passed per-step.\n",
        "                    _ckpt_hist_step = partial(\n",
        "                        lambda hist, p_reset, p_inc, p_dec, p_keep, gamma, p_copy, power_flag, seq_len_local:\n",
        "                            histogram_kernel_to_use(\n",
        "                                hist,\n",
        "                                p_reset, p_inc, p_dec, p_keep,\n",
        "                                1e-30,\n",
        "                                gamma,\n",
        "                                power_flag,\n",
        "                                seq_len=seq_len_local,\n",
        "                                p_copy=p_copy\n",
        "                            ),\n",
        "                        power_flag=True,\n",
        "                        seq_len_local=T,\n",
        "                    )\n",
        "\n",
        "                for t in range(T):\n",
        "\n",
        "\n",
        "                    assert state_prob.shape ==          (BW, bs, h), f'state_prob.shape: {state_prob.shape}'\n",
        "\n",
        "                    # print(f\"[debug, t={t}]  forKeys={keys}  cand_prob: min={cand_prob.min():.3e}  max={cand_prob.max():.3e}  mean={cand_prob.mean():.3e}\")\n",
        "                    # assert cand_prob.shape == (2, BW, bs, h), f'cand_prob.shape: {cand_prob.shape}'\n",
        "                    # cand_prob = cand_prob.view(2, bs, h)\n",
        "\n",
        "                    shifts_ = 0\n",
        "                    if incrDecrAsIndependentAdditiveGates:\n",
        "                        assert False, \"Unsupported/code path removed as of v0.660+\"\n",
        "                    else:\n",
        "                        shifts_ = 0\n",
        "\n",
        "\n",
        "                    # Build base positions for reset/no-reset in one shot\n",
        "                    state_pos_branches = state_pos\n",
        "                    assert state_pos_branches.shape == (BW, bs, h), f'state_pos_branches.shape: {state_pos_branches.shape}'\n",
        "                    state_pos_branches = state_pos_branches.unsqueeze(0)\n",
        "\n",
        "\n",
        "                    if not stochasticMatrixForResetPosBr:\n",
        "                        assert False, 'Unsupported/code path removed as of v0.660+'\n",
        "                        # assert shifts_.shape == (1, 1, bs, h) == state_pos_branches.shape, f'shifts_.shape: {shifts_.shape}, state_pos_branches.shape: {state_pos_branches.shape}'\n",
        "\n",
        "                    state_pos_branches_before_shifts = state_pos_branches.view(-1, bs, h).detach()\n",
        "                    if reset_probs_T is not None:\n",
        "                        # assert reset_probs_T.shape == (bs, h, T), f'reset_probs_T.shape: {reset_probs_T.shape}'\n",
        "                        if PERMUTE_TIME_IDX_TO_DIM_0:\n",
        "                            if SEPARATE_GATE_PROBS_TO_LISTS_BEFORE_TIMESLICES:\n",
        "                                reset_probs_t = reset_probs_list[t]\n",
        "                            else:\n",
        "                                reset_probs_t = reset_probs_T[t, :, :].contiguous()\n",
        "                            assert reset_probs_t.shape == (bs, h), f'reset_probs_t.shape: {reset_probs_t.shape}'\n",
        "                        else:\n",
        "                            reset_probs_t = reset_probs_T[:, :, t]\n",
        "                            assert reset_probs_t.shape == (bs, h), f'reset_probs_t.shape: {reset_probs_t.shape}'\n",
        "\n",
        "                        if stochasticMatrixForResetPosBr:\n",
        "\n",
        "                            if SEPARATE_GATE_PROBS_TO_LISTS_BEFORE_TIMESLICES:\n",
        "                                 # **no** view ⇒ no select_backward at all\n",
        "                                 p_incr_t, p_decr_t, p_keep_t = p_incr_list[t], p_decr_list[t], p_keep_list[t]\n",
        "                                #  assert p_incr_t.shape == (bs, h), f'p_incr_t.shape: {p_incr_t.shape}'\n",
        "                            else:\n",
        "                                if PERMUTE_TIME_IDX_TO_DIM_0:\n",
        "                                    p_incr_t, p_decr_t, p_keep_t = p_id_h[t, :, 0, :, :].unbind(0)\n",
        "                                    # gates_t = p_id_h[t, :, 0, :, :].clone()      #   1 copy, contiguous\n",
        "\n",
        "                                    # # gates_t is independent storage, so the views returned by unbind()\n",
        "                                    # # will never trigger a scatter-backward.\n",
        "                                    # p_incr_t, p_decr_t, p_keep_t = gates_t.unbind(0)   # each [bs, h]\n",
        "                                else:\n",
        "                                    p_incr_t, p_decr_t, p_keep_t = p_id_h[:, 0, :, :, t].unbind(0)\n",
        "\n",
        "                                p_incr_t = p_incr_t.contiguous()\n",
        "                                p_decr_t = p_decr_t.contiguous()\n",
        "                                p_keep_t = p_keep_t.contiguous()\n",
        "\n",
        "                            assert p_incr_t.shape == (bs, h), f'p_incr_t.shape: {p_incr_t.shape}'\n",
        "                            assert p_decr_t.shape == (bs, h), f'p_decr_t.shape: {p_decr_t.shape}'\n",
        "                            sharpen_after_pos_copy = False\n",
        "                            p_copy_t = None\n",
        "\n",
        "                            p_copy_t = None\n",
        "                            if (Position_Copying_Enabled and not for_keys):\n",
        "                                p_copy_t = _p_copy_at(t)\n",
        "                                if p_copy_t is not None:\n",
        "                                    assert p_copy_t.shape == (P_hist + 1, bs, h), f'p_copy_t.shape: {p_copy_t.shape}'\n",
        "                            assert hist.shape == (P_hist, bs, h), f'hist.shape: {hist.shape}'\n",
        "\n",
        "\n",
        "                            if Input_Dependent_Gamma_Exponents:\n",
        "                                gammas_t = gammas_all[:, t]  # [bs, h_ops]\n",
        "                            else:\n",
        "                                # gammas_t = 2.0\n",
        "                                gammas_t = gammas_all\n",
        "\n",
        "\n",
        "                            # now call with the 3D views:\n",
        "                            # grab the t'th slice from each 4D buffer:\n",
        "                            if PREALLOCED_HISTOGRAM_TENSORS:\n",
        "                                next_hist_buf_t = _hist_buf[t]   # shape [P_hist, bs, h]\n",
        "                                inc_roll_buf_t  = _inc_buf[t]\n",
        "                                dec_roll_buf_t  = _dec_buf[t]\n",
        "                                reset_buf_t = _reset_buf[t]\n",
        "                            else:\n",
        "                                next_hist_buf_t = None\n",
        "                                inc_roll_buf_t  = None\n",
        "                                dec_roll_buf_t  = None\n",
        "                                reset_buf_t = None\n",
        "\n",
        "                            if COUNT_UPDATE_FN_TOTAL_RUNTIME and GRANULAR_PROFILE:\n",
        "                                start = torch.cuda.Event(enable_timing=True)\n",
        "                                end   = torch.cuda.Event(enable_timing=True)\n",
        "\n",
        "                                torch.cuda.synchronize()\n",
        "                                start.record()\n",
        "\n",
        "\n",
        "                            if kernel_name is not None and 'dummy' in kernel_name:\n",
        "                                hist_next = histogram_kernel_to_use( # <-- for version7()\n",
        "                                        hist,\n",
        "                                        reset_probs_t, p_incr_t, p_decr_t, p_keep_t,\n",
        "                                        p_copy_t, 1e-30,\n",
        "                                        gammas_t,\n",
        "                                        not sharpen_after_pos_copy,\n",
        "                                        next_hist_buf_t,\n",
        "                                        inc_roll_buf_t,\n",
        "                                        dec_roll_buf_t\n",
        "                                    )\n",
        "                            # elif (kernel_name is not None and 'noslices_symmetric' in kernel_name) or True:\n",
        "                            elif True:\n",
        "                                if ENABLE_RSE_UPDATE_CHECKPOINT and self.training: # Grad checkpointing - default = False\n",
        "                                    # sentinel to keep all ckpt inputs tensors (older PyTorch can’t handle None)\n",
        "                                    pc = p_copy_t if (p_copy_t is not None) else hist.new_zeros(0)\n",
        "\n",
        "                                    def _step(hh, pr, pi, pd, pk, gm, pc_):\n",
        "                                        # _pcopy = None if pc_.numel() == 0 else pc_\n",
        "                                        _pcopy=None\n",
        "                                        return histogram_kernel_to_use(\n",
        "                                            hh, pr, pi, pd, pk,\n",
        "                                            1e-40, gm,\n",
        "                                            not sharpen_after_pos_copy,   # captured from the current iteration\n",
        "                                            seq_len=T,\n",
        "                                            p_copy=_pcopy\n",
        "                                        )\n",
        "\n",
        "                                    hist_next = torch.utils.checkpoint.checkpoint(\n",
        "                                        _step,\n",
        "                                        hist, reset_probs_t, p_incr_t, p_decr_t, p_keep_t, gammas_t, pc,\n",
        "                                        use_reentrant=False\n",
        "                                    )\n",
        "                                else:\n",
        "                                    hist_next = histogram_kernel_to_use(\n",
        "                                        hist,\n",
        "                                        reset_probs_t,\n",
        "                                        p_incr_t,\n",
        "                                        p_decr_t,\n",
        "                                        p_keep_t,\n",
        "                                        1e-30,\n",
        "                                        gammas_t,\n",
        "                                        not sharpen_after_pos_copy,\n",
        "                                        seq_len=T,\n",
        "                                        p_copy=p_copy_t,\n",
        "                                    )\n",
        "\n",
        "                            elif 'hist_update_step_conv' in kernel_name:\n",
        "                                assert SYMMETRIC_UPDATE_FN\n",
        "                                    # <negativePosViaSymmUpdate> with signature:\n",
        "                                    #     x:        torch.Tensor,           # [P, bs, h]\n",
