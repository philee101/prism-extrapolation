        "# # load_ckpt('backup42.pth', for_model=model_rse)\n",
        "# model_rse.to(device)\n",
        "# optimizers_dict = reinitOptimizers(wgt_decay=0, learn_r =6.2e-5, ignore_wd_for_relative_encodings=True)\n",
        "# optimizer_RSE, optimizer_baseline = optimizers_dict['rse'], optimizers_dict['baseline']"
      ],
