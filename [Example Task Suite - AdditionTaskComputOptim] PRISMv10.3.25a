      "source": [
        "# !wget -O 'backup.pt' 'https://www.dropbox.com/scl/fi/7my2gimlqaml5ac8utpb2/train-divergence-autosave_rse_20_27_28-09-25_epoch_33763_model_type-rse_train_iterations_33840.pth?rlkey=zmwg2yw671oeittfomomyhceu&dl=0'\n",
        "# load_ckpt('/content/first_run_results_after_remove_softplus_for_abs_alpha_coeff/[maxTrain30, ~12.5k iter, iter100acc@60, 94acc@80, 92acc@100].pth', model_rse)"
