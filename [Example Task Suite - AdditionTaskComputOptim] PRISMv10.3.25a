    {
      "cell_type": "markdown",
      "source": [
        "# Init Optimizers"
      ],
      "metadata": {
        "id": "RTF8vzs2Zk8v"
      }
    },
    {
      "cell_type": "markdown",
      "source": [
        "## AdamW with AdaptiveEpsilon"
      ],
      "metadata": {
        "id": "A5B9xedvl84w"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import math\n",
        "import torch\n",
        "from torch.optim.optimizer import Optimizer\n",
        "\n",
        "class AdamWAdaptiveEpsilon(Optimizer):\n",
        "    r\"\"\"Implements AdamW algorithm with a modified scaling for certain parameter groups.\n",
        "\n",
        "    This optimizer behaves like AdamW, but for any parameter group that has\n",
        "    the extra boolean parameter 'limit_avg_sq_scaling' set to True, the update is modified so that\n",
        "    the effective ratio \\(\\hat{m}/\\text{denom}\\) (where \\(\\hat{m}\\) is the bias-corrected\n",
        "    first moment and \\(\\text{denom} = \\sqrt{\\hat{v}} + \\epsilon\\)) is never larger than 1 in magnitude.\n",
        "\n",
        "    Normally, AdamW updates parameters as:\n",
        "\n",
        "        p.data -= step_size * ( \\hat{m} / (\\sqrt{\\hat{v}}+\\epsilon) )\n",
        "\n",
        "    With the modification, for parameter groups with 'limit_avg_sq_scaling'=True the denominator is replaced element-wise by:\n",
        "\n",
        "        modified_denom = torch.where( |exp_avg| > (sqrt(exp_avg_sq)+eps), |exp_avg|, (sqrt(exp_avg_sq)+eps) )\n",
        "\n",
        "    This ensures that:\n",
        "\n",
        "        |exp_avg / modified_denom| ≤ 1.\n",
        "\n",
        "    Arguments:\n",
        "        params (iterable): iterable of parameters to optimize or dicts defining parameter groups.\n",
        "            Each dict may optionally include the key 'limit_avg_sq_scaling' (default: False).\n",
        "        lr (float, optional): learning rate (default: 1e-3)\n",
        "        betas (Tuple[float, float], optional): coefficients used for computing running averages of gradient and its square (default: (0.9, 0.999))\n",
        "        eps (float, optional): term added to the denominator to improve numerical stability (default: 1e-8)\n",
        "        weight_decay (float, optional): weight decay (L2 penalty) (default: 0.01)\n",
        "        amsgrad (bool, optional): whether to use the AMSGrad variant (default: False)\n",
        "        limit_avg_sq_scaling (bool, optional): if True, limits the effective scaling of the update so that\n",
        "            |exp_avg/denom| ≤ 1 (default: False). This flag can also be set in a parameter group to override the global setting.\n",
        "    \"\"\"\n",
        "    def __init__(self, params, lr=1e-3, betas=(0.9, 0.999), eps=1e-8,\n",
        "                 weight_decay=0.01, amsgrad=False, limit_avg_sq_scaling=False, fused=True):\n",
        "        defaults = dict(lr=lr, betas=betas, eps=eps,\n",
        "                        weight_decay=weight_decay, amsgrad=amsgrad,\n",
        "                        limit_avg_sq_scaling=limit_avg_sq_scaling, fused=True)\n",
        "        super(AdamWAdaptiveEpsilon, self).__init__(params, defaults)\n",
        "\n",
        "    def step(self, closure=None):\n",
        "        \"\"\"Performs a single optimization step.\n",
        "\n",
        "        Arguments:\n",
        "            closure (callable, optional): A closure that reevaluates the model and returns the loss.\n",
        "        \"\"\"\n",
        "        loss = None\n",
        "        if closure is not None:\n",
        "            loss = closure()\n",
        "\n",
        "        for group in self.param_groups:\n",
        "            lr         = group['lr']\n",
        "            beta1, beta2 = group['betas']\n",
        "            eps        = group['eps']\n",
        "            weight_decay = group['weight_decay']\n",
        "            amsgrad    = group['amsgrad']\n",
        "            limit_scaling = group.get('limit_avg_sq_scaling', False)\n",
        "\n",
        "            for p in group['params']:\n",
        "                if p.grad is None:\n",
        "                    continue\n",
        "                grad = p.grad.data\n",
        "                if grad.is_sparse:\n",
        "                    raise RuntimeError('CustomAdamW does not support sparse gradients')\n",
        "\n",
        "                state = self.state[p]\n",
        "\n",
        "                # State initialization\n",
        "                if not state:\n",
        "                    state['step'] = 0\n",
        "                    # Exponential moving average of gradient values\n",
        "                    state['exp_avg'] = torch.zeros_like(p.data)\n",
        "                    # Exponential moving average of squared gradient values\n",
        "                    state['exp_avg_sq'] = torch.zeros_like(p.data)\n",
        "                    if amsgrad:\n",
        "                        state['max_exp_avg_sq'] = torch.zeros_like(p.data)\n",
        "\n",
        "                exp_avg, exp_avg_sq = state['exp_avg'], state['exp_avg_sq']\n",
        "                if amsgrad:\n",
        "                    max_exp_avg_sq = state['max_exp_avg_sq']\n",
        "\n",
        "                state['step'] += 1\n",
        "                step = state['step']\n",
        "\n",
        "                # Apply decoupled weight decay\n",
        "                if weight_decay != 0:\n",
        "                    p.data.add_(p.data, alpha=-weight_decay * lr)\n",
        "\n",
        "                # Update biased first and second moment estimates\n",
        "                exp_avg.mul_(beta1).add_(grad, alpha=1 - beta1)\n",
        "                exp_avg_sq.mul_(beta2).addcmul_(grad, grad, value=1 - beta2)\n",
        "\n",
        "                if amsgrad:\n",
        "                    # Maintain maximum of all 2nd moment running averages till now\n",
        "                    torch.max(max_exp_avg_sq, exp_avg_sq, out=max_exp_avg_sq)\n",
        "                    denom = max_exp_avg_sq.sqrt().add_(eps)\n",
        "                else:\n",
        "                    denom = exp_avg_sq.sqrt().add_(eps)\n",
        "\n",
        "                # Compute bias-corrected moments\n",
        "                bias_correction1 = 1 - beta1 ** step\n",
        "                bias_correction2 = 1 - beta2 ** step\n",
        "                # step_size = lr * math.sqrt(bias_correction2) / bias_correction1\n",
        "                step_size = lr * (bias_correction2 ** 0.5) / bias_correction1\n",
        "\n",
        "                if limit_scaling:\n",
        "                    # Modify the denominator element-wise such that\n",
        "                    # |exp_avg / modified_denom| ≤ 1.\n",
        "                    # If |exp_avg| is larger than the current denominator, use |exp_avg| instead.\n",
        "                    denom = torch.where(torch.abs(exp_avg) > denom, torch.abs(exp_avg), denom)\n",
        "                    # denom = (torch.abs(exp_avg) + 1e-9)\n",
        "\n",
        "                # Parameter update\n",
        "                p.data.addcdiv_(exp_avg, denom, value=-step_size)\n",
        "\n",
        "        return loss\n"
      ],
      "metadata": {
        "id": "Taczbgkwtg0w",
        "scrolled": true,
        "trusted": true,
        "execution": {
