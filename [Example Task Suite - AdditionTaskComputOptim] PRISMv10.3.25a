        "    hist_expanded = hist.unsqueeze(-1)  # [P, bs, h, 1]\n",
        "    weights_expanded = w_tensor.unsqueeze(0)  # [1, bs, h, 3]\n",
        "    hist_weighted = hist_expanded * weights_expanded  # [P, bs, h, 3]\n",
        "\n",
        "    hist_inc, hist_dec, hist_keep = hist_weighted.unbind(-1)\n",
        "\n",
        "    # ========== OPTIMIZED SHIFT OPERATIONS ==========\n",
