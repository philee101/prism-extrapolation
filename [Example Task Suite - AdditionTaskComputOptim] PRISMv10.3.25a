    {
      "cell_type": "code",
      "source": [
        "\n",
        "import re\n",
        "import os\n",
        "import random\n",
        "import numpy as np\n",
        "import torch\n",
        "from torch.utils.data import Dataset\n",
        "\n",
        "# --------------------------\n",
        "# Vocabulary Setup\n",
        "# --------------------------\n",
        "RemoveDigitHintsForMultDataset = True\n",
        "\n",
        "PAD_CHARACTER = '[PAD]'\n",
        "NEW_COLUMN_CHARACTER = '|'\n",
        "END_OF_PROBLEM_CHARACTER = '.'\n",
        "ARROW_SYMBOL = '→'  # New token to separate the chain-of-thought reasoning from the final output\n",
        "EPSILON_DIGIT = 'ε'  # used in CoT when a digit is missing\n",
        "\n",
        "\n",
        "# Base single-char tokens (PAD and ARROW are included)\n",
        "base_tokens = list('0123456789+=\\n.|*AB[]x,:') + [PAD_CHARACTER, '→', EPSILON_DIGIT]\n",
        "\n",
        "repeat_n_task_tokens = ['z','%']\n",
        "base_tokens = base_tokens + repeat_n_task_tokens\n",
        "\n",
        "# Read the SCAN file to extract unique words.\n",
        "scan_file_path = 'tasks_train_length_dl.txt'\n",
        "unique_words = set()\n",
        "unique_words_scan = set()\n",
        "if os.path.exists(scan_file_path):\n",
        "    with open(scan_file_path, 'r', encoding='utf-8') as file:\n",
        "        scan_data = file.read()\n",
        "        lines = scan_data.strip().split('\\n')\n",
        "    for line in lines:\n",
        "        # Remove \"IN:\" and \"OUT:\" markers for vocabulary extraction.\n",
        "        line = line.replace('IN:', '').replace('OUT:', '')\n",
        "        words = re.split(r'\\s+', line.strip())\n",
        "        unique_words.update(words)\n",
        "    unique_words_scan = sorted(unique_words)\n",
        "else:\n",
        "    print(f\"The file '{scan_file_path}' does not exist.\")\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "# Use these as our SCAN words.\n",
        "SCAN_WORDS = list(unique_words_scan)\n",
        "print(f'LEN of SCAN_WORDS: {len(SCAN_WORDS)}')\n",
        "\n",
        "# Construct digit->mapping tokens.\n",
        "mapping_tokens = []\n",
        "for d in range(10):\n",
        "    if d == 0:\n",
        "        mapping_tokens.append(f\"({d}->0)\")\n",
        "    else:\n",
        "        mapping_tokens.append(f\"({d}->0)\")\n",
        "        mapping_tokens.append(f\"({d}->1)\")\n",
        "\n",
        "# The full vocabulary is:\n",
        "\n",
        "vocab_tokens = base_tokens + SCAN_WORDS + mapping_tokens + ['NESTED']\n",
        "token2idx = {tok: i for i, tok in enumerate(vocab_tokens)}\n",
        "idx2token = {i: tok for tok, i in token2idx.items()}\n",
        "SCAN_WORDS_AND_NUMBERS = SCAN_WORDS + ['1', '2', '3', '4', '5', '6', '7',\n",
        "                                       '8', '9', '0', ':', 'A', 'B', 'NESTED']\n",
        "\n",
        "# Build regex patterns.\n",
        "scan_word_pattern = re.compile(r'\\b(' + '|'.join(map(re.escape, SCAN_WORDS_AND_NUMBERS)) + r')\\b')\n",
        "non_scan_word_pattern = re.compile(r'\\b(' + '|'.join(map(re.escape, base_tokens + mapping_tokens)) + r')\\b')\n",
        "mapping_tokens_sorted = sorted(mapping_tokens, key=lambda s: -len(s))\n",
        "mapping_pattern = re.compile('(' + '|'.join(re.escape(tok) for tok in mapping_tokens_sorted) + ')')\n",
        "\n",
        "# --------------------------\n",
        "# Tokenization Functions\n",
        "# --------------------------\n",
        "\n",
        "def encode_problem(problem: str, is_SCAN_problem=True) -> list:\n",
        "    \"\"\"\n",
        "    Tokenize by scanning from left to right, matching the longest known token\n",
        "    that prefixes the remaining text.  If no multi-char token is found,\n",
        "    we fall back to single-character tokens.  If still not found, error.\n",
        "    \"\"\"\n",
        "    # Optionally remove all spaces\n",
        "    problem = problem.replace(\" \", \"\")\n",
        "\n",
        "    tokens = []\n",
        "    i = 0\n",
        "    length = len(problem)\n",
        "\n",
        "    # sorted_vocab_tokens is your global or you can build it inside the function.\n",
        "    # e.g. sorted_vocab_tokens = sorted(vocab_tokens, key=len, reverse=True)\n",
        "\n",
        "    while i < length:\n",
        "        # We'll look at problem[i:] and see if it starts with any known token.\n",
        "        substring = problem[i:]\n",
        "\n",
        "        match_found = False\n",
        "\n",
        "        # 1) Try multi-char tokens first (descending length)\n",
        "        for tok in vocab_tokens:\n",
        "            if substring.startswith(tok):\n",
        "                # print(f'encoding problem, i={i}, substring={substring}, tok={tok}')\n",
        "                # matched a token\n",
        "                tokens.append(token2idx[tok])\n",
        "                i += len(tok)\n",
        "                match_found = True\n",
        "                break\n",
        "\n",
        "        if not match_found:\n",
        "            # 2) Try single-character fallback:\n",
        "            ch = substring[0]\n",
        "            if ch in token2idx:\n",
        "                tokens.append(token2idx[ch])\n",
        "                i += 1\n",
        "            else:\n",
        "                raise ValueError(f\"Unknown token/character '{ch}' at position {i}\")\n",
        "\n",
        "    return tokens\n",
        "\n",
        "\n",
        "\n",
        "def decode_problem(indices, mode='scan_dataset'):\n",
        "    tokens = [idx2token[idx] for idx in indices]\n",
        "    # Remove trailing pad tokens.\n",
        "    while tokens and tokens[-1] == PAD_CHARACTER:\n",
        "        tokens.pop()\n",
        "    if mode == 'scan_dataset':\n",
        "        return ' '.join(tokens)\n",
        "    else:\n",
        "        return ''.join(tokens)\n",
        "\n",
        "def char2idx(token: str) -> int:\n",
        "    return token2idx[token]\n",
        "\n",
        "def idx2char(idx: int) -> str:\n",
        "    return idx2token[idx]\n"
      ],
      "metadata": {
