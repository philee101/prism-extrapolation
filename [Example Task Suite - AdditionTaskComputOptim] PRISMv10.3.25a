    {
      "cell_type": "code",
      "source": [
        "import torch\n",
        "import torch.nn.functional as F\n",
        "\n",
        "@torch.compile(dynamic=False)\n",
        "def hist_update_v7_fast_bwd_mod_2_noslices_symmetric_conv(\n",
        "    hist:   torch.Tensor,         # [2*seq_len+1, bs, h]\n",
        "    p_reset: torch.Tensor,        # [bs, h]\n",
        "    p_inc:   torch.Tensor,        # [bs, h]\n",
        "    p_dec:   torch.Tensor,        # [bs, h]\n",
        "    p_keep:  torch.Tensor,        # [bs, h]\n",
        "    eps:     float,\n",
        "    gamma:   torch.Tensor | float,  # scalar or [h]\n",
        "    power:   bool,\n",
        "    seq_len: int,\n",
        "    p_copy:  torch.Tensor | None = None,  # [2*seq_len+2, bs, h] or None\n",
        "):\n",
        "    # shapes\n",
        "    L, bs, h = hist.shape\n",
        "    mid = seq_len\n",
        "\n",
        "    # 1) gates (same math as original)\n",
        "    inv_r  = 1.0 - p_reset\n",
        "    w_inc  = inv_r * p_inc\n",
        "    w_dec  = inv_r * p_dec\n",
        "    w_keep = inv_r * p_keep\n",
        "\n",
        "    # 2) 3-tap depthwise conv across position axis with ZERO padding\n",
        "    #    kernel per (b,h): [w_inc, w_keep, w_dec]\n",
        "    #    out[i] = w_inc*hist[i-1] + w_keep*hist[i] + w_dec*hist[i+1]\n",
        "    #    boundary clamping fixed below.\n",
        "    x = hist.permute(1, 2, 0).reshape(1, bs*h, L).contiguous()               # [1, bs*h, L]\n",
        "    k = torch.stack((w_inc, w_keep, w_dec), dim=-1).reshape(bs*h, 1, 3)      # [bs*h, 1, 3]\n",
        "    out = F.conv1d(x, k, bias=None, stride=1, padding=1, groups=bs*h)        # [1, bs*h, L]\n",
        "    out = out.view(bs, h, L).permute(2, 0, 1).contiguous()                   # [L, bs, h]\n",
        "\n",
        "    # 3) edge clamping fix-ups (no slicing/select; tiny)\n",
        "    #    add w_dec*hist[0] to row 0 and w_inc*hist[-1] to row L-1\n",
        "    edge_idx   = torch.tensor((0, L-1), device=hist.device)\n",
        "    hist_edges = hist.index_select(0, edge_idx)                              # [2, bs, h]\n",
        "    w_edges    = torch.stack((w_dec, w_inc), dim=0)                          # [2, bs, h]\n",
        "    out.index_add_(0, edge_idx, hist_edges * w_edges)                        # in-place OK (pre-pow)\n",
        "\n",
        "    # 4) reset triad at {mid-1, mid, mid+1} (pre-pow, still safe)\n",
        "    reset_idx  = torch.tensor((mid-1, mid, mid+1), device=hist.device)\n",
        "    reset_rows = torch.stack((p_reset * p_dec,   # −1\n",
        "                              p_reset * p_keep,  #  0\n",
        "                              p_reset * p_inc),  # +1\n",
        "                             dim=0)                                                  # [3, bs, h]\n",
        "    out.index_add_(0, reset_idx, reset_rows)\n",
        "\n",
        "    # 5) optional position copying (no slicing)\n",
        "    if p_copy is not None:\n",
        "        # p_copy: [L+1, bs, h], last row = “no copy”\n",
        "        idx_all  = torch.arange(L, device=hist.device)\n",
        "        last_idx = torch.tensor((L,), device=hist.device)\n",
        "        pos_cols = p_copy.index_select(0, idx_all)                                  # [L, bs, h]\n",
        "        no_copy  = p_copy.index_select(0, last_idx).view(bs, h)                     # [bs, h]\n",
        "        out = out * no_copy.unsqueeze(0) + pos_cols                                  # out-of-place\n",
        "\n",
        "    # 6) optional power sharpening (out-of-place → avoids PowBackward1 versioning issues)\n",
        "    if power:\n",
        "        out = (out + eps).pow(gamma)\n",
        "\n",
        "    # 7) normalize (out-of-place)\n",
        "    out = out / (out.sum(0, keepdim=True) + eps)\n",
        "    return out\n"
      ],
