    },
    {
      "cell_type": "code",
      "source": [
        "  # Transformer Model\n",
        "  # Modified CustomTransformer\n",
        "  USE_WEIGHT_TIED_EMBEDS = False\n",
        "  ABLATE_REL_ENC_ENTIRE_CLASS = False\n",
        "  ABLATE_REL_ENC_ENTIRE_FWD = False\n",
        "  ABLATE_GET_PE_VECTORS = False\n",
        "  USE_FIXED_NORM_FOR_ZEROTH_PE = False\n",
        "  ADD_STANDALONE_GRU_AT_LAYER = [1,3,5]\n",
        "\n",
        "  class CustomTransformer(nn.Module):\n",
        "\n",
        "      # CustomTransformer.init()\n",
        "      def __init__(self, vocab_size, d_model, num_heads, num_layers, d_ff, max_seq_len,\n",
        "                  model_is_rse=False, path_for_rotation_matrices=None,\n",
        "                  override_rotation_matrices=None,\n",
        "                    num_purely_content_attn_heads: int = 0,   # [MOD] new arg, for PRISM arch. only\n",
        "                  ):\n",
        "          global NUM_FIXED_KEY_RE\n",
        "\n",
        "          super(CustomTransformer, self).__init__()\n",
        "          self.embedding = nn.Embedding(vocab_size, VOCAB_N_DIM_)\n",
        "\n",
        "          self.positional_encoding = PositionalEncoding(d_model, max_seq_len)\n",
        "          self.model_is_rse = model_is_rse\n",
        "          self.pos_x_shift_relative = None\n",
        "          self.num_purely_content_attn_heads = num_purely_content_attn_heads  # [MOD]\n",
        "\n",
        "          self.max_len = max_seq_len\n",
        "          self.d_model = d_model\n",
        "\n",
        "          self.path_for_rotation_matrices = path_for_rotation_matrices\n",
        "          self.lnorm_lstm_out = nn.LayerNorm(d_model, elementwise_affine=0, bias=0)\n",
        "          self.num_layers = num_layers\n",
        "          self.num_heads = num_heads\n",
        "\n",
        "          # --- Standalone per-layer GRU(s) for residual on embeddings -------------\n",
        "          self.standalone_grus = nn.ModuleDict()\n",
        "          if ADD_STANDALONE_GRU_AT_LAYER is not None:\n",
        "              # normalise to a list of indices\n",
        "              if isinstance(ADD_STANDALONE_GRU_AT_LAYER, int):\n",
        "                  gru_layer_indices = [ADD_STANDALONE_GRU_AT_LAYER]\n",
        "              else:\n",
        "                  gru_layer_indices = list(ADD_STANDALONE_GRU_AT_LAYER)\n",
        "\n",
        "              for li in gru_layer_indices:\n",
        "                  assert 0 <= li < self.num_layers+1, f\"ADD_STANDALONE_GRU_AT_LAYER contains invalid index {li}\"\n",
        "                  # GRU maps [B, S, D] -> [B, S, D]; residual added to token_stream\n",
        "\n",
        "                  self.standalone_grus[str(li)] = nn.GRU(\n",
        "                      input_size=VOCAB_N_DIM_,\n",
        "                      hidden_size=VOCAB_N_DIM_,\n",
        "                      num_layers=1,\n",
        "                      batch_first=True,\n",
        "                      bidirectional=False\n",
        "                  )\n",
        "              self.lnorm_for_standalone_gru_in = nn.LayerNorm(VOCAB_N_DIM, elementwise_affine=1, bias=1) if not ReplaceLNWithSmoothCapIfRemoveRSE_LN else SoftCapLNorm()\n",
        "\n",
        "\n",
        "\n",
        "          if model_is_rse:\n",
        "\n",
        "              # MARK: TransformerLayerBeforeRSE\n",
        "              relative_encodings = nn.ModuleList([])\n",
        "\n",
        "              ############\n",
        "              # MARK: FixedOutput+ResetGates for >= 1 keyOperators:\n",
        "              # fixed_gate_mask: init as bool tensor equaling 1 for the first index of every operator with a repeating pattern for every NUM_QK_OPERATOR_PAIRS_PER_HEAD, zeros elsewhere:\n",
        "              # MARK: FixedOutput+ResetGates for >= 1 keyOperators\n",
        "              assert NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE % 2 == 0, f'NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE = {NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE}'\n",
        "              fixed_gate_mask = None\n",
        "              FIXED_GATES_FOR_ABS_POS_ENC_ENABLED = percentageFixedKeyRE is not None and NUM_FIXED_KEY_RE is not None and percentageFixedKeyRE > 0 and NUM_FIXED_KEY_RE > 0\n",
        "\n",
        "              if FIXED_GATES_FOR_ABS_POS_ENC_ENABLED:\n",
        "\n",
        "                  fixed_gate_mask = torch.zeros(NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE, dtype=torch.bool)\n",
        "                  skip_value_for_fixed_gates = NUM_QK_OPERATOR_PAIRS_PER_HEAD # every nth operator. Set equal to 1 for every key operator\n",
        "                  # C.f. comments for <percentageFixedKeyRE>:\n",
        "                  if NUM_FIXED_KEY_RE is not None and NUM_FIXED_KEY_RE > 0:\n",
        "                      # skip_value_for_fixed_gates : set to NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE // NUM_FIXED_KEY_RE\n",
        "                      skip_value_for_fixed_gates = (NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE // 2) // NUM_FIXED_KEY_RE\n",
        "                      print(f'[Transformer.init(): NUM_FIXED_KEY_RE={NUM_FIXED_KEY_RE}, percentageFixedKeyRE={percentageFixedKeyRE}] Setting skip_value_for_fixed_gates = {skip_value_for_fixed_gates}')\n",
        "\n",
        "                  count = 0\n",
        "                  for i in range(NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE // 2, NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE, skip_value_for_fixed_gates):\n",
        "                      fixed_gate_mask[i] = True\n",
        "                      count += 1\n",
        "                      if NUM_FIXED_KEY_RE is not None and count >= NUM_FIXED_KEY_RE:\n",
        "                          break\n",
        "\n",
        "                  if NUM_FIXED_KEY_RE is not None and count < NUM_FIXED_KEY_RE:\n",
        "                      print(f'[Transformer.init()] Warning: NUM_FIXED_KEY_RE != available count, NUM_FIXED_KEY_RE = {NUM_FIXED_KEY_RE}, count = {count}')\n",
        "                      NUM_FIXED_KEY_RE = count\n",
        "                      print(f'[Transformer.init()] ... NUM_FIXED_KEY_RE to min(available count,NUM_FIXED_KEY_RE) = {NUM_FIXED_KEY_RE}')\n",
        "                  elif NUM_FIXED_KEY_RE is not None and count > NUM_FIXED_KEY_RE:\n",
        "                      assert False, f'NUM_FIXED_KEY_RE = {NUM_FIXED_KEY_RE} > count = {count}'\n",
        "\n",
        "\n",
        "\n",
        "                  print(f'Number of fixed, absolute key RE/histograms = {fixed_gate_mask.sum()}')\n",
        "\n",
        "                  if skip_value_for_fixed_gates == NUM_QK_OPERATOR_PAIRS_PER_HEAD and not perOperatorAttnHeads and not percentageFixedKeyRE:\n",
        "                      assert sum(fixed_gate_mask) == NUM_HEADS\n",
        "\n",
        "\n",
        "              self.re_range_list_mask = re_range_list_mask\n",
        "\n",
        "              for layer_idx, maskVal in enumerate(re_range_list_mask):\n",
        "                  if not maskVal or ABLATE_REL_ENC_ENTIRE_CLASS:\n",
        "                      re = None\n",
        "                  else:\n",
        "                      re = RelativePositionEncoding(\n",
        "                                              max_seq_len, num_operators=NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE,\n",
        "                                              intermediate_dim= 192,\n",
        "                                              num_layers_per_gate=NUM_LAYERS_PER_RE_GATE,\n",
        "                                              use_lstm=pre_relative_encoding_layer_options == PRE_RELATIVE_ENCODING_LAYER_OPTIONS.gru,\n",
        "                                              fixed_gate_mask=fixed_gate_mask\n",
        "                                              )\n",
        "\n",
        "                  relative_encodings.append(re)\n",
        "              self.relative_encodings = relative_encodings\n",
        "\n",
        "\n",
        "              # Optionally label these for debugging.\n",
        "              for i, re in enumerate(self.relative_encodings):\n",
        "                  if re is not None:\n",
        "                      re.label = f'Relative_enc, layer {i}, isAdditional=False, num_operators={re.num_operators}'\n",
        "\n",
        "              self.additional_relative_encodings = nn.ModuleDict({\n",
        "                  f'layer_{i}': nn.ModuleList() for i in range(num_layers)\n",
        "              })\n",
        "              self.ledgerForAddedRelativePositionalEnc = []\n",
        "\n",
        "              # (Later, each MHA instance in the decoder layers that uses RPSE will be provided its corresponding upstream matrices.)\n",
        "          else:\n",
        "              self.relative_encodings = None\n",
        "              self.additional_relative_encodings = None\n",
        "\n",
        "          self.layers = nn.ModuleList([\n",
        "              DecoderLayer(d_model, num_heads, d_ff, dropout=ATTN_FF_OUTPUT_DROPOUT,\n",
        "                          # upstream_rotation_matrices=retrieveAll[0], layer_index=i)\n",
        "                          upstream_rotation_matrices=None,\n",
        "                          layer_index=i,\n",
        "                          num_upstream_operators=(NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE if not perOperatorAttnHeads else NUM_OPERATORS_PER_SA_LAYER),\n",
        "                          model_is_rse=model_is_rse,\n",
        "                          num_purely_content_attn_heads=num_purely_content_attn_heads\n",
        "                          )\n",
        "              for i in range(num_layers)\n",
        "          ])\n",
        "\n",
        "          for decoder in self.layers:\n",
        "              assert type(decoder.self_attn) == MultiHeadAttention_ScalarPos if self.model_is_rse else MultiHeadAttention, f'type(decoder.self_attn) = {type(decoder.self_attn)}'\n",
        "\n",
        "          if not USE_WEIGHT_TIED_EMBEDS:\n",
        "              # self.fc_out = nn.Linear(d_model, vocab_size)\n",
        "              self.fc_out = nn.Linear(VOCAB_N_DIM_, vocab_size, bias=False)\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "      def state_dict(self, *args, **kwargs):\n",
        "          \"\"\"Serialize state including the ledger\"\"\"\n",
        "          state = super().state_dict(*args, **kwargs)\n",
        "          if self.model_is_rse:\n",
        "              state[\"ledgerForAddedRelativePositionalEnc\"] = json.dumps(self.ledgerForAddedRelativePositionalEnc)  # Save as JSON string\n",
        "\n",
        "          return state\n",
        "\n",
        "      def load_state_dict(self, state_dict, strict=False):\n",
        "          \"\"\"Load state and reconstruct dynamically added relative positional encodings without infinite recursion\"\"\"\n",
        "          if \"ledgerForAddedRelativePositionalEnc\" in state_dict and self.model_is_rse:\n",
        "              loaded_ledger = json.loads(state_dict[\"ledgerForAddedRelativePositionalEnc\"])\n",
        "              del state_dict[\"ledgerForAddedRelativePositionalEnc\"]\n",
        "\n",
        "              print(f'Length of ledgerForAddedRelativePositionalEnc = {len(loaded_ledger)}')\n",
        "\n",
        "              # Clear any existing additional_relative_encodings before re-adding\n",
        "              self.additional_relative_encodings = nn.ModuleDict({\n",
        "                  f'layer_{i}': nn.ModuleList() for i in range(len(self.layers))\n",
        "              })\n",
        "              self.ledgerForAddedRelativePositionalEnc = []\n",
        "              # Reconstruct additional relative encodings from the ledger\n",
        "              for entry in loaded_ledger:\n",
        "                  self.addRelativePositionalEncWithNumOperatorsAtLayer(\n",
        "                      num_operators=entry[\"num_operators\"],\n",
        "                      layer_index=entry[\"layer_index\"],\n",
        "                      fixed_output_gates=entry[\"fixed_output_gates\"],\n",
        "                      fixed_reset_gates=entry[\"fixed_reset_gates\"],\n",
        "                      for_load=True\n",
        "                  )\n",
        "\n",
        "          sd_to_pass_to_super = state_dict.copy()\n",
        "          ret = super().load_state_dict(sd_to_pass_to_super, strict=strict)\n",
        "\n",
        "          return ret\n",
        "\n",
        "      def _pe_with_zeroed_row(self, base_pe: torch.Tensor, zpos: int) -> torch.Tensor:\n",
        "          \"\"\"\n",
        "          Return a fresh PE table identical to base_pe except row `zpos` is zero.\n",
        "          Implemented via unbind -> list replace -> stack (no in-place slice on base).\n",
        "          \"\"\"\n",
        "          key = (int(zpos), base_pe.device, base_pe.dtype)\n",
        "\n",
        "          if not hasattr(self, '_pe_zero_cache'):\n",
        "              self._pe_zero_cache = {}\n",
        "\n",
        "          cached = self._pe_zero_cache.get(key, None)\n",
        "          if cached is not None and cached.shape == base_pe.shape:\n",
        "              return cached\n",
        "\n",
        "          rows = list(torch.unbind(base_pe, dim=0))       # tuple->list of [D] tensors\n",
        "          rows[zpos] = torch.zeros_like(rows[zpos])       # replace that one row\n",
        "          out = torch.stack(rows, dim=0)                  # [L, D]\n",
        "\n",
        "          # Safe to cache because base_pe is a fixed table (no grads)\n",
        "          self._pe_zero_cache[key] = out\n",
        "          return out\n",
        "\n",
        "      @torch._dynamo.disable\n",
        "      def _standalone_rnn_fwd(self, token_stream, rnn):\n",
        "          return rnn(token_stream)\n",
        "\n",
        "      # <CustomTransformer.forward()>\n",
        "      @torch.compile(dynamic=False)\n",
        "      def forward(self, x, mask, pos_x_shift=-1):\n",
        "\n",
        "\n",
        "          if not ALLOW_X_SHIFT:\n",
        "              pos_x_shift = None\n",
        "\n",
        "          batch_size, seq_len = x.shape\n",
        "\n",
        "          if pos_x_shift == -1:\n",
        "              # print(f'pos_x_shift = -1')\n",
        "              # TODO: Generate a random offset for each batch:\n",
        "              # pos_x_shift = np.random.randint(0, max(0, MAX_SEQ_LEN-seq_len-2))\n",
        "              # Convert pos_x_shift to tensor of shape batch size, 1:\n",
        "              # pos_x_shift = torch.tensor([pos_x_shift] * batch_size, dtype=torch.long, device=x.device)\n",
        "\n",
        "              with torch.no_grad():\n",
        "                  # for b in range(batch_size):\n",
        "                  #     pos_x_shift[b] = np.random.randint(0, max(0, MAX_SEQ_LEN-seq_len-1))\n",
        "                  # Use batched randint generation using torch:\n",
        "\n",
        "                  pos_x_shift = torch.randint(1,  max(0, MAX_SEQ_LEN - seq_len-3) + 1,\n",
        "                                              (batch_size,), dtype=torch.long, device=x.device)\n",
        "                  assert pos_x_shift.shape == (batch_size,)\n",
        "                  # print(f'pos_x_shift = {pos_x_shift}')\n",
        "\n",
        "\n",
        "          with torch.no_grad():\n",
        "              if True:\n",
        "                  self.pos_x_shift_relative = pos_x_shift\n",
        "              else:\n",
        "                  self.pos_x_shift_relative = None\n",
        "\n",
        "\n",
        "\n",
        "          # Embedding\n",
        "          token_stream = self.embedding(x)\n",
        "          # Print min, max, avg norm of the initial embeddings:\n",
        "          if VERBOSE_LOGGING:\n",
        "              print(f'[CustomTransformer.forward] avg norm of initial embeddings: {torch.mean(torch.norm(token_stream, dim=-1))}, max norm = {torch.max(torch.norm(token_stream, dim=-1))}, min norm = {torch.min(torch.norm(token_stream, dim=-1))}')\n",
        "\n",
        "          if not self.model_is_rse:\n",
        "              position_stream = self.positional_encoding(x, pos_x_shift=pos_x_shift)\n",
        "              token_stream = token_stream + position_stream\n",
        "              position_stream = None\n",
        "          else:\n",
        "              position_stream = None\n",
        "\n",
        "          for rec_step in range(N_RECURRENT_STEPS):\n",
        "              current_layer_idx_since_new_re_layer = -1\n",
        "              if self.model_is_rse:\n",
        "                  re_q, re_k, re_q_prob, re_k_prob, lstm_output_q, lstm_output_k = None, None, None, None, None, None\n",
        "\n",
        "              for i, layer in enumerate(self.layers):\n",
        "\n",
        "                    current_layer_idx_since_new_re_layer += 1\n",
        "\n",
        "                    # --- Standalone GRU residual on embeddings at this layer (if configured)\n",
        "                    if str(i) in self.standalone_grus:\n",
        "\n",
        "                        if VERBOSE_LOGGING:\n",
        "                            print(f'[CustomTransformer standalone GRU] invoked at layer idx {i}')\n",
        "                        # token_stream: [B, S, D]; GRU returns output per position\n",
        "                        # gru_out, _ = self.standalone_grus[str(i)](self.lnorm_for_standalone_gru_in(token_stream))\n",
        "                        gru_out, _ = self._standalone_rnn_fwd(self.lnorm_for_standalone_gru_in(token_stream),\n",
        "                                                          self.standalone_grus[str(i)])\n",
        "                        # residual add hidden states at the same positions\n",
        "                        print_norms = True\n",
        "                        if print_norms and VERBOSE_LOGGING:\n",
        "                            print(f'[CustomTransformer standalone GRU] avg gru_out norm at layer idx {i}: {torch.mean(torch.norm(gru_out, dim=-1))}, max norm = {torch.max(torch.norm(gru_out, dim=-1))}, avg token stream norm = {torch.mean(torch.norm(token_stream, dim=-1))}, max norm = {torch.max(torch.norm(token_stream, dim=-1))}')\n",
        "\n",
        "                        token_stream = token_stream + gru_out if not ResidualStreamLN else F.layer_norm(token_stream, token_stream.shape[-1:]) + gru_out\n",
        "\n",
        "                    # Convert re_range_list_mask to python list to avoid data-dependent branching on torch tensors - slowing down torch.compile via graph breaks:\n",
        "                    range_list_mask_as_python_list = list(self.re_range_list_mask.cpu().numpy())\n",
        "\n",
        "                    # if self.model_is_rse and self.relative_encodings and i < len(self.relative_encodings) and self.re_range_list_mask[i] == True:\n",
        "                    if self.model_is_rse and self.relative_encodings and i < len(self.relative_encodings) and range_list_mask_as_python_list[i] == True:\n",
        "                        if ABLATE_REL_ENC_ENTIRE_CLASS:\n",
        "                              re_q = torch.zeros(batch_size, NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE//2, 1, 1, device=x.device)\n",
        "                              re_k = torch.zeros_like(re_q)\n",
        "                              re_q_prob = torch.zeros_like(re_q)\n",
        "                              re_k_prob = torch.zeros_like(re_q)\n",
        "                              lstm_output_q = None\n",
        "                              lstm_output_k = None\n",
        "                              lstm_output_for_value_ctx_transform = None\n",
        "                              position_stream = (re_q, re_k, re_q_prob, re_k_prob, lstm_output_q, lstm_output_k)\n",
        "\n",
        "\n",
        "                        gru_embeddings = None\n",
        "\n",
        "                        if self.relative_encodings[i] is not None:\n",
        "                            current_layer_idx_since_new_re_layer = 0\n",
        "\n",
        "                            if not ABLATE_REL_ENC_ENTIRE_FWD:\n",
        "\n",
        "                                re_q, re_k, re_q_prob, re_k_prob, lstm_output_q, lstm_output_k, lstm_output_for_value_ctx_transform, extra_data = self.relative_encodings[i](token_stream ,\n",
        "                                                                pos_x_shift_relative=pos_x_shift)\n",
        "                                gru_embeddings = extra_data[\"gru_embeddings\"]\n",
        "                                assert gru_embeddings.shape == (batch_size, seq_len, VOCAB_N_DIM)\n",
        "                                zpos = _get_zeroth_position_in_pe_table_given_seq_len(seq_len)  # index of the zeroth PE in the PE table\n",
        "\n",
        "\n",
        "                            else:\n",
        "                                re_q = torch.zeros(batch_size, num_ops//2, seq_len, seq_len+1, device=x.device)\n",
        "                                re_k = torch.zeros_like(re_q)\n",
        "                                re_q_prob = torch.zeros_like(re_q)\n",
        "                                re_k_prob = torch.zeros_like(re_q)\n",
        "                                lstm_output_q = None\n",
        "                                lstm_output_k = None\n",
        "                                lstm_output_for_value_ctx_transform = None\n",
        "\n",
        "\n",
        "                            if i > 0 and VERBOSE_LOGGING:\n",
        "                                print(f'[Transformer.forward()] rse invoked at transformerLayer {i+1}, setting position stream at this layer')\n",
        "\n",
        "                            if lstm_output_for_value_ctx_transform is not None:\n",
        "                                assert lstm_output_for_value_ctx_transform.shape == (batch_size, seq_len, VOCAB_N_DIM)\n",
        "\n",
        "                            # MARK: RelativeEncodingLSTMHiddenOutputsRelevanceEncoding\n",
        "                            if RelativeEncodingLSTMHiddenOutputsRelevanceEncoding_IS_ENABLED:\n",
        "                                num_ops = self.relative_encodings[i].num_operators\n",
        "                                assert num_ops % 2 == 0\n",
        "                                lstm_output_q_dim = lstm_output_q.shape[-1]\n",
        "                                assert lstm_output_q.shape == (batch_size, num_ops // 2, seq_len, lstm_output_q_dim)\n",
        "                                assert lstm_output_k.shape == (batch_size, num_ops // 2, seq_len, lstm_output_q_dim)\n",
        "                                # lstm_output_q = lstm_output_q.sum(dim=1)\n",
        "                                # lstm_output_k = lstm_output_k.sum(dim=1)\n",
        "\n",
        "                                # assert lstm_output.shape == (batch_size, seq_len, VOCAB_N_DIM)\n",
        "                            else:\n",
        "                                lstm_output_q = None\n",
        "                                lstm_output_k = None\n",
        "                                lstm_output_for_value_ctx_transform = None\n",
        "\n",
        "\n",
        "\n",
        "                            num_ops = self.relative_encodings[i].num_operators\n",
        "\n",
        "                            if not ABLATE_REL_ENC_ENTIRE_FWD:\n",
        "                                branches_for_re_q = re_q.shape[-1]\n",
        "                                branches_for_re_k = re_k.shape[-1]\n",
        "                                branches_for_re_q_prob = re_q_prob.shape[-1]\n",
        "                                branches_for_re_k_prob = re_k_prob.shape[-1]\n",
        "                                assert branches_for_re_q == branches_for_re_q_prob\n",
        "\n",
        "                                assert branches_for_re_k == branches_for_re_k_prob\n",
        "                                assert re_q.shape == (batch_size, num_ops//2, seq_len, branches_for_re_q), f're_q.shape = {re_q.shape}, expected {batch_size, num_ops//2, seq_len, self.d_model}'\n",
        "                                assert re_k.shape == (batch_size, num_ops//2, seq_len, branches_for_re_k), f're_k.shape = {re_k.shape}, expected {batch_size, num_ops//2, seq_len, self.d_model}'\n",
        "                                assert re_q_prob.shape == (batch_size, num_ops//2, seq_len, branches_for_re_q_prob), f're_q_prob.shape = {re_q_prob.shape}, expected {batch_size, num_ops//2, seq_len, self.d_model}'\n",
        "                                assert re_k_prob.shape == (batch_size, num_ops//2, seq_len, branches_for_re_k_prob), f're_k_prob.shape = {re_k_prob.shape}, expected {batch_size, num_ops//2, seq_len, self.d_model}'\n",
        "\n",
        "\n",
        "                    update_position_stream = self.model_is_rse and self.relative_encodings and i < len(self.relative_encodings) and self.re_range_list_mask[i] == True and self.relative_encodings[i] is not None and re_q is not None\n",
        "                    if perOperatorAttnHeads:\n",
        "                        update_position_stream = True\n",
        "                    if update_position_stream:\n",
        "                        if VERBOSE_LOGGING:\n",
        "                            print(f'[CustomTransformer.forward()] updating position stream at layer {i}, current_layer_idx_since_new_re_layer = {current_layer_idx_since_new_re_layer}, perOperatorAttnHeads = {perOperatorAttnHeads}')\n",
        "                        assert re_q is not None\n",
        "                        assert re_k is not None\n",
        "                        assert re_q_prob is not None\n",
        "                        assert re_k_prob is not None\n",
        "\n",
        "                        if not perOperatorAttnHeads:\n",
        "                            position_stream = (re_q, re_k, re_q_prob, re_k_prob, lstm_output_q, lstm_output_k)\n",
        "                        else:\n",
        "                            assert NUM_OPERATORS_PER_SA_LAYER // NUM_QK_OPERATOR_PAIRS_PER_HEAD > 0, f'NUM_OPERATORS_PER_SA_LAYER = {NUM_OPERATORS_PER_SA_LAYER}'\n",
        "                            assert (NUM_OPERATORS_PER_SA_LAYER // NUM_QK_OPERATOR_PAIRS_PER_HEAD) % 2 == 0, f'NUM_OPERATORS_PER_SA_LAYER = {NUM_OPERATORS_PER_SA_LAYER}'\n",
        "\n",
        "                            size_of_per_layer_ops_tensor = (NUM_OPERATORS_PER_SA_LAYER // 2)\n",
        "                            # idx_in_ops_tensor = i * size_of_per_layer_ops_tensor\n",
        "                            idx_in_ops_tensor = current_layer_idx_since_new_re_layer * size_of_per_layer_ops_tensor\n",
        "                            if VERBOSE_LOGGING:\n",
        "                                print(f'[CustomTransformer.forward(): perOperatorAttnHeads] idx_in_ops_tensor = {idx_in_ops_tensor}, layer idx = {i}, current_layer_idx_since_new_re_layer = {current_layer_idx_since_new_re_layer}')\n",
        "                            num_ops_half = num_ops // 2\n",
        "                            if idx_in_ops_tensor+size_of_per_layer_ops_tensor > num_ops_half or num_ops_half % size_of_per_layer_ops_tensor != 0:\n",
        "                                # idx_in_ops_tensor = num_ops_half - size_of_per_layer_ops_tensor\n",
        "\n",
        "                                assert False, f\"Number of Orperators and RE layers must be assigned evenly: the number of transformer layers <NUM_LAYERS> must be divisible by the number of RE layers given by total_num_re_layers. The re_range_list_mask must have nonzero values that are equally spaced. Set hyperparameters correctly and retry. Found size_of_per_layer_ops_tensor = {size_of_per_layer_ops_tensor}, idx_in_ops_tensor = {idx_in_ops_tensor}, num_ops_half = {num_ops_half}\"\n",
        "\n",
        "                            position_stream = (re_q[:, idx_in_ops_tensor:idx_in_ops_tensor+size_of_per_layer_ops_tensor],\\\n",
        "                                              re_k[:, idx_in_ops_tensor:idx_in_ops_tensor+size_of_per_layer_ops_tensor],\\\n",
        "                                              re_q_prob[:, idx_in_ops_tensor:idx_in_ops_tensor+size_of_per_layer_ops_tensor],\\\n",
        "                                              re_k_prob[:, idx_in_ops_tensor:idx_in_ops_tensor+size_of_per_layer_ops_tensor],\\\n",
        "                                              None, None)\n",
        "                            assert len(position_stream[0].shape) == 4, f'len(position_stream[0].shape) = {len(position_stream[0].shape)}'\n",
        "\n",
        "                            # position_stream = (re_q, re_k, lstm_output_q, lstm_output_k)\n",
        "\n",
        "\n",
        "                        if USE_SINUSOIDAL_PE and not ABLATE_GET_PE_VECTORS:\n",
        "\n",
        "                            # Build absolute PE table for this call and zero-out the zeroth PE row if needed\n",
        "                            abs_enc_with_adjusted_zeroth_pe = self.layers[0].self_attn.abs_enc  # [MAX_LEN+pad, d_model]\n",
        "\n",
        "                            if USE_LEARNABLE_ZEROTH_PE_MHA:\n",
        "                                zpos_for_len = _get_zeroth_position_in_pe_table_given_seq_len(seq_len)\n",
        "                                abs_enc_with_adjusted_zeroth_pe = self._pe_with_zeroed_row(\n",
        "                                    abs_enc_with_adjusted_zeroth_pe, zpos_for_len\n",
        "                                )\n",
        "\n",
        "                            base_ops_per_head = NUM_QK_OPERATOR_PAIRS_PER_HEAD\n",
        "                            # prob_q.shape => torch.Size([1, 5, 23, 47])\n",
        "\n",
        "                            vecs_q, vecs_k = _get_PE_encoding_vectors_fused(query=re_q,\n",
        "                                                                                              position_stream=position_stream,\n",
        "                                                                                              d_model=self.d_model,\n",
        "                                                                                              num_heads=NUM_HEADS,\n",
        "                                                                                              base_ops_per_head=base_ops_per_head,\n",
        "                                                                                              abs_enc=abs_enc_with_adjusted_zeroth_pe,\n",
        "                                                                                              positions_x_shift_relative=pos_x_shift,\n",
        "                                                                                              )\n",
        "\n",
        "                            position_stream = (vecs_q, vecs_k, lstm_output_q, lstm_output_k)\n",
        "\n",
        "                            # default position_stream (no zeroth-prob extras)\n",
        "                            # ---- NEW: append per-head zeroth-PE probabilities (after vecs_q/k exist) ----\n",
        "                            if USE_LEARNABLE_ZEROTH_PE_MHA:\n",
        "                                zpos = _get_zeroth_position_in_pe_table_given_seq_len(seq_len)  # index of the zeroth PE in the PE table\n",
        "\n",
        "                                # probabilities at zeroth-distance row, shape [B, O_total, S]\n",
        "                                p0_q = re_q_prob[:, :, :, zpos]\n",
        "                                p0_k = re_k_prob[:, :, :, zpos]\n",
        "\n",
        "                                B, O_total, S = p0_q.shape\n",
        "                                O_per_head = O_total // self.num_heads\n",
        "                                assert O_total % self.num_heads == 0, \"operators-per-head must divide evenly\"\n",
        "\n",
        "                                # reshape to per head then average across operators → [B, H, S]\n",
        "                                p0_q_h = p0_q.view(B, self.num_heads, O_per_head, S).mean(dim=2)\n",
        "                                p0_k_h = p0_k.view(B, self.num_heads, O_per_head, S).mean(dim=2)\n",
        "\n",
        "                                # extend the tuple we pass into MHA\n",
        "                                position_stream = (vecs_q, vecs_k, p0_q_h, p0_k_h, lstm_output_q, lstm_output_k)\n",
        "\n",
        "                        else:\n",
        "                            vecs_q = torch.zeros(batch_size, num_ops // 2, seq_len, self.d_model, device=x.device)\n",
        "                            vecs_k = torch.zeros_like(vecs_q)\n",
        "                            position_stream = (vecs_q, vecs_k, lstm_output_q, lstm_output_k)\n",
        "\n",
        "\n",
        "                        assert isinstance(position_stream, tuple)\n",
        "\n",
        "                        if VERBOSE_LOGGING:\n",
        "                            print(f'[CustomTransformer.forward()]: avg norm of position_stream at layer {i}: norm_of_q:\\\n",
        "                            {torch.mean(torch.norm(position_stream[0], dim=-1))},\\\n",
        "                            norm_of_k: {torch.mean(torch.norm(position_stream[1], dim=-1))},\\\n",
        "                            maximum norm q = {torch.max(torch.norm(position_stream[0], dim=-1))},\\\n",
        "                            maximum norm k = {torch.max(torch.norm(position_stream[1], dim=-1))}')\n",
        "                            # Print associated re_q_prob, re_k_prob:\n",
        "                            print(f'[CustomTransformer.forward() positionStream]: avg re_q_prob norm at layer {i}: {torch.mean(torch.norm(re_q_prob, dim=-1))},\\\n",
        "                            avg re_k_prob norm at layer {i}: {torch.mean(torch.norm(re_k_prob, dim=-1))}')\n",
        "\n",
        "\n",
        "\n",
        "                    if VERBOSE_LOGGING:\n",
        "                        print(f'avg token_stream norm at layer {i}: {torch.mean(torch.norm(token_stream, dim=-1))}, max norm = {torch.max(torch.norm(token_stream, dim=-1))}')\n",
        "\n",
        "                    if self.model_is_rse:\n",
        "                          token_stream = layer(token_stream=token_stream\n",
        "                                              , position_stream=position_stream\n",
        "                                              , mask=mask, layer_index=i,\n",
        "                                              lstm_output_for_value_context_transform=None,\n",
        "                                              valuesForInputDependentAlphaCoeffs=gru_embeddings)\n",
        "\n",
        "                          ADD_GRU_EMBEDDINGS_TO_VALUE_VECTORS = False\n",
        "                          if ADD_GRU_EMBEDDINGS_TO_VALUE_VECTORS: # <gruValueEmb>\n",
        "                              assert token_stream.shape == (batch_size, seq_len, VOCAB_N_DIM)\n",
        "                              token_stream = token_stream + gru_embeddings\n",
        "                    else:\n",
        "                          token_stream = layer(token_stream, position_stream=None, mask=mask, layer_index=i)\n",
        "\n",
        "\n",
        "          if ADD_FINAL_LOGITS_LN:\n",
        "              assert token_stream.shape == (batch_size, seq_len, VOCAB_N_DIM)\n",
        "              token_stream = F.layer_norm(token_stream, token_stream.shape[-1:])\n",
        "\n",
        "\n",
        "          # Explicitly compute logits using tied weights\n",
        "          if USE_WEIGHT_TIED_EMBEDS:\n",
        "              logits = torch.matmul(token_stream, self.embedding.weight.T)  # x: [batch_size, seq_len, d_model], embedding.weight: [vocab_size, d_model]\n",
        "          else:\n",
        "              logits = self.fc_out(token_stream)\n",
        "\n",
        "\n",
        "          return logits, token_stream\n",
        "\n"
      ],
      "metadata": {
