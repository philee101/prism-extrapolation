    {
      "cell_type": "markdown",
      "source": [
        "## Evaluate OddsFirst-DM"
      ],
      "metadata": {
        "id": "qq4m9dxUcdE6"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "def evaluate_extrapolation_odds_first(\n",
        "                                         for_model='baseline',\n",
        "                                         min_seq_len_for_dataset=1,\n",
        "                                         max_seq_len_for_dataset=5,\n",
        "                                         printOutputsAndTargets=False,\n",
        "                       examples_per_sequence=1,\n",
        "                       visualize_attn_weights=False\n",
        "                       , train_set=False, n_total_examples=100, seed=None):\n",
        "    if seed is not None:\n",
        "        set_purely_random_seed(seed)\n",
        "    else:\n",
        "        set_purely_random_seed()\n",
        "\n",
        "    print('---' * 10)\n",
        "    print(f'Evaluating on extrapolation_len={min_seq_len_for_dataset}->{max_seq_len_for_dataset}, model={for_model}')\n",
        "    print('---' * 10)\n",
        "    test_loader =  _create_dataset(for_mode='odds_first',\n",
        "                                   examples_per_sequence=1, num_total_examples=n_total_examples,\n",
        "                                batch_size=1, min_seq_len_for_dataset=min_seq_len_for_dataset,\n",
        "                                max_seq_len_for_dataset=max_seq_len_for_dataset,\n",
        "                                )\n",
        "\n",
        "    if for_model == 'rse':\n",
        "        if model_baseline is not None:\n",
        "            model_baseline.to('cpu')\n",
        "        model_rse.to(device)\n",
        "        acc = evaluate_multibatch(model_rse, test_loader, criterion, device,\n",
        "                       printOutputsAndTargets=printOutputsAndTargets,\n",
        "                       visualize_attn_example_index=0 if visualize_attn_weights else None,\n",
        "                       visualize_attn_layer_skip=1,\n",
        "\n",
        "                       )\n",
        "        print(f'accuracy for rse: {acc}')\n",
        "    else:\n",
        "        if model_rse is not None:\n",
        "            model_rse.to('cpu')\n",
        "        model_baseline.to(device)\n",
        "        acc = evaluate(model_to_use, test_loader, criterion, device,\n",
        "                       printOutputsAndTargets=printOutputsAndTargets,\n",
        "                       visualize_attn_example_index=0 if visualize_attn_weights else None,\n",
        "                       visualize_attn_layer_skip=1,\n",
        "\n",
        "                       )\n",
        "    print(f'accuracy for baseline: {acc}')\n",
        "    print('---' * 10)\n",
        "    print(f'Done Evaluating on extrapolation_len={min_seq_len_for_dataset}->{max_seq_len_for_dataset}, model={for_model}')\n",
        "    print('---' * 10)\n",
        "\n"
      ],
      "metadata": {
        "id": "h2MXezqNceqK",
        "trusted": true,
        "execution": {
