    {
      "cell_type": "code",
      "source": [
        "# Plot the distribution of token embedding norms:\n",
        "## Import matplotlib:\n",
        "import matplotlib.pyplot as plt\n",
        "## Plot:\n",
        "embeds = model_rse.embedding\n",
        "# Plot the distribution of token embedding norms:\n",
        "## Import matplotlib:\n",
        "import matplotlib.pyplot as plt\n",
        "## Plot:\n",
        "embeds = model_rse.embedding\n",
        "assert embeds.weight.shape == (VOCAB_SIZE, VOCAB_N_DIM)\n",
        "\n",
        "# Calculate the norms of the embeddings\n",
        "embedding_norms = torch.norm(embeds.weight, dim=1).detach().cpu().numpy()\n",
        "assert embedding_norms.shape == (VOCAB_SIZE,)\n",
        "\n",
        "# Create the histogram plot:\n",
        "plt.figure(figsize=(10, 6))\n",
        "plt.hist(embedding_norms, bins=10, color='skyblue', edgecolor='black')\n",
        "plt.title('Distribution of Token Embedding Norms')\n",
        "\n"
      ],
