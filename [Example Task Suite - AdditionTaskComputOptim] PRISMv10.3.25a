    {
      "cell_type": "markdown",
      "source": [
        "# visualize_latest_cached_real_positions()"
      ],
      "metadata": {
        "id": "v33vdBh_ehYi"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import matplotlib.pyplot as plt\n",
        "import matplotlib.ticker as ticker\n",
        "\n",
        "def visualize_latest_cached_real_positions(for_model, first_half=True, group_size=4):\n",
        "    if for_model is None or not for_model.model_is_rse:\n",
        "        return\n",
        "    assert for_model.model_is_rse\n",
        "    module_num = 0\n",
        "\n",
        "    # for module_ in for_model.modules():\n",
        "    for module_ in for_model.relative_encodings:\n",
        "            module_num += 1\n",
        "        # print(f'type(module_) = {type(module_)}, isinstance(module_, RelativePositionEncoding) = {isinstance(module_, RelativePositionEncoding)}')\n",
        "\n",
        "\n",
        "        # if isinstance(module_, RelativePositionEncoding) or isinstance(module_, nn.ModuleList):\n",
        "\n",
        "\n",
        "\n",
        "            if isinstance(module_, nn.ModuleList) and (len(module_) == 0 or not isinstance(module_[-1]\n",
        "                                                                                           , RelativePositionEncoding)):\n",
        "\n",
        "                print(f'len(module_) = {len(module_)}')\n",
        "                continue\n",
        "\n",
        "            if isinstance(module_, nn.ModuleList):\n",
        "                continue\n",
        "\n",
        "\n",
        "            if isinstance(module_, RelativePositionEncoding):\n",
        "                list_ = [module_]\n",
        "            else:\n",
        "                list_ = [module_]\n",
        "                # print(f'list_ = {list_}')\n",
        "\n",
        "\n",
        "            # list_ = [module_]\n",
        "\n",
        "            print(f'module_num = {module_num}')\n",
        "\n",
        "\n",
        "            for _, module in enumerate(list_):\n",
        "                if module is None:\n",
        "                    continue\n",
        "\n",
        "\n",
        "                assert hasattr(module, 'latest_cached_real_positions'), f'type(module_) == {type(module_)}'\n",
        "                # print(f'latest_cached_real_positions = {module.latest_cached_real_positions}')\n",
        "\n",
        "                if module.latest_cached_real_positions is None:\n",
        "                    print(f'module.latest_cached_real_positions is None')\n",
        "                    continue\n",
        "\n",
        "\n",
        "                # assert real_positions.shape == (self.num_operators, batch_size, seq_len)\n",
        "                # assert module.latest_cached_real_positions.shape[:2] ==\\\n",
        "                #   (module.num_operators, module.latest_cached_real_positions.shape[1])\n",
        "                # latest_cached_real_positions is the integral of the RPE's operator over the sequence index\n",
        "                # Plot the values w.r.t. sequence index, i.e. over seq-len:\n",
        "                rng = range(module.num_operators // 2) if first_half else range(module.num_operators // 2, module.num_operators)\n",
        "\n",
        "                # Draw 4 graphs at a time:\n",
        "                # group_size = 4\n",
        "                graph_number = 0\n",
        "                for subgroup in range(rng[0], rng[-1] + 1, group_size):\n",
        "\n",
        "                    graph_number += 1\n",
        "\n",
        "                    plt.figure(figsize=(10, 6))\n",
        "                    for j in range(group_size):\n",
        "                        if subgroup + j >= module.num_operators:\n",
        "                            break\n",
        "\n",
        "\n",
        "                        # Print the max sequence index:\n",
        "                        print(f'max sequence index = {module.latest_cached_real_positions.shape[1] - 1}')\n",
        "                        # plt.title(f'Latest Cached Real Positions for fixed_output_gates = {module.fixed_output_gates}, fixed_reset_gates = {module.fixed_reset_gates}, range = {rng}, RE num = {module_num}')\n",
        "                        # Include first_half:\n",
        "                        keys_or_queries = \"Query Relative Positions\" if first_half else \"Key Relative Positions\"\n",
        "                        plt.title(f'Graph {graph_number-1}, Latest Cached Real Positions, range = {rng}, RE/layer num = {module_num}, {keys_or_queries}, module_num = {module_num}')\n",
        "\n",
        "                        # for o in rng:\n",
        "                        # plt.plot(module.latest_cached_real_positions[o, :], label=f'Operator {o}')\n",
        "                        plt.plot(module.latest_cached_real_positions[subgroup + j, :], label=f'Operator {subgroup + j}')\n",
        "                        plt.xlabel('Sequence Index')\n",
        "                        plt.ylabel('Value')\n",
        "                        # plt.title(f'Latest Cached Real Positions for Operator {o}, fixed_output_gates = {module.fixed_output_gates}, fixed_reset_gates = {module.fixed_reset_gates}, range = {rng}')\n",
        "\n",
        "                        # Assign each sequence position its own tick:\n",
        "                        # plt.xticks(range(module.latest_cached_real_positions.shape[1]))\n",
        "                        ax = plt.gca()\n",
        "                        max_ticks = 20\n",
        "                        ax.xaxis.set_major_locator(\n",
        "                        ticker.MaxNLocator(nbins=max_ticks, integer=True)\n",
        "                        )\n",
        "                        # Remove scientific notation from y label:\n",
        "                        plt.ticklabel_format(axis='y', style='plain')\n",
        "                        plt.legend(bbox_to_anchor=(1.05, 1), loc='upper left')\n",
        "\n",
        "\n",
        "                        plt.grid(True)\n",
        "                        # Set y range to min an max of the data\n",
        "                        # min_of_y_data = module.latest_cached_real_positions[o, :].min().item()\n",
        "                        # max_of_y_data = module.latest_cached_real_positions[o, :].max().item()\n",
        "                        min_of_y_data = module.latest_cached_real_positions[subgroup + j, :].min().item()\n",
        "                        max_of_y_data = module.latest_cached_real_positions[subgroup + j, :].max().item()\n",
        "                        print(f'min_of_y_data = {min_of_y_data}, max_of_y_data = {max_of_y_data}')\n",
        "\n",
        "                            # plt.ylim(min_of_y_data - 0.05 * (max_of_y_data - min_of_y_data), max_of_y_data + 0.05 * (max_of_y_data - min_of_y_data))\n",
        "                    plt.show()\n",
        "visualize_latest_cached_real_positions(for_model=model_rse, first_half=True, group_size=1)\n",
        "\n",
        "if model_rse is not None:\n",
        "    assert model_rse.relative_encodings is not None and len(model_rse.relative_encodings) > 0"
      ],
      "metadata": {
        "id": "HoXlLrUQgo91",
