        "\n",
        "class BinarySwitchSTE(torch.autograd.Function):\n",
        "    \"\"\"\n",
        "    Forward:\n",
        "      out = mask * a + (1 - mask) * b,\n",
        "      where mask is binary (0 or 1).\n",
        "\n",
        "    Backward:\n",
        "      Instead of simply passing through the gradient as identity,\n",
        "      we use the derivative of a smooth surrogate:\n",
        "\n",
        "        f(a,b) = σ(α*(a-b)) * a + (1-σ(α*(a-b))) * b,\n",
        "\n",
        "      with a steepness parameter α.\n",
        "    \"\"\"\n",
        "\n",
        "    @staticmethod\n",
        "    def forward(ctx, a, b, mask):\n",
        "        # Save a, b, and mask for backward\n",
        "        ctx.save_for_backward(a, b, mask)\n",
        "        # Hard decision in forward: use the provided binary mask.\n",
        "        return mask * a + (1 - mask) * b\n",
        "\n",
        "    @staticmethod\n",
        "    def backward(ctx, grad_output):\n",
        "        a, b, mask = ctx.saved_tensors\n",
        "        alpha = 10.0  # Hyperparameter controlling the steepness\n",
        "        # Compute the surrogate soft-switch value\n",
        "        s = torch.sigmoid(alpha * (a - b))\n",
        "        # Surrogate function: f(a,b) = s * a + (1-s) * b.\n",
        "        # Its partial derivatives are:\n",
        "        grad_a = grad_output * (s + alpha * s * (1 - s) * (a - b))\n",
        "        grad_b = grad_output * ((1 - s) - alpha * s * (1 - s) * (a - b))\n",
        "        # We do not backpropagate gradients into the mask.\n",
        "        grad_mask = None\n",
        "        return grad_a, grad_b, grad_mask\n",
        "\n",
        "def binary_switch_ste(a, b, mask):\n",
        "    \"\"\"\n",
        "    Convenience wrapper for BinarySwitchSTE.\n",
        "    \"\"\"\n",
        "    return BinarySwitchSTE.apply(a, b, mask)\n"
      ],
      "metadata": {
        "id": "HAhpDpO_Wp6g",
