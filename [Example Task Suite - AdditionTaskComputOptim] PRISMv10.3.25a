        "class ClampSTE(torch.autograd.Function):\n",
        "    @staticmethod\n",
        "    def forward(ctx, x):\n",
        "        # In forward pass, clamp below at 0\n",
        "        return torch.clamp(x, min=0.0)\n",
        "\n",
        "    @staticmethod\n",
        "    def backward(ctx, grad_output):\n",
        "        # Pass gradient through as though we never clamped\n",
        "        return grad_output\n",
        "\n",
        "def clamp_ste(x):\n",
        "    \"\"\"\n",
        "    A convenient wrapper for the custom clamp STE.\n",
        "    \"\"\"\n",
        "    return ClampSTE.apply(x)\n"
      ],
      "metadata": {
        "id": "ISAWioBSAKpR",
        "scrolled": true,
