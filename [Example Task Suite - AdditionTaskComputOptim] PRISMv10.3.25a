      "cell_type": "code",
      "source": [
        "from tqdm import tqdm\n",
        "from IPython.display import clear_output\n",
        "import datetime\n",
        "\n",
        "ABLATE_AUTOSAVING = False\n",
        "\n",
        "def saveCkptForMostRecentEpoch(losses_dict, for_model, save_file_base_name):\n",
        "    if ABLATE_AUTOSAVING:\n",
        "        return\n",
        "    most_recent_epoch = get_latest_epoch_index(losses_dict, 'rse' if for_model.model_is_rse else 'baseline')\n",
        "    print(f'most_recent_epoch = {most_recent_epoch}')\n",
        "    utc_time = time.strftime(\"%H:%M:%d-%m-%y\")\n",
        "    global num_invocations_continue_training\n",
        "    train_iterations = num_invocations_continue_training\n",
        "\n",
        "    save_ckpt_name = f'autosave_{save_file_base_name}_{utc_time}_epoch_{most_recent_epoch}_model_type={\"rse\" if for_model.model_is_rse else \"baseline\"}_train_iterations_{train_iterations}'\n",
        "    torch.save(for_model.state_dict(), save_ckpt_name + '.pth')\n",
        "    print(f'AutoSaved model state dict to {save_ckpt_name}, file size in MB = {os.path.getsize(save_ckpt_name + \".pth\") / 1e6}')\n",
        "\n",
        "def remove_old_autosaved_files_earlier_than(hours_to_keep=24, in_directory=None):\n",
        "    if in_directory is None:\n",
        "        # in_directory = '/kaggle/working/'\n",
        "        in_directory = '.'\n",
        "\n",
        "    list_of_files = os.listdir(in_directory)\n",
        "    for file in list_of_files:\n",
        "        if file.startswith('autosave_'):\n",
        "            file_path = os.path.join(in_directory, file)\n",
        "            file_creation_time = os.path.getctime(file_path)\n",
        "            current_time = time.time()\n",
        "            if current_time - file_creation_time > hours_to_keep * 3600:\n",
        "                os.remove(file_path)\n",
        "                print(f\"Removed old autosaved file: {file}\")\n",
        "\n",
        "\n",
        "def continue_training(max_iterations=ITERATIONS_PER_EPOCH,\n",
        "                      num_epochs=1, optimizers_dict={},\n",
        "                      num_examples_per_batched_data=50 if BATCH_SIZE == 1 else 1,\n",
        "                      min_seq_len_for_dataset=1,\n",
        "                      max_seq_len_for_dataset=TRAIN_SEQ_LEN,\n",
        "                      examples_per_sequence=1,\n",
        "                      print_losses_every_iter=None,\n",
        "                      dataset_init_seed=None,\n",
        "                      dataset_initial_offset=0,\n",
        "                      task='token_copy',\n",
        "                      args_for_breadth_first={'max_depth': 2, 'max_children': 3},\n",
        "                      turn_off_aux_losses=False, # Set this to True only when debugging gradients for token losses\n",
        "                      min_digits_arithmetic=None,\n",
        "                      max_digits_arithmetic=None,\n",
        "                      hold_n_for_repeat_n_copy=3,\n",
        "                      ):\n",
        "\n",
        "    global num_invocations_continue_training, MODEL_EVALUATE_MODE\n",
        "    MODEL_EVALUATE_MODE = False\n",
        "\n",
        "\n",
        "    assert len(optimizers_dict) > 0, \"optimizers_dict is empty\"\n",
        "\n",
        "    batch_sz = BATCH_SIZE\n",
        "\n",
        "    if dataset_init_seed is not None:\n",
        "        set_global_seed(dataset_init_seed)\n",
        "    else:\n",
        "        set_purely_random_seed()\n",
        "\n",
        "    total_elapsed_time = 0\n",
        "\n",
        "    for epoch in range(num_epochs):\n",
        "\n",
        "        # gc.collect()\n",
        "        if num_invocations_continue_training % 100 == 0 and num_invocations_continue_training > 0:\n",
        "            torch.cuda.empty_cache()\n",
        "\n",
        "        timestamp = datetime.datetime.now()\n",
        "        dataset_abstract = _create_dataset(task,\n",
        "                                           min_digits_mult=min_digits_arithmetic,\n",
        "                                           max_digits_mult=max_digits_arithmetic,\n",
        "\n",
        "                                        max_seq_len_for_dataset=max_seq_len_for_dataset,\n",
        "                                                min_seq_len_for_dataset=min_seq_len_for_dataset,\n",
        "                                                examples_per_sequence=examples_per_sequence,\n",
        "                                        num_total_examples = num_examples_per_batched_data * batch_sz,\n",
        "                                        batch_size=batch_sz,\n",
        "                                        scan_file_path='tasks_train_length_dl.txt',\n",
        "                                        stratify_by_length=task == 'scan_dataset',\n",
        "                                           args_for_breadth_first=args_for_breadth_first,\n",
        "                                           hold_n_for_repeat_n_copy=hold_n_for_repeat_n_copy,\n",
        "\n",
        "                                        )\n",
        "\n",
        "        num_invocations_continue_training = num_invocations_continue_training + 1\n",
        "        # if num_invocations_continue_training % 25 == 0 and num_invocations_continue_training > 0:\n",
        "        #     clear_cached_sigmoid_activation_values(model_rse)\n",
        "        #     gc.collect()\n",
        "        #     torch.cuda.empty_cache()\n",
        "\n",
        "\n",
        "        print('---' * 30)\n",
        "        print(f\"Epoch {epoch+1}/{num_epochs}\")\n",
        "\n",
        "        # Rotated Adam model\n",
        "        print(\"Training RSE model with Adam optimizer...\")\n",
        "        if model_rse is not None:\n",
        "\n",
        "            # Move model_baseline IF model_baseline is defined:\n",
        "            if model_baseline is not None:\n",
        "                model_baseline.to('cpu')\n",
        "\n",
        "            model_rse.to(device)\n",
        "            _ablateREGPUStorageIfApplcbl()\n",
        "            optim_rse = optimizers_dict.get('rse', None); assert optim_rse is not None, \"optim_rse is None\"\n",
        "\n",
        "            # with torch.no_grad():\n",
        "            results = train_with_enhanced_logging(model_rse, train_dataset=dataset_abstract,\n",
        "                                                            optimizer=optim_rse,\n",
        "                                                              latest_epoch_index=epoch,\n",
        "                                                              learning_rate=None,\n",
        "                                                              losses_dict=losses_dict, model_type='rse',\n",
        "                                                        print_losses_every_iter=print_losses_every_iter,\n",
        "                                                        max_iterations=1,\n",
        "                                                        iter_offset=epoch + dataset_initial_offset,\n",
        "                                                        turn_off_aux_losses=turn_off_aux_losses,\n",
        "                                                      )\n",
        "            token_loss = results[1]\n",
        "            orthog_loss = results[2]\n",
        "            # print(f\"[Model: {'rse'}] Token Loss: {token_loss:.10f}\")\n",
        "            # Print epoch completed:\n",
        "            print(f'---' * 30)\n",
        "            print(f'---' * 30)\n",
        "            print(f\"[Model: {'RSE'}, Epoch {epoch + 1} Completed]: Token Loss: {token_loss:.15f}, max_seq_len_for_dataset = {max_seq_len_for_dataset}, orthog_loss = {orthog_loss}\")\n",
        "            print(f'---' * 30)\n",
        "            if (num_invocations_continue_training % 180 == 0) and num_invocations_continue_training > 0 and model_rse is not None:\n",
        "                    saveCkptForMostRecentEpoch(losses_dict, for_model=model_rse, save_file_base_name='rse')\n",
        "                    if (num_invocations_continue_training % 180 == 0) and num_invocations_continue_training > 0:\n",
        "                        print('Autosaving...')\n",
        "                        remove_old_autosaved_files_earlier_than(hours_to_keep=9, in_directory=None)\n",
        "\n",
        "\n",
        "\n",
        "        if model_baseline is not None:\n",
        "            # Move model_baseline IF model_baseline is defined:\n",
        "            if model_rse is not None:\n",
        "                model_rse.to('cpu')\n",
        "            model_baseline.to(device)\n",
        "\n",
        "\n",
        "            # print(\"Evaluating RSE model...\")\n",
        "            # val_loss_RSE = evaluate(model_RSE, valid_loader, losses_dict, model_type='rotated_adam')\n",
        "\n",
        "            if (num_invocations_continue_training % 180 == 0) and num_invocations_continue_training > 0 and model_baseline is not None:\n",
        "                print('Autosaving...')\n",
        "                remove_old_autosaved_files_earlier_than(hours_to_keep=9, in_directory=None)\n",
        "                saveCkptForMostRecentEpoch(losses_dict, for_model=model_baseline, save_file_base_name='baseline')\n",
        "\n",
        "\n",
        "            # Baseline model\n",
        "            optim_baseline = optimizers_dict.get('baseline', None); assert optim_baseline is not None, \"optim_baseline is None\"\n",
        "            print(\"Training Baseline model with Adam optimizer...\")\n",
        "\n",
        "            if model_rse is not None:\n",
        "                model_rse.to('cpu')\n",
        "            model_baseline.to(device)\n",
        "\n",
        "            results = train_with_enhanced_logging(model_baseline, train_dataset=dataset_abstract,\n",
        "                                                        optimizer=optim_baseline,\n",
        "                                                        latest_epoch_index=epoch,\n",
        "                                                        learning_rate=None,\n",
        "                                                        losses_dict=losses_dict, model_type='baseline',\n",
        "                                                  print_losses_every_iter=None)\n",
        "            token_loss = results[1]\n",
        "            print(f'---' * 30)\n",
        "            print(f'---' * 30)\n",
        "            print(f\"[Model: {'Baseline'}, Epoch {epoch + 1} Completed]: Token Loss: {token_loss:.10f}, max_seq_len_for_dataset = {max_seq_len_for_dataset}\")\n",
        "            print(f'---' * 30)\n",
        "\n",
        "            # print(\"Evaluating Baseline model...\")\n",
        "            # val_loss_baseline = evaluate(model_baseline, valid_loader, losses_dict, model_type='baseline')\n",
        "\n",
        "            # print(\"Evaluating Baseline model with Adam optimizer...\")\n",
        "            # val_loss_adam = evaluate(model_baseline, valid_loader, losses_dict, model_type='baseline')\n",
        "            if (num_invocations_continue_training % 90 == 0) and num_invocations_continue_training > 0:\n",
        "                    saveCkptForMostRecentEpoch(losses_dict, for_model=model_baseline, save_file_base_name='baseline_adam')\n",
        "\n",
        "\n",
        "        if num_invocations_continue_training % 30 == 0 and num_invocations_continue_training > 0:\n",
        "              clear_output(wait=True)  # Clears the previous output\n",
        "\n",
        "        if epoch % 600 == 0 and epoch > 0:\n",
        "\n",
        "            plotAll(losses_dict)\n",
        "\n",
        "        elapsed_time = datetime.datetime.now() - timestamp\n",
        "        # format as seconds:\n",
        "        elapsed_time = elapsed_time.total_seconds()\n",
        "        total_elapsed_time = total_elapsed_time + elapsed_time\n",
        "        print(f'[continue_training()] {num_invocations_continue_training} iterations completed, num seconds for iter = {elapsed_time}, avg seconds per iter = {total_elapsed_time / (epoch + 1)}')\n",
        "\n",
        "        timestamp = datetime.datetime.now()\n",
        "\n",
        "\n",
        "\n",
        "    print(\"Training completed.\")\n"
      ],
