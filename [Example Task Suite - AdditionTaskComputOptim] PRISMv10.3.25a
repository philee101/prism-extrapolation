      "cell_type": "code",
      "source": [
        "import torch\n",
        "import torch.nn.functional as F\n",
        "\n",
        "@torch.compile(dynamic=False)\n",
        "def hist_update_v7_fast_bwd_noslices_symmetric_asstrided(\n",
        "    hist:   torch.Tensor,         # [2*seq_len+1, bs, h]\n",
        "    p_reset: torch.Tensor,        # [bs, h]\n",
        "    p_inc:   torch.Tensor,        # [bs, h]\n",
        "    p_dec:   torch.Tensor,        # [bs, h]\n",
        "    p_keep:  torch.Tensor,        # [bs, h]\n",
        "    eps:     float,\n",
        "    gamma:   torch.Tensor | float,  # scalar or [h]\n",
        "    power:   bool,\n",
        "    seq_len: int,\n",
        "    p_copy:  torch.Tensor | None = None,  # [2*seq_len+2, bs, h] or None\n",
        "):\n",
        "    L, bs, h = hist.shape\n",
        "    N = bs * h\n",
        "    dt, dev = hist.dtype, hist.device\n",
        "    mid = seq_len\n",
        "\n",
        "    # Flatten once\n",
        "    hist2    = hist.view(L, N)\n",
        "    p_reset2 = p_reset.view(N)\n",
        "    inv_r2   = 1.0 - p_reset2\n",
        "\n",
        "    w_inc2  = inv_r2 * p_inc.view(N)   # [N]\n",
        "    w_dec2  = inv_r2 * p_dec.view(N)   # [N]\n",
        "    w_keep2 = inv_r2 * p_keep.view(N)  # [N]\n",
        "\n",
        "    # ---- tri-tap via zero-padded as_strided window (no index/gather/select) ----\n",
        "    # pad one row on top & bottom: [L+2, N], autograd-friendly\n",
        "    pad2 = F.pad(hist2, (0, 0, 1, 1))  # pad rows: (left,right,top,bottom)\n",
        "    # window of shape [L, N, 3] stepping along time with stride=N\n",
        "    win = pad2.as_strided(size=(L, N, 3),\n",
        "                          stride=(N, 1, N),\n",
        "                          storage_offset=0)\n",
        "\n",
        "    # Map taps: [prev, cur, next] ↔ [inc-from-prev, keep, dec-from-next]\n",
        "    w3 = torch.stack((w_inc2, w_keep2, w_dec2), dim=-1)        # [N,3]\n",
        "    out2 = (win * w3.unsqueeze(0)).sum(dim=-1)                 # [L,N]\n",
        "\n",
        "    # Add the two \"carry\" edge terms exactly as in original:\n",
        "    #   out[0]  += hist_dec[0]\n",
        "    #   out[-1] += hist_inc[-1]\n",
        "    out2.narrow(0, 0,   1).add_(hist2.narrow(0, 0,   1) * w_dec2.unsqueeze(0))\n",
        "    out2.narrow(0, L-1, 1).add_(hist2.narrow(0, L-1, 1) * w_inc2.unsqueeze(0))\n",
        "\n",
        "    # ---- Reset spikes (no index tensors) ----\n",
        "    r_m1 = (p_reset2 * p_dec.view(N)).view(1, N)   # [-1]\n",
        "    r_0  = (p_reset2 * p_keep.view(N)).view(1, N)  # [0]\n",
        "    r_p1 = (p_reset2 * p_inc.view(N)).view(1, N)   # [+1]\n",
        "    if mid > 0:\n",
        "        out2.narrow(0, mid-1, 1).add_(r_m1)\n",
        "    out2.narrow(0, mid,   1).add_(r_0)\n",
        "    if mid + 1 < L:\n",
        "        out2.narrow(0, mid+1, 1).add_(r_p1)\n",
        "\n",
        "    # ---- Optional position copying (prefer unbind over slicing) ----\n",
        "    if p_copy is not None:\n",
        "        rows = p_copy.unbind(0)     # list of L+1 tensors, each [bs,h]\n",
        "        no_copy  = rows[-1].view(1, N)         # [1,N]\n",
        "        pos_cols = torch.stack(rows[:-1], 0).view(L, N)  # [L,N]\n",
        "        out2.mul_(no_copy).add_(pos_cols)\n",
        "\n",
        "    # ---- Power & normalize in 3D so gamma [h] broadcasts cheaply ----\n",
        "    out3 = out2.view(L, bs, h)\n",
        "    if power:\n",
        "        if isinstance(gamma, torch.Tensor):\n",
        "            g = gamma.to(device=dev, dtype=dt)\n",
        "            if g.numel() == h:\n",
        "                out3 = (out3 + eps).pow(g.view(1, 1, h))\n",
        "            else:\n",
        "                out3 = (out3 + eps).pow(g)\n",
        "        else:\n",
        "            out3 = (out3 + eps).pow(gamma)\n",
        "\n",
        "    denom = out3.sum(0, keepdim=True).add_(eps)  # [1,bs,h]\n",
        "    out3 = out3 / denom\n",
        "    return out3\n"
      ],
