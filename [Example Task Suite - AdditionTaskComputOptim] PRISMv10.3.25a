        "import torch\n",
        "\n",
        "@torch.compile(dynamic=False)\n",
        "def hist_update_v7_fast_bwd_mod_2_noslices_symmetric_padstrided_softmax_v3(\n",
        "    hist:   torch.Tensor,         # [2*seq_len+1, bs, h]\n",
        "    p_reset: torch.Tensor,        # [bs, h]\n",
        "    p_inc:   torch.Tensor,        # [bs, h]\n",
        "    p_dec:   torch.Tensor,        # [bs, h]\n",
        "    p_keep:  torch.Tensor,        # [bs, h]\n",
        "    eps:     float,\n",
        "    gamma:   torch.Tensor|float,  # scalar or [h]\n",
        "    power:   bool,                # honored; when False we keep mass-preserving fast path\n",
        "    seq_len: int,\n",
        "    p_copy:  torch.Tensor|None = None,   # [2*seq_len+2, bs, h] or None\n",
        "    *,\n",
        "    pad_buf: torch.Tensor|None = None,   # optional (L+2,bs,h) prealloc\n",
        "):\n",
        "    L, bs, h = hist.shape\n",
        "    mid = seq_len\n",
        "\n",
        "    # per-(b,h) weights\n",
        "    inv_r  = 1.0 - p_reset\n",
        "    w_inc  = inv_r * p_inc\n",
        "    w_dec  = inv_r * p_dec\n",
        "    w_keep = inv_r * p_keep\n",
        "    w_inc_u  = w_inc.unsqueeze(0)    # [1,bs,h]\n",
        "    w_dec_u  = w_dec.unsqueeze(0)\n",
        "    w_keep_u = w_keep.unsqueeze(0)\n",
        "\n",
        "    # zero-padded staging\n",
        "    if pad_buf is None:\n",
        "        pad = hist.new_zeros((L + 2, bs, h))\n",
        "    else:\n",
        "        pad = pad_buf\n",
        "        pad.zero_()\n",
        "    pad.narrow(0, 1, L).copy_(hist)\n",
        "    pad[0].add_(hist[0])         # carry for dec\n",
        "    pad[L + 1].add_(hist[L-1])   # carry for inc\n",
        "\n",
        "    prev = pad.narrow(0, 0, L)   # i-1 with carry\n",
        "    curr = pad.narrow(0, 1, L)   # i\n",
        "    nxt  = pad.narrow(0, 2, L)   # i+1 with carry\n",
        "\n",
        "    # fused 3-tap mix\n",
        "    out = curr * w_keep_u\n",
        "    out = out.addcmul(prev, w_dec_u)\n",
        "    out = out.addcmul(nxt,  w_inc_u)\n",
        "\n",
        "    # reset triad (3 rows)\n",
        "    pr = p_reset\n",
        "    out[mid    ].add_(pr * p_keep)\n",
        "    if mid + 1 < L: out[mid + 1].add_(pr * p_inc)\n",
        "    if mid - 1 >= 0: out[mid - 1].add_(pr * p_dec)\n",
        "\n",
        "    # optional copy-blend\n",
        "    if p_copy is not None:\n",
        "        pos_cols, no_copy = p_copy.split([L, 1], dim=0)  # views\n",
        "        out = out * no_copy + pos_cols\n",
        "\n",
        "    if power:\n",
        "        # softmax( gamma * log(out+eps) ) along L\n",
        "        z = (out + eps).log()\n",
        "        if isinstance(gamma, torch.Tensor) and gamma.numel() == h:\n",
        "            z = z * gamma.to(device=out.device, dtype=out.dtype).view(1, 1, h)\n",
        "        else:\n",
        "            z = z * float(gamma)\n",
        "        # single fused reduction+exp kernel\n",
        "        out = torch.softmax(z, dim=0)\n",
        "        return out\n",
        "\n",
        "    # no-pow path (mass-preserving): divide by (1+eps) without a reduction\n",
        "    inv_1peps = 1.0 / (1.0 + eps)\n",
        "    out.mul_(inv_1peps)\n",
        "    return out\n"
      ],
