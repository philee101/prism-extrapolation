        "def build_target_masks_vec(batch):\n",
        "    # Vectorised multi-span mask builder (your train version, kept identical)\n",
        "    B, L = batch.shape\n",
        "    dev  = batch.device\n",
        "    eq_dense  = torch.full((B, L), False, device=dev)\n",
        "    dot_dense = torch.full((B, L), False, device=dev)\n",
        "\n",
        "    eq_pos2D  = (batch == char2idx('=')).nonzero(as_tuple=False)\n",
        "    dot_pos2D = (batch == char2idx(END_OF_PROBLEM_CHARACTER)).nonzero(as_tuple=False)\n",
        "    if eq_pos2D.numel():\n",
        "        eq_dense [eq_pos2D[:, 0], eq_pos2D[:, 1]] = True\n",
        "    if dot_pos2D.numel():\n",
        "        dot_dense[dot_pos2D[:, 0], dot_pos2D[:, 1]] = True\n",
        "\n",
        "    c_eq  = torch.cumsum(eq_dense.int(),  dim=1)\n",
        "    c_dot = torch.cumsum(dot_dense.int(), dim=1)\n",
        "    inside = (c_eq - c_dot) > 0                          # True for model timesteps [eq … dot-1]\n",
        "\n",
        "    # targets are shifted by +1 time step relative to model timesteps\n",
        "    arange_L  = torch.arange(L, device=dev).unsqueeze(0)\n",
        "    first_eq  = torch.where(eq_dense,  arange_L, L).amin(dim=1)\n",
        "    first_dot = torch.where(dot_dense, arange_L, L).amin(dim=1)\n",
        "\n",
        "    tgt_mask = (arange_L > first_eq.unsqueeze(1)) & (arange_L <= first_dot.unsqueeze(1))\n",
        "    return inside, tgt_mask   # [B,L], [B,L]\n",
        "\n",
