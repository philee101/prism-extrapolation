      "cell_type": "code",
      "source": [
        "import torch\n",
        "\n",
        "@torch.compile(dynamic=False)\n",
        "def hist_update_v7_fast_bwd_noslices_symmetric_unbind_mixmask(\n",
        "    hist:   torch.Tensor,         # [2*seq_len+1, bs, h]\n",
        "    p_reset: torch.Tensor,        # [bs, h]\n",
        "    p_inc:   torch.Tensor,        # [bs, h]\n",
        "    p_dec:   torch.Tensor,        # [bs, h]\n",
        "    p_keep:  torch.Tensor,        # [bs, h]\n",
        "    eps:     float,\n",
        "    gamma:   torch.Tensor | float, # scalar or [h]\n",
        "    power:   bool,                 # True in practice\n",
        "    seq_len: int,\n",
        "    p_copy:  torch.Tensor | None = None,   # [2*seq_len+2, bs, h] or None\n",
        "):\n",
        "    # shapes / constants\n",
        "    L, bs, h = hist.shape\n",
        "    mid = seq_len\n",
        "\n",
        "    # weights (per (b,h))\n",
        "    inv_r  = 1.0 - p_reset\n",
        "    w_inc  = inv_r * p_inc\n",
        "    w_dec  = inv_r * p_dec\n",
        "    w_keep = inv_r * p_keep\n",
        "    w_inc_u  = w_inc.unsqueeze(0)   # [1,bs,h]\n",
        "    w_dec_u  = w_dec.unsqueeze(0)\n",
        "    w_keep_u = w_keep.unsqueeze(0)\n",
        "\n",
        "    # ----- 3-tap neighbor mix with unbind/tuples (no tensor indexing ops) -----\n",
        "    rows = hist.unbind(dim=0)                   # tuple of L tensors [bs,h]\n",
        "    # carry at ends (symmetric “hold”):\n",
        "    prev_rows = (rows[0],)      + rows[:-1]     # prev[i] = rows[i-1], prev[0]=rows[0]\n",
        "    next_rows = rows[1:]        + (rows[-1],)   # next[i] = rows[i+1], next[L-1]=rows[-1]\n",
        "\n",
        "    prev = torch.stack(prev_rows, dim=0)        # [L,bs,h]\n",
        "    nxt  = torch.stack(next_rows, dim=0)        # [L,bs,h]\n",
        "\n",
        "    # FMA chain: out = hist*w_keep + prev*w_dec + nxt*w_inc\n",
        "    out = hist.mul(w_keep_u)\n",
        "    out = out.addcmul(prev, w_dec_u)\n",
        "    out = out.addcmul(nxt,  w_inc_u)\n",
        "\n",
        "    # --------------------- reset triad without indexing -----------------------\n",
        "    # Build 3 one-row masks as broadcasts (no index_add/select):\n",
        "    ar   = torch.arange(L, device=hist.device)\n",
        "    m0   = (ar ==  mid   ).view(L, 1, 1)\n",
        "    mp   = (ar == (mid+1)).view(L, 1, 1) if mid+1 < L else None\n",
        "    mm   = (ar == (mid-1)).view(L, 1, 1) if mid-1 >= 0 else None\n",
        "\n",
        "    pr = p_reset\n",
        "    # out += onehot(mid) * (pr*p_keep) + onehot(mid+1)*(pr*p_inc) + onehot(mid-1)*(pr*p_dec)\n",
        "    out = out + m0 * (pr * p_keep).unsqueeze(0)\n",
        "    if mp is not None:\n",
        "        out = out + mp * (pr * p_inc ).unsqueeze(0)\n",
        "    if mm is not None:\n",
        "        out = out + mm * (pr * p_dec ).unsqueeze(0)\n",
        "\n",
        "    # ------------------------ optional copy blend -----------------------------\n",
        "    if p_copy is not None:\n",
        "        # p_copy: [L+1,bs,h] where last row is “no-copy”\n",
        "        copy_rows = p_copy.unbind(dim=0)          # tuple length L+1\n",
        "        no_copy  = copy_rows[-1].unsqueeze(0)     # [1,bs,h]\n",
        "        pos_cols = torch.stack(copy_rows[:-1], 0) # [L,bs,h]\n",
        "        out = out * no_copy + pos_cols\n",
        "\n",
        "    # ----------------------- power + normalization ----------------------------\n",
        "    if power:\n",
        "        base = out + eps\n",
        "        if isinstance(gamma, torch.Tensor) and gamma.numel() == h:\n",
        "            out_p = torch.pow(base, gamma.view(1, 1, h))\n",
        "        else:\n",
        "            out_p = torch.pow(base, float(gamma))\n",
        "        denom = out_p.sum(dim=0, keepdim=True).add_(eps)\n",
        "        out = out_p / denom\n",
        "        return out\n",
        "\n",
        "    # mass-preserving fast path (rare for you)\n",
        "    out.mul_(1.0 / (1.0 + eps))\n",
        "    return out\n"
      ],
      "metadata": {
        "id": "i-Ght9XTcluu",
