        "\n",
        "import os\n",
        "\n",
        "if not TRAIN_BASELINE_TRANSFORMER:\n",
        "    model_rse = CustomTransformer(VOCAB_SIZE,\n",
        "                                  EMBED_SIZE, NUM_HEADS, NUM_LAYERS,\n",
        "\n",
        "                                  2048,\n",
        "\n",
        "                                  MAX_SEQ_LEN, model_is_rse=True,\n",
        "                                  num_purely_content_attn_heads=0,\n",
        "\n",
        "                                  ).to(torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\"))\n",
        "    model_rse.positional_encoding.encoding = model_rse.positional_encoding.encoding.to(torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\"))\n",
        "    model_baseline = None\n",
        "else:\n",
        "\n",
        "    model_baseline = CustomTransformer(VOCAB_SIZE, EMBED_SIZE, NUM_HEADS, NUM_LAYERS,\n",
        "                                  VOCAB_N_DIM,\n",
        "                                  MAX_SEQ_LEN, model_is_rse=False,\n",
        "      )\n",
        "    model_rse = None\n",
        "\n",
        "model_to_use = model_rse if not TRAIN_BASELINE_TRANSFORMER else model_baseline\n",
        "assert model_to_use is not None\n",
        "print(f'Total number of trainable parameters in model_to_use: {sum(p.numel() for p in model_to_use.parameters() if p.requires_grad)}')\n",
        "\n"
