      "source": [
        "## 7/9/25 - rse v0.940 - symmetric update fn / negativePosViaSymmUpdate"
      ],
      "metadata": {
        "id": "hfz4-sE21o2m"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "def _get_zeroth_position_in_pe_table_given_seq_len(seq_len: int) -> int:\n",
        "    return seq_len\n",
        "\n",
        "\n",
        "@torch.compile(dynamic=False)\n",
        "def hist_update_v7_fast_bwd_mod_2_noslices_symmetric(\n",
        "    hist:   torch.Tensor,         # [2P*seq_len+1, bs, h]\n",
        "    p_reset: torch.Tensor,        # [bs, h]\n",
        "    p_inc:   torch.Tensor,        # [bs, h]\n",
        "    p_dec:   torch.Tensor,        # [bs, h]\n",
        "    p_keep:  torch.Tensor,        # [bs, h]\n",
        "    eps:     float,\n",
        "    gamma:   torch.Tensor|float,  # scalar or [h]\n",
        "    power:   bool,\n",
        "    seq_len: int,\n",
        "    p_copy:  torch.Tensor|None = None,\n",
        "):\n",
        "    L, bs, h = hist.shape\n",
        "    # Uncomment this assertion if debugging:\n",
        "    # assert L == 2*seq_len + 1, f\"Expected length {2*seq_len+1}, got {L}\"\n",
        "    mid = seq_len # \"\"\" <=> _get_zeroth_position_in_pe_table_given_seq_len() \"\"\"\n",
        "    one = torch.ones_like(p_reset)\n",
        "\n",
        "    inv_r   = one - p_reset\n",
        "    w_inc   = inv_r * p_inc\n",
        "    w_dec   = inv_r * p_dec\n",
        "    w_keep  = inv_r * p_keep\n",
        "\n",
        "    hist_inc  = hist * w_inc.unsqueeze(0)\n",
        "    hist_dec  = hist * w_dec.unsqueeze(0)\n",
        "    hist_keep = hist * w_keep.unsqueeze(0)\n",
        "\n",
        "    zero = torch.zeros(1, bs, h, device=hist.device, dtype=hist.dtype)\n",
        "    inc_shift = torch.cat([zero, hist_inc[:-1]], dim=0)\n",
        "    inc_shift = inc_shift + torch.cat([torch.zeros_like(hist_inc[:-1]), hist_inc[-1:]], dim=0)\n",
        "    dec_shift = torch.cat([hist_dec[1:], zero], dim=0)\n",
        "    dec_shift = dec_shift + torch.cat([hist_dec[:1], torch.zeros_like(hist_dec[1:])], dim=0)\n",
        "\n",
        "    out = hist_keep + inc_shift + dec_shift\n",
        "\n",
        "    # ● Reset → three‐way\n",
        "    reset_blk = torch.zeros_like(out)\n",
        "    reset_blk[mid    ] = p_reset * p_keep       # reset+keep → 0\n",
        "    reset_blk[mid + 1] = p_reset * p_inc        # reset+inc  → +1\n",
        "    reset_blk[mid - 1] = p_reset * p_dec        # reset+decr → −1\n",
        "    out = out + reset_blk\n",
        "\n",
        "    if p_copy is not None:\n",
        "        pos_cols = p_copy[:-1]\n",
        "        no_copy  = p_copy[-1]\n",
        "        out = out * no_copy.unsqueeze(0) + pos_cols\n",
        "\n",
        "    if power:\n",
        "        out = (out + eps).pow(gamma)\n",
        "    out = out.div(out.sum(0, keepdim=True).add_(eps))\n",
        "    return out\n"
      ],
      "metadata": {
        "id": "0aaIzYB5qsV-",
        "trusted": true,
        "execution": {
