      "cell_type": "code",
      "source": [
        "import torch\n",
        "\n",
        "@torch.compile(dynamic=False)  # prefer False; it lets Inductor hard-fuse better\n",
        "def hist_update_v7_fast_bwd_mod_2_noslices_symmetric_split_softmax(\n",
        "    hist:   torch.Tensor,         # [2*seq_len+1, bs, h]\n",
        "    p_reset: torch.Tensor,        # [bs, h]\n",
        "    p_inc:   torch.Tensor,        # [bs, h]\n",
        "    p_dec:   torch.Tensor,        # [bs, h]\n",
        "    p_keep:  torch.Tensor,        # [bs, h]\n",
        "    eps:     float,\n",
        "    gamma:   torch.Tensor|float,  # scalar or [h]\n",
        "    power:   bool,\n",
        "    seq_len: int,\n",
        "    p_copy:  torch.Tensor|None = None,   # [2*seq_len+2, bs, h] or None\n",
        "):\n",
        "    L, bs, h = hist.shape\n",
        "    mid = seq_len\n",
        "    one = torch.ones_like(p_reset)\n",
        "\n",
        "    inv_r  = one - p_reset\n",
        "    w_inc  = inv_r * p_inc\n",
        "    w_dec  = inv_r * p_dec\n",
        "    w_keep = inv_r * p_keep\n",
        "\n",
        "    # weight per column, broadcast on row\n",
        "    hist_inc  = hist * w_inc.unsqueeze(0)   # [L,bs,h]\n",
        "    hist_dec  = hist * w_dec.unsqueeze(0)\n",
        "    hist_keep = hist * w_keep.unsqueeze(0)\n",
        "\n",
        "    # ---------- build ±1 shifts via split + cat (no index tensors) ----------\n",
        "    zero_row = torch.zeros(1, bs, h, device=hist.device, dtype=hist.dtype)\n",
        "\n",
        "    # +1 shift: [0; x[:-1]]  with carry x[-1] added to last row\n",
        "    inc_main, inc_last = hist_inc.split([L-1, 1], dim=0)        # views\n",
        "    inc_shift = torch.cat([zero_row, inc_main], dim=0) \\\n",
        "              + torch.cat([torch.zeros_like(inc_main), inc_last], dim=0)\n",
        "\n",
        "    # -1 shift: [x[1:]; 0]  with carry x[0] added to first row\n",
        "    dec_first, dec_rest = hist_dec.split([1, L-1], dim=0)       # views\n",
        "    dec_shift = torch.cat([dec_rest, zero_row], dim=0) \\\n",
        "              + torch.cat([dec_first, torch.zeros_like(dec_rest)], dim=0)\n",
        "\n",
        "    out = hist_keep + inc_shift + dec_shift                     # [L,bs,h]\n",
        "\n",
        "    # ---------- reset triad at rows mid-1, mid, mid+1 (const indices; fast) ----------\n",
        "    reset_blk = torch.zeros_like(out)\n",
        "    # row mid\n",
        "    reset_blk[mid] = (p_reset * p_keep)\n",
        "    # row mid+1 if exists\n",
        "    if mid + 1 < L:\n",
        "        reset_blk[mid + 1] = (p_reset * p_inc)\n",
        "    # row mid-1 if exists\n",
        "    if mid - 1 >= 0:\n",
        "        reset_blk[mid - 1] = (p_reset * p_dec)\n",
        "\n",
        "    out = out + reset_blk\n",
        "\n",
        "    # ---------- optional position-copy (use split, not tensor indexing) ----------\n",
        "    if p_copy is not None:\n",
        "        # p_copy: [L+1,bs,h] => (pos_cols[L,bs,h], no_copy[1,bs,h])\n",
        "        pos_cols, no_copy = p_copy.split([L, 1], dim=0)\n",
        "        out = out * no_copy + pos_cols\n",
        "\n",
        "    # ---------- sharpen + normalize ----------\n",
        "    if power:\n",
        "        # (out + eps)^gamma / sum(...)  == softmax(gamma * log(out+eps), dim=0)\n",
        "        if isinstance(gamma, torch.Tensor) and gamma.numel() == h:\n",
        "            g = gamma.to(device=hist.device, dtype=hist.dtype).view(1, 1, h)\n",
        "        else:\n",
        "            g = torch.as_tensor(gamma, device=hist.device, dtype=hist.dtype).view(1, 1, 1)\n",
        "        logits = torch.log(out.clamp_min(eps)) * g\n",
        "        out = torch.softmax(logits, dim=0)\n",
        "    else:\n",
        "        denom = out.sum(0, keepdim=True) + eps\n",
        "        out = out / denom\n",
        "\n",
        "    return out\n"
      ],
      "metadata": {
        "id": "WWqlAN7rCvy0",
