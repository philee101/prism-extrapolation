    {
      "cell_type": "code",
      "source": [
        "# ───────────────────────── evaluation ────────────────────────────────────\n",
        "def evaluate_multibatch(model, dataloader, criterion, device,\n",
        "             printOutputsAndTargets=False,\n",
        "             visualize_attn_example_index=None,\n",
        "             visualize_attn_layer_skip=1,\n",
        "             ):\n",
        "    \"\"\"\n",
        "    Works for arbitrary dataloader batch-sizes (B ≥ 1).\n",
        "    \"\"\"\n",
        "    model.eval()\n",
        "\n",
        "    total_correct, total_samples = 0, 0\n",
        "    total_loss_weighted = 0.0\n",
        "    total_valid_tokens  = 0\n",
        "    attn_weights_dict = {}\n",
        "\n",
        "    with torch.inference_mode(), torch.compiler.set_stance(\"force_eager\"):\n",
        "\n",
        "        with torch.no_grad():\n",
        "            for ei, batch in enumerate(dataloader):\n",
        "                batch = batch.to(device)                      # (B, S)\n",
        "                if batch.dim() == 1:                          # single example edge-case\n",
        "                    batch = batch.unsqueeze(0)                # (1, S)\n",
        "\n",
        "                B, S = batch.shape\n",
        "                if ei == 0:\n",
        "                    print(f\"(Evaluation) sample batch-size = {B}, seq_len = {S}\")\n",
        "\n",
        "                # ───── build autoregressive mask & run model ────────────────\n",
        "                tgt_mask = generate_square_subsequent_mask(S).to(device)      # (S, S)\n",
        "                outputs, _ = model(batch, tgt_mask, pos_x_shift=-1)           # (B, S, V)\n",
        "\n",
        "                # ───── capture attention maps (only once per layer) ─────────\n",
        "                for li, layer in enumerate(model.layers):\n",
        "                    entry = {}\n",
        "                    if hasattr(layer.self_attn, \"attn_weights\"):\n",
        "                        entry[\"pos\"] = layer.self_attn.attn_weights\n",
        "                    if getattr(layer, \"content_attn\", None) is not None and hasattr(layer.content_attn, \"attn_weights\"):\n",
        "                        entry[\"content\"] = layer.content_attn.attn_weights\n",
        "                    if entry:\n",
        "                        attn_weights_dict[li] = entry\n",
        "\n",
        "                if ei == 0 and visualize_attn_example_index is not None:\n",
        "                    ex_idx = visualize_attn_example_index % B\n",
        "                    print(\"visualisation example:\",\n",
        "                          decode_problem(batch[ex_idx].cpu().numpy()))\n",
        "                    visualize_attention(attn_weights_dict,\n",
        "                                        visualize_attn_example_index=ex_idx,\n",
        "                                        visualize_attn_layer_skip=visualize_attn_layer_skip, kind=\"pos\")\n",
        "                    visualize_attention(attn_weights_dict,\n",
        "                                        visualize_attn_example_index=ex_idx,\n",
        "                                        visualize_attn_layer_skip=visualize_attn_layer_skip, kind=\"content\")\n",
        "\n",
        "                # ───── token-level masks for **all** samples in the batch (vectorised) ───\n",
        "                # pred_mask: positions whose logits predict (eq … dot-1)\n",
        "                # tgt_mask_vec: positions that are the targets (eq+1 … dot)\n",
        "                pred_mask, tgt_mask_vec = build_target_masks_vec(batch)   # [B, S] each\n",
        "\n",
        "                # ─────── loss (token-wise, batch-size invariant) ──────────\n",
        "                # Select exactly-and-only the valid positions across the batch\n",
        "                logits_sel = outputs[pred_mask]                 # [N, V]\n",
        "                targs_sel  = batch [tgt_mask_vec]               # [N]\n",
        "                valid_this = int(tgt_mask_vec.sum().item())     # == pred_mask.sum()\n",
        "\n",
        "                if valid_this > 0:\n",
        "                    # criterion has reduction='mean', so weight it by #tokens\n",
        "                    batch_mean_loss = criterion(logits_sel.view(-1, VOCAB_SIZE),\n",
        "                                                targs_sel.view(-1))\n",
        "                    total_loss_weighted += batch_mean_loss.item() * valid_this\n",
        "                    total_valid_tokens  += valid_this\n",
        "\n",
        "                # ─────── accuracy (iterate sample-by-sample; unchanged) ───────────────\n",
        "                tgt_out_mask    = tgt_mask_vec\n",
        "                tgt_out_mask_lm = pred_mask\n",
        "\n",
        "                for b in range(B):\n",
        "                    mask = tgt_out_mask[b]                              # (S,)\n",
        "                    if not mask.any():\n",
        "                        continue\n",
        "\n",
        "                    seq        = batch[b]\n",
        "                    seq_logits = outputs[b]                             # (S, V)\n",
        "\n",
        "                    # build ground-truth & predictions token lists\n",
        "                    tgt_answer, pred_answer = [], []\n",
        "                    for pos in mask.nonzero(as_tuple=False).flatten():\n",
        "                        tgt_answer .append(seq[pos].item())\n",
        "                        pred_answer.append(seq_logits[pos-1])           # AR: t-1 prediction\n",
        "\n",
        "                    tgt_str      = decode_problem(tgt_answer)\n",
        "                    _, pred_idx  = torch.max(torch.stack(pred_answer), dim=-1)\n",
        "                    pred_str     = decode_problem(pred_idx.cpu().numpy())\n",
        "\n",
        "                    total_samples += 1\n",
        "                    if pred_str == tgt_str:\n",
        "                        total_correct += 1\n",
        "\n",
        "                    if printOutputsAndTargets:\n",
        "                        prompt = decode_problem(seq[:mask.nonzero()[0]].cpu().numpy())\n",
        "                        print(\"Problem :\", prompt)\n",
        "                        print(\"Predicted:\", pred_str)\n",
        "                        print(\"Expected :\", tgt_str)\n",
        "                        print(f\"correct ={pred_str == tgt_str}\\n\"\n",
        "                              f\"running-acc={total_correct/total_samples:.3f}, total_samples = {total_samples}\\n{'-'*15}\")\n",
        "\n",
        "                # quick heartbeat\n",
        "                if total_samples and total_samples % 50 == 0:\n",
        "                    print(f\"[Eval] processed {total_samples} examples — \"\n",
        "                          f\"running accuracy = {total_correct/total_samples:.3f}\")\n",
        "\n",
        "        accuracy = total_correct / max(total_samples, 1)\n",
        "        avg_loss = (total_loss_weighted / max(total_valid_tokens, 1))\n",
        "        print(f\"Evaluate: correct={total_correct}/{total_samples} \"\n",
        "              f\"({accuracy*100:.2f}%), avg-loss={avg_loss:.4f}\")\n",
        "        return accuracy * 100\n",
        "\n",
        "\n",
        "\n",
        "def evaluate(model, dataloader, criterion, device, printOutputsAndTargets=False,\n",
        "            visualize_attn_example_index=None,\n",
        "            visualize_attn_layer_skip=1,\n",
        "          ):\n",
        "    with torch.inference_mode(), torch.compiler.set_stance(\"force_eager\"):\n",
        "\n",
        "        model.eval()\n",
        "\n",
        "        total_correct = 0\n",
        "        total_samples = 0\n",
        "        accuracy = 0.0\n",
        "        attn_weights_dict = {}\n",
        "        total_loss = 0\n",
        "\n",
        "\n",
        "        with torch.no_grad():\n",
        "            # print(f'Dataloader shape = {dataloader.dataset.batches[0].shape}')\n",
        "\n",
        "            for ei, batch in enumerate(dataloader):\n",
        "                batch = batch.to(device)\n",
        "                batch = batch.squeeze(0)\n",
        "\n",
        "\n",
        "                if len(batch.shape) == 1:\n",
        "                    batch = batch.unsqueeze(0)\n",
        "                assert len(batch.shape) == 2\n",
        "                batch_size = batch.shape[0]\n",
        "                assert(batch.shape[0] == 1)\n",
        "\n",
        "                print(f'evaluate(): batch.shape = {batch.shape}')\n",
        "                if ei == 0:\n",
        "                    print('(Evaluation: Sample seq length = %d)' % (batch.shape[1]))\n",
        "\n",
        "                # assert(BATCH_SIZE == 1)\n",
        "\n",
        "                # if batch[0, 0] == END_OF_PROBLEM_CHARACTER:\n",
        "                #   batch = batch[0, 1:]\n",
        "\n",
        "                equals_pos = (batch == char2idx('=')).nonzero(as_tuple=True)[1]\n",
        "                period_pos = (batch == char2idx(END_OF_PROBLEM_CHARACTER)).nonzero(as_tuple=True)[1]\n",
        "\n",
        "                if period_pos[0] == 0:\n",
        "                    period_pos = period_pos[1:]\n",
        "                    # print(f'advanced period_pos = {period_pos}')\n",
        "\n",
        "                    # equals_pos = equals_pos[1:]\n",
        "\n",
        "                # assert(period_pos.shape[-1] == dataloader.dataset.examples_per_sequence)\n",
        "                # assert(equals_pos.shape[-1] == dataloader.dataset.examples_per_sequence)\n",
        "\n",
        "                tgt_mask = generate_square_subsequent_mask(batch.size(1)).to(device)\n",
        "                # print(f'batch.shape = {batch.shape}')\n",
        "                outputs, _ = model(batch, tgt_mask, pos_x_shift=-1)\n",
        "\n",
        "\n",
        "                # Collect attention weights for visualization\n",
        "                # for li,layer in enumerate(model.layers):\n",
        "                #     if hasattr(layer.self_attn, 'attn_weights'):\n",
        "                #         attn_weights_dict[li] = layer.self_attn.attn_weights\n",
        "                #         print(f'evaluate(): len(attn_weights_dict[{li}]) = {len(attn_weights_dict[li])}')\n",
        "                for li, layer in enumerate(model.layers):\n",
        "                    entry = {}\n",
        "                    if hasattr(layer.self_attn, \"attn_weights\"):\n",
        "                        entry[\"pos\"] = layer.self_attn.attn_weights\n",
        "                    if getattr(layer, \"content_attn\", None) is not None and hasattr(layer.content_attn, \"attn_weights\"):\n",
        "                        entry[\"content\"] = layer.content_attn.attn_weights\n",
        "                    if entry:\n",
        "                        attn_weights_dict[li] = entry\n",
        "\n",
        "\n",
        "                # Visualize attention weights if specified\n",
        "                if ei == 0:\n",
        "                  if visualize_attn_example_index is not None:\n",
        "                      print('visualization example = ', decode_problem(batch[:,:][0].cpu().numpy()))\n",
        "                      print('equals sign positions: ', equals_pos)\n",
        "                      print('------')\n",
        "                      print('problem delimiter positions: ', period_pos)\n",
        "                      visualize_attention(attn_weights_dict, visualize_attn_example_index=visualize_attn_example_index,\n",
        "                                          visualize_attn_layer_skip=visualize_attn_layer_skip)\n",
        "\n",
        "                      # [ADD - RSEv0.99999-bench-v3.1]]  content-head visualization when present\n",
        "                      content_heads_global = 0\n",
        "                      for lyr in model.layers:\n",
        "                          if getattr(lyr, \"content_attn\", None) is not None:\n",
        "                              content_heads_global = int(lyr.content_attn.num_heads)\n",
        "                              break\n",
        "\n",
        "                      if content_heads_global > 0:\n",
        "                          visualize_attention(attn_weights_dict,\n",
        "                                              visualize_attn_example_index=ex_idx,\n",
        "                                              visualize_attn_layer_skip=visualize_attn_layer_skip,\n",
        "                                              kind=\"content\",\n",
        "                                              num_heads_override=content_heads_global)\n",
        "\n",
        "                # Print full problem:\n",
        "                # print(f'evaluate(): full example = {decode_problem(batch[0, :].cpu().numpy())}')\n",
        "                tgt_output_indxs = np.zeros(batch[:, :].shape[1], dtype=np.bool_)\n",
        "                tgt_output_indxs_model = np.zeros(batch[:, :].shape[1], dtype=np.bool_)  # lagged one position behind for AR LM loss\n",
        "                for i in range(len(equals_pos)):\n",
        "                    eq_pos = equals_pos[i]\n",
        "                    period_p = period_pos[i]\n",
        "                    assert(period_p > eq_pos)\n",
        "                    for j in range(eq_pos, period_p):\n",
        "                        tgt_output_indxs[j+1] = True\n",
        "                        tgt_output_indxs_model[j] = True\n",
        "\n",
        "                tgt_output_for_loss_calc = batch[:, tgt_output_indxs]\n",
        "                outputs_for_loss_calc = outputs[:, tgt_output_indxs_model]\n",
        "\n",
        "                token_loss = criterion(outputs_for_loss_calc.view(-1, VOCAB_SIZE), tgt_output_for_loss_calc.contiguous().view(-1))\n",
        "                total_loss += token_loss.item()\n",
        "\n",
        "                scanningAnswer = False\n",
        "                curPromptStr = []\n",
        "\n",
        "                for j in range(len(tgt_output_indxs)):\n",
        "                    if True and j-1 >= 0:\n",
        "                        curPromptStr.append(batch[0, j-1].item())\n",
        "\n",
        "                    if not scanningAnswer and tgt_output_indxs[j]:\n",
        "                        scanningAnswer = True\n",
        "\n",
        "                        next_answer, pred_answer = [], []\n",
        "                        k = j\n",
        "                        while True:\n",
        "                            if not tgt_output_indxs[k]:\n",
        "                                break\n",
        "\n",
        "                            next_answer.append(batch[0, k].item())\n",
        "                            pred_answer.append(outputs[0, k-1].cpu())\n",
        "                            k += 1\n",
        "                            if k >= len(tgt_output_indxs):\n",
        "                                break\n",
        "\n",
        "                    if scanningAnswer and (not tgt_output_indxs[j] or j == len(tgt_output_indxs)-1):\n",
        "\n",
        "                        scanningAnswer = False\n",
        "                        total_samples += 1\n",
        "                        _, predicted = torch.max(torch.tensor(np.array(pred_answer, dtype=np.int32)), dim=-1)\n",
        "                        pred_str = decode_problem(predicted[:].numpy())\n",
        "                        tgt_str = decode_problem(next_answer[:])\n",
        "                        if j == len(tgt_output_indxs)-1:\n",
        "                            assert(tgt_str[-1] == '.')\n",
        "                        if pred_str == tgt_str:\n",
        "                            total_correct += 1\n",
        "                        if printOutputsAndTargets:\n",
        "                          # print('Whole batch = ', decode_problem(batch[0].cpu().numpy()))\n",
        "                          assert(not NEW_COLUMN_CHARACTER in curPromptStr)\n",
        "                          print('Problem: ', decode_problem(curPromptStr))\n",
        "                          print('-----\\nPredicted: %s\\n---\\nExpected = %s\\ncorrect=%d' % (pred_str,\n",
        "                                                                                          tgt_str,\n",
        "                                                                                          pred_str == tgt_str))\n",
        "                          # pretty_print_alignment(pred_str, tgt_str)\n",
        "                          print('-----\\n')\n",
        "                          print(f'Current accuracy = {total_correct / total_samples}, total_samples = {total_samples}, current iteration = {ei}')\n",
        "                          print('---------------')\n",
        "                        accuracy = total_correct / total_samples\n",
        "                        if total_samples % 50 == 0:\n",
        "                          print('Eval batch %d: current accuracy: %.3f' % (total_samples,accuracy))\n",
        "\n",
        "                        curPromptStr = []\n",
        "\n",
        "        print(f'Evaluate: num correct = {total_correct}, total_samples = {total_samples}')\n",
        "        print(f\"Accuracy: {accuracy * 100:.2f}%\")\n",
        "        print(f'Len dataloader = {len(dataloader)}')\n",
        "        print(f\"Avg Loss: {total_loss / len(dataloader)}\")\n",
        "        return accuracy * 100\n"
      ],
