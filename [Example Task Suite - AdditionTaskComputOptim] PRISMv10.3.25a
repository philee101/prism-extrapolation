    {
      "cell_type": "code",
      "source": [
        "if perOperatorAttnHeads:\n",
        "    print(f'NUM_LAYERS = {NUM_LAYERS}')\n",
        "    print(f'NUM_OPERATORS_PER_SA_LAYER = {NUM_OPERATORS_PER_SA_LAYER}')\n",
        "    print(f'NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE = {NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE}')\n",
        "    TOTAL_OPERATORS = NUM_OPERATORS_PER_SA_LAYER * NUM_LAYERS\n",
        "    print(f'TOTAL OPERATORS = {TOTAL_OPERATORS}')\n",
        "    assert TOTAL_OPERATORS == NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE * total_num_re_layers, f'TOTAL_OPERATORS = {TOTAL_OPERATORS}, NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE = {NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE}'\n",
        "    print(f'NUM_HEADS = {NUM_HEADS}')\n",
        "    size_of_per_layer_ops_tensor = (NUM_OPERATORS_PER_SA_LAYER // 2)\n",
        "    print(f'size_of_per_layer_ops_tensor = {size_of_per_layer_ops_tensor}')"
      ],
      "metadata": {
        "id": "rnDPLJKutmdH",
        "trusted": true
      },
      "outputs": [],
