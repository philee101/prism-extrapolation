      "cell_type": "code",
      "source": [
        "# 8.30.25:\n",
        "import torch\n",
        "import torch.nn.functional as F\n",
        "\n",
        "import torch\n",
        "import torch.nn.functional as F\n",
        "\n",
        "@torch.compile(dynamic=False)\n",
        "def hist_update_v7_fast_bwd_mod_2_noslices_symmetric_gather(\n",
        "    hist:   torch.Tensor,         # [2*seq_len+1, bs, h]\n",
        "    p_reset: torch.Tensor,        # [bs, h]\n",
        "    p_inc:   torch.Tensor,        # [bs, h]\n",
        "    p_dec:   torch.Tensor,        # [bs, h]\n",
        "    p_keep:  torch.Tensor,        # [bs, h]\n",
        "    eps:     float,\n",
        "    gamma:   torch.Tensor | float,  # scalar or [h]\n",
        "    power:   bool,\n",
        "    seq_len: int,\n",
        "    p_copy:  torch.Tensor | None = None,  # [2*seq_len+2, bs, h] or None\n",
        "):\n",
        "    L, bs, h = hist.shape\n",
        "    mid = seq_len\n",
        "    dev = hist.device\n",
        "\n",
        "    one   = torch.ones_like(p_reset)\n",
        "    inv_r = one - p_reset\n",
        "\n",
        "    # weights\n",
        "    w_inc  = inv_r * p_inc\n",
        "    w_dec  = inv_r * p_dec\n",
        "    w_keep = inv_r * p_keep\n",
        "\n",
        "    # scale once\n",
        "    hist_keep = hist * w_keep.unsqueeze(0)\n",
        "    hist_inc  = hist * w_inc.unsqueeze(0)\n",
        "    hist_dec  = hist * w_dec.unsqueeze(0)\n",
        "\n",
        "    # build source-row indices for each destination row (time-invariant, hoisted by Inductor)\n",
        "    ar = torch.arange(L, device=dev)\n",
        "    src_for_inc = torch.clamp(ar - 1, min=0)          # dest i ← src i-1 (clamped at 0)\n",
        "    src_for_dec = torch.clamp(ar + 1, max=L - 1)      # dest i ← src i+1 (clamped at L-1)\n",
        "\n",
        "    idx_exp_inc = src_for_inc.view(L, 1, 1).expand(L, bs, h)\n",
        "    idx_exp_dec = src_for_dec.view(L, 1, 1).expand(L, bs, h)\n",
        "\n",
        "    # shift via gather (single read kernel each)\n",
        "    inc_shift = hist_inc.gather(0, idx_exp_inc)       # wrap-free (already clamped)\n",
        "    dec_shift = hist_dec.gather(0, idx_exp_dec)\n",
        "\n",
        "    # edge corrections to match your “clamped+add” semantics:\n",
        "    #   inc: add hist_inc[-1] again to last row and remove the accidental hist_inc[0] at row 0\n",
        "    #   dec: add hist_dec[0]  again to first row and remove the accidental hist_dec[-1] at row L-1\n",
        "    out = hist_keep + inc_shift + dec_shift\n",
        "\n",
        "    i0   = torch.tensor((0,),    device=dev)\n",
        "    iL1  = torch.tensor((L - 1,), device=dev)\n",
        "\n",
        "    inc_first = hist_inc.index_select(0, i0).squeeze(0)   # [bs,h]\n",
        "    inc_last  = hist_inc.index_select(0, iL1).squeeze(0)  # [bs,h]\n",
        "    dec_first = hist_dec.index_select(0, i0).squeeze(0)   # [bs,h]\n",
        "    dec_last  = hist_dec.index_select(0, iL1).squeeze(0)  # [bs,h]\n",
        "\n",
        "    # out[0] -= inc_first;  out[L-1] += inc_last\n",
        "    out.index_add_(0, torch.tensor((0, L - 1), device=dev),\n",
        "                   torch.stack((-inc_first, inc_last), dim=0))\n",
        "    # out[L-1] -= dec_last; out[0]   += dec_first\n",
        "    out.index_add_(0, torch.tensor((L - 1, 0), device=dev),\n",
        "                   torch.stack((-dec_last,  dec_first), dim=0))\n",
        "\n",
        "    # reset triad (pre-pow, still safe)\n",
        "    reset_idx  = torch.tensor((mid - 1, mid, mid + 1), device=dev)\n",
        "    reset_rows = torch.stack((p_reset * p_dec,   # −1\n",
        "                              p_reset * p_keep,  #  0\n",
        "                              p_reset * p_inc),  # +1\n",
        "                             dim=0)  # [3,bs,h]\n",
        "    out.index_add_(0, reset_idx, reset_rows)\n",
        "\n",
        "    # optional position copying\n",
        "    if p_copy is not None:\n",
        "        idx_all  = torch.arange(L, device=dev)\n",
        "        last_idx = torch.tensor((L,), device=dev)\n",
        "        pos_cols = p_copy.index_select(0, idx_all)                  # [L, bs, h]\n",
        "        no_copy  = p_copy.index_select(0, last_idx).view(bs, h)     # [bs, h]\n",
        "        out = out * no_copy.unsqueeze(0) + pos_cols                 # out-of-place\n",
        "\n",
        "    # optional sharpening (out-of-place)\n",
        "    if power:\n",
        "        out = (out + eps).pow(gamma)\n",
        "\n",
        "    # normalize (out-of-place)\n",
        "    out = out / (out.sum(0, keepdim=True) + eps)\n",
        "    return out\n"
      ],
