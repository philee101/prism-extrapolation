    {
      "cell_type": "code",
      "source": [
        "from matplotlib.ticker import LogLocator\n",
        "\n",
        "def appendHyperParamsToTitle(title):\n",
        "        # ret = f'{title}, lr = {LEARNING_R}, embed_size = {embed_size}, num_heads = {num_heads}, num_layers = {num_layers}, max_seq_len = {MAX_SEQ_LEN}, beta1 = {beta1}, beta2 = {beta2}, vocab_size = {VOCAB_SIZE}, weight_tie_unembed = {WEIGHT_TIE_UNEMBED}, reset_baseline_adam_optim_second_moments_every_tracker_update_interval = {RESET_BASELINE_ADAM_OPTIM_SECOND_MOMENTS_EVERY_TRACKER_UPDATE_INTERVAL}'\n",
        "        # include bs:\n",
        "        ret = f'{title}, lr = {None}, embed_size = {EMBED_SIZE}, num_heads = {NUM_HEADS}, num_layers = {NUM_LAYERS}'\n",
        "        return ret\n",
        "\n",
        "\n",
        "\n",
        "from matplotlib.ticker import LogLocator, ScalarFormatter\n",
        "\n",
        "def plot_wall_clock_times(losses_dict, title='Loss vs Wall-Clock Time', logTransform=False, precision=0):\n",
        "    # Extract wall-clock time and losses\n",
        "    times_RSE = losses_dict['wall_clock_time_RSE']\n",
        "    train_losses_RSE = convertTupleListIntoLossesList(losses_dict['train_losses_RSE'])\n",
        "    times_baseline = losses_dict['wall_clock_time_baseline']\n",
        "    train_losses_baseline = convertTupleListIntoLossesList(losses_dict['train_losses_baseline'])\n",
        "\n",
        "    # Plot the losses w.r.t. wall-clock time\n",
        "    plt.figure(figsize=(12, 6))  # Set rectangular aspect ratio\n",
        "    fig, ax = plt.subplots(figsize=(12, 6))  # Ensure the subplot also uses the rectangular size\n",
        "\n",
        "    plt.plot(times_RSE, train_losses_RSE, label='Rotated Adam - Training Loss')\n",
        "    plt.plot(times_baseline, train_losses_baseline, label='Baseline - Training Loss')\n",
        "    plt.xlabel('Wall-Clock Time (seconds)')\n",
        "    plt.ylabel('Loss')\n",
        "\n",
        "    # Log scale:\n",
        "    if logTransform:\n",
        "        ax.set_yscale('log')\n",
        "\n",
        "        # Use LogLocator to ensure all gridlines are labeled\n",
        "        ax.yaxis.set_major_locator(LogLocator(base=10.0, subs=None, numticks=10))\n",
        "        ax.yaxis.set_minor_locator(LogLocator(base=10.0, subs=np.arange(2, 10) * 0.1, numticks=10))\n",
        "\n",
        "        # Set custom scientific notation for the y-axis\n",
        "        formatter = CustomScalarFormatter(precision=precision, useMathText=True)\n",
        "        formatter.set_scientific(True)\n",
        "        formatter.set_powerlimits((-1, 1))\n",
        "        ax.yaxis.set_major_formatter(formatter)\n",
        "\n",
        "        # Rotate labels for horizontal alignment\n",
        "        ax.tick_params(axis='y', which='major', labelrotation=0)\n",
        "\n",
        "    # Add gridlines\n",
        "    plt.grid(True, which='both', axis='y')\n",
        "\n",
        "    plt.title(title)\n",
        "    plt.legend()\n",
        "    plt.tight_layout()\n",
        "    plt.show()\n",
        "\n",
        "\n",
        "def plotAll_(losses_dict, plotEpochsOrIterations='Iterations', logTransform=False):\n",
        "    print('Plotting iterations...')\n",
        "\n",
        "\n",
        "    plotTrainValLosses(losses_dict, model_type='rse', title=appendHyperParamsToTitle('Training and Validation Loss - Rotated Adam'),\n",
        "                       plotEpochsOrIterations=plotEpochsOrIterations, logTransform=logTransform)\n",
        "    plotTrainValLosses(losses_dict, model_type='baseline', title=appendHyperParamsToTitle('Training and Validation Loss - Baseline'),\n",
        "                       plotEpochsOrIterations=plotEpochsOrIterations, logTransform=logTransform)\n",
        "    if not logTransform:\n",
        "        plotCombinedTrainValLosses(losses_dict, title=appendHyperParamsToTitle('Training and Validation Loss, log scale'),\n",
        "                                   plotEpochsOrIterations=plotEpochsOrIterations, logTransform=False)\n",
        "    plotCombinedTrainValLosses(losses_dict, title=appendHyperParamsToTitle('Training and Validation Loss, log scale'),\n",
        "                               logTransform=True, plotEpochsOrIterations=plotEpochsOrIterations)\n",
        "\n",
        "\n",
        "\n",
        "def plotAll(losses_dict, logTransform=True, task=None, title=None, path_for_image_and_json=None, smoothing_window=50, showLegend=True):\n",
        "    print('Plotting iterations...')\n",
        "    appendedTitle = (task + \": \" if task is not None else '') + 'Training and Validation Loss, log scale'\n",
        "    if title is not None:\n",
        "        appendedTitle = appendedTitle + ', ' + title\n",
        "\n",
        "    # Export to json:\n",
        "    base_name = f'losses_dict_{task}'\n",
        "    # Append date-time to base_name\n",
        "    import datetime\n",
        "    base_name = f'{base_name}_{datetime.datetime.now().strftime(\"%Y-%m-%d_%H-%M-%S\")}'\n",
        "    path_for_json = f'{base_name}.json' if path_for_image_and_json is None else path_for_image_and_json + '.json'\n",
        "    # path_for_image = f'losses_dict_{task}.png' if path_for_image_and_json is None else path_for_image_and_json + '.png'\n",
        "    path_for_image = f'{base_name}.png' if path_for_image_and_json is None else path_for_image_and_json + '.png'\n",
        "    plotCombinedTrainValLosses(losses_dict, title=appendHyperParamsToTitle(appendedTitle),\n",
        "                               logTransform=True, plotEpochsOrIterations='epochs',\n",
        "                               save_fig_filename=path_for_image, smoothing_window=smoothing_window, show_legend=showLegend)\n",
        "\n",
        "    exportLossesDictToJSON(losses_dict, path=path_for_json)\n",
        "\n",
        "\n",
        "# plotAll(losses_dict)\n"
      ],
      "metadata": {
