    {
      "cell_type": "code",
      "source": [
        "\n",
        "def histogram_update_learnable_sharpened_copy_pos_optim_v7_fix_autograd_mod_2(\n",
        "\n",
        "    hist: torch.Tensor,             # [P, bs, h]\n",
        "    p_reset: torch.Tensor,          # [bs, h]\n",
        "    p_incr: torch.Tensor,           # [bs, h]\n",
        "    p_decr: torch.Tensor,           # [bs, h]\n",
        "    p_keep: torch.Tensor,           # [bs, h]\n",
        "    p_copy: Optional[torch.Tensor], # [P+1, bs, h] or [bs, h, P+1]\n",
        "    eps: float,\n",
        "    gamma: torch.Tensor,            # scalar or [h]\n",
        "    power_sharpen: bool,\n",
        "    buf: torch.Tensor,              # [P, bs, h]  (pre-allocated)\n",
        "    inc_buf: torch.Tensor,          # [P, bs, h]  (pre-allocated)\n",
        "    dec_buf: torch.Tensor,          # [P, bs, h]  (pre-allocated)\n",
        "    ) -> torch.Tensor:\n",
        "    P, bs, h = hist.shape\n",
        "\n",
        "    # 1) total & no-reset weights\n",
        "    # total = hist.sum(0)                    # [bs, h]\n",
        "    total = 1.0\n",
        "    nr    = 1.0 - p_reset                  # [bs, h]\n",
        "    # w_inc = nr * p_incr                    # [bs, h]\n",
        "    # w_dec = nr * p_decr\n",
        "    # w_k   = nr * p_keep\n",
        "    w_dki_tensor = torch.stack([nr*p_decr, nr*p_keep, nr*p_incr], dim=0)\n",
        "\n",
        "\n",
        "    # 3) compute base flows\n",
        "    hc = hist\n",
        "    # base_keep = hc * w_k.unsqueeze(0)    # [P, bs, h]\n",
        "    # base_inc  = hc * w_inc.unsqueeze(0)\n",
        "    # base_dec  = hc * w_dec.unsqueeze(0)\n",
        "\n",
        "    # assert hist.shape == (P, bs, h);\n",
        "    # assert w_dki_tensor.shape == (3, bs, h)\n",
        "    combined = hist * w_dki_tensor.unsqueeze(1)\n",
        "    # assert combined.shape == (3, P, bs, h)\n",
        "    base_dec, base_keep, base_inc = combined.unbind(0)\n",
        "\n",
        "    # 4) inc-roll into inc_buf\n",
        "    if inc_buf is None:\n",
        "        inc_buf = torch.zeros_like(base_inc)\n",
        "    inc_buf[1:].copy_( base_inc[:-1] )\n",
        "    inc_buf[-1].add_( base_inc[-1] )       # clamp overflow\n",
        "\n",
        "    # # 5) dec-roll into dec_buf\n",
        "    if dec_buf is None:\n",
        "        dec_buf = torch.zeros_like(base_dec)\n",
        "    dec_buf[:-1].copy_( base_dec[1:] )\n",
        "    dec_buf[0].add_( base_dec[0] )         # clamp underflow\n",
        "\n",
        "    # 6) accumulate no-copy branches\n",
        "\n",
        "    if buf is not None and False:\n",
        "        buf.add_(base_keep + base_dec + base_inc)\n",
        "\n",
        "    else :\n",
        "        # buf = (base_keep + base_dec + base_inc)\n",
        "        # buf = combined.sum(0)\n",
        "        # buf.add_(base_keep).add_(inc_buf).add_(dec_buf)\n",
        "        # buf = base_keep + base_dec + base_inc\n",
        "        # buf.add_(base_keep + inc_buf + dec_buf)\n",
        "        buf = base_keep + inc_buf + dec_buf\n",
        "\n",
        "        buf[1].add_( total * p_reset * p_incr )               # to bin 1\n",
        "        buf[0].add_( total * p_reset * (p_decr + p_keep) )     # to bin 0\n",
        "\n",
        "    # 7) copy branch\n",
        "    if p_copy is not None and Position_Copying_Enabled:\n",
        "        # accept either [bs,h,P+1] or [P+1,bs,h]\n",
        "        if p_copy.dim() == 3 and p_copy.size(0) != P+1:\n",
        "            p_copy = p_copy.permute(2, 0, 1)\n",
        "        pos_cols = p_copy[:-1]              # [P, bs, h]\n",
        "        no_copy  = p_copy[-1]               # [bs, h]\n",
        "\n",
        "        buf.mul_( no_copy.unsqueeze(0) )    # scale normal flows\n",
        "        buf.add_( total.unsqueeze(0) * pos_cols )  # jump mass\n",
        "\n",
        "    # 8) sharpening & normalize\n",
        "    if True:\n",
        "        # In-place:\n",
        "        if True:\n",
        "            buf = buf.add_(eps).pow_(gamma)\n",
        "            # torch.pow(buf.add(eps), gamma, out=buf\n",
        "        else:\n",
        "            buf = (buf + eps).pow(gamma)\n",
        "\n",
        "\n",
        "    buf = buf.div( buf.sum(0, keepdim=True).add(eps))\n",
        "\n",
        "    return buf\n",
        "\n",
        "@torch.compile(dynamic=False)\n",
        "def histogram_update_learnable_sharpened_copy_pos_optim_v7_fix_autograd_mod_3(\n",
        "\n",
        "    hist: torch.Tensor,             # [P, bs, h]\n",
        "    p_reset: torch.Tensor,          # [bs, h]\n",
        "    p_incr: torch.Tensor,           # [bs, h]\n",
        "    p_decr: torch.Tensor,           # [bs, h]\n",
        "    p_keep: torch.Tensor,           # [bs, h]\n",
        "    p_copy: Optional[torch.Tensor], # [P+1, bs, h] or [bs, h, P+1]\n",
        "    eps: float,\n",
        "    gamma: torch.Tensor,            # scalar or [h]\n",
        "    power_sharpen: bool,\n",
        "    buf: torch.Tensor,              # [P, bs, h]  (pre-allocated)\n",
        "    inc_buf: torch.Tensor,          # [P, bs, h]  (pre-allocated)\n",
        "    dec_buf: torch.Tensor,          # [P, bs, h]  (pre-allocated)\n",
        "    ) -> torch.Tensor:\n",
        "    P, bs, h = hist.shape\n",
        "\n",
        "    total = 1.0\n",
        "    nr    = 1.0 - p_reset                  # [bs, h]\n",
        "\n",
        "    w_dki_tensor = torch.stack([nr*p_decr, nr*p_keep, nr*p_incr], dim=0)\n",
        "\n",
        "    combined = hist * w_dki_tensor.unsqueeze(1)\n",
        "    # assert combined.shape == (3, P, bs, h)\n",
        "\n",
        "    \"\"\" base_dec, base_keep, base_inc => combined.unbind(0) \"\"\"\n",
        "\n",
        "    # 4) inc-roll into inc_buf\n",
        "    if inc_buf is None:\n",
        "        inc_buf = torch.zeros_like(combined[2])\n",
        "    inc_buf[1:].copy_( combined[2,:-1] )\n",
        "    inc_buf[-1].add_( combined[2,-1] )       # clamp overflow\n",
        "\n",
        "    # # 5) dec-roll into dec_buf\n",
        "    if dec_buf is None:\n",
        "        dec_buf = torch.zeros_like(combined[0])\n",
        "    dec_buf[:-1].copy_( combined[0,1:] )\n",
        "    dec_buf[0].add_( combined[0,0] )         # clamp underflow\n",
        "\n",
        "    # 6) accumulate no-copy branches\n",
        "\n",
        "    if buf is not None and False:\n",
        "        # buf.add_(base_keep + base_dec + base_inc)\n",
        "        pass\n",
        "\n",
        "    else :\n",
        "        buf = combined[1] + inc_buf + dec_buf\n",
        "\n",
        "        buf[1].add_( total * p_reset * p_incr )               # to bin 1\n",
        "        buf[0].add_( total * p_reset * (p_decr + p_keep) )     # to bin 0\n",
        "\n",
        "    # 7) copy branch\n",
        "    if p_copy is not None and Position_Copying_Enabled:\n",
        "        # accept either [bs,h,P+1] or [P+1,bs,h]\n",
        "        if p_copy.dim() == 3 and p_copy.size(0) != P+1:\n",
        "            p_copy = p_copy.permute(2, 0, 1)\n",
        "        pos_cols = p_copy[:-1]              # [P, bs, h]\n",
        "        no_copy  = p_copy[-1]               # [bs, h]\n",
        "\n",
        "        buf.mul_( no_copy.unsqueeze(0) )    # scale normal flows\n",
        "        buf.add_( total.unsqueeze(0) * pos_cols )  # jump mass\n",
        "\n",
        "    # 8) sharpening & normalize\n",
        "    if True:\n",
        "        # In-place:\n",
        "        if True:\n",
        "            buf = buf.add_(eps).pow_(gamma)\n",
        "            # torch.pow(buf.add(eps), gamma, out=buf\n",
        "        else:\n",
        "            buf = (buf + eps).pow(gamma)\n",
        "\n",
        "\n",
        "    buf = buf.div( buf.sum(0, keepdim=True).add(eps))\n",
        "\n",
        "    return buf\n",
        "\n"
      ],
