    {
      "cell_type": "code",
      "source": [
        "import re\n",
        "\n",
        "# Basic list of “verbs” and possible direction keywords.\n",
        "VERBS = {\"turn\", \"walk\", \"run\", \"jump\", \"look\"}\n",
        "MODIFIERS = {\"opposite\", \"around\"}\n",
        "DIRECTIONS = {\"left\", \"right\"}\n",
        "REPETITIONS = {\"twice\": 2, \"thrice\": 3}\n",
        "\n",
        "\n",
        "def parse_scan_command(command_text: str):\n",
        "    \"\"\"\n",
        "    Splits an action phrase like\n",
        "       \"jump around left thrice\"\n",
        "    or \"run opposite right\"\n",
        "    or \"turn right\"\n",
        "    into a structure:\n",
        "    {\n",
        "       \"verb\": \"jump\",\n",
        "       \"modifier\": \"around\"  (or \"opposite\" or None),\n",
        "       \"direction\": \"left\"   (or \"right\" or None),\n",
        "       \"repeat\": 3           (2 for twice, 3 for thrice, else 1)\n",
        "    }\n",
        "    \"\"\"\n",
        "    words = command_text.strip().split()\n",
        "    # Default\n",
        "    verb = None\n",
        "    modifier = None\n",
        "    direction = None\n",
        "    repeat = 1\n",
        "\n",
        "    # Last word might be \"twice\"/\"thrice\"\n",
        "    if words and words[-1] in REPETITIONS:\n",
        "        repeat = REPETITIONS[words[-1]]\n",
        "        words = words[:-1]  # remove that from the list\n",
        "\n",
        "    # We expect a structure like [<verb>, <modifier?>, <direction?>]\n",
        "    # e.g., [\"run\", \"opposite\", \"right\"]\n",
        "    # or     [\"jump\", \"around\", \"left\"]\n",
        "    # or     [\"turn\", \"left\"]\n",
        "    # or     [\"look\"]  (no direction, no modifier)\n",
        "    # We'll parse from left to right.\n",
        "\n",
        "    if not words:\n",
        "        return None  # edge case\n",
        "\n",
        "    # Verb is usually first\n",
        "    if words[0] in VERBS:\n",
        "        verb = words[0]\n",
        "        remainder = words[1:]\n",
        "    else:\n",
        "        # If the user wrote something like \"opposite left jump\"?\n",
        "        # In SCAN, typically the verb is first, but you can adapt logic as needed.\n",
        "        # We'll do a quick find:\n",
        "        found_verb = None\n",
        "        for i, w in enumerate(words):\n",
        "            if w in VERBS:\n",
        "                found_verb = w\n",
        "                # everything before that might be modifiers/directions\n",
        "                break\n",
        "        if found_verb is None:\n",
        "            return None\n",
        "        # Re-slice around that\n",
        "        idx = words.index(found_verb)\n",
        "        verb = found_verb\n",
        "        remainder = words[:idx] + words[idx+1:]\n",
        "\n",
        "    # Now remainder might contain \"opposite\", \"around\", \"left\", \"right\" in some order\n",
        "    # We'll look for known modifiers and directions\n",
        "    for w in remainder:\n",
        "        if w in MODIFIERS and (modifier is None):\n",
        "            modifier = w\n",
        "        elif w in DIRECTIONS and (direction is None):\n",
        "            direction = w\n",
        "        else:\n",
        "            # If more leftover tokens exist, handle as needed\n",
        "            pass\n",
        "\n",
        "    return {\n",
        "        \"verb\": verb,\n",
        "        \"modifier\": modifier,\n",
        "        \"direction\": direction,\n",
        "        \"repeat\": repeat\n",
        "    }\n",
        "\n",
        "def build_action_text(action_dict):\n",
        "    \"\"\"\n",
        "    Given a parsed dictionary like:\n",
        "       {\"verb\": \"walk\", \"modifier\": \"around\", \"direction\": \"left\", \"repeat\": 3}\n",
        "    returns the string:\n",
        "       \"walk around left\"\n",
        "\n",
        "    If `modifier` or `direction` is None, they are omitted.\n",
        "    \"\"\"\n",
        "    v = action_dict[\"verb\"]\n",
        "    m = action_dict[\"modifier\"]\n",
        "    d = action_dict[\"direction\"]\n",
        "\n",
        "    words = [v]\n",
        "    if m:\n",
        "        words.append(m)\n",
        "    if d:\n",
        "        words.append(d)\n",
        "    return \" \".join(words)\n",
        "\n",
        "\n",
        "\n",
        "def build_intermediate_expansion(\n",
        "    action_dict,\n",
        "    sub_label: str,\n",
        "    include_iteration_numbers: bool = False,\n",
        "    include_subphrase_letters: bool = False\n",
        "):\n",
        "    \"\"\"\n",
        "    Builds the *chain-of-thought* expansions, e.g.:\n",
        "      \"1A run left + 2A run left + 3A run left\"\n",
        "\n",
        "    If include_iteration_numbers=False, we omit \"1\", \"2\", \"3\".\n",
        "    If include_subphrase_letters=False, we omit \"A\", \"B\", \"C\".\n",
        "    \"\"\"\n",
        "    verb = action_dict[\"verb\"]\n",
        "    mod = action_dict[\"modifier\"]\n",
        "    direc = action_dict[\"direction\"]\n",
        "    r = action_dict[\"repeat\"]\n",
        "\n",
        "    pieces = []\n",
        "    for i in range(1, r+1):\n",
        "        # iteration portion\n",
        "        iteration_part = str(i) if include_iteration_numbers else \"\"\n",
        "        # letter portion\n",
        "        letter_part = sub_label if include_subphrase_letters else \"\"\n",
        "        # combine them, e.g. \"1A\"\n",
        "        combined_label = iteration_part + letter_part\n",
        "        if combined_label:\n",
        "            combined_label += \" \"  # add trailing space if non-empty\n",
        "\n",
        "        # e.g. \"run left\"\n",
        "        phrase_core = build_action_text(action_dict)\n",
        "\n",
        "        # final piece: \"1A run left\" or just \"run left\"\n",
        "        phrase = f\"{combined_label}{phrase_core}\"\n",
        "        pieces.append(phrase)\n",
        "\n",
        "    # If repeated, we separate them by \" + \"\n",
        "    return \" + \".join(pieces)\n",
        "\n",
        "def build_final_scan_expansion(\n",
        "    action_dict,\n",
        "    sub_label: str,\n",
        "    include_iteration_numbers: bool = False,\n",
        "    include_subphrase_letters: bool = False,\n",
        "    prepend_verb_phrase: bool = True\n",
        "):\n",
        "    \"\"\"\n",
        "    Returns something like:\n",
        "      1A run left: I_TURN_LEFT I_RUN 2A run left: I_TURN_LEFT I_RUN 3A run left: I_TURN_LEFT I_RUN\n",
        "\n",
        "    If include_iteration_numbers=False => omit \"1\", \"2\", \"3\"\n",
        "    If include_subphrase_letters=False => omit \"A\", \"B\", \"C\"\n",
        "    If prepend_verb_phrase=True, we insert \"run left:\" after the label.\n",
        "    \"\"\"\n",
        "    verb = action_dict[\"verb\"]           # turn / jump / run / walk / look\n",
        "    mod = action_dict[\"modifier\"]        # opposite / around / None\n",
        "    direc = action_dict[\"direction\"]     # left / right / None\n",
        "    r = action_dict[\"repeat\"]            # 1 / 2 / 3\n",
        "    verb_map = {\n",
        "        \"turn\": {\"left\": \"I_TURN_LEFT\", \"right\": \"I_TURN_RIGHT\"},\n",
        "        \"walk\": \"I_WALK\",\n",
        "        \"run\":  \"I_RUN\",\n",
        "        \"jump\": \"I_JUMP\",\n",
        "        \"look\": \"I_LOOK\",\n",
        "    }\n",
        "\n",
        "    def resolve_iverb(verb, direction):\n",
        "        if verb == \"turn\":\n",
        "            if direction == \"left\":\n",
        "                return [\"I_TURN_LEFT\"]\n",
        "            elif direction == \"right\":\n",
        "                return [\"I_TURN_RIGHT\"]\n",
        "            else:\n",
        "                return [\"I_TURN_LEFT\"]\n",
        "        else:\n",
        "            v = verb_map[verb] if verb in verb_map else None\n",
        "            if isinstance(v, dict):\n",
        "                return v.get(direction, \"I_TURN_LEFT\")\n",
        "            else:\n",
        "                return [v] if v else []\n",
        "\n",
        "    def expand_one_repetition(verb, mod, direc):\n",
        "        # Opposite => do 2 turns in that direction, then main action\n",
        "        if mod == \"opposite\":\n",
        "            if direc == \"left\":\n",
        "                prefix = [\"I_TURN_LEFT\", \"I_TURN_LEFT\"]\n",
        "            else:\n",
        "                prefix = [\"I_TURN_RIGHT\", \"I_TURN_RIGHT\"]\n",
        "\n",
        "            if verb == \"turn\":\n",
        "                return prefix\n",
        "            else:\n",
        "                main_act = resolve_iverb(verb, None)\n",
        "                return prefix + main_act\n",
        "\n",
        "        elif mod == \"around\":\n",
        "            # around => 4 times (turn left or right) + main action\n",
        "            if direc == \"left\":\n",
        "                turning_token = \"I_TURN_LEFT\"\n",
        "            else:\n",
        "                turning_token = \"I_TURN_RIGHT\"\n",
        "            expansions = []\n",
        "            for _ in range(4):\n",
        "                if verb == \"turn\":\n",
        "                    expansions.append(turning_token)\n",
        "                else:\n",
        "                    main_act = resolve_iverb(verb, None)\n",
        "                    expansions.extend([turning_token] + main_act)\n",
        "            return expansions\n",
        "\n",
        "        else:\n",
        "            # no special mod\n",
        "            if verb == \"turn\":\n",
        "                return resolve_iverb(verb, direc)\n",
        "            else:\n",
        "                if direc == \"left\":\n",
        "                    return [\"I_TURN_LEFT\"] + resolve_iverb(verb, None)\n",
        "                elif direc == \"right\":\n",
        "                    return [\"I_TURN_RIGHT\"] + resolve_iverb(verb, None)\n",
        "                else:\n",
        "                    return resolve_iverb(verb, None)\n",
        "\n",
        "    # Build expansions\n",
        "    all_segments = []\n",
        "    # We'll accumulate a list of string segments, e.g.:\n",
        "    #  [\"1A run left: I_TURN_LEFT I_RUN\", \"2A run left: I_TURN_LEFT I_RUN\", \"3A run left: I_TURN_LEFT I_RUN\"]\n",
        "    for i in range(1, r+1):\n",
        "        # e.g. \"1A\" or just \"\" or \"1\" etc.\n",
        "        iteration_part = str(i) if include_iteration_numbers else \"\"\n",
        "        letter_part = sub_label if include_subphrase_letters else \"\"\n",
        "        combined_label = iteration_part + letter_part\n",
        "        if combined_label:\n",
        "            combined_label += \" \"  # add trailing space if non-empty\n",
        "\n",
        "        expansions = expand_one_repetition(verb, mod, direc)  # a list like [\"I_TURN_LEFT\", \"I_RUN\", ...]\n",
        "\n",
        "        if prepend_verb_phrase:\n",
        "            # e.g. \"run left:\"\n",
        "            phrase_core = build_action_text(action_dict)  # \"run left\" or \"walk around left\"\n",
        "            # final prefix => \"1A run left:\"\n",
        "            prefix_str = f\"{combined_label}{phrase_core}:\"\n",
        "        else:\n",
        "            # e.g. just \"1A\"\n",
        "            prefix_str = combined_label.strip()  # remove trailing space if empty\n",
        "\n",
        "        # Combine prefix + expansions into one line\n",
        "        # e.g. \"1A run left: I_TURN_LEFT I_RUN\"\n",
        "        if prefix_str:\n",
        "            segment = \" \".join([prefix_str] + expansions)\n",
        "        else:\n",
        "            # If prefix_str is empty, e.g. if user has both flags off\n",
        "            # then it's just expansions\n",
        "            segment = \" \".join(expansions)\n",
        "\n",
        "        all_segments.append(segment)\n",
        "\n",
        "    # Then we join them with a space:\n",
        "    return \" \".join(all_segments)\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "def augment_scan_line_with_numbering(\n",
        "    line: str,\n",
        "    include_iteration_numbers: bool = False,\n",
        "    include_subphrase_letters: bool = False,\n",
        "    prepend_verb_phrase_in_final: bool = True\n",
        ") -> str:\n",
        "    \"\"\"\n",
        "    Takes a SCAN line like \"run left and walk around left thrice\"\n",
        "    and yields something like:\n",
        "      = 1A run left + 1B walk around left + 2B walk around left + 3B walk around left\n",
        "        → 1A run left: I_TURN_LEFT I_RUN 1B walk around left: I_TURN_LEFT I_WALK ...\n",
        "    depending on the boolean flags.\n",
        "    \"\"\"\n",
        "    # 1) Split at '='\n",
        "    if '=' not in line:\n",
        "        line = line.replace(\"IN:\", \"\").replace(\"OUT:\", \"=\")\n",
        "    parts = line.split('=', 1)\n",
        "    if len(parts) < 2:\n",
        "        return line\n",
        "\n",
        "    input_part = parts[0].strip()\n",
        "    output_part = parts[1].strip()\n",
        "\n",
        "    # 2) Break input_part on 'and' or 'after', reversing if 'after'\n",
        "    if \" after \" in input_part:\n",
        "        sub_phrases = re.split(r'\\bafter\\b', input_part)\n",
        "        sub_phrases = [p.strip() for p in sub_phrases if p.strip()]\n",
        "        sub_phrases = sub_phrases[::-1]  # reverse for 'after'\n",
        "        join_word = \" after \"\n",
        "    else:\n",
        "        sub_phrases = re.split(r'\\band\\b', input_part)\n",
        "        sub_phrases = [p.strip() for p in sub_phrases if p.strip()]\n",
        "        join_word = \" and \"\n",
        "\n",
        "    # 3) letters => 'A', 'B', 'C', ...\n",
        "    letters = \"ABCDEFGHIJKLMNOPQRSTUVWXYZ\"\n",
        "\n",
        "    intermediate_pieces = []\n",
        "    final_pieces = []\n",
        "    for sp_i, phrase_text in enumerate(sub_phrases):\n",
        "        parsed = parse_scan_command(phrase_text)\n",
        "        if not parsed:\n",
        "            continue\n",
        "        # sub_label => e.g. \"A\", \"B\", \"C\", ...\n",
        "        if sp_i < len(letters):\n",
        "            sub_label = letters[sp_i]\n",
        "        else:\n",
        "            sub_label = \"Z\"  # or handle bigger cases\n",
        "\n",
        "        # Build intermediate expansions (chain-of-thought)\n",
        "        interm = build_intermediate_expansion(\n",
        "            action_dict=parsed,\n",
        "            sub_label=sub_label,\n",
        "            include_iteration_numbers=include_iteration_numbers,\n",
        "            include_subphrase_letters=include_subphrase_letters\n",
        "        )\n",
        "        intermediate_pieces.append(interm)\n",
        "\n",
        "        # Build final expansions (SCAN tokens)\n",
        "        final_str = build_final_scan_expansion(\n",
        "            action_dict=parsed,\n",
        "            sub_label=sub_label,\n",
        "            include_iteration_numbers=include_iteration_numbers,\n",
        "            include_subphrase_letters=include_subphrase_letters,\n",
        "            prepend_verb_phrase= True  # <--- your default.  If you want a param for this, pass it in\n",
        "        )\n",
        "        final_pieces.append(final_str)\n",
        "\n",
        "    # 4) Re-join the sub-phrases. If you want the final intermediate text to also reflect \"after\" or \"and,\" do:\n",
        "    intermediate_combined = f\" {join_word} \".join(intermediate_pieces)\n",
        "    final_combined = \" \".join(final_pieces)\n",
        "\n",
        "    # 5) Reassemble =>  \"<input> = <intermediate> → <final>\"\n",
        "    new_line = f\"{input_part} = {intermediate_combined} → {final_combined}\"\n",
        "    return new_line\n",
        "\n",
        "# --------------------------------------------\n",
        "# BFS Digits Helpers\n",
        "# --------------------------------------------\n",
        "def generate_random_nested_list_old(\n",
        "    depth: int,\n",
        "    max_depth: int,\n",
        "    min_depth: int = 0,        # overall tree must have at least this depth on one branch\n",
        "    max_children: int = 3,\n",
        "    max_digits_per_list: int = 3,\n",
        "    force_until: int = 0        # if >0, then this branch is forced to recurse until depth == force_until\n",
        "):\n",
        "    import random\n",
        "    # Base case: when we've reached max_depth, return a flat list of random digits.\n",
        "    if depth >= max_depth:\n",
        "        n_digits = random.randint(1, max_digits_per_list)\n",
        "        return [random.randint(0, 9) for _ in range(n_digits)]\n",
        "\n",
        "    # If force_until is active and we haven't reached it, force recursion.\n",
        "    if depth < force_until:\n",
        "        n_children = random.randint(1, max_children)\n",
        "        result = []\n",
        "        for _ in range(n_children):\n",
        "            child = generate_random_nested_list(depth + 1, max_depth, min_depth,\n",
        "                                                  max_children, max_digits_per_list,\n",
        "                                                  force_until=force_until)\n",
        "            result.append(child)\n",
        "        return result\n",
        "    else:\n",
        "        # Normal (non-forced) generation:\n",
        "        # With some probability (say 50%), terminate by producing a flat list;\n",
        "        # otherwise, recurse further.\n",
        "        if random.random() < 0.5:\n",
        "            n_digits = random.randint(1, max_digits_per_list)\n",
        "            return [random.randint(0, 9) for _ in range(n_digits)]\n",
        "        else:\n",
        "            n_children = random.randint(1, max_children)\n",
        "            result = []\n",
        "            for _ in range(n_children):\n",
        "                # In normal mode, we do not force deeper.\n",
        "                child = generate_random_nested_list(depth + 1, max_depth, min_depth,\n",
        "                                                      max_children, max_digits_per_list,\n",
        "                                                      force_until=0)\n",
        "                result.append(child)\n",
        "            return result\n",
        "\n",
        "import random\n",
        "\n",
        "def generate_nested_branch(\n",
        "    current_depth: int,\n",
        "    min_depth: int,\n",
        "    max_depth: int,\n",
        "    max_children: int,\n",
        "    max_digits_per_list: int,\n",
        "    force: bool = False\n",
        "):\n",
        "    \"\"\"\n",
        "    Recursively generate a branch (i.e. a subtree).\n",
        "\n",
        "    - If force is True and current_depth < min_depth, then this branch is forced\n",
        "      to recurse (i.e. it will not terminate with a flat list until current_depth >= min_depth).\n",
        "    - When current_depth >= max_depth, always return a flat list of digits.\n",
        "    - Otherwise (if not forced), choose randomly whether to terminate or to recurse further.\n",
        "    \"\"\"\n",
        "\n",
        "    # print(f'generate_nested_branch: min_depth={min_depth}, max_depth={max_depth}')\n",
        "\n",
        "    # If we are forced and haven't reached min_depth, continue recursion.\n",
        "    if force and current_depth < min_depth:\n",
        "        n_children = random.randint(1, max_children)\n",
        "        branch = []\n",
        "        for _ in range(n_children):\n",
        "            branch.append(generate_nested_branch(\n",
        "                current_depth + 1,\n",
        "                min_depth,\n",
        "                max_depth,\n",
        "                max_children,\n",
        "                max_digits_per_list,\n",
        "                force=True))\n",
        "        return branch\n",
        "\n",
        "    # If we have reached maximum depth, always return a flat list.\n",
        "    if current_depth >= max_depth:\n",
        "        n_digits = random.randint(1, max_digits_per_list)\n",
        "        return [random.randint(0, 9) for _ in range(n_digits)]\n",
        "    # Otherwise (current_depth is >= min_depth and < max_depth):\n",
        "    # With some probability, terminate by returning a flat list.\n",
        "    if not force and random.random() < 0.5:\n",
        "        n_digits = random.randint(1, max_digits_per_list)\n",
        "        return [random.randint(0, 9) for _ in range(n_digits)]\n",
        "    else:\n",
        "        # Otherwise, recurse further.\n",
        "        n_children = random.randint(1, max_children)\n",
        "        branch = []\n",
        "        for _ in range(n_children):\n",
        "            branch.append(generate_nested_branch(\n",
        "                current_depth + 1,\n",
        "                min_depth,\n",
        "                max_depth,\n",
        "                max_children,\n",
        "                max_digits_per_list,\n",
        "                force=False))\n",
        "        return branch\n",
        "\n",
        "def generate_random_nested_list(\n",
        "    max_depth: int,\n",
        "    min_depth: int,\n",
        "    max_children: int = 3,\n",
        "    max_digits_per_list: int = 3,\n",
        "    must_have_digit_at_top: bool = True\n",
        "):\n",
        "    \"\"\"\n",
        "    Generates a tree (i.e. a nested list) that is guaranteed to have at least one branch\n",
        "    reaching at least 'min_depth'. This is achieved by forcing one child to recurse\n",
        "    until 'min_depth'. Other children are generated normally.\n",
        "\n",
        "    Optionally, if must_have_digit_at_top is True, a direct digit is prepended to the top-level,\n",
        "    ensuring that BFS will pick up a digit at depth 0.\n",
        "    \"\"\"\n",
        "    n_children = random.randint(1, max_children)\n",
        "    children = []\n",
        "\n",
        "    forced_index = random.randint(0, n_children - 1)\n",
        "    for i in range(n_children):\n",
        "        if i == forced_index:\n",
        "            child = generate_nested_branch(\n",
        "                current_depth=1,\n",
        "                min_depth=min_depth,\n",
        "                max_depth=max_depth,\n",
        "                max_children=max_children,\n",
        "                max_digits_per_list=max_digits_per_list,\n",
        "                force=True)\n",
        "        else:\n",
        "            child = generate_nested_branch(\n",
        "                current_depth=1,\n",
        "                min_depth=min_depth,\n",
        "                max_depth=max_depth,\n",
        "                max_children=max_children,\n",
        "                max_digits_per_list=max_digits_per_list,\n",
        "                force=False)\n",
        "        children.append(child)\n",
        "\n",
        "    if must_have_digit_at_top:\n",
        "        # Prepend a random digit to the top level.\n",
        "        top_digit = random.randint(0, 9)\n",
        "        return [top_digit] + children\n",
        "    else:\n",
        "        return children\n",
        "\n",
        "\n",
        "def nested_list_to_string(nested):\n",
        "    if isinstance(nested, int):\n",
        "        return str(nested)\n",
        "    if isinstance(nested, list):\n",
        "        inner = \", \".join(nested_list_to_string(x) for x in nested)\n",
        "        return f\"[{inner}]\"\n",
        "    return str(nested)\n",
        "\n",
        "from collections import deque\n",
        "\n",
        "def bfs_digits_by_level(nested_list):\n",
        "    queue = deque([nested_list])\n",
        "    levels = []\n",
        "    while queue:\n",
        "        level_size = len(queue)\n",
        "        digits_this_level = []\n",
        "        for _ in range(level_size):\n",
        "            current = queue.popleft()\n",
        "            if isinstance(current, int):\n",
        "                digits_this_level.append(current)\n",
        "            elif isinstance(current, list):\n",
        "                for item in current:\n",
        "                    if isinstance(item, int):\n",
        "                        digits_this_level.append(item)\n",
        "                    elif isinstance(item, list):\n",
        "                        queue.append(item)\n",
        "        if digits_this_level:\n",
        "            levels.append(digits_this_level)\n",
        "    return levels\n",
        "\n",
        "# Different version of bfs_digits_by_level() - appends + between empty strings/empty levels, whereas the original discards appending '+' between empty levels\n",
        "def bfs_digits_by_level_including_empty(nested_list):\n",
        "    \"\"\"\n",
        "    Performs BFS over 'nested_list', collecting digits found at each level\n",
        "    into `levels[i]`, and ALWAYS appending an entry for each level,\n",
        "    even if that level has no digits.\n",
        "    \"\"\"\n",
        "    queue = deque([nested_list])\n",
        "    levels = []\n",
        "    while queue:\n",
        "        level_size = len(queue)\n",
        "        digits_this_level = []\n",
        "        for _ in range(level_size):\n",
        "            current = queue.popleft()\n",
        "            if isinstance(current, list):\n",
        "                # BFS means: each sub-element that is a list gets enqueued\n",
        "                # each sub-element that is a digit goes to digits_this_level\n",
        "                for item in current:\n",
        "                    if isinstance(item, list):\n",
        "                        queue.append(item)\n",
        "                    elif isinstance(item, int):\n",
        "                        digits_this_level.append(item)\n",
        "            elif isinstance(current, int):\n",
        "                digits_this_level.append(current)\n",
        "        # **Always** append digits_this_level, even if it's empty.\n",
        "        levels.append(digits_this_level)\n",
        "    return levels\n",
        "\n",
        "\n",
        "def build_bfs_string_discard_empty(levels_of_digits):\n",
        "    parts = []\n",
        "    for digits in levels_of_digits:\n",
        "        # join digits in that level with no space\n",
        "        s = \"\".join(str(d) for d in digits)\n",
        "        parts.append(s)\n",
        "    # join levels with \"+\"\n",
        "    return \"+\".join(parts)\n",
        "\n",
        "def build_bfs_string_include_empty(levels_of_digits):\n",
        "    parts = []\n",
        "    for digits in levels_of_digits:\n",
        "        # If this level has digits [9,2,0], s = '920'\n",
        "        # If it has none, s = '' (the empty string).\n",
        "        s = \"\".join(str(d) for d in digits)\n",
        "        parts.append(s)\n",
        "    # Now we join with ' + '\n",
        "    return \" + \".join(parts)\n",
        "\n",
        "# MARK: improvedCoTAdd for TM3.1 of RSE v0.630\n",
        "def build_addition_cot_compact(\n",
        "    a_str_rev: str,\n",
        "    b_str_rev: str,\n",
        "    use_epsilon_missing: bool = False,\n",
        "    epsilon_char: str = EPSILON_DIGIT\n",
        ") -> str:\n",
        "    \"\"\"\n",
        "    Compact CoT: each column → 4 symbols [da][db][carry_out][digit].\n",
        "    - If use_epsilon_missing is True, a missing operand digit is shown as ε\n",
        "      (but numerically treated as 0 for the math).\n",
        "    - Steps joined by ',' and we omit any trailing carry step.\n",
        "    \"\"\"\n",
        "    carry = 0\n",
        "    steps = []\n",
        "    L = max(len(a_str_rev), len(b_str_rev))\n",
        "    for i in range(L):\n",
        "        a_ch = a_str_rev[i] if i < len(a_str_rev) else None\n",
        "        b_ch = b_str_rev[i] if i < len(b_str_rev) else None\n",
        "\n",
        "        da = int(a_ch) if a_ch is not None else 0\n",
        "        db = int(b_ch) if b_ch is not None else 0\n",
        "\n",
        "        total     = da + db + carry\n",
        "        digit     = total % 10\n",
        "        carry_out = total // 10\n",
        "\n",
        "        # What to *print* for the two operand digits in this step:\n",
        "        if use_epsilon_missing:\n",
        "            da_tok = a_ch if a_ch is not None else epsilon_char\n",
        "            db_tok = b_ch if b_ch is not None else epsilon_char\n",
        "        else:\n",
        "            da_tok = str(da)\n",
        "            db_tok = str(db)\n",
        "\n",
        "        steps.append(f\"{da_tok}{db_tok}{carry_out}{digit}\")\n",
        "        carry = carry_out\n",
        "\n",
        "    return \",\".join(steps)\n",
        "\n",
        "\n",
        "N_FILLER_FOR_HOLD_N = 15\n",
        "DISABLE_RANDOMIZED_FILLER_FOR_HOLD_N = False # Set to true for test set only\n",
        "# === Global max encoded length for MULT datasets (observed via simulation) ===\n",
        "GLOBAL_MULT_DATASET_MAX_TOKEN_LEN = None  # type: int | None\n",
        "MODEL_EVALUATE_MODE = False\n",
        "GLOBAL_MULT_WITNESS_AB = None  # type: tuple[int, int] | None\n",
        "# === Addition globals ===\n",
        "# GLOBAL_ADD_DATASET_MAX_TOKEN_LEN = None      # int | None\n",
        "# GLOBAL_ADD_WITNESS_AB = None                 # tuple[int, int] | None\n",
        "# ---- Global caches for ADDITION (keyed by max_digits) ----\n",
        "# try:\n",
        "#     GLOBAL_ADD_DATASET_MAX_TOKEN_LEN_MAP\n",
        "# except NameError:\n",
        "GLOBAL_ADD_DATASET_MAX_TOKEN_LEN_MAP = {}   # dict[int, int]\n",
        "\n",
        "# try:\n",
        "#     GLOBAL_ADD_WITNESS_AB_MAP\n",
        "# except NameError:\n",
        "GLOBAL_ADD_WITNESS_AB_MAP = {}              # dict[int, tuple[int,int]]\n",
        "\n",
        "\n",
        "\n",
        "# --------------------------\n",
        "# Dataset Implementation\n",
        "# --------------------------\n",
        "\n",
        "class ArithmeticDatasetWithBatching(Dataset):\n",
        "    \"\"\"\n",
        "    Extended dataset class supporting:\n",
        "      - 'addition', 'multiplication', 'token_copy', 'reverse'\n",
        "      - 'scan_dataset'\n",
        "      - and now a new 'dynamic_str_cpy' mode:\n",
        "         => Given a random digit string s plus a digit d unique in s,\n",
        "            the output is the substring of s from the (unique) position of d to end.\n",
        "    \"\"\"\n",
        "    def __init__(self, num_examples, max_digits, mode='multiplication',\n",
        "                 min_digits=1, examples_per_sequence=1,\n",
        "                 max_seq_len=30, min_seq_len=30,\n",
        "                 pin_min_and_max_digits_to_m_by_n_mult=False,\n",
        "                 batch_size=1, scan_file_path=None,\n",
        "                    # --- NEW CODE for stratify by length for SCAN task---\n",
        "                 stratify_by_length=False,\n",
        "                 odds_first_vocab_size: int = 2,\n",
        "\n",
        "                  max_depth_for_bft=2,\n",
        "                  max_children_for_bft=3,\n",
        "                  min_depth_for_bft=0,\n",
        "                 bucket_sort_vocab_size = 5, # Exactly the same as that used in the original: https://arxiv.org/pdf/2305.16843\n",
        "                 hold_n=3,\n",
        "                 reverse_input_output_step_size_for_hold_n=False,\n",
        "                 n_filler_for_hold_n=N_FILLER_FOR_HOLD_N,                   # ← new\n",
        "                 use_comma_delimiter=True,     # ← new\n",
        "                 randomize_padding_for_copy_hold_n=True,\n",
        "                 randomize_for_copy_hold_n=True,\n",
        "                #  <additionTask cot_epsilon_digit_tokens>\n",
        "                cot_epsilon_digit_tokens: bool = True,\n",
        "\n",
        "                 # ---------- NEW KNOBS for `datasetOptimForTorchCompile` ----------\n",
        "                 enforce_max_len_per_batch: bool = True,   # <<< NEW >>>\n",
        "                 pad_to_global_max: bool = False,           # <<< NEW >>>\n",
        "                 force_max_every_n: int | None = None      # <<< NEW >>>\n",
        "\n",
        "                 ):\n",
        "\n",
        "        super().__init__()\n",
        "        self.batch_size = batch_size\n",
        "        self.hold_n = hold_n\n",
        "        self.n_filler = n_filler_for_hold_n\n",
        "        self.hold_n  = hold_n\n",
        "\n",
        "        self.use_comma_delimiter = use_comma_delimiter\n",
        "        self.reverse_input_output_step_size_for_hold_n = reverse_input_output_step_size_for_hold_n\n",
        "\n",
        "        print(f'Initing dataset with batch size = {batch_size}')\n",
        "        self.mode = mode\n",
        "        self.max_depth_for_bft = max_depth_for_bft\n",
        "        self.max_children_for_bft = max_children_for_bft\n",
        "        self.min_depth_for_bft = min_depth_for_bft\n",
        "        self.cot_epsilon_digit_tokens = cot_epsilon_digit_tokens\n",
        "\n",
        "        self.scan_file_path = scan_file_path\n",
        "        self.stratify_by_length = stratify_by_length\n",
        "        self.odds_first_vocab_size = odds_first_vocab_size\n",
        "\n",
        "        self.max_seq_len = max_seq_len\n",
        "        self.min_seq_len = min_seq_len\n",
        "        self.bucket_sort_vocab_size = bucket_sort_vocab_size # Exactly the same as that used in the original: https://arxiv.org/pdf/2305.16843\n",
        "        self.batches = []\n",
        "        self.examples_per_sequence = examples_per_sequence\n",
        "        self.pin_min_and_max_digits_to_m_by_n_mult = pin_min_and_max_digits_to_m_by_n_mult\n",
        "        self.randomize_for_copy_hold_n = True\n",
        "\n",
        "        # ---------- NEW: controls for `datasetOptimForTorchCompile` ----------\n",
        "        self.enforce_max_len_per_batch = enforce_max_len_per_batch   # <<< NEW >>>\n",
        "        self.pad_to_global_max = pad_to_global_max                   # <<< NEW >>>\n",
        "        # Force one max-length sample every N examples (defaults to batch size)\n",
        "        self._force_every_n = force_max_every_n or batch_size        # <<< NEW >>>\n",
        "\n",
        "        # helper: sample a sequence length, ensuring every N-th is max_seq_len\n",
        "        def _sample_length_fn(i: int) -> int:                        # <<< NEW >>>\n",
        "            if self.enforce_max_len_per_batch and (i % self._force_every_n == 0):\n",
        "                return self.max_seq_len\n",
        "            return random.randint(self.min_seq_len, self.max_seq_len)\n",
        "        self._sample_length = _sample_length_fn                      # <<< NEW >>>\n",
        "\n",
        "        self._generate_examples(num_examples, max_digits, min_digits, examples_per_sequence)\n",
        "\n",
        "        self.shuffle_problems_and_generate_batches()\n",
        "\n",
        "\n",
        "    def _ensure_global_mult_max(self, min_digits: int, max_digits: int, samples: int = 1000) -> None:\n",
        "          \"\"\"\n",
        "          Monte-Carlo upper bound for encoded length in MULT and a witness (a,b).\n",
        "          Skips if globals already set.\n",
        "          \"\"\"\n",
        "          global GLOBAL_MULT_DATASET_MAX_TOKEN_LEN, GLOBAL_MULT_WITNESS_AB\n",
        "          if GLOBAL_MULT_DATASET_MAX_TOKEN_LEN is not None and GLOBAL_MULT_WITNESS_AB is not None:\n",
        "              self.global_max_encoded_len = GLOBAL_MULT_DATASET_MAX_TOKEN_LEN\n",
        "              self.global_mult_witness_ab = GLOBAL_MULT_WITNESS_AB\n",
        "              return\n",
        "\n",
        "          best_len = -1\n",
        "          best_pair = None\n",
        "          for s in range(samples):\n",
        "              # choose digit counts like your normal generator\n",
        "              if self.pin_min_and_max_digits_to_m_by_n_mult:\n",
        "                  a_digits = min_digits; b_digits = max_digits\n",
        "              else:\n",
        "                  # occasionally force a max sample to see the worst case\n",
        "                  if self.enforce_max_len_per_batch and (s % self._force_every_n == 0):\n",
        "                      a_digits = max_digits; b_digits = max_digits\n",
        "                  else:\n",
        "                      a_digits = random.randint(min_digits, max_digits)\n",
        "                      b_digits = random.randint(min_digits, max_digits)\n",
        "\n",
        "              a = self.random_number(a_digits, a_digits)\n",
        "              b = self.random_number(b_digits, b_digits)\n",
        "\n",
        "              prob = self.generate_multiplication_problem(a, b) + END_OF_PROBLEM_CHARACTER\n",
        "              # mirror batching: prepend NEW_COLUMN_CHARACTER when encoding\n",
        "              enc = encode_problem(f\"{NEW_COLUMN_CHARACTER}{prob}\", is_SCAN_problem=False)\n",
        "              L = len(enc)\n",
        "              if L > best_len:\n",
        "                  best_len = L\n",
        "                  best_pair = (a, b)\n",
        "\n",
        "          GLOBAL_MULT_DATASET_MAX_TOKEN_LEN = best_len\n",
        "          GLOBAL_MULT_WITNESS_AB = best_pair\n",
        "          self.global_max_encoded_len = best_len\n",
        "          self.global_mult_witness_ab = best_pair\n",
        "          print(f\"[ArithmeticDataset-MULT] GLOBAL_MULT_DATASET_MAX_TOKEN_LEN={best_len}, witness={best_pair}\")\n",
        "\n",
        "\n",
        "    def _generate_examples(self, num_examples, max_digits, min_digits, examples_per_sequence):\n",
        "        self.problems = []\n",
        "\n",
        "        # … existing modes above …\n",
        "\n",
        "        # ─── NEW MODE: copy_hold_n_sparse ───────────────────────\n",
        "        if self.mode in ('copy_hold_n', 'copy_hold_n_sparse'):\n",
        "            for _ in range(num_examples):\n",
        "                # sample a random digit sequence\n",
        "                length = random.randint(self.min_seq_len, self.max_seq_len)\n",
        "                seq = [str(random.randint(0, 9)) for _ in range(length)]\n",
        "\n",
        "                if self.reverse_input_output_step_size_for_hold_n:\n",
        "                    # inputs get hold_n, outputs are plain digits\n",
        "                    inp_parts = []\n",
        "                    for d in seq:\n",
        "                        inp_parts.append(d)\n",
        "                        inp_parts.extend(['z'] * self.hold_n)\n",
        "                        if self.use_comma_delimiter:\n",
        "                            inp_parts.append(',')\n",
        "\n",
        "                    if not self.randomize_for_copy_hold_n or DISABLE_RANDOMIZED_FILLER_FOR_HOLD_N:\n",
        "                        inp = '%' * self.n_filler\n",
        "                    else:\n",
        "                        inp = '%' * random.randint(3, max(self.n_filler+3,3+3))\n",
        "                    # inp = ''.join(inp_parts)\n",
        "                    inp = inp + ''.join(inp_parts)\n",
        "                    out = ''.join(seq)\n",
        "\n",
        "                else:\n",
        "                    # default: inputs = filler + digits, outputs = digit+hold_n+comma\n",
        "                    # inp = '%' * self.n_filler + ''.join(seq)\n",
        "                    if not self.randomize_for_copy_hold_n or DISABLE_RANDOMIZED_FILLER_FOR_HOLD_N:\n",
        "                        inp = '%' * self.n_filler\n",
        "                    else:\n",
        "                        inp = '%' * random.randint(3, max(self.n_filler+3,3+3))\n",
        "                    inp = inp + ''.join(seq)\n",
        "\n",
        "                    out_parts = []\n",
        "                    for d in seq:\n",
        "                        out_parts.append(d)\n",
        "                        out_parts.extend(['z'] * self.hold_n)\n",
        "                        if self.use_comma_delimiter:\n",
        "                            out_parts.append(',')\n",
        "                    out = ''.join(out_parts)\n",
        "\n",
        "                example = f\"{inp}={out}{END_OF_PROBLEM_CHARACTER}\"\n",
        "                self.problems.append(example)\n",
        "            return\n",
        "        # 0) Handle 'odds_first' mode\n",
        "        if self.mode == 'odds_first':\n",
        "            # Derived as an exact copy from:\n",
        "            # https://raw.githubusercontent.com/google-deepmind/\n",
        "            #   randomized_positional_encodings/refs/heads/main/\n",
        "            #   tasks/cs/odds_first.py\n",
        "\n",
        "            for i in range(num_examples):\n",
        "                # length = random.randint(self.min_seq_len, self.max_seq_len)\n",
        "                length = self._sample_length(i)                            # <<< NEW\n",
        "                # sample a random string over {0,..,vocab_size-1}\n",
        "                seq = [random.randint(0, self.odds_first_vocab_size-1)\n",
        "                       for _ in range(length)]\n",
        "                # odds first (1-based indexing→odd positions are seq[1], seq[3],…)\n",
        "                out_seq = seq[1::2] + seq[0::2]\n",
        "\n",
        "                inp = \"\".join(str(d) for d in seq)\n",
        "                out = \"\".join(str(d) for d in out_seq)\n",
        "                self.problems.append(f\"{inp}={out}{END_OF_PROBLEM_CHARACTER}\")\n",
        "            return\n",
        "\n",
        "\n",
        "        # 0) Handle 'stack_manipulation' mode\n",
        "        elif self.mode == 'stack_manipulation':\n",
        "            # Derived as an exact copy from:\n",
        "            # https://github.com/google-deepmind/randomized_positional_encodings/\n",
        "            #   blob/main/tasks/cs/stack_manipulation.py\n",
        "            for i in range(num_examples):\n",
        "\n",
        "                length = self._sample_length(i)                            # <<< NEW\n",
        "                # length = random.randint(self.min_seq_len, self.max_seq_len)\n",
        "                # If length == 1, just one bit, no actions\n",
        "                if length == 1:\n",
        "                    stack = [random.randint(0, 1)]\n",
        "                    actions = []\n",
        "                else:\n",
        "                    # choose initial stack length in [1, length-1]\n",
        "                    stack_len = random.randint(1, length - 1)\n",
        "                    stack = [random.randint(0, 1) for _ in range(stack_len)]\n",
        "                    # remaining tokens are actions in {2:POP, 3:PUSH0, 4:PUSH1}\n",
        "                    actions = [random.randint(2, 4) for _ in range(length - stack_len)]\n",
        "\n",
        "                # simulate\n",
        "                current = list(stack)\n",
        "                for act in actions:\n",
        "                    if act == 2:            # POP\n",
        "                        if current:\n",
        "                            current.pop()\n",
        "                    elif act in (3, 4):     # PUSH 0 or 1\n",
        "                        current.append(act - 3)\n",
        "\n",
        "                # build input string: stack bottom-to-top, then actions\n",
        "                inp_seq = stack + actions\n",
        "                inp = \"\".join(str(d) for d in inp_seq)\n",
        "\n",
        "                # build output: final stack top-to-bottom, then termination '2', pad with '0'\n",
        "                result = current[::-1]\n",
        "                result.append(2)  # termination symbol\n",
        "                # pad to (length+1)\n",
        "                pad_n = length + 1 - len(result)\n",
        "                result.extend([0] * pad_n)\n",
        "                out = \"\".join(str(d) for d in result)\n",
        "\n",
        "                self.problems.append(f\"{inp}={out}{END_OF_PROBLEM_CHARACTER}\")\n",
        "            return\n",
        "\n",
        "\n",
        "        # missing_duplicate\n",
        "        elif self.mode == 'missing_duplicate':\n",
        "            for i in range(num_examples):                                  # <<< CHANGED i\n",
        "                length = self._sample_length(i)                            # <<< NEW\n",
        "                half   = length // 2\n",
        "\n",
        "                # 1) sample original binary substring\n",
        "                orig = [str(random.randint(0, 1)) for _ in range(half)]\n",
        "                dup  = orig + orig\n",
        "\n",
        "                # 2) choose missing index and mask with '2'\n",
        "                idx     = random.randint(0, len(dup)-1)\n",
        "                missing = dup[idx]\n",
        "                dup[idx] = '2'\n",
        "\n",
        "                # 3) if odd length, pad with '3'\n",
        "                if length % 2 == 1:\n",
        "                    dup.append('3')\n",
        "\n",
        "                inp = \"\".join(dup)\n",
        "                # target is the missing bit ('0' or '1')\n",
        "                example = f\"{inp}={missing}{END_OF_PROBLEM_CHARACTER}\"\n",
        "                self.problems.append(example)\n",
        "            return\n",
        "\n",
        "        # Handle 'bucket_sort' mode\n",
        "        if self.mode == 'bucket_sort':\n",
        "            # Derived as an exact copy from:\n",
        "            # https://github.com/google-deepmind/randomized_positional_encodings/\n",
        "            #      blob/main/tasks/cs/bucket_sort.py\n",
        "            for i in range(num_examples):\n",
        "                # pick a random length in [min_seq_len, max_seq_len]\n",
        "                # length = random.randint(self.min_seq_len, self.max_seq_len)\n",
        "                length = self._sample_length(i)                            # <<< NEW\n",
        "                # sample tokens from {0,...,vocab_size-1}\n",
        "                # print(f'Generating bucket_sort problem with length={length}, min_seq_len={self.min_seq_len}, max_seq_len={self.max_seq_len}, bucket_sort_vocab_size={self.bucket_sort_vocab_size}')\n",
        "\n",
        "                seq = [random.randint(0, self.bucket_sort_vocab_size - 1)\n",
        "                       for _ in range(length)]\n",
        "\n",
        "                inp  = \"\".join(str(d) for d in seq)\n",
        "                outp = \"\".join(str(d) for d in sorted(seq))\n",
        "                # form \"input=sorted_output.\"\n",
        "                example = f\"{inp}={outp}{END_OF_PROBLEM_CHARACTER}\"\n",
        "                self.problems.append(example)\n",
        "            return\n",
        "\n",
        "        if self.mode == 'bfs_digits':\n",
        "            print(f'Generating BFS digits dataset, with num_examples={num_examples}, max_depth={self.max_depth_for_bft}, max_children={self.max_children_for_bft}')\n",
        "            for _ in range(num_examples):\n",
        "                # Generate random integer from min_depth_for_bft...max_depth_for_bft inclusive:\n",
        "                clamped_depth_random = random.randint(self.min_depth_for_bft, self.max_depth_for_bft)\n",
        "                nested_list = generate_random_nested_list(\n",
        "                    min_depth=clamped_depth_random,\n",
        "                    max_depth=clamped_depth_random,\n",
        "\n",
        "                    # min_depth=self.min_depth_for_bft,\n",
        "                    # max_depth=self.max_depth_for_bft,\n",
        "                    max_children=self.max_children_for_bft,\n",
        "\n",
        "                    max_digits_per_list=self.max_seq_len\n",
        "                )\n",
        "                nested_str = nested_list_to_string(nested_list)\n",
        "                # levels = bfs_digits_by_level(nested_list)\n",
        "                levels = bfs_digits_by_level_including_empty(nested_list)\n",
        "                # bfs_str = build_bfs_string(levels)\n",
        "                bfs_str = build_bfs_string_include_empty(levels)\n",
        "                example = f\"NESTED:{nested_str} = {bfs_str}{END_OF_PROBLEM_CHARACTER}\"\n",
        "\n",
        "                self.problems.append(example)\n",
        "            return\n",
        "\n",
        "\n",
        "        # 1) Handle 'scan_dataset' mode\n",
        "        if self.mode == 'scan_dataset':\n",
        "              import os, time\n",
        "              if not self.scan_file_path or (not os.path.exists(self.scan_file_path)):\n",
        "                  raise ValueError(\n",
        "                      f\"For 'scan_dataset' mode, must provide valid scan_file_path. \"\n",
        "                      f\"Given: {self.scan_file_path}\"\n",
        "                  )\n",
        "\n",
        "              start_time_for_runtime_logging = time.time()\n",
        "              with open(self.scan_file_path, 'r', encoding='utf-8') as f:\n",
        "                  lines = f.readlines()\n",
        "\n",
        "              random.shuffle(lines)\n",
        "              lines = lines[: num_examples * 10]  # oversample to give us room to hit targets\n",
        "\n",
        "              # Normalize and augment lines -> raw_lines\n",
        "              raw_lines = []\n",
        "              for line in lines:\n",
        "                  line = line.strip()\n",
        "                  if not line or \"OUT:\" not in line:\n",
        "                      continue\n",
        "                  # Convert IN:/OUT: -> \"=\" form and optionally augment\n",
        "                  line = line.replace(\"IN:\", \"\").replace(\"OUT:\", \"=\").strip()\n",
        "                  line = augment_scan_line_with_numbering(line)\n",
        "                  raw_lines.append(f\"{line}{END_OF_PROBLEM_CHARACTER}\")\n",
        "\n",
        "              # Length-filter into [min_seq_len, max_seq_len] in tokenized space\n",
        "              # and build length buckets for targeted selection.\n",
        "              from collections import defaultdict\n",
        "              length_buckets: dict[int, list[str]] = defaultdict(list)\n",
        "              filtered_lines = []\n",
        "              for line in raw_lines:\n",
        "                  tok_len = len(encode_problem(line))  # tokenized length\n",
        "                  if (self.min_seq_len is not None and tok_len < self.min_seq_len) or \\\n",
        "                    (self.max_seq_len is not None and tok_len > self.max_seq_len):\n",
        "                      continue\n",
        "                  filtered_lines.append(line)\n",
        "                  length_buckets[tok_len].append(line)\n",
        "\n",
        "              # Nothing to sample? Fall back safely.\n",
        "              if not filtered_lines:\n",
        "                  self.problems = []\n",
        "                  print(\"[ArithmeticDataset - SCAN] No lines within length bounds; produced 0 examples.\")\n",
        "                  return\n",
        "\n",
        "              # Sorted list of available lengths for nearest-length lookup.\n",
        "              avail_lengths = sorted(length_buckets.keys())\n",
        "\n",
        "              def _pop_from_bucket_of_length(L: int) -> str | None:\n",
        "                  \"\"\"Pop one line from exact-length bucket if available.\"\"\"\n",
        "                  bucket = length_buckets.get(L)\n",
        "                  if bucket:\n",
        "                      # pop() is O(1); order within a bucket is unimportant\n",
        "                      return bucket.pop()\n",
        "                  return None\n",
        "\n",
        "              def _nearest_length(target: int) -> int:\n",
        "                  \"\"\"\n",
        "                  Choose the available length closest to target; prefer longer on ties.\n",
        "                  \"\"\"\n",
        "                  # linear scan is fine (length set is small); if large, bisect would work too\n",
        "                  bestL, bestKey = None, None\n",
        "                  for L in avail_lengths:\n",
        "                      if not length_buckets[L]:  # skip depleted buckets\n",
        "                          continue\n",
        "                      # (distance, -L) so ties prefer larger L\n",
        "                      key = (abs(L - target), -L)\n",
        "                      if bestKey is None or key < bestKey:\n",
        "                          bestKey, bestL = key, L\n",
        "                  return bestL\n",
        "\n",
        "              # Helper to remove exhausted lengths from avail_lengths\n",
        "              def _prune_empty(L: int):\n",
        "                  if L in length_buckets and not length_buckets[L]:\n",
        "                      # lazy prune; leave L in avail_lengths if you prefer stability\n",
        "                      pass\n",
        "\n",
        "              # Decide how many we’ll actually produce\n",
        "              N = min(num_examples, len(filtered_lines))\n",
        "\n",
        "              selected: list[str] = []\n",
        "              # If you don’t want targeted sampling, keep legacy behavior.\n",
        "              if not getattr(self, \"enforce_max_len_per_batch\", False):\n",
        "                  random.shuffle(filtered_lines)\n",
        "                  selected = filtered_lines[:N]\n",
        "              else:\n",
        "                  # Targeted sampling: every self._force_every_n-th example aims for max length;\n",
        "                  # others aim for self._sample_length(i)\n",
        "                  for i in range(N):\n",
        "                      target_len = self._sample_length(i)  # this returns max_seq_len at forced indices\n",
        "                      # Try exact length first\n",
        "                      line = _pop_from_bucket_of_length(target_len)\n",
        "                      if line is None:\n",
        "                          # Fallback: nearest available (preferring longer)\n",
        "                          L_star = _nearest_length(target_len)\n",
        "                          if L_star is not None:\n",
        "                              line = _pop_from_bucket_of_length(L_star)\n",
        "                              _prune_empty(L_star)\n",
        "                      if line is None:\n",
        "                          # Final fallback: any remaining line\n",
        "                          # (flatten remaining buckets once, lazily)\n",
        "                          remaining = [ln for L, bucket in length_buckets.items() for ln in bucket if bucket]\n",
        "                          if not remaining:\n",
        "                              break\n",
        "                          line = remaining.pop()\n",
        "                          # Remove it from its bucket\n",
        "                          tok_len = len(encode_problem(line))\n",
        "                          if tok_len in length_buckets and line in length_buckets[tok_len]:\n",
        "                              length_buckets[tok_len].remove(line)\n",
        "                      selected.append(line)\n",
        "\n",
        "                  # If we fell short (e.g., not enough within bounds), pad from whatever remains\n",
        "                  if len(selected) < N:\n",
        "                      remaining = [ln for L, bucket in length_buckets.items() for ln in bucket if bucket]\n",
        "                      random.shuffle(remaining)\n",
        "                      selected.extend(remaining[: (N - len(selected))])\n",
        "\n",
        "              self.problems = selected\n",
        "              print(f'[ArithmeticDataset - SCAN dataset] total time to process lines: {time.time() - start_time_for_runtime_logging:.3f}s')\n",
        "              return\n",
        "\n",
        "\n",
        "        # 2) Handle other tasks (addition, multiplication, token_copy, reverse, etc.)\n",
        "        # Note: You might want to ensure the block below only runs if self.mode != 'scan_dataset'\n",
        "        # because the above block already populates self.problems.\n",
        "        # We'll do the standard loop:\n",
        "        elif self.mode != 'scan_dataset':\n",
        "\n",
        "\n",
        "            if self.mode in ( 'multiplication'):\n",
        "                assert self.enforce_max_len_per_batch, \"enforce_max_len_per_batch must be True for multiplication\"\n",
        "\n",
        "                # --- NEW: if MULT, compute witness once and pre-build pools ---\n",
        "                if self.mode == 'multiplication':\n",
        "                    global MODEL_EVALUATE_MODE\n",
        "                    self._ensure_global_mult_max(min_digits, max_digits, samples=1000)\n",
        "                    assert self.global_mult_witness_ab is not None, \"witness (a,b) unavailable\"\n",
        "\n",
        "                    # how many batches will be produced (target), so we can place 1 witness per batch\n",
        "                    n_batches_target = max(1, math.ceil(num_examples / self.batch_size))\n",
        "\n",
        "                    # build exactly n_batches_target witness examples\n",
        "                    if not MODEL_EVALUATE_MODE:\n",
        "                        a_wit, b_wit = self.global_mult_witness_ab\n",
        "                        self.special_examples = [\n",
        "                            self.generate_multiplication_problem(a_wit, b_wit) + END_OF_PROBLEM_CHARACTER\n",
        "                            for _ in range(n_batches_target)\n",
        "                        ]\n",
        "                    else:\n",
        "                        self.special_examples = []\n",
        "\n",
        "                    # build the remaining (normal) examples so total == num_examples\n",
        "                    n_normals = max(0, num_examples - len(self.special_examples))\n",
        "                    self._normal_examples = []\n",
        "                    for _ in range(n_normals):\n",
        "                        if self.pin_min_and_max_digits_to_m_by_n_mult:\n",
        "                            a = self.random_number(min_digits, min_digits)\n",
        "                            b = self.random_number(max_digits, max_digits)\n",
        "                        else:\n",
        "                            a = self.random_number(max_digits, min_digits)\n",
        "                            b = self.random_number(max_digits, min_digits)\n",
        "                        self._normal_examples.append(\n",
        "                            self.generate_multiplication_problem(a, b) + END_OF_PROBLEM_CHARACTER\n",
        "                        )\n",
        "\n",
        "                    # store (order will be enforced later in shuffle)\n",
        "                    self.problems = list(self._normal_examples) + list(self.special_examples)\n",
        "                    return\n",
        "            elif self.mode in ('addition'):\n",
        "                  # --- inside _generate_examples(...), in the 'addition' branch ---\n",
        "                  # 1) Find/cache the worst-case witness (still useful for global padding)\n",
        "                  self._ensure_global_add_max(min_digits, max_digits, samples=1000)\n",
        "\n",
        "                  _eval_mode = bool(globals().get(\"MODEL_EVALUATE_MODE\", False))\n",
        "\n",
        "                  # 2) Build exactly one witness per batch unless we're evaluating\n",
        "                  n_batches_target = max(1, math.ceil(num_examples / self.batch_size))\n",
        "                  if not _eval_mode:\n",
        "                      a_wit, b_wit = self.global_add_witness_ab\n",
        "                      self.special_examples = [\n",
        "                          self._build_add_example(a_wit, b_wit) for _ in range(n_batches_target)\n",
        "                      ]\n",
        "\n",
        "                  else:\n",
        "                      self.special_examples = []   # <<< no specials in eval\n",
        "\n",
        "                  # 3) Fill remainder with normal additions\n",
        "                  n_normals = max(0, num_examples - len(self.special_examples))\n",
        "                  self._normal_examples = []\n",
        "                  for _ in range(n_normals):\n",
        "                      if self.pin_min_and_max_digits_to_m_by_n_mult:\n",
        "                          a = self.random_number(min_digits, min_digits)\n",
        "                          b = self.random_number(max_digits, max_digits)\n",
        "                      else:\n",
        "                          a = self.random_number(max_digits, min_digits)\n",
        "                          b = self.random_number(max_digits, min_digits)\n",
        "                      self._normal_examples.append(self._build_add_example(a, b))\n",
        "\n",
        "                  # 4) Store; ordering/interleave handled in shuffle()\n",
        "                  self.problems = list(self._normal_examples) + list(self.special_examples)\n",
        "                  return\n",
        "            elif self.mode == 'token_copy':\n",
        "                length = random.randint(self.min_seq_len, self.max_seq_len)\n",
        "                digits = '0123456789'\n",
        "                problem = ''.join(random.choices(digits, k=length))\n",
        "                solution = problem\n",
        "                example = f\"{problem}={solution}{END_OF_PROBLEM_CHARACTER}\"\n",
        "                self.problems.append(example)\n",
        "                return\n",
        "\n",
        "            elif self.mode == 'reverse':\n",
        "                digits = '0123456789'\n",
        "                length = random.randint(self.min_seq_len, self.max_seq_len)\n",
        "                problem = ''.join(random.choices(digits, k=length))\n",
        "                solution = problem[::-1]\n",
        "                example = f\"{problem}={solution}{END_OF_PROBLEM_CHARACTER}\"\n",
        "                self.problems.append(example)\n",
        "                return\n",
        "\n",
        "            elif self.mode == 'dynamic_str_cpy':\n",
        "                for i in range(max(1, num_examples // examples_per_sequence)):\n",
        "                    for j in range(examples_per_sequence):\n",
        "                        length = self._sample_length(i * examples_per_sequence + j)   # <<< NEW\n",
        "                        d = random.choice('0123456789')\n",
        "                        idx = random.randrange(length)\n",
        "                        others = [x for x in '0123456789' if x != d]\n",
        "                        s_list = random.choices(others, k=length)\n",
        "                        s_list[idx] = d\n",
        "                        s = ''.join(s_list)\n",
        "                        solution = s[idx:]\n",
        "                        self.problems.append(f\"{s},{d}={solution}{END_OF_PROBLEM_CHARACTER}\")\n",
        "\n",
        "    def shuffle_problems_and_generate_batches(self):\n",
        "          assert len(self.problems) > 0\n",
        "\n",
        "          # -------------------------------\n",
        "          # 1) Build the source_list order\n",
        "          # -------------------------------\n",
        "          # If we have 'special_examples' (e.g., for addition/multiplication witnesses),\n",
        "          # interleave exactly one special per batch-worth of items.\n",
        "          if self.mode in ('addition', 'multiplication') and hasattr(self, 'special_examples') and self.special_examples:\n",
        "              import math\n",
        "              normals = list(getattr(self, '_normal_examples', []))\n",
        "              specials = list(self.special_examples)\n",
        "              np.random.shuffle(normals)\n",
        "\n",
        "              total_examples = len(normals) + len(specials)\n",
        "              n_batches_target = max(1, math.ceil(total_examples / self.batch_size))\n",
        "              # \"group\" = how many examples we will consume per batch (examples_per_sequence packed per slot)\n",
        "              group = self.batch_size * max(1, self.examples_per_sequence)\n",
        "\n",
        "              ordered = []\n",
        "              s_i = n_i = 0\n",
        "              for _ in range(n_batches_target):\n",
        "                  # place exactly one special at the start of this batch-worth\n",
        "                  if s_i < len(specials):\n",
        "                      ordered.append(specials[s_i]); s_i += 1\n",
        "                  # then fill remaining slots with normals\n",
        "                  for _ in range(group - 1):\n",
        "                      if n_i < len(normals):\n",
        "                          ordered.append(normals[n_i]); n_i += 1\n",
        "\n",
        "              # append leftovers (usually none for specials, maybe some normals)\n",
        "              ordered.extend(normals[n_i:])\n",
        "              ordered.extend(specials[s_i:])  # should be empty if counts matched\n",
        "\n",
        "              source_list = ordered\n",
        "          else:\n",
        "              # default: just shuffle the problems we already built\n",
        "              source_list = list(self.problems)\n",
        "              np.random.shuffle(source_list)\n",
        "\n",
        "          # ---------------------------------------\n",
        "          # 2) Encode into batches from source_list\n",
        "          # ---------------------------------------\n",
        "          self.batches = []\n",
        "          j = 0\n",
        "          total_examples = len(source_list)\n",
        "\n",
        "          while j < total_examples:\n",
        "              batch_combined_problems = []\n",
        "              while len(batch_combined_problems) < self.batch_size and j < total_examples:\n",
        "                  combined_problem = ''\n",
        "                  # pack up to examples_per_sequence problems into one slot\n",
        "                  for _ in range(self.examples_per_sequence):\n",
        "                      if j >= total_examples:\n",
        "                          break\n",
        "                      p = source_list[j]  # <<< USE source_list, not self.problems\n",
        "                      # keep MAX_SEQ_LEN guard\n",
        "                      if len(combined_problem + p) < MAX_SEQ_LEN - 5:\n",
        "                          combined_problem += p\n",
        "                          assert p[-1] == END_OF_PROBLEM_CHARACTER, \\\n",
        "                              f\"Every problem should end with END_OF_PROBLEM_CHARACTER: got {p[-1]}\"\n",
        "                          j += 1\n",
        "                      else:\n",
        "                          # if the very first item is too long, still include it to avoid stalling\n",
        "                          if not combined_problem:\n",
        "                              combined_problem = p\n",
        "                              j += 1\n",
        "                          break\n",
        "\n",
        "                  if combined_problem:\n",
        "                      combined_problem = f'{NEW_COLUMN_CHARACTER}{combined_problem}'\n",
        "                      encoded_problem = encode_problem(\n",
        "                          combined_problem,\n",
        "                          is_SCAN_problem=self.mode == 'scan_dataset' or self.mode == 'bfs_digits'\n",
        "                      )\n",
        "                      batch_combined_problems.append(encoded_problem)\n",
        "\n",
        "              if batch_combined_problems:\n",
        "                  self.batches.append(batch_combined_problems)\n",
        "\n",
        "          # ---------------------------------------\n",
        "          # 3) Pad to a single target length\n",
        "          # ---------------------------------------\n",
        "          if self.batch_size > 1:\n",
        "              # local fallback\n",
        "              batch_local_max = 0\n",
        "              for batch in self.batches:\n",
        "                  for p in batch:\n",
        "                      batch_local_max = max(batch_local_max, len(p))\n",
        "\n",
        "              # prefer global target if requested and available\n",
        "              if self.pad_to_global_max and getattr(self, \"_global_pad_target\", None):\n",
        "                  target_len = int(self._global_pad_target)\n",
        "              else:\n",
        "                  target_len = batch_local_max\n",
        "\n",
        "              # safety: raise target if we underestimated\n",
        "              for batch in self.batches:\n",
        "                  for p in batch:\n",
        "                      if len(p) > target_len:\n",
        "                          target_len = len(p)\n",
        "\n",
        "              pad_id = char2idx(PAD_CHARACTER)\n",
        "              new_batches = []\n",
        "              for batch in self.batches:\n",
        "                  new_batch = []\n",
        "                  for p in batch:\n",
        "                      if len(p) < target_len:\n",
        "                          p = p + [pad_id] * (target_len - len(p))\n",
        "                      new_batch.append(p)\n",
        "                  new_batches.append(new_batch)\n",
        "              self.batches = new_batches\n",
        "\n",
        "\n",
        "\n",
        "    def _build_add_example(self, a: int, b: int) -> str:\n",
        "          \"\"\"Build a *single* addition training example string (exactly as in generation).\"\"\"\n",
        "          a_rev, b_rev = str(a)[::-1], str(b)[::-1]\n",
        "          problem = f\"{a_rev}+{b_rev}=\"\n",
        "          cot = build_addition_cot_compact(\n",
        "              a_rev, b_rev,\n",
        "              use_epsilon_missing=self.cot_epsilon_digit_tokens\n",
        "          )\n",
        "          solution = str(a + b)[::-1]\n",
        "          return f\"{problem}{cot} → {solution}{END_OF_PROBLEM_CHARACTER}\"\n",
        "\n",
        "    # <datasetOptimForTorchCompile>\n",
        "    def _ensure_global_add_max(self, min_digits: int, max_digits: int, samples: int = 1000) -> None:\n",
        "        \"\"\"\n",
        "        Monte-Carlo upper bound for encoded length in ADD and a witness (a,b),\n",
        "        cached PER max_digits. Also sets self._global_pad_target for global padding.\n",
        "        \"\"\"\n",
        "        global GLOBAL_ADD_DATASET_MAX_TOKEN_LEN_MAP, GLOBAL_ADD_WITNESS_AB_MAP\n",
        "\n",
        "        key = int(max_digits)  # cache per \"maximum number of digits\"\n",
        "\n",
        "        if key in GLOBAL_ADD_DATASET_MAX_TOKEN_LEN_MAP and key in GLOBAL_ADD_WITNESS_AB_MAP:\n",
        "            self.global_add_max_encoded_len = GLOBAL_ADD_DATASET_MAX_TOKEN_LEN_MAP[key]\n",
        "            self.global_add_witness_ab      = GLOBAL_ADD_WITNESS_AB_MAP[key]\n",
        "            self._global_pad_target         = self.global_add_max_encoded_len\n",
        "            return\n",
        "\n",
        "        best_len  = -1\n",
        "        best_pair = None\n",
        "        for s in range(samples):\n",
        "            # Sample digit counts the same way you build training data\n",
        "            if self.pin_min_and_max_digits_to_m_by_n_mult:\n",
        "                a_digits = min_digits\n",
        "                b_digits = max_digits\n",
        "            else:\n",
        "                a_digits = random.randint(min_digits, max_digits)\n",
        "                b_digits = random.randint(min_digits, max_digits)\n",
        "\n",
        "            a = self.random_number(a_digits, a_digits)\n",
        "            b = self.random_number(b_digits, b_digits)\n",
        "\n",
        "            # Build & encode exactly like runtime (include NEW_COLUMN_CHARACTER)\n",
        "            example = self._build_add_example(a, b)\n",
        "            enc     = encode_problem(f\"{NEW_COLUMN_CHARACTER}{example}\", is_SCAN_problem=False)\n",
        "            L       = len(enc)\n",
        "            if L > best_len:\n",
        "                best_len  = L\n",
        "                best_pair = (a, b)\n",
        "\n",
        "        # Store in global dicts\n",
        "        GLOBAL_ADD_DATASET_MAX_TOKEN_LEN_MAP[key] = best_len\n",
        "        GLOBAL_ADD_WITNESS_AB_MAP[key]            = best_pair\n",
        "\n",
        "        # Reflect into the instance\n",
        "        self.global_add_max_encoded_len = best_len\n",
        "        self.global_add_witness_ab      = best_pair\n",
        "        self._global_pad_target         = best_len\n",
        "\n",
        "        print(f\"[ArithmeticDataset-ADD] key=max_digits={key} \"\n",
        "              f\"GLOBAL_ADD_DATASET_MAX_TOKEN_LEN_MAP[{key}]={best_len}, \"\n",
        "              f\"witness={best_pair}\")\n",
        "\n",
        "\n",
        "    def generate_multiplication_problem(self, a, b):\n",
        "        a_str = str(a)\n",
        "        b_str = str(b)\n",
        "        problem = f\"{a_str}x{b_str}=\"\n",
        "        problem += f\"{a}x[\"\n",
        "        summands = []\n",
        "        L = len(b_str)\n",
        "        for i, digit in enumerate(b_str):\n",
        "            if digit == '0':\n",
        "                summand = \"0\"\n",
        "            else:\n",
        "                summand = f\"{digit}*\"\n",
        "                mapping_tokens = []\n",
        "                for j in range(i, L):\n",
        "                    current_digit = b_str[j]\n",
        "                    if current_digit == '0':\n",
        "                        if RemoveDigitHintsForMultDataset:\n",
        "                            mapping_token = \"0\"\n",
        "                        else:\n",
        "                            mapping_token = f\"({current_digit}->0)\"\n",
        "                    else:\n",
        "                        mapping_value = \"1\" if j == i else \"0\"\n",
        "                        if RemoveDigitHintsForMultDataset:\n",
        "                            mapping_token = f\"{mapping_value}\"\n",
        "                        else:\n",
        "                            mapping_token = f\"({current_digit}->{mapping_value})\"\n",
        "                    mapping_tokens.append(mapping_token)\n",
        "                summand += \"\".join(mapping_tokens)\n",
        "            summands.append(summand)\n",
        "        problem += \"+\".join(summands) + \"]\"\n",
        "        return problem\n",
        "\n",
        "    def random_number(self, max_digits, min_digits=1):\n",
        "        num_digits = random.randint(min_digits, max_digits)\n",
        "        r = random.randint(10**(num_digits-1), 10**num_digits - 1)\n",
        "        while r == 0:\n",
        "            r = random.randint(10**(num_digits-1), 10**num_digits - 1)\n",
        "        return r\n",
        "\n",
        "    def __len__(self):\n",
        "        return len(self.batches)\n",
        "\n",
        "    def __getitem__(self, idx):\n",
        "        r = torch.tensor(self.batches[idx], dtype=torch.long)\n",
        "        return r\n",
        "\n",
        "\n",
        "import matplotlib.pyplot as plt\n",
        "from collections import Counter\n",
        "\n",
        "def visualize_length_distribution(lines):\n",
        "    \"\"\"\n",
        "    Given a list of text examples (lines), encode each with encode_problem,\n",
        "    compute the distribution of token lengths, and display a histogram.\n",
        "    \"\"\"\n",
        "    length_counts = Counter()\n",
        "    for line in lines:\n",
        "        token_len = len(encode_problem(line))\n",
        "        length_counts[token_len] += 1\n",
        "\n",
        "    lengths = sorted(length_counts.keys())\n",
        "    counts = [length_counts[l] for l in lengths]\n",
        "\n",
        "    plt.bar(lengths, counts)\n",
        "    plt.xlabel('Sequence length (tokens)')\n",
        "    plt.ylabel('Count')\n",
        "    plt.title('Length Distribution')\n",
        "    plt.show()\n"
      ],
      "metadata": {
        "id": "aMoAKImBF5yc",
        "trusted": true,
        "execution": {
          "iopub.status.busy": "2025-09-17T19:06:52.270669Z",
          "iopub.execute_input": "2025-09-17T19:06:52.270870Z",
