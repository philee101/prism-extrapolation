      "cell_type": "markdown",
      "source": [
        "## Print/Visualize cached sigmoid activation values\n"
      ],
      "metadata": {
        "id": "XW7XsTxCtg0y"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "def _plot_prob_distribution_of_activation_values(cached_sigmoid_activation_values, title='Probability Distribution of Cached Sigmoid Activation Values'):\n",
        "    # Convert to numpy array\n",
        "    cached_sigmoid_activation_values = np.array(cached_sigmoid_activation_values)\n",
        "    # Sort:\n",
        "    cached_sigmoid_activation_values.sort()\n",
        "    # Plot histogram\n",
        "    plt.figure(figsize=(10, 6))\n",
        "    plt.hist(cached_sigmoid_activation_values, bins=50, density=True, alpha=0.6, color='b')\n",
        "    plt.xlabel('Value')\n",
        "    plt.ylabel('Probability Density')\n",
        "    plt.title(title)\n",
        "    plt.grid(True)\n",
        "    plt.show()\n",
        "\n",
        "def visualize_cached_sigmoid_activation_values(model, gate='output'):\n",
        "    if model == None or not model.model_is_rse:\n",
        "        return\n",
        "    len_cached = 0\n",
        "    print(f'ALLOW_X_SHIFT = {ALLOW_X_SHIFT}')\n",
        "    if gate == 'output':\n",
        "\n",
        "        for module in model_rse.modules():\n",
        "            if hasattr(module, 'output_gate_sigmoid_activation_values_for_logging'):\n",
        "                # print(f'Scaling factors = {module.output_affine_scaling}')\n",
        "                # print(f'Module {type(module)} has cached output_gate_sigmoid_activation_values_for_logging:')\n",
        "                print('---' * 50)\n",
        "                print(f'output_gate_sigmoid_activation_values_for_logging for Module label: {module.label}')\n",
        "                cached = module.output_gate_sigmoid_activation_values_for_logging\n",
        "                len_cached = len(cached)\n",
        "                if len_cached == 0:\n",
        "                    continue\n",
        "\n",
        "                print(f'len_cached = {len_cached}, type(cached) = {type(cached)}, cached[0].shape = {cached[0].shape}')\n",
        "                cached = torch.tensor(list(cached))\n",
        "                print('cached tensor shape=',cached.shape)\n",
        "\n",
        "                for o in range(module.num_operators):\n",
        "                    print('---' * 10)\n",
        "                    print(f'Printing for operator {o}...')\n",
        "                    arr = cached[:, o].numpy()\n",
        "\n",
        "                    # Print min, max, mean, median:\n",
        "                    print(f'min: {np.min(arr)}, max: {np.max(arr)}, mean: {np.mean(arr)}, median: {np.median(arr)}')\n",
        "\n",
        "                    _plot_prob_distribution_of_activation_values(arr, title=f'Probability Distribution of Cached Output Sigmoid Activation Values for {module.label}')\n",
        "                print('---' * 50)\n",
        "\n",
        "    if gate == 'decrement':\n",
        "        for module in model_rse.modules():\n",
        "                if isinstance(module, RelativePositionEncoding):\n",
        "                    assert hasattr(module, 'output_gate_sigmoid_activation_values_for_logging')\n",
        "                    assert hasattr(module, 'reset_gate_sigmoid_activation_values_for_logging')\n",
        "                    assert hasattr(module, 'decrement_gate_sigmoid_activation_values_for_logging')\n",
        "\n",
        "                if hasattr(module, 'decrement_gate_sigmoid_activation_values_for_logging'):\n",
        "                    name_of_parameter = type(module)\n",
        "                    # print(f'[Layer {layer_idx}] Module {name_of_parameter} has cached reset_gate_sigmoid_activation_values_for_logging:')\n",
        "                    # print(f'Module {type(module)} has cached output_gate_sigmoid_activation_values_for_logging:')\n",
        "                    print(f'decrement_gate_sigmoid_activation_values_for_logging for Module label: {module.label}')\n",
        "\n",
        "                    cached = module.decrement_gate_sigmoid_activation_values_for_logging\n",
        "\n",
        "                    len_cached = len(cached)\n",
        "\n",
        "                    if len_cached == 0:\n",
        "                        continue\n",
        "\n",
        "                    print(f'len_cached = {len_cached}, type(cached) = {type(cached)}, cached[0].shape = {cached[0].shape}')\n",
        "                    cached = torch.tensor(list(cached))\n",
        "                    print('cached tensor shape=',cached.shape)\n",
        "\n",
        "                    for o in range(module.num_operators):\n",
        "                        print('---' * 10)\n",
        "                        print(f'Printing for operator {o}...')\n",
        "                        arr = cached[:, o].numpy()\n",
        "\n",
        "\n",
        "                        # Print min, max, mean, median:\n",
        "                        print(f'min: {np.min(arr)}, max: {np.max(arr)}, mean: {np.mean(arr)}, median: {np.median(arr)}')\n",
        "\n",
        "                        _plot_prob_distribution_of_activation_values(arr, title=f'Probability Distribution of Cached Decrement Sigmoid Activation Values for {module.label}')\n",
        "                    print('---' * 50)\n",
        "\n",
        "    if gate == 'reset':\n",
        "        for module in model_rse.modules():\n",
        "          if isinstance(module, RelativePositionEncoding):\n",
        "              assert hasattr(module, 'output_gate_sigmoid_activation_values_for_logging')\n",
        "              assert hasattr(module, 'reset_gate_sigmoid_activation_values_for_logging')\n",
        "\n",
        "          if hasattr(module, 'reset_gate_sigmoid_activation_values_for_logging'):\n",
        "              name_of_parameter = type(module)\n",
        "              # print(f'[Layer {layer_idx}] Module {name_of_parameter} has cached reset_gate_sigmoid_activation_values_for_logging:')\n",
        "              # print(f'Module {type(module)} has cached output_gate_sigmoid_activation_values_for_logging:')\n",
        "              print(f'reset_gate_sigmoid_activation_values_for_logging for Module label: {module.label}')\n",
        "\n",
        "              cached = module.reset_gate_sigmoid_activation_values_for_logging\n",
        "              len_cached = len(cached)\n",
        "\n",
        "              if len_cached == 0:\n",
        "\n",
        "                  print('len_cached == 0')\n",
        "                  continue\n",
        "\n",
        "              print(f'len_cached = {len_cached}, type(cached) = {type(cached)}, cached[0].shape = {cached[0].shape}')\n",
        "              cached = torch.tensor(list(cached))\n",
        "              print('cached tensor shape=',cached.shape)\n",
        "\n",
        "              for o in range(module.num_operators):\n",
        "                  print('---' * 10)\n",
        "                  print(f'Printing for operator {o}...')\n",
        "                  arr = cached[:, o].numpy()\n",
        "\n",
        "\n",
        "                  # Print min, max, mean, median:\n",
        "                  print(f'min: {np.min(arr)}, max: {np.max(arr)}, mean: {np.mean(arr)}, median: {np.median(arr)}')\n",
        "\n",
        "                  _plot_prob_distribution_of_activation_values(arr, title=f'Probability Distribution of Cached Reset Sigmoid Activation Values for {module.label}')\n",
        "              print('---' * 50)\n",
        "    return len_cached\n"
      ],
