        "#     stacked = torch.stack([p_keep, p_incr, p_decr], dim=0)      # [3, bs, h]\n",
        "#     noreset = (1.0 - p_reset).unsqueeze(0)                     # [1, bs, h]\n",
        "#     w_keep, w_inc, w_dec = (stacked * noreset).unbind(0)       # each [bs, h]\n",
