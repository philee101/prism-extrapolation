    {
      "cell_type": "markdown",
      "source": [
        "#### hist_update v7 fast_bwd mod 2 no slices - Fastest as of 7-5-25"
      ],
      "metadata": {
        "id": "2HnXh2GnE068"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "\n",
        "@torch.compile(dynamic=False)\n",
        "def hist_update_v7_fast_bwd_mod_2_noslices(\n",
        "    hist:   torch.Tensor,         # [P, bs, h]\n",
        "    p_reset: torch.Tensor,         # [bs, h]\n",
        "    p_inc:  torch.Tensor,         # [bs, h]\n",
        "    p_dec:  torch.Tensor,         # [bs, h]\n",
        "    p_keep: torch.Tensor,         # [bs, h]\n",
        "    p_copy: torch.Tensor|None,    # [P+1, bs, h]  or  [bs, h, P+1]\n",
        "    eps:    float,\n",
        "    gamma:  torch.Tensor|float,   # scalar or [h]  (broadcast ok)\n",
        "    power:  bool = True,\n",
        "):\n",
        "    P, bs, h = hist.shape\n",
        "    one      = torch.ones_like(p_reset)\n",
        "\n",
        "    # ---------- weights ----------------------------------------------------\n",
        "    inv_r   = one - p_reset\n",
        "    w_inc   = inv_r * p_inc\n",
        "    w_dec   = inv_r * p_dec\n",
        "    w_keep  = inv_r * p_keep\n",
        "\n",
        "    hist_inc  = hist * w_inc #.unsqueeze(0)     # [P,bs,h]\n",
        "    hist_dec  = hist * w_dec #.unsqueeze(0)\n",
        "    hist_keep = hist * w_keep#.unsqueeze(0)\n",
        "\n",
        "    # ---------- build INC & DEC shifts (no slice-writes) --------------------\n",
        "    zero_row = torch.zeros(1, bs, h, device=hist.device, dtype=hist.dtype)\n",
        "\n",
        "    # t → t+1  (prepend 0-row, drop last)  +  “overflow stays” add-in\n",
        "    inc_shift = torch.cat([zero_row, hist_inc[:-1]], dim=0)\n",
        "    inc_shift = inc_shift + torch.cat([                 # only last row gets extra\n",
        "        torch.zeros_like(hist_inc[:-1]),\n",
        "        hist_inc[-1:]], dim=0)\n",
        "\n",
        "    # t → t-1  (append 0-row, drop first)  +  “underflow stays” add-in\n",
        "    dec_shift = torch.cat([hist_dec[1:], zero_row], dim=0)\n",
        "    dec_shift = dec_shift + torch.cat([\n",
        "        hist_dec[:1],                                 # extra mass to row-0\n",
        "        torch.zeros_like(hist_dec[1:])], dim=0)\n",
        "\n",
        "    # ---------- base accumulation ------------------------------------------\n",
        "    out = hist_keep + inc_shift + dec_shift           # [P,bs,h]\n",
        "\n",
        "\n",
        "    # ---------- reset branches (build as tensor, add once) ------------------\n",
        "    total   = 1.0 #hist.sum(0)                             # [bs,h]\n",
        "\n",
        "    reset_block = torch.cat([\n",
        "        (total * p_reset * (p_dec + p_keep)).unsqueeze(0),  # row-0\n",
        "        (total * p_reset * p_inc)            .unsqueeze(0), # row-1\n",
        "        torch.zeros(P-2, bs, h, device=hist.device, dtype=hist.dtype)\n",
        "    ], dim=0)\n",
        "    out = out + reset_block\n",
        "\n",
        "    # assert torch.allclose(out.sum(0), torch.ones_like(out.sum(0)), atol=1e-4,), f\"maxDiff={torch.max(out.sum(0) - torch.ones_like(out.sum(0)))}\"\n",
        "\n",
        "    # ---------- copy branch -------------------------------------------------\n",
        "    # if p_copy is not None and Position_Copying_Enabled:\n",
        "    #     if p_copy.shape[0] != P + 1:                      # allow [bs,h,P+1]\n",
        "    #         p_copy = p_copy.permute(2, 0, 1)              # → [P+1,bs,h]\n",
        "    #     pos_cols, no_copy = p_copy[:-1], p_copy[-1]       # [P,bs,h]  [bs,h]\n",
        "    #     out = out * no_copy.unsqueeze(0) + total.unsqueeze(0) * pos_cols\n",
        "\n",
        "    # # ---------- sharpen + renorm -------------------------------------------\n",
        "    if power:\n",
        "        out = (out + eps).pow(gamma)\n",
        "    out = (out).div(out.sum(0, keepdim=True).add_(eps))\n",
        "\n",
        "    return out\n"
      ],
      "metadata": {
        "id": "4aG40Me8iH9w",
        "trusted": true,
        "execution": {
          "iopub.status.busy": "2025-09-17T19:06:51.219919Z",
          "iopub.execute_input": "2025-09-17T19:06:51.220176Z",
          "iopub.status.idle": "2025-09-17T19:06:51.236284Z",
          "shell.execute_reply.started": "2025-09-17T19:06:51.220154Z",
          "shell.execute_reply": "2025-09-17T19:06:51.235713Z"
        }
      },
      "outputs": [],
