    {
      "cell_type": "code",
      "source": [
        "def print_per_operator_gate_stats(model_rse):\n",
        "    for enc_i, rel_enc in enumerate(model_rse.relative_encodings):\n",
        "        if rel_enc is None:\n",
        "              continue\n",
        "        mg = rel_enc._merged_gate_mlp\n",
        "        fw = mg.final_weight    # [n_learnable, d_model, 3]\n",
        "        fb = mg.final_bias      # [n_learnable, 1, 3]\n",
        "        kw = mg.keep_weight     # [n_learnable, d_model, 1]\n",
        "        kb = mg.keep_bias       # [n_learnable, 1, 1]\n",
        "\n",
        "        # Which global operator indices are learnable?\n",
        "        learnable_ops = (~mg.fixed_gate_mask).nonzero(as_tuple=False).view(-1).tolist()\n",
        "\n",
        "        print(f\"[relative_encodings #{enc_i}] per-operator gate stats:\")\n",
        "        for local_idx, op_idx in enumerate(learnable_ops):\n",
        "            inc_norm   = fw[local_idx, :, 0].norm().item()\n",
        "            dec_norm   = fw[local_idx, :, 1].norm().item()\n",
        "            reset_norm = fw[local_idx, :, 2].norm().item()\n",
        "            keep_norm  = kw[local_idx, :, 0].norm().item()\n",
        "\n",
        "            inc_bias   = fb[local_idx, 0, 0].item()\n",
        "            dec_bias   = fb[local_idx, 0, 1].item()\n",
        "            reset_bias = fb[local_idx, 0, 2].item()\n",
        "            keep_bias  = kb[local_idx, 0, 0].item()\n",
        "\n",
        "            print(f\"  op {op_idx:3d}  \"\n",
        "                  f\"inc ‖W‖={inc_norm:6.3f}, bias={inc_bias:6.3f}   \"\n",
        "                  f\"dec ‖W‖={dec_norm:6.3f}, bias={dec_bias:6.3f}   \"\n",
        "                  f\"rst ‖W‖={reset_norm:6.3f}, bias={reset_bias:6.3f}   \"\n",
        "                  f\"kp ‖W‖={keep_norm:6.3f}, bias={keep_bias:6.3f}\")\n",
        "        print()\n",
        "\n",
        "print_per_operator_gate_stats(model_rse)"
      ],
      "metadata": {
        "id": "vrrKc3Pu0ryP",
        "scrolled": true,
        "trusted": true,
