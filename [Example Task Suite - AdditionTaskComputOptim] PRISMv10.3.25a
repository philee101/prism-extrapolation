    {
      "cell_type": "code",
      "source": [
        "\n",
        "\n",
        "def test_extrapolation_reverse(extrapolation_len=30, for_model='baseline', printOutputsAndTargets=False,\n",
        "                       examples_per_sequence=1,\n",
        "                       visualize_attn_weights=False,\n",
        "                               num_total_examples=100,\n",
        "                       ):\n",
        "    set_purely_random_seed()\n",
        "\n",
        "    test_dataset = _create_dataset(\"reverse\", num_total_examples=num_total_examples,\n",
        "                                  min_digits_mult=5, max_digits_mult=5,\n",
        "                                  examples_per_sequence=examples_per_sequence,\n",
        "                                  max_seq_len_for_dataset=extrapolation_len,\n",
        "                                   min_seq_len_for_dataset=extrapolation_len)\n",
        "    test_loader = DataLoader(test_dataset, batch_size=1, shuffle=False)\n",
        "    assert for_model in ['baseline', 'rse']\n",
        "\n",
        "    # # for item in test_loader.dataset:\n",
        "    # #     print(f'Shape of item = {item.shape}')\n",
        "    # # Preview the first batch:\n",
        "\n",
        "\n",
        "    # first_example = test_loader.dataset[0]\n",
        "    # print(f'first_example = {decode_problem(first_example.numpy())}')\n",
        "    print('---' * 10)\n",
        "    print(f'Evaluating on extrapolation_len={extrapolation_len}, model={for_model}')\n",
        "    print('---' * 10)\n",
        "\n",
        "    if for_model == 'rse':\n",
        "        if model_baseline is not None:\n",
        "            model_baseline.to('cpu')\n",
        "        model_rse.to(device)\n",
        "        acc = evaluate(model_rse, test_loader, criterion, device,\n",
        "                       printOutputsAndTargets=printOutputsAndTargets,\n",
        "                       visualize_attn_example_index=0 if visualize_attn_weights else None,\n",
        "                       visualize_attn_layer_skip=1,\n",
        "\n",
        "                       )\n",
        "        print(f'accuracy for rse: {acc}')\n",
        "    else:\n",
        "        if model_rse is not None:\n",
        "            model_rse.to('cpu')\n",
        "        model_baseline.to(device)\n",
        "        print(f'accuracy for baseline: {evaluate(model_baseline, test_loader, criterion, device, printOutputsAndTargets=printOutputsAndTargets)}')\n",
        "\n",
        "    print('---' * 10)\n",
        "    print(f'Done Evaluating on extrapolation_len={extrapolation_len}, model={for_model}')\n",
        "    print('---' * 10)"
      ],
      "metadata": {
        "id": "tGoaHTFIlQ1f",
        "scrolled": true,
        "trusted": true
