      "source": [
        "## Preview Missing Duplicate Dataset"
      ],
      "metadata": {
        "id": "e4kEw7W1YlCb"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "print('-----------------------------------------------------------------')\n",
        "print('Previewing MissingDuplicate dataset:')\n",
        "print('-----------------------------------------------------------------')\n",
        "\n",
        "train_dataset = _create_dataset(for_mode='missing_duplicate',\n",
        "                                examples_per_sequence=1, num_total_examples=20,\n",
        "                                batch_size=1,\n",
        "                                min_seq_len_for_dataset=2,\n",
        "                                max_seq_len_for_dataset=50,\n",
