      "source": [
        "import torch\n",
        "\n",
        "#@torch.compile(dynamic=False, fullgraph=True)\n",
        "def hist_update_v7_fast_bwd_noslices_symmetric_padstrided_softmax_flat(\n",
        "    hist:   torch.Tensor,         # [2*seq_len+1, bs, h]   (L, B, H)\n",
        "    p_reset: torch.Tensor,        # [bs, h]\n",
        "    p_inc:   torch.Tensor,        # [bs, h]\n",
        "    p_dec:   torch.Tensor,        # [bs, h]\n",
        "    p_keep:  torch.Tensor,        # [bs, h]\n",
        "    eps:     float,\n",
        "    gamma:   torch.Tensor|float,  # scalar or [h]\n",
        "    power:   bool,\n",
        "    seq_len: int,\n",
        "    p_copy:  torch.Tensor|None = None,   # [2*seq_len+2, bs, h] or None\n",
        "    *,\n",
        "    pad_buf: torch.Tensor|None = None,   # optional (L+2, B, H)\n",
        "):\n",
        "    # Shapes\n",
        "    L, B, H = hist.shape\n",
        "    mid = seq_len\n",
        "\n",
        "    # ---- flatten (B,H) → N to get [L,N] vectors; improves kernel heuristics\n",
        "    N = B * H\n",
        "    hist2 = hist.reshape(L, N)\n",
        "    pr    = p_reset.reshape(N)          # [N]\n",
        "    w_inc = (1.0 - pr) * p_inc.reshape(N)\n",
        "    w_dec = (1.0 - pr) * p_dec.reshape(N)\n",
        "    w_kee = (1.0 - pr) * p_keep.reshape(N)\n",
        "\n",
        "    # ---- zero-padded staging once; carry-in/out via two tiny writes\n",
        "    if pad_buf is None:\n",
        "        pad = hist2.new_zeros((L + 2, N))\n",
        "    else:\n",
        "        # reuse caller’s buffer; it must be (L+2,B,H)\n",
        "        pad = pad_buf.view(L + 2, N)\n",
        "        pad.zero_()\n",
        "\n",
        "    pad.narrow(0, 1, L).copy_(hist2)         # middle\n",
        "    pad[0].add_(hist2[0])                    # carry for dec into prev stream\n",
        "    pad[L + 1].add_(hist2[L - 1])            # carry for inc into next stream\n",
        "\n",
        "    prev = pad.narrow(0, 0, L)               # [L,N]  i-1 (with carry in row 0)\n",
        "    curr = pad.narrow(0, 1, L)               # [L,N]  i\n",
        "    nxt  = pad.narrow(0, 2, L)               # [L,N]  i+1 (with carry in row L-1)\n",
        "\n",
        "    # ---- fused 3-tap mix, all in-place on a single out buffer\n",
        "    out2 = curr.mul(w_kee)                   # out = curr * w_keep\n",
        "    out2.addcmul_(prev, w_dec)               # + prev * w_dec\n",
        "    out2.addcmul_(nxt,  w_inc)               # + next * w_inc       → [L,N]\n",
        "\n",
        "    # ---- reset triad (only three rows touched)\n",
        "    # row mid (0 shift)\n",
        "    out2[mid].add_(pr * p_keep.reshape(N))\n",
        "    # row mid+1 (+1 shift)\n",
        "    if mid + 1 < L:\n",
        "        out2[mid + 1].add_(pr * p_inc.reshape(N))\n",
        "    # row mid-1 (-1 shift)\n",
        "    if mid - 1 >= 0:\n",
        "        out2[mid - 1].add_(pr * p_dec.reshape(N))\n",
        "\n",
        "    # ---- optional copy-blend\n",
        "    if p_copy is not None:\n",
        "        # (L+1, B, H) → (L+1, N)   ; split is view, no data copy\n",
        "        cp = p_copy.view(L + 1, N)\n",
        "        pos_cols = cp.narrow(0, 0, L)        # [L,N]\n",
        "        no_copy  = cp.narrow(0, L, 1)        # [1,N]\n",
        "        out2.mul_(no_copy)                   # broadcast on row dim\n",
        "        out2.add_(pos_cols)\n",
        "\n",
        "    # ---- sharpen + normalize\n",
        "    if power:\n",
        "        # softmax( gamma * log(out+eps) ) along L  (dim=0)\n",
        "        z = (out2 + eps).log_()              # in-place to save a kernel\n",
        "        if isinstance(gamma, torch.Tensor) and gamma.numel() == H:\n",
        "            # expand γ from [H] → [N] once, then broadcast on row dim\n",
        "            gflat = gamma.to(device=out2.device, dtype=out2.dtype).repeat_interleave(B)  # [N]\n",
        "            z.mul_(gflat)                    # row-wise scale\n",
        "        else:\n",
        "            z.mul_(float(gamma))\n",
        "        out2 = torch.softmax(z, dim=0)       # single fused reduction kernel\n",
        "    else:\n",
        "        # mass-preserving path; avoid a reduction\n",
        "        inv_1peps = 1.0 / (1.0 + eps)\n",
        "        out2.mul_(inv_1peps)\n",
        "\n",
        "    return out2.view(L, B, H)\n"
      ],
      "metadata": {
        "id": "M-f7H1DJYm39",
