        "# Define enum copying from keys to keys or copying from keys to queries:\n",
        "# MARK: RMV_ResetGate_For_Add_Copy_Pos\n",
        "from enum import Enum\n",
        "class RelPosCopyRoute(Enum):\n",
        "    KEYS_TO_KEYS = 0\n",
        "    KEYS_TO_QUERIES = 1\n",
        "    NoCopy = 2"
      ],
