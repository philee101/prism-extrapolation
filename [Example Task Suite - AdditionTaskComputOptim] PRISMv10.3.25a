        "import seaborn as sns\n",
        "\n",
        "# def visualize_attention_slow(attn_weights_dict,\n",
        "#                         visualize_attn_example_index, visualize_attn_layer_skip=1,\n",
        "#                         visualize_attn_layer_indices=None):\n",
        "#     \"\"\"\n",
        "#     Visualizes the self-attention weights and segment boundaries for a given layer and example index.\n",
        "#     \"\"\"\n",
        "#     print('---\\nn layers = ', len(attn_weights_dict))\n",
        "#     def _visualize(layer_num_, head_idx):\n",
        "#         plt.figure(figsize=(5, 4))\n",
        "#         recurrent_array_entry = attn_weights_dict[layer_num_]  # lists attention weights of recurrent calls at the same layer\n",
        "#         # segment_entry = segment_boundaries_dict[layer_num_]\n",
        "#         print(f'visualize_attn().visualize(): layer_num_ = {layer_num_}, head_idx = {head_idx}, len(recurrent_array_entry) = {len(recurrent_array_entry)}')\n",
