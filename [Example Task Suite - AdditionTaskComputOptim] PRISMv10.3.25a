      "cell_type": "code",
      "source": [
        "# Print mha_bias_main_q/mha_bias_main_k:\n",
        "for layer, decoder_layer in enumerate(model_rse.layers):\n",
        "    for head_idx in range(decoder_layer.self_attn.num_heads):\n",
        "        print(f'---' * 10)\n",
        "        print(f'Layer {layer}, head {head_idx}')\n",
        "        print(f'mha_bias_main_q = {decoder_layer.self_attn.mha_bias_main_q[head_idx]}')\n",
        "        print(f'mha_bias_main_k = {decoder_layer.self_attn.mha_bias_main_k[head_idx]}')\n",
        "        print('---' * 10)"
