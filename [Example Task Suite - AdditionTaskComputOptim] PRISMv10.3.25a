      "cell_type": "markdown",
      "source": [
        "## 8.30.25 - more variants on the orig symmetric update fn to compare faster execution"
      ],
      "metadata": {
        "id": "-8oR9pAcYa-X"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "\n",
        "import torch\n",
        "import torch.nn.functional as F\n",
        "\n",
        "# 8.30.25:\n",
        "@torch.compile(dynamic=False)\n",
        "def hist_update_v7_fast_bwd_noslices_symmetric_v3(\n",
        "    hist:   torch.Tensor,         # [2*seq_len+1, bs, h]\n",
        "    p_reset: torch.Tensor,        # [bs, h]\n",
        "    p_inc:   torch.Tensor,        # [bs, h]\n",
        "    p_dec:   torch.Tensor,        # [bs, h]\n",
        "    p_keep:  torch.Tensor,        # [bs, h]\n",
        "    eps:     float,\n",
        "    gamma:   torch.Tensor | float,  # scalar or [h]\n",
        "    power:   bool,\n",
        "    seq_len: int,\n",
        "    p_copy:  torch.Tensor | None = None,\n",
        "):\n",
        "    L, bs, h = hist.shape\n",
        "\n",
        "    # Uncomment this assertion if debugging:\n",
        "    # assert L == 2*seq_len + 1, f\"Expected length {2*seq_len+1}, got {L}\"\n",
        "    mid = seq_len  # center index for position 0\n",
        "\n",
        "    # 1) shared base multiply\n",
        "    inv_r   = 1.0 - p_reset\n",
        "    base    = hist * inv_r.unsqueeze(0)          # [L, bs, h]\n",
        "    hist_inc  = base * p_inc.unsqueeze(0)\n",
        "    hist_dec  = base * p_dec.unsqueeze(0)\n",
        "    hist_keep = base * p_keep.unsqueeze(0)\n",
        "\n",
        "    # 2) shifts via index_add_ (no slicing/cat)\n",
        "    idx     = torch.arange(L, device=hist.device)\n",
        "    tgt_inc = torch.clamp(idx + 1, max=L - 1)    # [L]\n",
        "    tgt_dec = torch.clamp(idx - 1, min=0)        # [L]\n",
        "\n",
        "    inc_shift = torch.zeros_like(hist_inc)\n",
        "    dec_shift = torch.zeros_like(hist_dec)\n",
        "    inc_shift.index_add_(0, tgt_inc, hist_inc)   # i -> clamp(i+1)\n",
        "    dec_shift.index_add_(0, tgt_dec, hist_dec)   # i -> clamp(i-1)\n",
        "\n",
        "    out = hist_keep + inc_shift + dec_shift      # [L, bs, h]\n",
        "\n",
        "    # 3) reset contribution into rows mid-1, mid, mid+1\n",
        "    r_minus = (p_reset * p_dec)                  # [bs, h]\n",
        "    r_zero  = (p_reset * p_keep)                 # [bs, h]\n",
        "    r_plus  = (p_reset * p_inc)                  # [bs, h]\n",
        "\n",
        "    reset_rows = torch.stack((r_minus, r_zero, r_plus), dim=0)  # [3, bs, h]\n",
        "    reset_idx  = torch.tensor([mid - 1, mid, mid + 1],\n",
        "                              device=hist.device, dtype=torch.long)\n",
        "    out.index_add_(0, reset_idx, reset_rows)\n",
        "\n",
        "    # 4) optional position copy (last row = \"no copy\")\n",
        "    if p_copy is not None:\n",
        "        first_L = torch.arange(L, device=hist.device)\n",
        "        last_1  = torch.tensor([L], device=hist.device)\n",
        "        pos_cols = p_copy.index_select(0, first_L)         # [L, bs, h]\n",
        "        no_copy  = p_copy.index_select(0, last_1).squeeze(0)  # [bs, h]\n",
        "        out = out * no_copy.unsqueeze(0) + pos_cols\n",
        "\n",
        "    # 5) optional power, then normalize over position dim\n",
        "    if power:\n",
        "        out = (out + eps).pow(gamma)\n",
        "    out = out / (out.sum(0, keepdim=True).add_(eps))\n",
        "    return out"
      ],
      "metadata": {
