      "cell_type": "code",
      "source": [
        "import torch\n",
        "import torch.nn.functional as F\n",
        "\n",
        "# @torch.compile(dynamic=False)  # shapes are static across steps in your loop\n",
        "def hist_update_v7_fast_bwd_noslices_symmetric_roll_flat(\n",
        "    hist:   torch.Tensor,         # [2*seq_len+1, bs, h]\n",
        "    p_reset: torch.Tensor,        # [bs, h]\n",
        "    p_inc:   torch.Tensor,        # [bs, h]\n",
        "    p_dec:   torch.Tensor,        # [bs, h]\n",
        "    p_keep:  torch.Tensor,        # [bs, h]\n",
        "    eps:     float,\n",
        "    gamma:   torch.Tensor | float,  # scalar or [h]\n",
        "    power:   bool,\n",
        "    seq_len: int,\n",
        "    p_copy:  torch.Tensor | None = None,   # [2*seq_len+2, bs, h] or None\n",
        "):\n",
        "    L, bs, h = hist.shape\n",
        "    BH       = bs * h\n",
        "    mid      = seq_len\n",
        "    dev, dt  = hist.device, hist.dtype\n",
        "\n",
        "    # ----- flatten bs×h → BH to minimize broadcasting -----\n",
        "    H = hist.reshape(L, BH)\n",
        "\n",
        "    inv_r  = 1.0 - p_reset\n",
        "    w_inc  = (inv_r * p_inc ).reshape(BH)\n",
        "    w_dec  = (inv_r * p_dec ).reshape(BH)\n",
        "    w_keep = (inv_r * p_keep).reshape(BH)\n",
        "\n",
        "    H_inc  = H * w_inc\n",
        "    H_dec  = H * w_dec\n",
        "    H_keep = H * w_keep\n",
        "\n",
        "    # ----- position masks (on L only; broadcast over BH) -----\n",
        "    first = F.one_hot(torch.tensor(0,     device=dev), L).to(dt).view(L, 1)\n",
        "    last  = F.one_hot(torch.tensor(L - 1, device=dev), L).to(dt).view(L, 1)\n",
        "    not_first, not_last = (1.0 - first), (1.0 - last)\n",
        "\n",
        "    # ----- +1 and −1 shifts via roll; zero wrong edge; add carry via masked reduce -----\n",
        "    inc_roll  = torch.roll(H_inc,  shifts=+1, dims=0)          # prev\n",
        "    inc_last  = (H_inc * last).sum(dim=0, keepdim=True)        # [1,BH]\n",
        "    inc_shift = inc_roll * not_first + inc_last * last         # zero first, add carry to last\n",
        "\n",
        "    dec_roll  = torch.roll(H_dec,  shifts=-1, dims=0)          # next\n",
        "    dec_first = (H_dec * first).sum(dim=0, keepdim=True)       # [1,BH]\n",
        "    dec_shift = dec_roll * not_last  + dec_first * first       # zero last, add carry to first\n",
        "\n",
        "    out = H_keep + inc_shift + dec_shift                       # [L,BH]\n",
        "\n",
        "    # ----- reset spikes at {mid-1, mid, mid+1} via masks (no row indexing) -----\n",
        "    m0  = F.one_hot(torch.tensor(mid, device=dev), L).to(dt).view(L, 1)\n",
        "    mm1 = torch.zeros_like(m0) if mid == 0     else F.one_hot(torch.tensor(mid - 1, device=dev), L).to(dt).view(L, 1)\n",
        "    mp1 = torch.zeros_like(m0) if mid + 1 >= L else F.one_hot(torch.tensor(mid + 1, device=dev), L).to(dt).view(L, 1)\n",
        "\n",
        "    r_keep = (p_reset * p_keep).reshape(1, BH)\n",
        "    r_inc  = (p_reset * p_inc ).reshape(1, BH)\n",
        "    r_dec  = (p_reset * p_dec ).reshape(1, BH)\n",
        "\n",
        "    out = out + mm1 * r_dec + m0 * r_keep + mp1 * r_inc        # [L,BH]\n",
        "\n",
        "    # ----- optional position copy (tuple path; avoids tensor indexing) -----\n",
        "    if p_copy is not None:\n",
        "        rows = p_copy.unbind(dim=0)                 # tuple length L+1\n",
        "        no_copy  = rows[-1].reshape(1, BH)          # [1,BH]\n",
        "        pos_cols = torch.stack(rows[:L], dim=0)     # [L,bs,h] (no tensor slice; tuple slice)\n",
        "        pos_cols = pos_cols.reshape(L, BH)\n",
        "\n",
        "        out = out * no_copy + pos_cols              # [L,BH]\n",
        "\n",
        "    # ----- sharpen + normalize (no in-place after pow) -----\n",
        "    if power:\n",
        "        if isinstance(gamma, torch.Tensor):\n",
        "            if gamma.numel() == h:\n",
        "                g_flat = gamma.to(device=dev, dtype=dt).view(1, h).expand(bs, h).reshape(1, BH)\n",
        "            else:\n",
        "                # scalar-like tensor\n",
        "                g_flat = gamma.to(device=dev, dtype=dt).reshape(1, 1).expand(1, BH)\n",
        "            out = (out + eps).pow(g_flat)           # broadcast along BH\n",
        "        else:\n",
        "            out = (out + eps).pow(gamma)\n",
        "\n",
        "    denom = out.sum(dim=0, keepdim=True) + eps\n",
        "    out   = out / denom\n",
        "    return out.view(L, bs, h)\n"
      ],
      "metadata": {
        "id": "-faON4YKqVey",
        "trusted": true,
        "execution": {
