        "\n",
        "\n",
        "# Print total number of parameters:\n",
        "def print_total_params(model_rse):\n",
        "    print(f\"Total number of parameters in model_rse: {sum(p.numel() for p in model_rse.parameters())}\")\n",
        "    print(f\"Total number of trainable parameters in model_rse: {sum(p.numel() for p in model_rse.parameters() if p.requires_grad)}\")\n",
        "    # if model_baseline is not None:\n",
        "    #     print(f\"Total number of parameters in model_baseline: {sum(p.numel() for p in model_baseline.parameters())}\")\n",
        "    #     print(f\"Total number of trainable parameters in model_baseline: {sum(p.numel() for p in model_baseline.parameters() if p.requires_grad)}\")\n",
        "\n",
        "    # for name,param in model_rse.named_parameters():\n",
        "    #     if param.requires_grad:\n",
        "    #         print(f'name = {name},\\n\\tparam.shape = {param.shape},\\n\\ttotal params = {param.numel()}')\n",
        "\n",
        "print_total_params(model_rse if not TRAIN_BASELINE_TRANSFORMER else model_baseline)\n",
        "\n",
        "sortedParamsByNumel = sorted(model_rse.named_parameters(), key=lambda p: p[1].numel(), reverse=True)\n",
        "print('---'*100)\n",
        "print('---'*100)\n",
        "print('---'*100)\n",
        "print(f'Sorted params by numel:')\n",
        "runningTotal = 0\n",
        "for name, param in sortedParamsByNumel:\n",
        "    print(f'name = {name},\\n\\tparam.shape = {param.shape},\\n\\ttotal params = {param.numel()}')\n",
        "    runningTotal += param.numel()\n",
        "    print(f'runningTotal = {runningTotal}')\n",
        "\n",
        "\n",
        "print('---'*100)\n",
        "print('---'*100)"
