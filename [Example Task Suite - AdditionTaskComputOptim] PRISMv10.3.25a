      "cell_type": "code",
      "source": [
        "TOTAL_COUNT_OF_GRAD_NORMS_GR_THAN_1k = 0\n",
        "DONATED_BUFFERS_DISABLED = False\n",
        "\n",
        "import gc\n",
        "import time\n",
        "import tqdm\n",
        "# ---------------------------------------------------------------------\n",
        "# 1) create CUDA events once; reuse them every step\n",
        "# ---------------------------------------------------------------------\n",
        "import time, torch\n",
        "# ------------------------------------------------------------------\n",
        "# one-off CUDA events you can reuse forever\n",
        "_t0 = torch.cuda.Event(enable_timing=True)\n",
        "_t1 = torch.cuda.Event(enable_timing=True)\n",
        "\n",
        "def get_latest_epoch_index(losses_dict, model_type='RSE'):\n",
        "    # losses_dict: A list of tuples that indexes the iteration index of each epoch, along with the loss, of the form [(iteration index, epoch, loss)]\n",
        "    train_losses = losses_dict[f'train_losses_{model_type}']\n",
        "    get_previous_epoch = -1 # get the most recent epoch:\n",
        "    # get the most recent epoch:\n",
        "    for i in range(len(train_losses)):\n",
        "        if train_losses[i][1] > get_previous_epoch:\n",
        "            get_previous_epoch = train_losses[i][1]\n",
        "\n",
        "    if get_previous_epoch == -1:\n",
        "        get_previous_epoch = len(train_losses) - 1\n",
        "\n",
        "    return get_previous_epoch\n",
        "\n",
        "# Add a Parameter for Maximum Iterations:\n",
        "# Introduce a max_iterations parameter to control the number of steps per training run:\n",
        "from IPython.display import clear_output\n",
        "\n",
        "def train_with_enhanced_logging(model, train_dataset, optimizer, latest_epoch_index, learning_rate=None,\n",
        "          losses_dict={}, max_iterations=None, print_losses_every_iter=None, model_type='rse',\n",
        "          train_batch_sz_actual=None # train_batch_sz_actual: If None, then train on entire batch at a time\n",
        "                  , iter_offset=None,\n",
        "                  turn_off_aux_losses=False, # Set this to True only when debugging gradients for token losses\n",
        "          ):\n",
        "\n",
        "    global TOTAL_COUNT_OF_GRAD_NORMS_GR_THAN_1k\n",
        "    global DONATED_BUFFERS_DISABLED, max_grad_norm\n",
        "\n",
        "    # Start time for the current training run\n",
        "    import time\n",
        "    start_time = time.time()\n",
        "\n",
        "    # Retrieve the existing wall clock times and losses\n",
        "    wall_clock_times = losses_dict[f'wall_clock_time_{model_type}']\n",
        "    train_losses = losses_dict[f'train_losses_{model_type}']\n",
        "\n",
        "    # If the wall clock time list already has entries, use the last value as the base time\n",
        "    if wall_clock_times:\n",
        "        base_time = wall_clock_times[-1]  # Last recorded time\n",
        "    else:\n",
        "        base_time = 0  # Start from 0 if this is the first call to train()\n",
        "\n",
        "    # Determine the latest epoch index\n",
        "    latest_epoch_index = get_latest_epoch_index(losses_dict, model_type=model_type) + 1\n",
        "\n",
        "    model.train()\n",
        "    total_loss = 0\n",
        "    iter = 0\n",
        "\n",
        "    # dataloader = DataLoader(train_dataset, batch_size=train_dataset.batch_size, shuffle=True, num_workers=0)\n",
        "    if iter_offset is not None:\n",
        "        assert max_iterations == 1, f'max_iterations = {max_iterations}, iter_offset = {iter_offset}'\n",
        "        iter_offset = iter_offset % len(train_dataset)\n",
        "\n",
        "        dataloader = DataLoader(train_dataset[iter_offset : iter_offset+max_iterations+1], pin_memory=True)\n",
        "        print(f'train(): Set Iter offset: {iter_offset}, len of orig dataset = {len(train_dataset)}, len of offset dataset = {len(dataloader.dataset)}')\n",
        "    else:\n",
        "        dataloader = DataLoader(train_dataset, batch_size=1, shuffle=False, num_workers=0, pin_memory=True)\n",
        "\n",
        "    assert len(dataloader) >= 1, f'len(dataloader) = {len(dataloader)}'\n",
        "\n",
        "    # Calculate the number of steps in an epoch\n",
        "    steps_per_epoch = len(dataloader)\n",
        "    if max_iterations is not None:\n",
        "        print(f'STEPS_PER_EPOCH = {steps_per_epoch}')\n",
        "        percent_epoch = (max_iterations / steps_per_epoch) * 100\n",
        "        # print(f\"Training will consume {percent_epoch:.2f}% of an epoch.\")\n",
        "        print(f'Training for {max_iterations} iterations, will consume {percent_epoch:.2f}% of an epoch.')\n",
        "    else:\n",
        "        percent_epoch = 100\n",
        "\n",
        "    global global_iter\n",
        "\n",
        "    ########################################################################################################################\n",
        "    # Begin train\n",
        "    ########################################################################################################################\n",
        "\n",
        "    model.train()\n",
        "    total_loss = 0\n",
        "    total_token_loss_log = 0\n",
        "    total_orthog_loss = 0\n",
        "    count_for_current_avg_token_loss_summary = 0\n",
        "    total_token_loss_for_current_avg_loss_summary = 0\n",
        "    # If <optimizer> is a dict of optimizers, the key \"main\" must be present as the main optimizer whereas all other keys map to the auxiliary optimizers for special param groups:\n",
        "    if isinstance(optimizer, dict):\n",
        "        aux_optimizers = []\n",
        "        for k, v in optimizer.items():\n",
        "            if k != \"main\":\n",
        "                aux_optimizers.append(v)\n",
        "        optimizer = optimizer[\"main\"]\n",
        "    else:\n",
        "\n",
        "        aux_optimizers = []\n",
        "\n",
        "    optimizer.zero_grad(set_to_none=True)\n",
        "    LOG_TRAIN_PERF = True and ENABLE_CUDA_SYNCHRONIZE_TIMING_STATISTICS\n",
        "\n",
        "    # for outer_iter, batch in enumerate(dataloader):\n",
        "    for iter, batch in enumerate(dataloader):\n",
        "\n",
        "        with torch.no_grad():\n",
        "\n",
        "            batch = batch.squeeze(0)\n",
        "            batch = batch.to(device)\n",
        "            bs = batch.shape[0]\n",
        "            # Assert batch is contiguous:\n",
        "            assert batch.is_contiguous()\n",
        "\n",
        "            if bs > 1:\n",
        "              batch = batch.squeeze(1)\n",
        "\n",
        "            print(f'train(): Batch shape = {batch.shape}')\n",
        "            # if bs == 1:\n",
        "            #     assert batch[0, 0] != END_OF_PROBLEM_CHARACTER\n",
        "            # else:\n",
        "            #     # assert not (batch[:, 0] == END_OF_PROBLEM_CHARACTER).any()\n",
        "            #     # assert (batch[:, 0] != END_OF_PROBLEM_CHARACTER)\n",
        "            #     for i in range(bs):\n",
        "            #         assert batch[i, 0] != END_OF_PROBLEM_CHARACTER\n",
        "\n",
        "\n",
        "            equals_pos = (batch == char2idx('=')).nonzero(as_tuple=False)[:, :]\n",
        "            # print(f'equals_pos shape = {equals_pos.shape}') # equals_pos shape => torch.Size([batch size])\n",
        "            # print(f'equals_pos = {equals_pos}')\n",
        "\n",
        "            period_pos = (batch == char2idx(END_OF_PROBLEM_CHARACTER)).nonzero(as_tuple=False)[:, :]\n",
        "\n",
        "            tgt_input = batch[:, :]\n",
        "            sample_seq_len = batch.shape[1]\n",
        "\n",
        "            mask = generate_square_subsequent_mask(tgt_input.size(1)).to(device)\n",
        "\n",
        "            assert(MAX_SEQ_LEN-sample_seq_len >= 0)\n",
        "\n",
        "        outputs, embeddings = model(tgt_input,\n",
        "                                    mask,\n",
        "                                    pos_x_shift=-1,\n",
        "                                    )\n",
        "        # print(f'batch shape = {batch.shape}')\n",
        "\n",
        "        ###################################################################################################\n",
        "        ###################################################################################################\n",
        "\n",
        "\n",
        "        # ------------------ VECTORISED MASK BUILDING ---------------------\n",
        "        # ---------------------------------------------------------------------------\n",
        "        # Vectorised multi–segment mask builder\n",
        "        # ---------------------------------------------------------------------------\n",
        "        # ---------------------------------------------------------------------------\n",
        "        # Vectorised multi-span mask builder (correct lengths)\n",
        "        # ---------------------------------------------------------------------------\n",
        "        def build_target_masks(batch, equals_pos, period_pos):\n",
        "            with torch.no_grad():\n",
        "                B, L = batch.shape\n",
        "                dev  = batch.device\n",
        "\n",
        "                eq_dense  = torch.full((B, L), False, device=dev)\n",
        "                dot_dense = torch.full((B, L), False, device=dev)\n",
        "                eq_dense [equals_pos[:, 0], equals_pos[:, 1]] = True\n",
        "                dot_dense[period_pos[:, 0], period_pos[:, 1]] = True\n",
        "\n",
        "                c_eq  = torch.cumsum(eq_dense.int(),  dim=1)\n",
        "                c_dot = torch.cumsum(dot_dense.int(), dim=1)\n",
        "                inside = (c_eq - c_dot) > 0                          # True between '=' and '.'\n",
        "\n",
        "                # ── model predicts tokens at columns  [eq … dot-1] ──\n",
        "                tgt_mask_model =  inside                             # include '='  exclude '.'\n",
        "\n",
        "                # ── target is tokens at columns      [eq+1 … dot] ──\n",
        "                arange_L = torch.arange(L, device=dev).unsqueeze(0)\n",
        "\n",
        "                # indexes of the first '=' in each span\n",
        "                eq_pos    = torch.where(eq_dense, arange_L, L).amin(dim=1)\n",
        "                # indexes of the matching '.' (already the first after '=')\n",
        "                first_dot = torch.where(dot_dense, arange_L, L).amin(dim=1)\n",
        "\n",
        "                tgt_mask = (arange_L >  eq_pos.unsqueeze(1)) & \\\n",
        "                          (arange_L <= first_dot.unsqueeze(1))      # exclude '=' include '.'\n",
        "\n",
        "                return tgt_mask_model, tgt_mask\n",
        "\n",
        "\n",
        "\n",
        "        # ------------------ put the timing wrapper around it ---------------\n",
        "        if ENABLE_CUDA_SYNCHRONIZE_TIMING_STATISTICS:\n",
        "            torch.cuda.synchronize()\n",
        "            cpu_t0 = time.perf_counter()\n",
        "            _t0.record()\n",
        "\n",
        "        tgt_output_indxs_model, tgt_output_indxs = build_target_masks(\n",
        "                  batch, equals_pos, period_pos\n",
        "              )\n",
        "\n",
        "\n",
        "        if ENABLE_CUDA_SYNCHRONIZE_TIMING_STATISTICS:\n",
        "            _t1.record()\n",
        "            torch.cuda.synchronize()\n",
        "            cpu_dt = (time.perf_counter() - cpu_t0)*1e3       # ms\n",
        "            gpu_dt = _t0.elapsed_time(_t1)                    # ms\n",
        "\n",
        "            print(f\"[timing] target-mask generation: {cpu_dt:7.2f} ms \"\n",
        "                  f\"(GPU {gpu_dt:6.2f} ms, B={batch.size(0)}, L={batch.size(1)})\")\n",
        "\n",
        "\n",
        "        ####################################################################################################################################\n",
        "        ######################################################################################################################################################################################################\n",
        "\n",
        "\n",
        "        # print(f'tgt_output = {decode_problem(tgt_output[0].cpu().numpy())}, problem = {decode_problem(batch[0].cpu().numpy())}')\n",
        "        USE_IGNORE_IDX = True\n",
        "\n",
        "        if not USE_IGNORE_IDX:\n",
        "            with torch.no_grad():\n",
        "\n",
        "              tgt_output = batch[tgt_output_indxs]          # exactly what you did before\n",
        "\n",
        "            outputs_targs = outputs[tgt_output_indxs_model]\n",
        "            token_loss = criterion(outputs_targs.view(-1, VOCAB_SIZE), tgt_output.contiguous().view(-1))\n",
        "            assert token_loss.shape == ()\n",
        "        else:\n",
        "            # 1) logits for all but the final time‐step\n",
        "            pred_logits = outputs[:, :-1, :]                             # [B, L–1, V]\n",
        "\n",
        "            with torch.no_grad():\n",
        "                pred_mask   = tgt_output_indxs_model[:, :-1]                 # [B, L–1]\n",
        "                # 2) targets are all but the first time‐step of the raw batch\n",
        "                targs       = batch        [:, 1:]                           # [B, L–1]\n",
        "                targ_mask   = tgt_output_indxs[:, 1:]                        # [B, L–1]\n",
        "\n",
        "            # sanity check that we masked the same slots\n",
        "            assert torch.all(pred_mask == targ_mask), \"pred/target masks must match\"\n",
        "\n",
        "            # 3) flatten to compute a single CrossEntropyLoss\n",
        "            B, T1, V   = pred_logits.shape\n",
        "            logits     = pred_logits.reshape(B*T1, V)                    # [B*T1, V]\n",
        "\n",
        "            with torch.no_grad():\n",
        "                targs_flat = targs.reshape     (B*T1)                        # [B*T1]\n",
        "                mask_flat  = pred_mask.reshape (B*T1)                        # [B*T1]\n",
        "                # 4) replace invalid positions with ignore_index\n",
        "                ignore_id     = -100\n",
        "\n",
        "            targs_masked  = targs_flat.masked_fill(~mask_flat, ignore_id)\n",
        "\n",
        "            # 5) compute sum‐reduction over only the valid positions\n",
        "            loss_fn    = torch.nn.CrossEntropyLoss(\n",
        "                            reduction   = \"sum\",\n",
        "                            ignore_index= ignore_id\n",
        "                        )\n",
        "            token_loss = loss_fn(logits, targs_masked) / mask_flat.sum()\n",
        "\n",
        "        token_loss_for_summary = token_loss\n",
        "        if criterion.reduction == 'sum':\n",
        "            token_loss = token_loss / bs  # bs = the number of sequences in the batch\n",
        "            print(f'[SUM REDUCTION CE LOSS] Reducing token loss by {bs}')\n",
        "            # For token_loss_fdor_summary, maverage over all elements of the tensor as if mean reduction was taken:\n",
        "\n",
        "            num_target_tokens = tgt_output_indxs_model.sum()  # how many tokens are predicted\n",
        "            # token_loss_for_summary = (token_loss / num_target_tokens).item()\n",
        "            token_loss_for_summary = token_loss #/ num_target_tokens\n",
        "            # print(f'[SUM REDUCTION CE LOSS] Reducing token loss by {num_target_tokens}')\n",
        "\n",
        "\n",
        "        aux_loss = 0 #model.projection_loss(embeddings, attention_mask)\n",
        "\n",
        "        number_segmentation_loss = 0 # model.projection_loss(embeddings,\n",
        "        #                                                  number_segmentation_mask,\n",
        "        #                                                  head_key='number_segmentation', norm_threshold=0)\n",
        "\n",
        "\n",
        "        with torch.no_grad():\n",
        "            print(f'train(): full example = {decode_problem(batch[0, :].cpu().numpy())}')\n",
        "        if torch.isnan(token_loss):\n",
        "            print(\"NaN loss detected. Skipping batch.\")\n",
        "            continue\n",
        "\n",
        "        aux_coeff = 0.1\n",
        "        # total_loss_with_aux = token_loss + (0.005) * aux_loss + aux_coeff * number_segmentation_loss  # Combine token loss with auxiliary loss\n",
        "        APPLY_NORM_LOSS = False #False and not turn_off_aux_losses\n",
        "\n",
        "        total_loss_with_aux = token_loss\n",
        "        retain_graph = (not turn_off_aux_losses) and (MHA_NORM_REGULARIZATION_ON_ATTN_SCORES_ENABLED or LOGIT_LOSS_RSE_COPY_PROBS or RSE_COPY_PROBS_USE_MARGIN_REG)\n",
        "        if retain_graph and not DONATED_BUFFERS_DISABLED:\n",
        "            torch._functorch.config.donated_buffer=False\n",
        "            DONATED_BUFFERS_DISABLED = True\n",
        "\n",
        "        normReg = torch.tensor(0.0, device=device, requires_grad=True)\n",
        "        normRegGamma = 2e-3\n",
        "\n",
        "        if turn_off_aux_losses:\n",
        "            total_loss_with_aux.backward(retain_graph=retain_graph)\n",
        "        else:\n",
        "            norm_loss_rse_gate_activations = torch.tensor(0.0, device=device, requires_grad=True)\n",
        "\n",
        "            # Call _apply_activation_norm_regularization on all GateMLPs\n",
        "            if APPLY_NORM_LOSS:\n",
        "                # for module in model.modules():\n",
        "                for module_idx, module in enumerate(model.modules()):\n",
        "                    if isinstance(module, MergedGateMLP): #or isinstance(module, GateMLP)\n",
        "                        # print(f'[Train()] Calculating norm loss for module {module_idx}')\n",
        "                        latest_scalar_outputs = module.latest_scalar_outputs\n",
        "                        # print(f'[Train()] latest_scalar_outputs avg = {torch.mean(torch.stack(latest_scalar_outputs))}')\n",
        "\n",
        "                        normReg = module._apply_activation_norm_regularization(gamma=normRegGamma,\n",
        "                                                                               maxNormForSigmoid=8)\n",
        "                        # print(f'normReg = {normReg}')\n",
        "                        norm_loss_rse_gate_activations = normReg + norm_loss_rse_gate_activations\n",
        "                total_loss_with_aux = norm_loss_rse_gate_activations + total_loss_with_aux\n",
        "\n",
        "\n",
        "            if LOG_TRAIN_PERF:\n",
        "                          # if LOG_TRAIN_PERF:\n",
        "                # create once, to reuse every iteration\n",
        "                bwd_start = torch.cuda.Event(enable_timing=True)\n",
        "                bwd_end   = torch.cuda.Event(enable_timing=True)\n",
        "\n",
        "                # ─── wrap your backward pass ────────────────────────────────────────────\n",
        "                # make sure no syncs or .item() happen between these two records:\n",
        "                torch.cuda.synchronize()      # wait for all forward work to finish\n",
        "                bwd_start.record()\n",
        "\n",
        "\n",
        "\n",
        "            ortho_loss_linear_modules = False\n",
        "            if ortho_loss_linear_modules:\n",
        "                orthog_loss_linear_modules = orthogonal_regularizer_linear_modules(model, lambda_v=1e-4, lambda_ff=1e-4, only_offdiag=False)\n",
        "                total_loss_with_aux = orthog_loss_linear_modules + total_loss_with_aux\n",
        "                print(f'[Train()] ortho_loss_linear_modules = {orthog_loss_linear_modules}')\n",
        "\n",
        "\n",
        "            total_loss_with_aux.backward(retain_graph=retain_graph)\n",
        "\n",
        "            if LOG_TRAIN_PERF:\n",
        "                bwd_end.record()\n",
        "                torch.cuda.synchronize()      # wait for backward to finish\n",
        "                backward_time = bwd_start.elapsed_time(bwd_end)  # in milliseconds\n",
        "\n",
        "                # you can accumulate, log, or print it:\n",
        "                print(f\"[train() timing] backward pass: {backward_time:.2f} ms (iter {iter})\")\n",
        "                # ────────────────────────────────────────────────────────────────────────\n",
        "\n",
        "\n",
        "\n",
        "        # print(f\"[MANUAL CHECK] embeddings.grad: {model_rse.relative_encodings[0].cached_embeddings.grad.mean() if model_rse.relative_encodings[0].cached_embeddings.grad is not None else None}\")\n",
        "        # # print(f\"[MANUAL CHECK] positions_relative_absolute.grad: {model_rse.relative_encodings[0].cached_positions_relative_absolute.grad.mean() if model_rse.relative_encodings[0].cached_positions_relative_absolute.grad is not None else None}\")\n",
        "        # print(\"[DEBUG] positions_relative_absolute.grad (after backward):\", model_rse.relative_encodings[0].cached_positions_relative_absolute.grad)\n",
        "\n",
        "        if not turn_off_aux_losses:\n",
        "            # print(f'[Train()] Calculating norm loss..')\n",
        "            norm_loss_scores = torch.tensor(0.0, device=device, requires_grad=True)\n",
        "\n",
        "            if RelativeEncodingLSTMHiddenOutputsRelevanceEncoding_IS_ENABLED:\n",
        "                for layer in model.layers:\n",
        "                    sa = layer.self_attn\n",
        "                    norm_loss_scores = sa.mha_compute_norm_reg_loss_for_lstm_inputs(lambda_reg=1e-1, norm_threshold=(MHA_RELEVANCE_ENCODING_OUTPUT_DIM ** 0.5) // 2) + norm_loss_scores\n",
        "                    print(f'train(): norm_loss_lstm_scores = {norm_loss_scores}')\n",
        "\n",
        "            if not MHA_NORM_REGULARIZATION_ON_ATTN_SCORES_ENABLED:\n",
        "                pass\n",
        "                # for layer in model.layers:\n",
        "                #     sa = layer.self_attn\n",
        "                #     qk_loss = sa.mha_compute_minimum_scaling_factors_QK_loss(max_norm=1.0, lambda_reg=1e-3)\n",
        "                #     print(f'train(): qk_loss = {qk_loss}')\n",
        "                #     norm_loss_scores = qk_loss + norm_loss_scores\n",
        "            if MHA_NORM_REGULARIZATION_ON_ATTN_SCORES_ENABLED and model.model_is_rse:\n",
        "                for layer in model.layers:\n",
        "                    sa = layer.self_attn\n",
        "                    # norm_loss_scores = sa.mha_apply_activation_norm_reg(lambda_reg=1e-2) + norm_loss_scores\n",
        "                    norm_loss_scores = sa.mha_apply_activation_norm_reg_simple(lambda_reg=5, threshold=20.5) + norm_loss_scores\n",
        "                    # norm_loss_scores = sa.mha_apply_scores_matrix_norm_reg_naive(lambda_reg=1, threshold=20.5) + norm_loss_scores\n",
        "                    print(f'train(): norm_loss_scores = {norm_loss_scores}')\n",
        "\n",
        "            if model.model_is_rse and (LOGIT_LOSS_RSE_COPY_PROBS or RSE_COPY_PROBS_USE_MARGIN_REG):\n",
        "                # Apply softmax logit norm control loss:\n",
        "                if LOGIT_LOSS_RSE_COPY_PROBS and model.relative_encodings[0].logits_reg_loss is not None:\n",
        "                    logits_reg_loss = model.relative_encodings[0].logits_reg_loss\n",
        "                    logits_reg_loss.backward(retain_graph=False)\n",
        "                    print(f'[LOGIT_LOSS_RSE_COPY_PROBS]: logits_reg_loss = {logits_reg_loss}')\n",
        "                elif RSE_COPY_PROBS_USE_MARGIN_REG:\n",
        "                    copy_margin_loss = model.relative_encodings[0].copy_margin_loss\n",
        "                    copy_margin_loss.backward(retain_graph=False)\n",
        "                    print(f'[RSE_COPY_PROBS_USE_MARGIN_REG]: copy_margin_loss = {copy_margin_loss}')\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "            total_norm_loss = norm_loss_scores\n",
        "            if total_norm_loss > 0:\n",
        "                total_norm_loss.backward(retain_graph=False)\n",
        "            if global_iter % 1 == 0:\n",
        "                print(f'train(): Norm loss RSE = {norm_loss_rse_gate_activations/normRegGamma:.8f}, norm loss scores matrix + lstm_norm = {norm_loss_scores}')\n",
        "                # print(f'[train_with_enhanced_logging] Iter = {iter}, Loss = {token_loss_for_summary.item()}')\n",
        "\n",
        "\n",
        "        if iter % GRAD_ACCUMULATION_STEPS == 0 or iter == len(dataloader)-1 or (max_iterations is not None and iter >= max_iterations):\n",
        "\n",
        "\n",
        "            with torch.no_grad():\n",
        "\n",
        "                def get_and_print_total_grad_norm(always_print_high_tensor_norm=False):\n",
        "                    total_grad = 0\n",
        "                    for param in model.parameters():\n",
        "                        if param.grad is not None:\n",
        "                            total_grad += torch.norm(param.grad)\n",
        "\n",
        "                    PRINT_HIGH_TENSOR_NORMS = 0\n",
        "\n",
        "                    if model.model_is_rse and ((total_grad > 500 and PRINT_HIGH_TENSOR_NORMS) or always_print_high_tensor_norm):\n",
        "                        # Enumerate tensors that have grad in rse:\n",
        "                        print('---' * 30)\n",
        "                        print(f'-- Printing high tensor grad norms, total_grad={total_grad}')\n",
        "                        print('---' * 30)\n",
        "                        for name, param in model_rse.named_parameters():\n",
        "                            # if param.requires_grad:\n",
        "                            if param.grad is not None:\n",
        "                                if True or name.endswith('_gate') or len(param.shape) == 2:\n",
        "                                    if param.grad.norm() / total_grad > 0.03:\n",
        "                                        print(name, param.data.shape)\n",
        "                                        print(f'Grad norm for {name}: {param.grad.norm()}')\n",
        "                                        print(f'mean grad magnitude for {name}: {torch.mean(torch.abs(param.grad))}')\n",
        "                                        print(f'max grad magnitude for {name}: {torch.max(torch.abs(param.grad))}')\n",
        "                                        print(f'min grad magnitude for {name}: {torch.min(torch.abs(param.grad))}')\n",
        "                                        print('---' * 30)\n",
        "                        print('---' * 30)\n",
        "                        print('---' * 30)\n",
        "\n",
        "                        if total_grad > 10000:\n",
        "                            assert False\n",
        "\n",
        "\n",
        "                    return total_grad\n",
        "\n",
        "\n",
        "                ABLATE_GRAD_NORM_PROCESSING = False\n",
        "                if not ABLATE_GRAD_NORM_PROCESSING:\n",
        "\n",
        "                    if iter % 1 == 0:\n",
        "                        total_grad = get_and_print_total_grad_norm()\n",
        "                        print(f'Iter = {iter}, total_grad = {total_grad}')\n",
        "                        if total_grad > 1000:\n",
        "                            TOTAL_COUNT_OF_GRAD_NORMS_GR_THAN_1k += 1\n",
        "                        max_grad_norm = max(total_grad, max_grad_norm)\n",
        "                        print(f'[Train:] TOTAL_COUNT_OF_GRAD_NORMS_GR_THAN_1k = {TOTAL_COUNT_OF_GRAD_NORMS_GR_THAN_1k}, max_grad_norm all iters = {max_grad_norm}')\n",
        "\n",
        "\n",
        "\n",
        "                    # max_norm = max(30, 0.1 * total_grad)\n",
        "                    max_norm = 5\n",
        "                    # Clip grad norm to max_norm with the exclusion of pos_coeffs_q:\n",
        "                    parameters_to_remove = set()\n",
        "                    for name, param in model.named_parameters():\n",
        "                        if 'pos_coeffs_Q' in name or 'post_scaling_factors_QK' in name:\n",
        "                            parameters_to_remove.add(param)\n",
        "\n",
        "                    parameters_to_clip = [p for p in model.parameters() if p not in parameters_to_remove]\n",
        "\n",
        "                    torch.nn.utils.clip_grad_norm_(parameters_to_clip, max_norm)\n",
        "                    # nn.utils.clip_grad_value_(parameters_to_clip, clip_value=0.1)\n",
        "                    # Print the max grads for all parameters whose name contains pos_coeffs_Q:\n",
        "                    for name, param in model.named_parameters():\n",
        "\n",
        "                        if 'post_scaling_factors_QK' in name or 'coeffsForAttenBias_' in name:\n",
        "                            if param.grad is not None:\n",
        "                            # Print with 8 digits of prec.:\n",
        "                                print(f'train(): Max grad for {name}: {param.grad.abs().max():.15f}, min grad: {param.grad.abs().min():.15f}, shape = {param.shape}')\n",
        "                                # print(f'train(): grad tensor for {name} = {param.grad}')\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "            if aux_optimizers is not None and not turn_off_aux_losses:\n",
        "                for aux_optimizer in aux_optimizers:\n",
        "                    aux_optimizer.step()\n",
        "\n",
        "            if hasattr(optimizer, 'scheduler'):\n",
        "                optimizer.scheduler.step()\n",
        "\n",
        "\n",
        "            ortho_loss = 0\n",
        "            # Apply orthog. regularization for lstm cells:\n",
        "\n",
        "            if model.model_is_rse and not turn_off_aux_losses and 1:\n",
        "                ortho_loss = torch.tensor(0.0, device=device, requires_grad=True)\n",
        "                beta = 0 #1e-3\n",
        "                if beta > 0:\n",
        "                    for re in model.relative_encodings:\n",
        "                        if re is None:\n",
        "                            continue\n",
        "\n",
        "\n",
        "                        ortho_loss = ortho_loss + re._apply_orthogonal_regularization(beta=beta) + ortho_loss\n",
        "\n",
        "                        if beta > 0:\n",
        "                            print(f'train(): ortho_loss = {ortho_loss / beta}')\n",
        "                            total_loss += ortho_loss.item()\n",
        "                            total_orthog_loss += ortho_loss.item()\n",
        "                    ortho_loss.backward()\n",
        "\n",
        "\n",
        "            optimizer.step()\n",
        "            optimizer.zero_grad(set_to_none=True)\n",
        "            if LINEAR_MODULE_SPECTRAL_NORM and model_to_use == model_rse:\n",
        "                print(f'[train()] applying spectral norm to linear modules')\n",
        "                project_mats_(model_rse)\n",
        "\n",
        "            for aux_optimizer in aux_optimizers:\n",
        "                aux_optimizer.zero_grad(set_to_none=True)\n",
        "\n",
        "\n",
        "        if max_iterations and iter >= max_iterations:\n",
        "            print(f\"Training stopped after {iter} iterations.\")\n",
        "            break\n",
        "\n",
        "        # total_token_loss_log += token_loss.item()\n",
        "        total_token_loss_log += token_loss_for_summary.item()\n",
        "        total_loss += token_loss_for_summary.item()\n",
        "        train_losses.append((iter, latest_epoch_index, token_loss.item()))\n",
        "        count_for_current_avg_token_loss_summary += 1\n",
        "        total_token_loss_for_current_avg_loss_summary += token_loss.item()\n",
        "\n",
        "        if print_losses_every_iter is not None and global_iter % print_losses_every_iter == 0:\n",
        "            # clear_output(wait=True)\n",
        "            # print(f'\\nIter: {iter}, Loss: {token_loss.item()}, [Epoch: {latest_epoch_index+1}]')\n",
        "            model_type = 'rse' if model.model_is_rse else 'baseline'\n",
        "            print('---' * 20)\n",
        "            # print(f'Iter: {iter}, Model type: {model_type}, Loss: {token_loss.item()}, [Epoch: {latest_epoch_index+1}]')\n",
        "            print(f'Iter: {iter} of {len(dataloader)}, Model type: {model_type}, Loss: {token_loss_for_summary.item()}, [Epoch: {latest_epoch_index+1}]')\n",
        "            print(f'Current average loss: {total_token_loss_for_current_avg_loss_summary / count_for_current_avg_token_loss_summary}')\n",
        "            print(f'over num minibatches: {count_for_current_avg_token_loss_summary}')\n",
        "            print('---' * 20)\n",
        "            count_for_current_avg_token_loss_summary = 0; total_token_loss_for_current_avg_loss_summary = 0\n",
        "\n",
        "\n",
        "        global_iter += 1\n",
        "\n",
        "        # if iter % 100 == 0:\n",
        "        #     print('---' * 10)\n",
        "        #     print(f'Train: Iter = {iter} of {len(dataloader)}')\n",
        "        #     print('---' * 10)\n",
        "\n",
        "    return total_loss / len(dataloader), total_token_loss_log/len(dataloader), total_orthog_loss / len(dataloader), aux_loss * aux_coeff, number_segmentation_loss * aux_coeff\n"
      ],
      "metadata": {
        "id": "H0FcvqkQDRQj",
        "scrolled": true,
        "trusted": true,
        "execution": {
          "iopub.status.busy": "2025-09-18T01:33:18.507678Z",
          "iopub.execute_input": "2025-09-18T01:33:18.508265Z",
          "iopub.status.idle": "2025-09-18T01:33:18.551607Z",
          "shell.execute_reply.started": "2025-09-18T01:33:18.508243Z",
          "shell.execute_reply": "2025-09-18T01:33:18.550876Z"
        }
