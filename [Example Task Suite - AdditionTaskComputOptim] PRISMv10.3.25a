    {
      "cell_type": "markdown",
      "source": [
        "# Sinusoidal Positional Encoding"
      ],
      "metadata": {
        "id": "sdaWssxoCuko"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "asymptotically_correct_pe_approx = None"
      ],
      "metadata": {
        "id": "XvU5_SuhPsIt",
        "trusted": true,
        "execution": {
          "iopub.status.busy": "2025-09-17T19:06:50.676286Z",
          "iopub.execute_input": "2025-09-17T19:06:50.676535Z",
          "iopub.status.idle": "2025-09-17T19:06:50.691245Z",
          "shell.execute_reply.started": "2025-09-17T19:06:50.676505Z",
          "shell.execute_reply": "2025-09-17T19:06:50.690493Z"
        }
      },
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "code",
      "source": [
        "#     return torch.FloatTensor(pe)\n",
        "\n",
        "def positional_encoding_1d(d_model, length, use_asymptotically_correct_approx=False):\n",
        "    \"\"\"Generate a 1D sinusoidal positional encoding\"\"\"\n",
        "    if use_asymptotically_correct_approx:\n",
        "        global asymptotically_correct_pe_approx\n",
        "        assert asymptotically_correct_pe_approx is not None, \"Must call construct_sinusoidal_pe_with_asymptotic_correctness first\"\n",
        "        return asymptotically_correct_pe_approx\n",
        "\n",
        "    pe = np.zeros((length, d_model))\n",
        "    div_term = np.exp(np.arange(0, d_model, 2) * -(np.log(10000.0) / d_model))\n",
        "    position = np.arange(0, length).reshape(-1, 1)\n",
        "    pe[:, 0::2] = np.sin(position * div_term)\n",
        "    pe[:, 1::2] = np.cos(position * div_term)\n",
        "    # Ensure FloatTensor is explicitly float32\n",
        "    return torch.tensor(pe, dtype=torch.float32)\n",
        "\n",
        "def sinusoidal_encoding_vector_norm_vs_d_model(d_model):\n",
        "    return 0.7071 * (d_model ** 0.5)\n",
        "\n"
      ],
      "metadata": {
        "id": "wh7EOFxi-kAt",
        "scrolled": true,
        "trusted": true,
        "execution": {
          "iopub.status.busy": "2025-09-17T19:06:50.692041Z",
          "iopub.execute_input": "2025-09-17T19:06:50.692205Z",
          "iopub.status.idle": "2025-09-17T19:06:50.703637Z",
          "shell.execute_reply.started": "2025-09-17T19:06:50.692192Z",
          "shell.execute_reply": "2025-09-17T19:06:50.702899Z"
        }
      },
      "outputs": [],
      "execution_count": null
    },
