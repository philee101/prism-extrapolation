    },
    {
      "cell_type": "code",
      "source": [
        "def hist_update_v8_pipelined(\n",
        "    hist:   torch.Tensor,         # [P, bs, h]\n",
        "    p_reset: torch.Tensor,         # [bs, h]\n",
        "    p_inc:  torch.Tensor,         # [bs, h]\n",
        "    p_dec:  torch.Tensor,         # [bs, h]\n",
        "    p_keep: torch.Tensor,         # [bs, h]\n",
        "    p_copy: torch.Tensor|None,    # [P+1, bs, h]  or  [bs, h, P+1]\n",
        "    eps:    float,\n",
        "    gamma:  torch.Tensor|float,   # scalar or [h]  (broadcast ok)\n",
        "    power:  bool = True,\n",
        "):\n",
        "    P, bs, h = hist.shape\n",
        "    device, dtype = hist.device, hist.dtype\n",
        "\n",
        "    # ========== PIPELINE STAGE 1: Independent Weight Computations ==========\n",
        "    # All weight computations are independent and can run in parallel\n",
        "    one = torch.ones_like(p_reset)\n",
        "    inv_r = one - p_reset\n",
        "\n",
        "    # These can all be computed in parallel - no dependencies\n",
        "    w_inc_future = torch.jit.fork(lambda: inv_r * p_inc)\n",
        "    w_dec_future = torch.jit.fork(lambda: inv_r * p_dec)\n",
        "    w_keep_future = torch.jit.fork(lambda: inv_r * p_keep)\n",
        "\n",
        "    # Also compute reset weights in parallel\n",
        "    reset_base_future = torch.jit.fork(lambda: p_reset * (p_dec + p_keep))\n",
        "    reset_inc_future = torch.jit.fork(lambda: p_reset * p_inc)\n",
        "\n",
        "    # ========== PIPELINE STAGE 2: Collect weights and spawn hist operations ==========\n",
        "    w_inc = torch.jit.wait(w_inc_future)\n",
        "    w_dec = torch.jit.wait(w_dec_future)\n",
        "    w_keep = torch.jit.wait(w_keep_future)\n",
        "\n",
        "    # Spawn independent histogram multiplications\n",
        "    hist_inc_future = torch.jit.fork(lambda: hist * w_inc)\n",
        "    hist_dec_future = torch.jit.fork(lambda: hist * w_dec)\n",
        "    hist_keep_future = torch.jit.fork(lambda: hist * w_keep)\n",
        "\n",
        "    # Pre-allocate zero tensors for shifts (independent)\n",
        "    zero_row = torch.zeros(1, bs, h, device=device, dtype=dtype)\n",
        "    zero_block_future = torch.jit.fork(lambda: torch.zeros(P-2, bs, h, device=device, dtype=dtype))\n",
        "\n",
        "    # ========== PIPELINE STAGE 3: Build shift operations in parallel ==========\n",
        "    hist_inc = torch.jit.wait(hist_inc_future)\n",
        "    hist_dec = torch.jit.wait(hist_dec_future)\n",
        "    hist_keep = torch.jit.wait(hist_keep_future)\n",
        "\n",
        "    # INC shift operations (t → t+1)\n",
        "    def build_inc_shift():\n",
        "        inc_base = torch.cat([zero_row, hist_inc[:-1]], dim=0)\n",
        "        inc_overflow = torch.cat([\n",
        "            torch.zeros_like(hist_inc[:-1]),\n",
        "            hist_inc[-1:]], dim=0)\n",
        "        return inc_base + inc_overflow\n",
        "\n",
        "    # DEC shift operations (t → t-1)\n",
        "    def build_dec_shift():\n",
        "        dec_base = torch.cat([hist_dec[1:], zero_row], dim=0)\n",
        "        dec_underflow = torch.cat([\n",
        "            hist_dec[:1],\n",
        "            torch.zeros_like(hist_dec[1:])], dim=0)\n",
        "        return dec_base + dec_underflow\n",
        "\n",
        "    # Launch shift computations in parallel\n",
        "    inc_shift_future = torch.jit.fork(build_inc_shift)\n",
        "    dec_shift_future = torch.jit.fork(build_dec_shift)\n",
        "\n",
        "    # ========== PIPELINE STAGE 4: Build reset block in parallel ==========\n",
        "    reset_base = torch.jit.wait(reset_base_future)\n",
        "    reset_inc = torch.jit.wait(reset_inc_future)\n",
        "    zero_block = torch.jit.wait(zero_block_future)\n",
        "\n",
        "    def build_reset_block():\n",
        "        total = 1.0  # hist.sum(0) if needed\n",
        "        return torch.cat([\n",
        "            (total * reset_base).unsqueeze(0),  # row-0\n",
        "            (total * reset_inc).unsqueeze(0),   # row-1\n",
        "            zero_block\n",
        "        ], dim=0)\n",
        "\n",
        "    reset_block_future = torch.jit.fork(build_reset_block)\n",
        "\n",
        "    # ========== PIPELINE STAGE 5: Accumulate results ==========\n",
        "    inc_shift = torch.jit.wait(inc_shift_future)\n",
        "    dec_shift = torch.jit.wait(dec_shift_future)\n",
        "    reset_block = torch.jit.wait(reset_block_future)\n",
        "\n",
        "    # Final accumulation\n",
        "    out = hist_keep + inc_shift + dec_shift + reset_block\n",
        "\n",
        "    # ========== PIPELINE STAGE 6: Final normalization (sequential) ==========\n",
        "    if power:\n",
        "        out = (out + eps).pow(gamma)\n",
        "    out = (out + eps) / (out.sum(0, keepdim=True) + eps)\n",
        "\n",
        "    return out\n",
        "\n",
        "\n",
        "# Alternative version using torch.stack for better memory locality\n",
        "@torch.compile(dynamic=False)\n",
        "def hist_update_v8_pipelined_stack(\n",
        "    hist:   torch.Tensor,         # [P, bs, h]\n",
        "    p_reset: torch.Tensor,         # [bs, h]\n",
        "    p_inc:  torch.Tensor,         # [bs, h]\n",
        "    p_dec:  torch.Tensor,         # [bs, h]\n",
        "    p_keep: torch.Tensor,         # [bs, h]\n",
        "    p_copy: torch.Tensor|None,    # [P+1, bs, h]  or  [bs, h, P+1]\n",
        "    eps:    float,\n",
        "    gamma:  torch.Tensor|float,   # scalar or [h]  (broadcast ok)\n",
        "    power:  bool = True,\n",
        "):\n",
        "    P, bs, h = hist.shape\n",
        "    device, dtype = hist.device, hist.dtype\n",
        "\n",
        "    # ========== VECTORIZED WEIGHT COMPUTATION ==========\n",
        "    inv_r = 1.0 - p_reset\n",
        "\n",
        "    # Stack all weight computations for single broadcast operation\n",
        "    weights = torch.stack([\n",
        "        inv_r * p_inc,   # w_inc\n",
        "        inv_r * p_dec,   # w_dec\n",
        "        inv_r * p_keep,  # w_keep\n",
        "        p_reset * (p_dec + p_keep),  # reset_base\n",
        "        p_reset * p_inc  # reset_inc\n",
        "    ], dim=0)  # [5, bs, h]\n",
        "\n",
        "    w_inc, w_dec, w_keep, reset_base, reset_inc = weights.unbind(0)\n",
        "\n",
        "    # ========== VECTORIZED HISTOGRAM OPERATIONS ==========\n",
        "    # Stack histogram multiplications for better memory access\n",
        "    hist_weighted = torch.stack([\n",
        "        hist * w_inc,   # hist_inc\n",
        "        hist * w_dec,   # hist_dec\n",
        "        hist * w_keep   # hist_keep\n",
        "    ], dim=0)  # [3, P, bs, h]\n",
        "\n",
        "    hist_inc, hist_dec, hist_keep = hist_weighted.unbind(0)\n",
        "\n",
        "    # ========== OPTIMIZED SHIFT OPERATIONS ==========\n",
        "    zero_row = torch.zeros(1, bs, h, device=device, dtype=dtype)\n",
        "\n",
        "    # INC shift with single concatenation\n",
        "    inc_shifts = torch.stack([\n",
        "        torch.cat([zero_row, hist_inc[:-1]], dim=0),  # base shift\n",
        "        torch.cat([torch.zeros_like(hist_inc[:-1]), hist_inc[-1:]], dim=0)  # overflow\n",
        "    ], dim=0)\n",
        "    inc_shift = inc_shifts.sum(0)\n",
        "\n",
        "    # DEC shift with single concatenation\n",
        "    dec_shifts = torch.stack([\n",
        "        torch.cat([hist_dec[1:], zero_row], dim=0),  # base shift\n",
        "        torch.cat([hist_dec[:1], torch.zeros_like(hist_dec[1:])], dim=0)  # underflow\n",
        "    ], dim=0)\n",
        "    dec_shift = dec_shifts.sum(0)\n",
        "\n",
        "    # ========== RESET BLOCK ==========\n",
        "    total = 1.0\n",
        "    reset_block = torch.cat([\n",
        "        (total * reset_base).unsqueeze(0),\n",
        "        (total * reset_inc).unsqueeze(0),\n",
        "        torch.zeros(P-2, bs, h, device=device, dtype=dtype)\n",
        "    ], dim=0)\n",
        "\n",
        "    # ========== FINAL ACCUMULATION ==========\n",
        "    out = hist_keep + inc_shift + dec_shift + reset_block\n",
        "\n",
        "    # ========== NORMALIZATION ==========\n",
        "    if power:\n",
        "        out = (out + eps).pow(gamma)\n",
        "    out = (out + eps) / (out.sum(0, keepdim=True) + eps)\n",
        "\n",
        "    return out\n",
        "\n",
        "\n",
        "# Version optimized for modern GPU architectures\n",
        "@torch.compile(dynamic=False)\n",
        "def hist_update_v8_pipelined_gpu(\n",
        "    hist:   torch.Tensor,         # [P, bs, h]\n",
        "    p_reset: torch.Tensor,         # [bs, h]\n",
        "    p_inc:  torch.Tensor,         # [bs, h]\n",
        "    p_dec:  torch.Tensor,         # [bs, h]\n",
        "    p_keep: torch.Tensor,         # [bs, h]\n",
        "    p_copy: torch.Tensor|None,    # [P+1, bs, h]  or  [bs, h, P+1]\n",
        "    eps:    float,\n",
        "    gamma:  torch.Tensor|float,   # scalar or [h]  (broadcast ok)\n",
        "    power:  bool = True,\n",
        "):\n",
        "    P, bs, h = hist.shape\n",
        "    device, dtype = hist.device, hist.dtype\n",
        "\n",
        "    # ========== FUSED WEIGHT COMPUTATION ==========\n",
        "    inv_r = 1.0 - p_reset\n",
        "\n",
        "    # Fuse all weight computations into single kernel\n",
        "    w_tensor = torch.stack([inv_r * p_inc, inv_r * p_dec, inv_r * p_keep], dim=-1)  # [bs, h, 3]\n",
        "    w_inc, w_dec, w_keep = w_tensor.unbind(-1)\n",
        "\n",
        "    # ========== FUSED HISTOGRAM WEIGHTING ==========\n",
        "    # Reshape for efficient broadcasting: [P, bs, h, 1] * [1, 1, 1, 3] → [P, bs, h, 3]\n",
        "    hist_expanded = hist.unsqueeze(-1)  # [P, bs, h, 1]\n",
        "    weights_expanded = w_tensor.unsqueeze(0)  # [1, bs, h, 3]\n",
        "    hist_weighted = hist_expanded * weights_expanded  # [P, bs, h, 3]\n",
        "\n",
        "    hist_inc, hist_dec, hist_keep = hist_weighted.unbind(-1)\n",
        "\n",
        "    # ========== OPTIMIZED SHIFT OPERATIONS ==========\n",
        "    # Pre-allocate output tensor to avoid multiple allocations\n",
        "    shifts = torch.zeros(2, P, bs, h, device=device, dtype=dtype)\n",
        "\n",
        "    # INC shift operations\n",
        "    shifts[0, 1:] = hist_inc[:-1]  # base shift\n",
        "    shifts[0, -1] += hist_inc[-1]  # overflow to last position\n",
        "\n",
        "    # DEC shift operations\n",
        "    shifts[1, :-1] = hist_dec[1:]  # base shift\n",
        "    shifts[1, 0] += hist_dec[0]    # underflow to first position\n",
        "\n",
        "    inc_shift, dec_shift = shifts.unbind(0)\n",
        "\n",
        "    # ========== RESET COMPUTATION ==========\n",
        "    total = 1.0\n",
        "    reset_vals = torch.stack([\n",
        "        total * p_reset * (p_dec + p_keep),  # row 0\n",
        "        total * p_reset * p_inc              # row 1\n",
        "    ], dim=0)  # [2, bs, h]\n",
        "\n",
        "    # ========== FINAL ASSEMBLY ==========\n",
        "    out = hist_keep + inc_shift + dec_shift\n",
        "    out[0] += reset_vals[0]  # Add reset to row 0\n",
        "    out[1] += reset_vals[1]  # Add reset to row 1\n",
        "\n",
        "    # ========== NORMALIZATION ==========\n",
        "    if power:\n",
        "        out = (out + eps).pow(gamma)\n",
        "    out = (out + eps) / (out.sum(0, keepdim=True) + eps)\n",
        "\n",
        "    return out\n",
        "\n"
      ],
