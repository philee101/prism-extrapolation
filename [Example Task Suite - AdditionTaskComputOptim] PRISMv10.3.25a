    {
      "cell_type": "markdown",
      "source": [
        "## Begin RSE class"
      ],
      "metadata": {
        "id": "iycvybkIb5Ia"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import torch\n",
        "import torch.nn.functional as F\n",
        "\n",
        "@torch.compile(dynamic=False)\n",
        "def softplus_cap_at_bounds(x, beta=1.0, bounds=3.0):\n",
        "    \"\"\"\n",
        "    Smooth soft-cap using softplus:\n",
        "      f(x) = bounds - softplus(5 - x, beta)\n",
        "    As x → -∞, f(x) ~ x (up to a tiny offset near the transition);\n",
        "    As x → +∞, f(x) → bounds.\n",
        "    Increase beta for a sharper transition.\n",
        "    \"\"\"\n",
        "    x = torch.abs(x)\n",
        "    # return bounds - F.softplus((bounds) - x, beta=beta)\n",
        "    return F.softplus(torch.tensor(bounds)) - F.softplus(torch.tensor(bounds) - x, beta=beta)\n"
      ],
      "metadata": {
        "id": "OubHdkrmuRD-",
        "trusted": true,
        "execution": {
          "iopub.status.busy": "2025-09-17T19:06:51.783236Z",
