    },
    {
      "cell_type": "code",
      "source": [
        "wgt_decay = 1e-3 # 2e-3"
      ],
      "metadata": {
        "id": "Lm-84-jIV-qp",
        "scrolled": true,
        "trusted": true,
        "execution": {
          "iopub.status.busy": "2025-09-17T19:06:59.324631Z",
          "iopub.execute_input": "2025-09-17T19:06:59.324836Z",
          "iopub.status.idle": "2025-09-17T19:06:59.341087Z",
          "shell.execute_reply.started": "2025-09-17T19:06:59.324812Z",
          "shell.execute_reply": "2025-09-17T19:06:59.340343Z"
        }
      },
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "code",
      "source": [
        "\n",
        "\n",
        "\n",
        "def get_optimizer_RSE(\n",
        "    model,\n",
        "    weight_decay=wgt_decay,\n",
        "    lr=1e-4,\n",
        "    ignore_wd_for_relative_encodings=False,\n",
        "    adam_eps=1e-9,\n",
        "    freeze_mha_pos_biases=False,   # <-- NEW\n",
        "    # <pgForDB> - parameter groups for dist bias\n",
        "    attn_bias_lr=None,             # <-- NEW (overrides freeze when > 0)\n",
        "):\n",
        "    \"\"\"\n",
        "    Builds AdamWAdaptiveEpsilon with your existing param groups, plus:\n",
        "      - If freeze_mha_pos_biases=True and attn_bias_lr is None/<=0: freezes six MHA-pos tensors.\n",
        "      - If attn_bias_lr > 0: overrides freeze, creates a separate LR group for those tensors.\n",
        "    \"\"\"\n",
        "\n",
        "    # ------------- identify the six target tensors -------------\n",
        "    # support both names with/without trailing \"_\"\n",
        "    target_fragments = {\n",
        "        # \"zeroth_pe_bias_u\",\n",
        "        # \"zeroth_pe_bias_v\",\n",
        "        # \"attn_dist_bias_u\", \"attn_dist_bias_u_\",\n",
        "        # \"attn_dist_bias_v\", \"attn_dist_bias_v_\",\n",
        "        # \"attn_dist_scale_u\", \"attn_dist_scale_u_\",\n",
        "        # \"attn_dist_scale_v\", \"attn_dist_scale_v_\",\n",
        "    }\n",
        "\n",
        "    bias_params = []        # (optionally) separate LR group\n",
        "    bias_param_names = []   # pretty print\n",
        "\n",
        "    # ------------- collect base groups as before -------------\n",
        "    decay_params = []\n",
        "    no_decay_params = []\n",
        "    post_scaling_factors_QK_params = []  # special group\n",
        "\n",
        "    # First pass: decide freeze/collect\n",
        "    use_bias_param_group = (attn_bias_lr is not None) and (attn_bias_lr > 0)\n",
        "\n",
        "    for name, param in model.named_parameters():\n",
        "        # collect the six MHA-pos tensors\n",
        "        # <pgForDB> - parameter groups for dist bias\n",
        "        is_mha_pos_bias = any(frag in name for frag in target_fragments)\n",
        "\n",
        "        if is_mha_pos_bias:\n",
        "            if use_bias_param_group:\n",
        "                # ensure trainable and put into separate group later\n",
        "                if not param.requires_grad:\n",
        "                    param.requires_grad_(True)\n",
        "                bias_params.append(param)\n",
        "                bias_param_names.append(name)\n",
        "                # Do not add them to any other group\n",
        "                continue\n",
        "            elif freeze_mha_pos_biases:\n",
        "                # freeze & skip entirely\n",
        "                if param.requires_grad:\n",
        "                    param.requires_grad_(False)\n",
        "                continue\n",
        "            # else: fall through to normal grouping (no freeze, no separate group)\n",
        "\n",
        "        # skip frozen params\n",
        "        if not param.requires_grad:\n",
        "            continue\n",
        "\n",
        "        # your existing grouping rules\n",
        "        if ('post_scaling_factors_QK' in name or\n",
        "            'post_scaling_factors_Keys' in name or\n",
        "            'alpha_z0_head' in name):\n",
        "            print(f'post_scaling_factors_QK_params: {name}')\n",
        "            post_scaling_factors_QK_params.append(param)\n",
        "\n",
        "        elif '_hh' in name or '_ih' in name:\n",
        "            print(f'ignoring weight decay for GRU parameter: {name}')\n",
        "            no_decay_params.append(param)\n",
        "        elif not ignore_wd_for_relative_encodings:\n",
        "            decay_params.append(param)\n",
        "\n",
        "        elif 'relative_encodings' in name:\n",
        "            print(f'ignoring weight decay for {name}')\n",
        "            no_decay_params.append(param)\n",
        "\n",
        "        elif ('pos_coeffs_Q' in name or 'pos_coeffs_K' in name or\n",
        "              'postSoftmaxScalingFactors_' in name or\n",
        "              'alignment_weights_' in name or\n",
        "              'final_self_attention_softmax_temps_' in name):\n",
        "            print(f'ignoring weight decay for {name}')\n",
        "            no_decay_params.append(param)\n",
        "\n",
        "        else:\n",
        "            decay_params.append(param)\n",
        "\n",
        "    # Build param groups (keep existing 3, append the new one if requested)\n",
        "    param_groups = [\n",
        "        {\"params\": decay_params, \"weight_decay\": weight_decay},\n",
        "        {\"params\": no_decay_params, \"weight_decay\": 0.0},\n",
        "        {\"params\": post_scaling_factors_QK_params,\n",
        "         \"lr\": 0.012,\n",
        "         \"weight_decay\": 0, #1e-1,\n",
        "         \"limit_avg_sq_scaling\": True,\n",
        "         \"betas\": (0.03, 0.94)},\n",
        "    ]\n",
        "\n",
        "    if use_bias_param_group and len(bias_params) > 0:\n",
        "        # put the six tensors in their own group, no weight decay\n",
        "        param_groups.append({\n",
        "            \"params\": bias_params,\n",
        "            \"lr\": float(attn_bias_lr),\n",
        "            \"weight_decay\": 0.0,\n",
        "        })\n",
        "        print(f\"[OptimizerInit] attn_bias_lr={attn_bias_lr:.3g} → created separate LR group \"\n",
        "              f\"with {len(bias_params)} tensor(s).\")\n",
        "        print(\"  ↳ Grouped:\", \", \".join(bias_param_names))\n",
        "    elif freeze_mha_pos_biases:\n",
        "        print(\"[OptimizerInit] freeze_mha_pos_biases=True → six MHA-pos tensors frozen \"\n",
        "              \"(excluded from optimizer groups).\")\n",
        "\n",
        "    # Initialize optimizer\n",
        "    optimizer = AdamWAdaptiveEpsilon(\n",
        "        param_groups,\n",
        "        lr=lr,\n",
        "        weight_decay=weight_decay,\n",
        "        betas=(0.9, 0.99),\n",
        "        eps=adam_eps,\n",
        "        fused=True\n",
        "    )\n",
        "\n",
        "    return {'main': optimizer}\n"
      ],
      "metadata": {
        "id": "ykdycVUrmxN1",
        "scrolled": true,
        "trusted": true,
        "execution": {
          "iopub.status.busy": "2025-09-17T19:06:59.341908Z",
          "iopub.execute_input": "2025-09-17T19:06:59.342274Z",
          "iopub.status.idle": "2025-09-17T19:06:59.355121Z",
          "shell.execute_reply.started": "2025-09-17T19:06:59.342252Z",
          "shell.execute_reply": "2025-09-17T19:06:59.354541Z"
        }
      },
      "outputs": [],
      "execution_count": null
    },
