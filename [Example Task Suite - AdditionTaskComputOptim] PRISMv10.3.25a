      "source": [
        "# Reset all post_scaling_factors_QK in MHA:\n",
        "\n",
        "RESET_POST_SCALING_FACTORS_QK = True\n",
        "def _RESET_All_POST_SCALING_FACTORS_QK_If_Applicble():\n",
        "\n",
        "    save_ckpt('backup_rse_before_resetting_post_scaling_factors_QK.pth', for_model=model_rse)\n",
        "\n",
        "    for lidx,layer in enumerate(model_rse.layers):\n",
        "        sa = layer.self_attn\n",
        "        # sa.post_scaling_factors_QK = nn.Parameter(torch.randn(sa.post_scaling_factors_QK.shape) * 0.002, requires_grad=True)\n",
        "        # Divide existing coeffs by 10:\n",
        "\n",
        "        sa.post_scaling_factors_QK = nn.Parameter(sa.post_scaling_factors_QK / 50 + torch.randn(sa.post_scaling_factors_QK.shape, device=device) * 0.001, requires_grad=True)\n",
        "        print(f'layer {lidx} post_scaling_factors_QK = {sa.post_scaling_factors_QK}')\n",
        "    model_rse.to(device)\n",
        "if RESET_POST_SCALING_FACTORS_QK:\n",
        "    _RESET_All_POST_SCALING_FACTORS_QK_If_Applicble()"
      ],
