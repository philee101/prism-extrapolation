        "# # Target A100 (sm_80, sm_86) so Inductor can JIT-optimize correctly\n",
        "# # os.environ['TORCH_CUDA_ARCH_LIST'] = '8.0;8.6+PTX'\n",
        "\n",
        "# os.environ['DYNAMO_CACHE_SIZE_LIMIT']= '32'\n",
        "# os.environ['TORCH_DYNAMO_DYNAMIC_SHAPES'] = '1'\n",
