        "    ], dim=0)  # [2, bs, h]\n",
        "\n",
        "    # ========== FINAL ASSEMBLY ==========\n",
        "    out = hist_keep + inc_shift + dec_shift\n",
        "    out[0] += reset_vals[0]  # Add reset to row 0\n",
        "    out[1] += reset_vals[1]  # Add reset to row 1\n",
        "\n",
        "    # ========== NORMALIZATION ==========\n",
        "    if power:\n",
        "        out = (out + eps).pow(gamma)\n",
        "    out = (out + eps) / (out.sum(0, keepdim=True) + eps)\n",
        "\n",
        "    return out\n",
        "\n",
