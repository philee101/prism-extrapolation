    {
      "cell_type": "code",
      "source": [],
      "metadata": {
        "id": "oXqnttkqg40d",
        "trusted": true
      },
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "code",
      "source": [
        "ablate_abs_pos_enc = False\n",
        "\n",
        "#@torch.compile(dynamic=False)\n",
        "def _apply_abs_concat_and_ln_optim(enc_q, enc_k, B, H, O, S, d, abs_enc, ablate_abs_pos_enc=False):\n",
        "    assert enc_q.shape == enc_k.shape == (B, H, O, S, d), f'enc_q.shape = {enc_q.shape}, enc_k.shape = {enc_k.shape}, expected shape = {B, H, O, S, d}'\n",
        "\n",
        "    #  expected shape = (10, 40, 3, 30, 768)\n",
        "    total_enc_per_head = O\n",
        "\n",
        "    # 4) Optional absolute-PE concatenation\n",
        "    if CONCAT_ABS_POSITION_ENCODINGS:\n",
        "        total_enc_per_head = total_enc_per_head + 1\n",
        "\n",
        "        abs_pe = abs_enc[:S].view(1, 1, 1, S, d)\n",
        "        abs_pe = abs_pe.   expand(B, H, 1, S, d)\n",
        "\n",
        "        if ablate_abs_pos_enc:\n",
        "            abs_pe = torch.zeros_like(abs_pe)\n",
        "            print(f'WARNING: ablating absolute position encoding in _apply_abs_concat_and_ln_optim()')\n",
        "\n",
        "        enc_q  = torch.cat([enc_q, abs_pe], dim=2)\n",
        "        enc_k  = torch.cat([enc_k, abs_pe], dim=2)\n",
        "\n",
        "\n",
        "    # 5) Optional custom LN scaling\n",
        "\n",
        "    if MHA_USE_CUSTOM_LN:\n",
        "        assert False, \"Unsupported\"\n",
        "        # vector_norm_per_enc = sinusoidal_encoding_vector_norm_vs_d_model(d)\n",
        "        # expected_total_vector_norm   = ((vector_norm_per_enc**2) * total_enc_per_head) ** 0.5\n",
        "        # scale = (d**0.5) / expected_total_vector_norm # Since Layer Norm normalizes vectors to dim ** 0.5\n",
        "        # enc_q.mul_(scale)\n",
        "        # enc_k.mul_(scale)\n",
        "    else:\n",
        "\n",
        "        # Normalize over dims 2 and 4:\n",
        "        assert enc_q.shape == (B, H, total_enc_per_head, S, d) and enc_k.shape == (B, H, total_enc_per_head, S, d), f'enc_q.shape = {enc_q.shape}, enc_k.shape = {enc_k.shape}, expected shape = {B, H, O, S, d}'\n",
        "        if PE_VECTOR_NORM_FOR_INNER_PROD_POSITION_SCORES:\n",
        "            d = PE_VECTOR_NORM_FOR_INNER_PROD_POSITION_SCORES ** 2\n",
        "\n",
        "        enc_q = enc_q / (enc_q.norm(dim=(-3, -1), keepdim=True) + 1e-9) * (d ** 0.5)\n",
        "        enc_k = enc_k / (enc_k.norm(dim=(-3, -1), keepdim=True) + 1e-9) * (d ** 0.5)\n",
        "\n",
        "        # enc_q = enc_q.permute(0, 1, 3, 2, 4) # [B, H, S, total_enc_per_head, d]\n",
        "        # enc_k = enc_k.permute(0, 1, 3, 2, 4) # [B, H, S, total_enc_per_head, d]\n",
        "\n",
        "        # enc_q = enc_q / (enc_q.norm(dim=(-2, -1), keepdim=True) + 1e-9) * (d ** 0.5)\n",
        "        # enc_k = enc_k / (enc_k.norm(dim=(-2, -1), keepdim=True) + 1e-9) * (d ** 0.5)\n",
        "        # # print(f'enc_k norms = {enc_k.norm(dim=(-2, -1)).mean()}, min = {enc_k.norm(dim=(-2, -1)).min()}, max = {enc_k.norm(dim=(-2, -1)).max()}')\n",
        "\n",
        "        # enc_q = enc_q.permute(0, 1, 3, 2, 4)\n",
        "        # enc_k = enc_k.permute(0, 1, 3, 2, 4)\n",
        "    return enc_q, enc_k\n",
        "\n",
        "\n",
        "\n",
        "# somewhere in module scope (e.g. at top of your transformer file)\n",
        "\n",
        "# @torch.compile(dynamic=False)\n",
        "def _get_PE_encoding_vectors_fused(\n",
        "    query, position_stream,\n",
        "    d_model, num_heads, base_ops_per_head,\n",
        "    abs_enc, positions_x_shift_relative=None\n",
        "):\n",
        "\n",
        "\n",
        "    # ensure prior work is done\n",
        "    if ENABLE_CUDA_SYNCHRONIZE_TIMING_STATISTICS:\n",
        "        _pe_fuse_start = torch.cuda.Event(enable_timing=True)\n",
        "        _pe_fuse_end   = torch.cuda.Event(enable_timing=True)\n",
        "        torch.cuda.synchronize()\n",
        "        _pe_fuse_start.record()\n",
        "\n",
        "\n",
        "    # --- original fused code ---\n",
        "    _, _, prob_q, prob_k, *_ = position_stream  # [B, ops/2, S, branches]\n",
        "    branches_q = prob_q.size(-1)\n",
        "    with torch.no_grad():\n",
        "        table_q    = abs_enc[:branches_q]           # [branches_q, d_model]\n",
        "    enc_q      = torch.matmul(prob_q, table_q)  # [B, ops/2, S, d_model]\n",
        "\n",
        "    branches_k = prob_k.size(-1)\n",
        "    with torch.no_grad():\n",
        "        table_k    = abs_enc[:branches_k]\n",
        "    enc_k      = torch.matmul(prob_k, table_k)\n",
        "\n",
        "    # reshape to (B, heads, ops_per_head, S, d_model)\n",
        "    B, half_ops, S, _ = enc_q.shape\n",
        "    if VERBOSE_LOGGING:\n",
        "        print(f'enc_q.shape = {enc_q.shape}, prob_q.shape = {prob_q.shape}')\n",
        "    enc_q = enc_q.view(B, num_heads, base_ops_per_head, S, d_model)\n",
        "    enc_k = enc_k.view(B, num_heads, base_ops_per_head, S, d_model)\n",
        "\n",
        "    enc_q, enc_k = _apply_abs_concat_and_ln_optim(\n",
        "        enc_q, enc_k, B, num_heads, base_ops_per_head, S, d_model,\n",
        "        abs_enc, ablate_abs_pos_enc\n",
        "    )\n",
        "    # --- end original code ---\n",
        "\n",
        "    # record & sync to measure\n",
        "    if ENABLE_CUDA_SYNCHRONIZE_TIMING_STATISTICS:\n",
        "        _pe_fuse_end.record()\n",
        "        torch.cuda.synchronize()\n",
        "        elapsed_ms = _pe_fuse_start.elapsed_time(_pe_fuse_end)\n",
        "        print(f\"[_get_PE_encoding_vectors_fused_timed timing] fused PE‐encoding block: {elapsed_ms:.2f} ms\")\n",
        "\n",
        "    return enc_q, enc_k\n",
        "\n",
        "\n",
        "@torch.compile(dynamic=False)\n",
        "def _get_PE_encoding_vectors_from_scalar_positions_and_norm_new(\n",
        "    query,  # [B, S, ?]\n",
        "    position_stream,  # contains prob_q, prob_k\n",
        "    d_model, num_heads, base_ops_per_head,\n",
        "    abs_enc,  # [MAX_SEQ_LEN+1, d_model]\n",
        "    positions_x_shift_relative=None\n",
        "):\n",
        "    assert stochasticMatrixForResetPosBr, f'This method is only supported for stochasticMatrixForResetPosBr = True'\n",
        "    B, S = query.shape[0], query.shape[-2]\n",
        "    half_ops = num_heads * base_ops_per_head\n",
        "\n",
        "    # unpack\n",
        "    _, _, prob_q, prob_k, *_ = position_stream\n",
        "    # permute to [half_ops, B, S, branches]\n",
        "    prob_q = prob_q.permute(1,0,2,3)#.contiguous()\n",
        "    prob_k = prob_k.permute(1,0,2,3)#.contiguous()\n",
        "    _, _, _, branches_q = prob_q.shape\n",
        "    _, _, _, branches_k = prob_k.shape\n",
        "\n",
        "    # FLATTEN, MATMUL, RESHAPE\n",
        "    def project(probs, branches):\n",
        "        # probs: [half_ops, B, S, branches]\n",
        "        flat = probs.reshape(-1, branches)                    # [N, branches]\n",
        "        table = abs_enc[:branches]                            # [branches, d_model]\n",
        "        out  = flat @ table                                   # [N, d_model]\n",
        "        return out.view(half_ops, B, S, d_model)              # back to 4-D\n",
        "\n",
        "    enc_q = project(prob_q, branches_q)\n",
        "    enc_k = project(prob_k, branches_k)\n",
        "\n",
        "    # reshape into (B, heads, ops_per_head, S, d_model) and LN/etc. just as before\n",
        "    enc_q = (enc_q\n",
        "             .view(num_heads, base_ops_per_head, B, S, d_model)\n",
        "             .permute(2,0,1,3,4))\n",
        "             #.contiguous())\n",
        "    enc_k = (enc_k\n",
        "             .view(num_heads, base_ops_per_head, B, S, d_model)\n",
        "             .permute(2,0,1,3,4))\n",
        "            #  .contiguous())\n",
        "\n",
        "    # then apply your _apply_abs_concat_and_ln_optim exactly as before\n",
        "    enc_q, enc_k = _apply_abs_concat_and_ln_optim(\n",
        "        enc_q, enc_k, B, num_heads, base_ops_per_head, S, d_model,\n",
        "        abs_enc, ablate_abs_pos_enc\n",
        "    )\n",
        "    return enc_q, enc_k\n"
      ],
      "metadata": {
