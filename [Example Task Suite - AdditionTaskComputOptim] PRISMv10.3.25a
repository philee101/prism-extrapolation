    {
      "cell_type": "markdown",
      "source": [
        "## Default MHA for Baseline Transformer"
      ],
      "metadata": {
        "id": "O-K-ha3zEc9-"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "regular_mha_use_high_dim_output_proj = True\n",
        "\n",
        "class MultiHeadAttention(nn.Module):\n",
        "    def __init__(self, d_model, num_heads, head_dim=None):\n",
        "        super(MultiHeadAttention, self).__init__()\n",
        "        if head_dim is None:\n",
        "            assert d_model % num_heads == 0\n",
        "            head_dim = d_model // num_heads\n",
        "            self.has_custom_head_dim = False\n",
        "        else:\n",
        "            self.has_custom_head_dim = True\n",
        "\n",
        "        self.d_model = d_model\n",
        "        self.q_linear = nn.Linear(d_model, head_dim * num_heads)\n",
        "        self.k_linear = nn.Linear(d_model, head_dim * num_heads)\n",
        "        # self.v_linear = nn.Linear(d_model, head_dim * num_heads)\n",
        "        self.v_linear = nn.Linear(VOCAB_N_DIM, VOCAB_N_DIM * num_heads)\n",
        "        self.num_heads = num_heads\n",
        "        self.head_dim = head_dim\n",
        "\n",
        "        # self.out = nn.Linear(head_dim * num_heads, d_model)\n",
        "        # Instead of a single `out` projection, we use per-head transformations to d_model\n",
        "        # self.head_projections = nn.Parameter(torch.empty(num_heads, head_dim, d_model))\n",
        "        if not regular_mha_use_high_dim_output_proj:\n",
        "            self.head_projections = nn.Parameter(torch.empty(num_heads, VOCAB_N_DIM, VOCAB_N_DIM))\n",
        "            # Xavier initialization per head\n",
        "            for i in range(num_heads):\n",
        "                nn.init.xavier_uniform_(self.head_projections[i])\n",
        "        else:\n",
        "            self.head_projections = nn.Parameter(torch.empty(num_heads*d_model, d_model))\n",
        "            nn.init.xavier_uniform_(self.head_projections.T)\n",
        "\n",
        "\n",
        "        # Apply to out_linear\n",
        "        # self.out.apply(scaled_xavier_init)\n",
        "        self.q_linear.apply(scaled_xavier_init)\n",
        "        self.k_linear.apply(scaled_xavier_init)\n",
        "        self.v_linear.apply(scaled_xavier_init)\n",
        "        self.attn_weights = []\n",
        "\n",
        "    def clear_cached_self_attn_weights_for_visualization(self):\n",
        "        self.attn_weights = []\n",
        "        # [ADD - RSEv0.99999-bench-v3.1]]  also clear content-attn caches if present\n",
        "        if getattr(self, \"content_attn\", None) is not None:\n",
        "            self.content_attn.attn_weights = []\n",
        "\n",
        "    def forward(self, query, key, value, mask=None):\n",
        "        self.clear_cached_self_attn_weights_for_visualization()\n",
        "        batch_size = query.size(0)\n",
        "\n",
        "        assert mask is not None, \"Mask is required for multi-head attention\"\n",
        "        seq_len = query.size(1)\n",
        "\n",
        "\n",
        "        # Linear projections\n",
        "        Q = self.q_linear(query) #.view(batch_size, seq_len, self.num_heads, self.head_dim).transpose(1, 2)\n",
        "        K = self.k_linear(key) #.view(batch_size, seq_len, self.num_heads, self.head_dim).transpose(1, 2)\n",
        "        V = self.v_linear(value) #.view(batch_size, seq_len, self.num_heads, self.head_dim).transpose(1, 2)\n",
        "\n",
        "        # Apply residual QKV:\n",
        "        # Q = Q + Q_orig\n",
        "        # K = K + K_orig\n",
        "        # V = V + V_orig\n",
        "        Q = Q.view(batch_size, seq_len, self.num_heads, self.head_dim).transpose(1, 2)\n",
        "        K = K.view(batch_size, seq_len, self.num_heads, self.head_dim).transpose(1, 2)\n",
        "        # V = V.view(batch_size, seq_len, self.num_heads, self.head_dim).transpose(1, 2)\n",
        "        V = V.view(batch_size, seq_len, self.num_heads, VOCAB_N_DIM).transpose(1, 2)\n",
        "\n",
        "        assert Q.shape == K.shape == (batch_size, self.num_heads, seq_len, self.head_dim)\n",
        "        assert V.shape == (batch_size, self.num_heads, seq_len, VOCAB_N_DIM)\n",
        "\n",
        "        # Scaled dot-product attention\n",
        "        scores = torch.matmul(Q, K.transpose(-2, -1)) / np.sqrt(self.head_dim)\n",
        "\n",
        "        if mask is not None:\n",
        "            scores = scores.masked_fill(mask == 1, float('-inf'))\n",
        "\n",
        "        # attn = torch.softmax(scores, dim=-1)\n",
        "        attn = softmax_lse(scores, dim=-1)\n",
        "        assert attn.shape == (batch_size, self.num_heads, seq_len, seq_len)\n",
        "        output = torch.matmul(attn, V)  # [batch_size, num_heads, seq_len, head_dim]\n",
        "        assert output.shape == (batch_size, self.num_heads, seq_len, self.head_dim)\n",
        "\n",
        "        # Block diagonal projection via einsum\n",
        "        # Each head projects separately to d_model, then summed across heads\n",
        "        if not regular_mha_use_high_dim_output_proj:\n",
        "            output = torch.einsum(\"bnsh,nhd->bnsd\", output, self.head_projections)  # [batch_size, seq_len, d_model]\n",
        "\n",
        "            output = output / (self.head_dim ** 0.5)\n",
        "\n",
        "            # Sum over heads (instead of concatenation)\n",
        "            output = output.sum(dim=1)  # [batch_size, seq_len, d_model]\n",
        "\n",
        "        else:\n",
        "            # head_projections was inited as nn.Parameter(torch.empty(num_heads*d_model, d_model))\n",
        "            output = output.permute(0, 1, 3, 2).contiguous()\n",
        "            assert output.shape == (batch_size, self.num_heads, self.head_dim, seq_len), f'output.shape: {output.shape}'\n",
        "            output = output.view(batch_size, self.num_heads*self.head_dim, seq_len)\n",
        "            assert output.shape == (batch_size, self.num_heads*self.head_dim, seq_len), f'output.shape: {output.shape}'\n",
        "            output = torch.einsum(\"bds,dn->bsn\", output, self.head_projections)\n",
        "            assert output.shape == (batch_size, seq_len, self.d_model), f'output.shape: {output.shape}, expected: {(batch_size, seq_len, self.d_model)}'\n",
        "\n",
        "\n",
        "        if not self.training:\n",
        "            self.attn_weights.append(attn.detach().cpu().numpy())\n",
        "\n",
        "        return output"
      ],
      "metadata": {
        "id": "JG31OULbEc9-",
        "scrolled": true,
