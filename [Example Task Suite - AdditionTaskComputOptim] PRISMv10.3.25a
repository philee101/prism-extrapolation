        "\n",
        "                            # ------------------------------------------------------------------\n",
        "                            # ❷  Determine state_pos_branches\n",
        "                            # ------------------------------------------------------------------\n",
        "                            # <addPosCopyingForHMM>:\n",
        "                            if (Position_Copying_Enabled                                          # global flag\n",
        "                                    # and not keys                                                  # queries only\n",
        "                                    ):           # tensors present\n",
        "\n",
        "                                # Concatenate along the branch dimension\n",
        "                                assert state_pos_base.shape == (P_hist, bs, h), f'state_pos_base.shape: {state_pos_base.shape}, expected: {P_hist, bs, h}'\n",
        "                                state_pos_branches = state_pos_base\n",
        "                                assert branches == P_hist, f'branches = {branches}, P_hist = {P_hist}, T = {T}, P_hist + T = {P_hist + T}, BW={BW}, BRANCH_FACTOR={BRANCH_FACTOR}'\n",
        "\n",
        "                            else:   # Position-copying OFF  →  original behaviour\n",
        "                                state_pos_branches   = state_pos_base\n",
        "                                # cand_prob            = cand_prob_base\n",
        "\n",
        "                        else:\n",
        "                            assert False, 'Unsupported/code path removed as of v0.660+'\n",
        "                    else:\n",
        "                        assert False, 'Unsupported/code path removed as of v0.660+'\n",
        "\n",
        "\n",
        "\n",
        "                    if not stochasticMatrixForResetPosBr:\n",
        "                        assert False, 'Unsupported/code path removed as of v0.660+'\n",
        "\n",
        "                    if Position_Copying_Enabled:\n",
        "                        state_pos_branches_after_shifts = state_pos_branches.view(-1, bs, h)\n",
        "\n",
        "                    if not stochasticMatrixForResetPosBr:\n",
        "                        assert False, 'Unsupported/code path removed as of v0.660+'\n",
        "                        # assert state_pos_branches_after_shifts.shape == (2 if ResetGateBranching else 1, bs, h), f'state_pos_branches_after_shifts.shape: {state_pos_branches_after_shifts.shape}'\n",
        "                    else:\n",
        "                        # assert state_pos_branches_after_shifts.shape == (P_hist, bs, h), f'state_pos_branches_after_shifts.shape: {state_pos_branches_after_shifts.shape}'\n",
        "                        assert state_pos_branches.shape == (branches, bs, h), f'state_pos_branches.shape: {state_pos_branches.shape}, expected: {branches, bs, h}, keys = {keys}'\n",
        "\n",
        "\n",
        "                    # Determine state_pos_branches:\n",
        "                    BIG_JUMPS_ONLY = False # Branch if the deviation > 1 from cur pos\n",
        "                    jump_mask = None\n",
        "\n",
        "                    if not for_keys and Position_Copying_Enabled:\n",
        "\n",
        "\n",
        "                        if True:\n",
        "                            state_pos_branches_relative = state_pos_branches # For current and next relative position\n",
        "\n",
        "\n",
        "\n",
        "                            if BIG_JUMPS_ONLY:\n",
        "                                all_positions_next = all_scalar_position_probabilities_for_copy\n",
        "                                assert not ResetGateBranching, f'{ResetGateBranching} is not supported with BIG_JUMPS_ONLY'\n",
        "                                assert state_pos_branches_before_shifts.shape == (2 if ResetGateBranching else 1, bs, h), f'state_pos_branches_before_shifts.shape: {state_pos_branches_before_shifts.shape}'\n",
        "                                # last index is the “no-jump” branch, which holds the current position\n",
        "                                # curr = all_positions_next[-1]                     # The current position (bs, h)\n",
        "                                curr_pos_at_t_before_shifts = state_pos_branches_before_shifts.view(2 if ResetGateBranching else 1, bs, h)\n",
        "                                deltas = (all_positions_next - curr_pos_at_t_before_shifts).abs().detach()  # (BRANCH_FACTOR, bs, h)\n",
        "                                assert deltas.shape == (BRANCH_FACTOR, bs, h), f'deltas.shape: {deltas.shape}'\n",
        "\n",
        "                                # Build a boolean mask: only allow branches with jump > 2,\n",
        "                                # plus always allow the “no-jump” branch\n",
        "                                jump_mask = deltas > 1                                  # (BRANCH_FACTOR, bs, h)\n",
        "                                jump_mask[-1, :, :] = True                              # keep the no-jump branch\n",
        "\n",
        "\n",
        "                                # Now permute so it lines up with your per-time candidate_logits:\n",
        "                                #   candidate_logits has shape [bs, h, BRANCH_FACTOR] at time t\n",
        "                                # mask_t = mask.permute(1, 2, 0)                     # (bs, h, BRANCH_FACTOR)\n",
        "\n",
        "                                assert jump_mask.shape == cand_prob.shape, f'mask.shape = {jump_mask.shape}, cand_prob.shape={cand_prob.shape}'\n",
        "                    else:\n",
        "                        state_pos_branches_relative = state_pos_branches\n",
        "\n",
        "\n",
        "                    if all_scalar_position_probabilities_for_copy is not None:\n",
        "                        assert branches == P_hist, f'branches = {branches}, P_hist = {P_hist}, T = {T}, P_hist + T = {P_hist + T}, BRANCH_FACTOR = {BRANCH_FACTOR}, BW={BW}'\n",
        "\n",
        "                    assert state_pos_branches.shape == (branches, bs, h), f'state_pos_branches.shape: {state_pos_branches.shape}, expected: {P_hist, bs, h}'\n",
        "\n",
        "                    state_pos_branches = state_pos_branches.view(branches, bs, h)\n",
        "                    state_pos_branches_relative = state_pos_branches_relative.view(-1, bs, h)\n",
        "\n",
        "                    assert cand_prob.shape == (branches, bs, h), f'cand_prob.shape: {cand_prob.shape}, expected: {branches, bs, h}, keys={keys}, P_hist={P_hist}, T={T}'\n",
        "\n",
        "                    cand_prob_for_topk = cand_prob\n",
        "\n",
        "\n",
        "                    topk_idx = None\n",
        "                    if BW == 1 and USE_ARGMAX_OVER_TOPK:\n",
        "                        if self.training:\n",
        "                            topk_idx = None\n",
        "                        else:\n",
        "                            topk_idx = cand_prob_for_topk.argmax(dim=0, keepdim=True)\n",
        "                            topk_val = cand_prob_for_topk.gather(0, topk_idx)\n",
        "                    else:\n",
        "                        topk_val, topk_idx = cand_prob_for_topk.topk(BW, dim=0, largest=True)\n",
        "\n",
        "                    if topk_idx is not None:\n",
        "                        topk_idx = topk_idx.detach()\n",
        "                        assert topk_idx.shape == (BW, bs, h), f'topk_idx.shape: {topk_idx.shape}'\n",
        "                        assert topk_val.shape == (BW, bs, h), f'top_val.shape: {topk_val.shape}'\n",
        "                        state_pos = torch.gather(state_pos_branches_relative, 0, topk_idx.detach()) # For position at time >= t+1\n",
        "                        assert state_pos.shape == (BW, bs, h), f'state_pos.shape: {state_pos.shape}'\n",
        "\n",
        "                        state_prob = topk_val\n",
        "                        assert state_prob.shape == (BW, bs, h), f'state_prob.shape: {state_prob.shape}'\n",
        "\n",
        "\n",
        "\n",
        "                    # DETACH_IF_COPY = True\n",
        "                    # if not keys and DETACH_IF_COPY:\n",
        "                    #     state_pos_branches_relative = torch.where(topk_idx != branches-1, state_pos_branches_relative.detach(), state_pos_branches_relative)\n",
        "                    #     state_pos_branches = state_pos_branches_relative\n",
        "\n",
        "\n",
        "                    assert state_pos_branches_relative.shape == (branches, bs, h) == state_pos_branches.shape == (branches, bs, h), f'state_pos_branches.shape: {state_pos_branches.shape}'\n",
        "                    assert cand_prob.shape == (branches, bs, h), f'cand_prob.shape: {cand_prob.shape}'\n",
        "                    # Attach grad hook to cand_prob:\n",
        "                    def attach_grad_hook_for_fn_name(fn_name, variable):\n",
        "                        def grad_hook(grad):\n",
        "                            print(f\"[RSE DEBUG] grad_hook for {fn_name}: min: {torch.min(grad)}, max: {torch.max(grad)}, mean: {torch.mean(grad.abs())}, forKeys = {keys}\")\n",
        "                            return grad\n",
        "\n",
        "                        return grad_hook\n",
        "\n",
        "                    # if self.training:\n",
        "                    #     cand_prob.register_hook(attach_grad_hook_for_fn_name('cand_prob', cand_prob))\n",
        "\n",
        "                    # Assert prob_soft.requires_grad:\n",
        "                    # if self.training:\n",
        "                    #     assert prob_soft.requires_grad, f'prob_soft.requires_grad: {prob_soft.requires_grad}'\n",
        "\n",
        "                    assert cand_prob.shape == (branches, bs, h), f'cand_prob.shape: {cand_prob.shape}'\n",
        "\n",
        "                    if stochasticMatrixForResetPosBr:\n",
        "                          state_prob_branches = cand_prob\n",
        "                          assert state_pos_branches.shape == (branches, bs, h), f'state_pos_branches.shape: {state_pos_branches.shape}, expected: {branches, bs, h}'\n",
        "                          assert state_prob_branches.shape == (branches, bs, h), f'state_prob_branches.shape: {state_prob_branches.shape}'\n",
        "\n",
        "                    else:\n",
        "                        assert False, 'Unsupported/code path removed as of v0.660+'\n",
        "\n",
        "                    PRINT_STATE_PROB_MIN_MAX_MEAN = False\n",
        "                    if PRINT_STATE_PROB_MIN_MAX_MEAN:\n",
        "                        if t % 3 == 0:\n",
        "                            with torch.no_grad():\n",
        "                                # print(f'[DEBUG] branches_prob at time {t}: min: {torch.min(branches_prob[-1])}, max: {torch.max(branches_prob[-1])}, mean: {torch.mean(branches_prob[-1])}')\n",
        "                                print(f'[DEBUG] state_prob at time {t}: min: {torch.min(state_prob[-1])}, max: {torch.max(state_prob[-1])}, mean: {torch.mean(state_prob[-1])}')\n",
        "\n",
        "                    if not USE_PREALLOC_SCALAR_BUFFER:\n",
        "                        pos_t_list.append(state_pos_branches)\n",
        "                        prob_t_list.append(state_prob_branches)\n",
        "                    else:\n",
        "                        # pos_t_stack[t, :, :, :]  = state_pos_branches\n",
        "                        # prob_t_stack[t, :, :, :] = state_prob_branches\n",
        "                        # with torch.no_grad():\n",
        "                        pos_t_stack.select(0, t).copy_(state_pos_branches)\n",
        "                        prob_t_stack.select(0, t).copy_(state_prob_branches)\n",
        "\n",
        "\n",
        "\n",
        "                    if not self.training:\n",
        "                        with torch.no_grad(): # For debugging/visualization\n",
        "                            state_pos = torch.gather(state_pos_branches, 0, topk_idx.detach()) # For position at time >= t+1\n",
        "                            assert state_pos.shape == (BW, bs, h), f'state_pos.shape: {state_pos.shape}'\n",
        "                            pos_best = state_pos.view(bs, half_ops)\n",
        "\n",
        "                            assert pos_best.shape == (bs, half_ops), f'pos_best.shape: {pos_best.shape}'\n",
        "\n",
        "                            best_pos_list.append(pos_best)\n",
        "\n",
        "\n",
        "                if COUNT_UPDATE_FN_TOTAL_RUNTIME:\n",
        "                    if not GRANULAR_PROFILE:\n",
        "\n",
        "                        end.record()\n",
        "                        torch.cuda.synchronize()\n",
        "\n",
        "                        print(f\"[COUNT UPDATE FN TOTAL RUNTIME] All histogram updates took {start.elapsed_time(end):.2f} ms\")\n",
        "                    else:\n",
        "                        print(f\"[COUNT UPDATE FN TOTAL RUNTIME granular] All histogram updates took {UPDATE_FN_TOTAL_RUNTIME:.2f} ms\")\n",
        "\n",
        "                ########### End loop over seq_len T for PositionCopying ##############\n",
        "\n",
        "\n",
        "                # End PositionCopyingEnabled if-branch\n",
        "\n",
        "            if not USE_PREALLOC_SCALAR_BUFFER:\n",
        "                pos_t_stack = torch.stack(pos_t_list, dim=2)\n",
        "                assert pos_t_stack.shape == (branches, bs, seq_len, half_ops), f'pos_t_stack.shape: {pos_t_stack.shape}'\n",
        "                pos_t_stack = pos_t_stack.permute(3, 1, 2, 0).contiguous()\n",
        "            else:\n",
        "                assert pos_t_stack.shape == (seq_len, branches, bs, half_ops), f'pos_t_stack.shape: {pos_t_stack.shape}'\n",
        "                pos_t_stack = pos_t_stack.permute(3, 2, 0, 1).contiguous()\n",
        "\n",
        "            assert pos_t_stack.shape == (half_ops, bs, seq_len, branches), f'pos_t_stack.shape: {pos_t_stack.shape}'\n",
        "            # pos_t_stack = pos_t_stack.view(half_ops, bs, seq_len * branches)\n",
        "            # assert pos_t_stack.shape == (half_ops, bs, seq_len * branches), f'pos_t_stack.shape: {pos_t_stack.shape}'\n",
        "\n",
        "            if not USE_PREALLOC_SCALAR_BUFFER:\n",
        "                prob_t_stack = torch.stack(prob_t_list, dim=2)\n",
        "                if ASSERT_CORRECT_SHAPES:\n",
        "                  assert prob_t_stack.shape == (branches, bs, seq_len, half_ops), f'prob_t_stack.shape: {prob_t_stack.shape}'\n",
        "\n",
        "                  assert prob_t_stack.shape == (branches, bs, seq_len, half_ops), f'prob_t_stack.shape: {prob_t_stack.shape}'\n",
        "                prob_t_stack = prob_t_stack.permute(3, 1, 2, 0).contiguous()\n",
        "            else:\n",
        "                assert prob_t_stack.shape == (seq_len, branches, bs, half_ops), f'prob_t_stack.shape: {prob_t_stack.shape}'\n",
        "                prob_t_stack = prob_t_stack.permute(3, 2, 0, 1).contiguous()\n",
        "\n",
        "            # if ASSERT_CORRECT_SHAPES:\n",
        "            assert prob_t_stack.shape == (half_ops, bs, seq_len, branches), f'prob_t_stack.shape: {prob_t_stack.shape}'\n",
        "            # prob_t_stack = prob_t_stack.unsqueeze(-1)\n",
        "\n",
        "            ################################################################################################################\n",
        "            # MARK: scalar posEnc via curveFit of SPE innerProd responseFunction - part of main implementation\n",
        "\n",
        "            # pos_t_stack = prob_t_stack * pos_t_stack\n",
        "            # pos_t_stack = pos_t_stack * prob_t_stack\n",
        "            assert pos_t_stack.shape == (half_ops, bs, seq_len, branches), f'pos_t_stack.shape: {pos_t_stack.shape}'\n",
        "            pos_t_stack = pos_t_stack.permute(1, 0, 2, 3)\n",
        "            assert pos_t_stack.shape == (bs, half_ops, seq_len, branches), f'enc_weighted.shape: {enc_weighted.shape}'\n",
        "            prob_t_stack = prob_t_stack.permute(1, 0, 2, 3)\n",
        "            assert prob_t_stack.shape == (bs, half_ops, seq_len, branches), f'enc_weighted.shape: {enc_weighted.shape}'\n",
        "            ################################################################################################################\n",
        "\n",
        "\n",
        "            if not self.training and not DISABLE_POSITION_CACHING:\n",
        "                with torch.no_grad(): # For debugging\n",
        "                    # stack into a [half_ops, bs, seq_len] tensor\n",
        "                    best_positions = torch.stack(best_pos_list, dim=-1)\n",
        "                    # print(f'[best_positions.shape] = {best_positions.shape}')\n",
        "                    if ASSERT_CORRECT_SHAPES:\n",
        "                        assert best_positions.shape == (bs, half_ops, seq_len), f'best_positions.shape: {best_positions.shape}'\n",
        "                    best_positions = best_positions.permute(1, 0, 2)\n",
        "                    assert best_positions.shape == (half_ops, bs, seq_len), f'best_positions.shape: {best_positions.shape}'\n",
        "            else:\n",
        "                best_positions = None\n",
        "\n",
        "            return pos_t_stack, prob_t_stack, best_positions\n",
        "\n",
        "\n",
        "    # MARK: RSPE.forward()\n",
        "    # @torch.compile(dynamic=False)\n",
        "    def forward(self, embeddings, pos_x_shift_relative=0):\n",
        "        \"\"\"\n",
        "        Forward pass for Relative Position Encoding.\n",
        "\n",
        "        Args:\n",
        "            embeddings (Tensor): Inbput tensor of shape [batch_size, seq_len, latent dim].\n",
        "            pos_x_shift_relative (Tensor, optional): Positional shift for relative encoding.\n",
        "\n",
        "        Returns:\n",
        "            Tensor: Encoded positions of shape [batch_size, seq_len, branches].\n",
        "        \"\"\"\n",
        "\n",
        "        # Compute reset and output probabilities\n",
        "\n",
        "        if not removeRSE_LN or ReplaceLNWithSmoothCapIfRemoveRSE_LN:\n",
        "            embeddings = self.layer_norm(embeddings)\n",
        "\n",
        "        bs, seq_len, _ = embeddings.shape\n",
        "        assert embeddings.shape == (bs, seq_len, VOCAB_N_DIM_), f\"Expected shape {(bs, seq_len, VOCAB_N_DIM_)}, but got {embeddings.shape}\"\n",
        "        # embeddings_ = embeddings.unsqueeze(1).expand(-1, self.num_operators, -1, -1)\n",
        "        # assert embeddings_.shape == (bs, self.num_operators, seq_len, VOCAB_N_DIM)\n",
        "        embeddings_orig = embeddings\n",
        "        assert embeddings_orig.shape == (bs, seq_len, VOCAB_N_DIM_)\n",
        "\n",
        "        lstm_output = None; lstm_output_for_relevance_entity_encoding = None\n",
        "\n",
        "        if self.use_lstm:\n",
        "            lstm_output, lstm_output_for_relevance_entity_encoding = self._parallel_lstm_cells_forward(embeddings)\n",
        "            # assert lstm_output.shape == (bs, self.num_operators, seq_len, VOCAB_N_DIM), f\"Expected shape {(bs, self.num_operators, seq_len, VOCAB_N_DIM)}, but got {lstm_output.shape}\"\n",
        "            assert lstm_output.shape == (bs, NUM_LSTM_CELLS, seq_len, VOCAB_N_DIM), f\"Expected shape {(bs, NUM_LSTM_CELLS, seq_len, self.lstm_hidden_dim)}, but got {lstm_output.shape}\"\n",
        "            # if not removeRSE_LN or ReplaceLNWithSmoothCapIfRemoveRSE_LN:\n",
        "            #     lstm_output = self.lstm_post_norm(lstm_output)\n",
        "            if RelativeEncodingLSTMHiddenOutputsRelevanceEncoding_IS_ENABLED:\n",
        "                lstm_output_for_relevance_entity_encoding = self.lstm_post_norm(lstm_output_for_relevance_entity_encoding)\n",
        "\n",
        "            # Add lstm_output to embeddings for every NUM_LSTM_CELLS uniformly to all operators:\n",
        "            assert lstm_output.shape == (bs, NUM_LSTM_CELLS, seq_len, VOCAB_N_DIM)\n",
        "            to_add = torch.einsum('bnsv->bsv', lstm_output)\n",
        "\n",
        "            assert to_add.shape == (bs, seq_len, VOCAB_N_DIM)\n",
        "            if not removeRSE_LN:\n",
        "                output_embeddings = F.layer_norm(to_add, to_add.shape[-1:])\n",
        "            else :\n",
        "                output_embeddings = to_add\n",
        "\n",
        "\n",
        "            if VERBOSE_LOGGING:\n",
        "                print(f'[RSPE LSTM]: to_add norm: {torch.mean(torch.norm(to_add, dim=-1))}, min norm: {torch.min(torch.norm(to_add, dim=-1))}, max norm: {torch.max(torch.norm(to_add, dim=-1))}')\n",
        "                # print(f'[RSPE LSTM]: embeddings_ norm: {torch.mean(torch.norm(embeddings_, dim=-1))}, min norm: {torch.min(torch.norm(embeddings_, dim=-1))}, max norm: {torch.max(torch.norm(embeddings_, dim=-1))}')\n",
        "                if RelativeEncodingLSTMHiddenOutputsRelevanceEncoding_IS_ENABLED:\n",
        "                    print(f'[RSPE LSTM]: lstm_output_for_relevance_entity_encoding norm: {torch.mean(torch.norm(lstm_output_for_relevance_entity_encoding, dim=-1))}, min norm: {torch.min(torch.norm(lstm_output_for_relevance_entity_encoding, dim=-1))}, max norm: {torch.max(torch.norm(lstm_output_for_relevance_entity_encoding, dim=-1))}')\n",
        "\n",
        "            # if not removeRSE_LN or ReplaceLNWithSmoothCapIfRemoveRSE_LN:\n",
        "            #     to_add = self.residual_lstm_output_norm(to_add)\n",
        "\n",
        "            if RSE_LSTM_USE_RESIDUAL_CONNECTION:\n",
        "                # embeddings_ = embeddings_orig + to_add\n",
        "                # <lstmOutResidualGain>\n",
        "                embeddings_ = embeddings_orig + to_add\n",
        "                # </lstmOutResidualGain>\n",
        "                assert embeddings_.shape == (bs, seq_len, VOCAB_N_DIM)\n",
        "                # embeddings_ = embeddings_.unsqueeze(1).expand(-1, self.num_operators, -1, -1)\n",
        "            else:\n",
        "                embeddings_ = to_add\n",
        "\n",
        "\n",
        "            assert embeddings_.shape == (bs, seq_len, VOCAB_N_DIM)\n",
        "\n",
        "            embeddings = embeddings_\n",
        "        else:\n",
        "            # embeddings = embeddings.unsqueeze(1).expand(-1, self.num_operators, -1, -1)\n",
        "            pass\n",
        "\n",
        "        # if not removeRSE_LN:\n",
        "        #     embeddings = embeddings / (embeddings.norm(dim=-1, keepdim=True) + 1e-9)\n",
        "        # else:\n",
        "        #     pass\n",
        "\n",
        "        # assert embeddings.shape == (bs, self.num_operators, seq_len, VOCAB_N_DIM), f\"Expected shape {(bs, self.num_operators, seq_len, VOCAB_N_DIM)}, but got {embeddings.shape}\"\n",
        "        assert embeddings.shape == (bs, seq_len, VOCAB_N_DIM), f\"Expected shape {(bs, seq_len, VOCAB_N_DIM_)}, but got {embeddings.shape}\"\n",
        "\n",
        "        bs, seq_len, _ = embeddings.size()\n",
        "        # half_ops = no // 2\n",
        "        half_ops = self.num_operators // 2\n",
        "\n",
        "        merged_gate_outputs, latentsFor_gamma_proj = self._merged_gate_mlp(self._mgmlpInputProj(embeddings))\n",
        "        # [num_operators, batch_size, seq_len, 3]:\n",
        "        assert merged_gate_outputs.shape == (self.num_operators, bs, seq_len, MERGED_GATE_MLP_NUM_GATES), f'merged_gate_outputs shape: {merged_gate_outputs.shape}'\n",
        "        assert latentsFor_gamma_proj.shape == (self.num_operators, bs, seq_len, self._merged_gate_mlp.intermediate_dim), f'latentFor_gamma_proj shape: {latentFor_gamma_proj.shape}'\n",
        "\n",
        "\n",
        "        reset_bias = -0.5\n",
        "        reset_logits = torch.stack([\n",
        "            merged_gate_outputs[..., -1] + (reset_bias if not USE_RESET_GATE_OVERSMOOTHING_FIXES else 0.0),  # reset gate ON\n",
        "            torch.zeros_like(merged_gate_outputs[..., -1]),  # reset gate OFF\n",
        "        ], dim=-1)\n",
        "        assert reset_logits.shape == (self.num_operators, bs, seq_len, 2), f'reset_logits shape: {reset_logits.shape}'\n",
        "\n",
        "        softmax_logits_normalizer_re = 1.0\n",
        "        gumbel_tau_re = 7.2\n",
        "        USE_GUMBEL_RSE = False\n",
        "\n",
        "        # with torch.compiler.set_stance(\"force_eager\"):\n",
        "\n",
        "        if USE_RESET_GATE_OVERSMOOTHING_FIXES:\n",
        "            # Linear estimator:\n",
        "            # <reset_probs> ranges from [0,~2] if USE_RESET_GATE_OVERSMOOTHING_FIXES enabled. See the comments for <resetGateOversmoothingFix>: for details on why.\n",
        "            reset_probs = torch.nn.functional.softplus(reset_logits)\n",
        "\n",
        "        else:\n",
        "            if USE_GUMBEL_RSE:\n",
        "                reset_probs = gumbel_softmax_STE(reset_logits / softmax_logits_normalizer_re, tau=gumbel_tau_re, alpha=0.95)\n",
        "            else:\n",
        "                reset_probs = softmax_lse(reset_logits / softmax_logits_normalizer_re)\n",
        "                # reset_probs = gumbel_softmax_STE(reset_logits / softmax_logits_normalizer_re, tau=gumbel_tau_re, alpha=1.0)\n",
        "\n",
        "        # MARK: partialAbsolutePosKeyGates:\n",
        "        # For operator indices where self._erged_gate_mlp.fixed_gate_mask == 1, set reset_probs to 0 at reset_probs[..., 0] and 0 at the 'no reset' branch\n",
        "        if self._merged_gate_mlp.fixed_gate_mask is not None:\n",
        "            fgm = self._merged_gate_mlp.fixed_gate_mask\n",
        "            assert fgm.shape == (self.num_operators,), f'fgm.shape: {fgm.shape}'\n",
        "            assert reset_probs.shape == (self.num_operators, bs, seq_len, 2), f'reset_probs shape: {reset_probs.shape}'\n",
        "            zero_one_tensor = torch.zeros_like(reset_probs[:])\n",
        "            zero_one_tensor[..., 1] = 1 # For indices at fixed_gate_mask, set reset gate probability to 0 so no resets are used, only increments to reflect absolute pos encoding\n",
        "\n",
        "            reset_probs = torch.where(fgm.unsqueeze(-1).unsqueeze(-1).unsqueeze(-1) == 1,\n",
        "                                      zero_one_tensor,\n",
        "                                      reset_probs)\n",
        "        ## MARK: Position_Copying_Enabled: set reset_probs to zero:\n",
        "        # set_reset_probs_to_zero = False\n",
        "        # if set_reset_probs_to_zero:\n",
        "        #     reset_probs = torch.zeros(self.num_operators, bs, seq_len, 2, device=embeddings.device)\n",
        "        #     reset_probs[..., 0] = -1 # Set reset gate probability to 0 so no resets are used\n",
        "        assert reset_probs.shape == (self.num_operators, bs, seq_len, 2), f'reset_probs shape: {reset_probs.shape}'\n",
        "        # if discrete: quantize using ste:\n",
        "\n",
        "        reset_probs_before_ste = reset_probs.detach()\n",
        "        assert reset_probs.shape == (self.num_operators, bs, seq_len, 2), f'reset_probs shape: {reset_probs.shape}'\n",
        "\n",
        "\n",
        "        assert merged_gate_outputs.shape == (self.num_operators, bs, seq_len, MERGED_GATE_MLP_NUM_GATES), f'merged_gate_outputs shape: {merged_gate_outputs.shape}'\n",
        "        # Softmax normalize over last dim:\n",
        "        if True:\n",
        "\n",
        "            all_unnormalized_logits = merged_gate_outputs\n",
        "\n",
        "            assert all_unnormalized_logits.shape == (self.num_operators, bs, seq_len, MERGED_GATE_MLP_NUM_GATES), f'all_unnormalized_logits shape: {all_unnormalized_logits.shape}'\n",
        "\n",
        "            # Extract only incr,decr,keep - excluding reset\n",
        "            incr_decr_action_logits = all_unnormalized_logits[:, :, :, :MERGED_GATE_MLP_NUM_GATES-1]\n",
        "            incr_decr_action_logits = incr_decr_action_logits.view(self.num_operators, bs, seq_len, MERGED_GATE_MLP_NUM_GATES-1)\n",
        "            # Mod3 of 0.630 <softMaxOverIncrDecr>:\n",
        "\n",
        "            # -- Concat zero at dim = -1 for keep branch:\n",
        "            if not USE_WEIGHTS_FOR_KEEP_GATE:\n",
        "                incr_decr_action_logits = torch.cat([incr_decr_action_logits, torch.zeros_like(incr_decr_action_logits[:, :, :, 0:1])],\n",
        "                                                      dim=-1)\n",
        "            else:\n",
        "                assert incr_decr_action_logits.shape == (self.num_operators, bs, seq_len, MERGED_GATE_MLP_NUM_GATES-1), f'incr_decr_action_logits shape: {incr_decr_action_logits.shape}'\n",
        "            # -- take softmax at dim=-1:\n",
        "            # with torch.compiler.set_stance(\"force_eager\"):\n",
        "            if not USE_GUMBEL_RSE:\n",
        "                # incr_decr_action_probabilities = torch.softmax(incr_decr_action_logits, dim=-1) # incr/decr/keep\n",
        "                incr_decr_action_probabilities = softmax_lse(incr_decr_action_logits)\n",
        "            else:\n",
        "                incr_decr_action_probabilities = gumbel_softmax_STE(incr_decr_action_logits, tau=gumbel_tau_re, alpha=0.98)\n",
        "            assert incr_decr_action_probabilities.shape == (self.num_operators, bs, seq_len, 3), f'incr_decr_action_probabilities shape: {incr_decr_action_probabilities.shape}'\n",
        "\n",
        "            # MARK: partialAbsolutePosKeyGates:\n",
        "            # For operator indices where self._merged_gate_mlp.fixed_gate_mask == 1, set incr_decr_action_probabilities to 1 at incr_decr_action_probabilities[..., 0] and 0 elsewhere:\n",
        "            if self._merged_gate_mlp.fixed_gate_mask is not None:\n",
        "                assert self._merged_gate_mlp.fixed_gate_mask.shape == (self.num_operators,), f'self._merged_gate_mlp.fixed_gate_mask.shape: {self._merged_gate_mlp.fixed_gate_mask.shape}'\n",
        "                assert incr_decr_action_probabilities.shape == (self.num_operators, bs, seq_len, 3)\n",
        "                fgm = self._merged_gate_mlp.fixed_gate_mask\n",
        "                zero_one_tensor = torch.zeros_like(incr_decr_action_probabilities[:])\n",
        "                zero_one_tensor[..., 0] = 1 # For indices at fixed_gate_mask, set reset gate probability to 0 so no resets are used\n",
        "\n",
        "                incr_decr_action_probabilities = torch.where(fgm.unsqueeze(-1).unsqueeze(-1).unsqueeze(-1) == 1,\n",
        "                                                             zero_one_tensor,\n",
        "                                                             incr_decr_action_probabilities)\n",
        "\n",
        "\n",
        "            # -- concat dummy zero entry at new dim at -1 to maintain bwd compat:\n",
        "            incr_decr_action_probabilities = incr_decr_action_probabilities.unsqueeze(-1)\n",
        "            # incr_decr_action_probabilities = torch.cat([incr_decr_action_probabilities, torch.zeros_like(incr_decr_action_probabilities[:, :, :, :, 0:1])],\n",
        "            #                                               dim=-1)\n",
        "            # assert incr_decr_action_probabilities.shape == (self.num_operators, bs, seq_len, MERGED_GATE_MLP_NUM_GATES-1, 2), f'incr_decr_action_probabilities shape: {incr_decr_action_probabilities.shape}, expected: {self.num_operators, bs, seq_len, MERGED_GATE_MLP_NUM_GATES, 2}'\n",
        "\n",
        "\n",
        "        B = self.beam_width\n",
        "        ASSRT_SHAPES_INSIDE_LOOP = False\n",
        "        MASK_DECREMENT_PROBS = False\n",
        "        CLAMP_TO_MIN_POSITION_WITHOUT_STE = False\n",
        "\n",
        "        # Connect grad hook for reset_probs and print min, max, mean{abs(grad)}:\n",
        "        CONNECT_GRAD_HOOK_FOR_RESET_PROBS = True\n",
        "        if self.training and CONNECT_GRAD_HOOK_FOR_RESET_PROBS:\n",
        "            def create_named_hook(name):\n",
        "                def hook(grad):\n",
        "                    if grad is not None:\n",
        "                        print(f\"[RSE DEBUG] Grad hook '{name}' triggered, avg grad: {torch.mean(grad.abs())}, min grad: {torch.min(grad)}, max grad: {torch.max(grad)}\")\n",
        "\n",
        "\n",
        "\n",
        "                return hook\n",
        "            # reset_probs.register_hook(create_named_hook(\"reset_probs\"))\n",
        "            # # Also register the incr_decr_reset logits:\n",
        "            # incr_decr_action_probabilities.register_hook(create_named_hook(\"incr_decr_action_probabilities\"))\n",
        "            # all_unnormalized_logits.register_hook(create_named_hook(\"all_unnormalized_logits\"))\n",
        "\n",
        "        # Initialize real positions\n",
        "        batch_size, seq_len, _ = embeddings.size()\n",
        "\n",
        "        cached_hists_q_fordebug = [] if not DISABLE_POSITION_CACHING else None\n",
        "        cached_hists_k_fordebug = [] if not DISABLE_POSITION_CACHING else None\n",
        "\n",
        "        \"\"\"\n",
        "        _processQueriesOrKeys_AllBranches(): new main params\n",
        "        batch_size=None, embeddings=None, reset_probs=None, incr_decr_action_probabilities=None,\n",
        "                                          reset_logits=None,\n",
        "                                          cached_hists_q_fordebug=None, seq_len, [...],\n",
        "        \"\"\"\n",
        "\n",
        "\n",
        "        if ABLATE_PROC_QK:\n",
        "            r2_streams_K = r2_streams_K = torch.zeros(bs, half_ops, seq_len, EMBED_SIZE, device=embeddings.device)\n",
        "            r2_streams_K_prob = torch.zeros_like(r2_streams_K)\n",
        "            best_positions_K = None\n",
        "        else:\n",
        "\n",
        "            r2_streams_K, r2_streams_K_prob, best_positions_K = self._processQueriesOrKeys_AllBranches(for_keys=True,\n",
        "                                                                                                      batch_size=bs,\n",
        "                                                                                                      embeddings=latentsFor_gamma_proj,\n",
        "                                                                                                      #  embeddings,\n",
        "                                                                                                      reset_probs=reset_probs,\n",
        "                                                                                                      incr_decr_action_probabilities=incr_decr_action_probabilities,\n",
        "                                                                                                      reset_logits=reset_logits,\n",
        "                                                                                                      cached_hists_q_fordebug=cached_hists_q_fordebug,\n",
        "                                                                                                      cached_hists_k_fordebug=cached_hists_k_fordebug,\n",
        "                                                                                                      seq_len=seq_len,\n",
        "\n",
        "                                                                                                      half_ops=half_ops)\n",
        "        assert r2_streams_K_prob.shape == r2_streams_K.shape == (bs, half_ops, seq_len, r2_streams_K.shape[-1]), f'r2_streams_K_prob.shape: {r2_streams_K_prob.shape}'\n",
        "\n",
        "\n",
        "        KtoQ_copy_probabilities = None\n",
        "        if ABLATE_PROC_QK:\n",
        "            r1_streams_Q = torch.zeros(bs, half_ops, seq_len, EMBED_SIZE, device=embeddings.device)\n",
        "            r1_streams_Q_prob = torch.zeros_like(r1_streams_Q)\n",
        "            best_positions_Q = None\n",
        "        elif not ABLATE_PROC_QK:\n",
        "\n",
        "            all_key_scalar_rel_positions_for_copy = None\n",
        "            k2Q_copiedOrKeptScalars = None\n",
        "            all_key_abs_positions_for_copy = None\n",
        "            k2Q_copyProbs = None\n",
        "\n",
        "            if Position_Copying_Enabled:\n",
        "\n",
        "                branches_for_keys = r2_streams_K.shape[-1]\n",
        "                assert branches_for_keys == seq_len*2+1, f'branches_for_keys: {branches_for_keys}'\n",
        "\n",
        "                assert r2_streams_K_prob.shape ==              (bs, half_ops, seq_len, branches_for_keys), f'r2_streams_K_prob.shape: {r2_streams_K_prob.shape}, expected: {bs, half_ops, seq_len, branches_for_keys}'\n",
        "                # assert key_positions_for_address_copy.shape == (bs, half_ops, seq_len, branches_for_keys), f'key_positions_for_address_copy.shape: {key_positions_for_address_copy.shape}, expected: {bs, half_ops, seq_len, branches_for_keys}'\n",
        "\n",
        "                # <floatRelPositionsForPosCopy>\n",
        "                all_key_float_rel_positions_for_copy = r2_streams_K_prob\n",
        "\n",
        "\n",
        "                \"\"\" Use func compute_candidate_relative_positions_timewise_null_weight_for_qk_token_copy(\n",
        "                        # self,\n",
        "                        # embeddings,\n",
        "                        # key_rel_positions_for_addr_copy,\n",
        "                        # positions_x_shift_relative=None\n",
        "                        # ):\n",
        "                Return signature:\n",
        "                        copiedOrKeptScalars: shape (bs, half_ops, seq_len),\n",
        "                        copyProbs: shape         (bs, half_ops, seq_len, seq_len+1) # <-- Where copyProbs[..., -1] is prob that no copy is performed.\n",
        "                        # copy_bool_mask: shape == (bs, half_ops, seq_len, seq_len+1)\n",
        "\n",
        "                \"\"\"\n",
        "                _, k2Q_copyProbs, _, _ = self.compute_candidate_relative_positions_timewise_null_weight_for_qk_token_copy(embeddings=embeddings,\n",
        "                    key_rel_positions_for_addr_copy=None,\n",
        "                    positions_x_shift_relative=None,\n",
        "                    copyingFromKeysToQueries=RelPosCopyRoute.KEYS_TO_QUERIES)\n",
        "\n",
        "\n",
        "                ##########\n",
        "                # MARK: copyRelViaAbsPos:\n",
        "                # - for all_key_abs_positions_for_copy, set it equal to the absolute positions of all of the key positions:\n",
        "                # - must be equal to the shape of all_key_scalar_rel_positions_for_copy\n",
        "                ##########\n",
        "                if copyRelViaAbsPos: # Default: FALSE\n",
        "                    all_key_abs_positions_for_copy = torch.arange(seq_len, device=embeddings.device)\n",
        "                    all_key_abs_positions_for_copy = all_key_abs_positions_for_copy.unsqueeze(0).unsqueeze(0).expand(bs, half_ops, seq_len)\n",
        "\n",
        "                # Parameters for proc-queries-or-key nested func:\n",
        "                #           keys: determining key positions or otherwise query positions\n",
        "                #           half_ops: number of operators for the queries and keys == self.num_operators // 2\n",
        "\n",
        "                #           copiedOrKeptScalars: shape (bs, half_ops, seq_len),\n",
        "                #           copyProbs: shape (bs, half_ops, seq_len, seq_len+1) # <-- Where copyProbs[..., -1] is prob that no copy is performed.\n",
        "\n",
        "\n",
        "            r1_streams_Q, r1_streams_Q_prob, best_positions_Q = self._processQueriesOrKeys_AllBranches(for_keys=False,\n",
        "                                                                                                  half_ops=half_ops,\n",
        "                                                                                                                                                                                                         batch_size=bs,\n",
        "                                                                                              embeddings=latentsFor_gamma_proj,\n",
        "                                                                                                      #  embeddings,\n",
        "                                                                                              reset_probs=reset_probs,\n",
        "                                                                                              incr_decr_action_probabilities=incr_decr_action_probabilities,\n",
        "                                                                                              reset_logits=reset_logits,\n",
        "                                                                                              cached_hists_q_fordebug=cached_hists_q_fordebug,\n",
        "                                                                                            cached_hists_k_fordebug=cached_hists_k_fordebug,\n",
        "                                                                                                  seq_len=seq_len,\n",
        "\n",
        "\n",
        "                                                    all_scalar_position_probabilities_for_copy=all_key_float_rel_positions_for_copy,\n",
        "                                                        # all_scalar_histogram_rel_positions_for_copy=r2_streams_K,\n",
        "                                                        # all_abs_positions_for_copy=all_key_abs_positions_for_copy,\n",
        "                                                          copyProbs=k2Q_copyProbs,\n",
        "                                                          # copy_bool_mask=None,\n",
        "                )\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "        # For debug stack <cached_hists_q_fordebug> and <cached_hists_k_fordebug>\n",
        "\n",
        "        if cached_hists_q_fordebug is not None and not DISABLE_POSITION_CACHING and not self.training:\n",
        "            with torch.no_grad():\n",
        "\n",
        "                # stack cached_hists_q/k_fordebug to have shape  == (P, T, bs, half_ops)\n",
        "                self.cached_hists_q_fordebug = torch.stack(cached_hists_q_fordebug, dim=1).cpu()\n",
        "                self.cached_hists_k_fordebug = torch.stack(cached_hists_k_fordebug, dim=1).cpu()\n",
        "                # [P, T, bs, half_ops]\n",
        "                P = self.cached_hists_q_fordebug.shape[0]\n",
        "                assert  self.cached_hists_q_fordebug.shape == (P, seq_len, bs, half_ops), f'self.cached_hists_q_fordebug.shape: {self.cached_hists_q_fordebug.shape}'\n",
        "\n",
        "                # assert self.cached_hists_k_fordebug.shape ==\n",
        "\n",
        "\n",
        "        n_branches_to_be_summed_over_later = r2_streams_K.shape[-1]\n",
        "        assert r2_streams_K.shape == (bs, half_ops, seq_len, n_branches_to_be_summed_over_later), f'r2_streams_K.shape: {r2_streams_K.shape}'\n",
        "        if VERBOSE_LOGGING:\n",
        "            print(f'[r2_streams_K.shape] = {r2_streams_K.shape}, r2_streams_K_prob.shape = {r2_streams_K_prob.shape}')\n",
        "            print(f'[r1_streams_Q.shape] = {r1_streams_Q.shape}, r1_streams_Q_prob.shape = {r1_streams_Q_prob.shape}')\n",
        "        n_branches_to_be_summed_over_later = r1_streams_Q.shape[-1]\n",
        "        assert r1_streams_Q.shape == (bs, half_ops, seq_len, n_branches_to_be_summed_over_later), f'r1_streams_Q.shape: {r1_streams_Q.shape}'\n",
        "        assert r2_streams_K_prob.shape == r2_streams_K.shape == (bs, half_ops, seq_len, r2_streams_K.shape[-1]), f'r2_streams_K_prob.shape: {r2_streams_K_prob.shape}'\n",
        "        assert r1_streams_Q_prob.shape == r1_streams_Q.shape == (bs, half_ops, seq_len, r1_streams_Q.shape[-1]), f'r1_streams_Q_prob.shape: {r1_streams_Q_prob.shape}'\n",
        "\n",
        "\n",
        "        # Expected return value for q and k: == (batch_size, num_ops//2, seq_len), f're_k.shape = {re_k.shape}, expected {batch_size, num_ops//2, seq_len, latent dim}'\n",
        "\n",
        "\n",
        "        # def debug_hook_Q(grad):\n",
        "        #     print(f\"[DEBUG] Grad for r1_streams_Q: mean = {torch.mean(grad.abs())}, min = {torch.min(grad)}, max = {torch.max(grad)}, norm = {torch.norm(grad)}\")\n",
        "        # def debug_hook_K(grad):\n",
        "        #     print(f\"[DEBUG] Grad for r2_streams_K: mean = {torch.mean(grad.abs())}, min = {torch.min(grad)}, max = {torch.max(grad)}, norm = {torch.norm(grad)}\")\n",
        "\n",
        "        register_hooks_for_dbg = True\n",
        "        # if self.training and register_hooks_for_dbg:\n",
        "        #     r1_streams_Q.register_hook(debug_hook_Q)\n",
        "        #     r2_streams_K.register_hook(debug_hook_K)\n",
        "\n",
        "\n",
        "        # Cache max probability positions:\n",
        "        if best_positions_Q is not None and not DISABLE_POSITION_CACHING:\n",
        "\n",
        "            with torch.no_grad(): # For debugging rel positions:\n",
        "                # best_positions_Q, best_positions_K: each [half_ops, bs, seq_len]\n",
        "                assert best_positions_Q.shape == (half_ops, bs, seq_len)\n",
        "                assert best_positions_K.shape == (half_ops, bs, seq_len)\n",
        "                positions_relative_final = torch.cat([best_positions_Q, best_positions_K], dim=0)\n",
        "                assert positions_relative_final.shape == (self.num_operators, bs, seq_len)\n",
        "                self.latest_cached_real_positions = positions_relative_final[:, 0, :].clone().detach().cpu()\n",
        "\n",
        "        # For debugging relative position 'action' probabilities:\n",
        "        if not DISABLE_POSITION_CACHING and not self.training:\n",
        "            with torch.no_grad():\n",
        "                assert incr_decr_action_probabilities.shape == (self.num_operators, bs, seq_len, MERGED_GATE_MLP_NUM_GATES-1, 1), f'incr_decr_action_probabilities.shape: {incr_decr_action_probabilities.shape}'\n",
        "                incr_decr_action_probabilities_ = incr_decr_action_probabilities[..., 0]\n",
        "                assert incr_decr_action_probabilities_.shape == (self.num_operators, bs, seq_len, MERGED_GATE_MLP_NUM_GATES-1), f'incr_decr_action_probabilities_.shape: {incr_decr_action_probabilities_.shape}'\n",
        "                candidate_scores_to_cache = incr_decr_action_probabilities_.detach().permute(1, 0, 2, 3)\n",
        "                assert candidate_scores_to_cache.shape == (bs, self.num_operators, seq_len, MERGED_GATE_MLP_NUM_GATES-1), f'candidate_scores_to_cache.shape: {candidate_scores_to_cache.shape}'\n",
        "                # Append reset probs index 0 to last dim:\n",
        "                assert reset_probs_before_ste.shape == (self.num_operators, bs, seq_len, 2), f'reset_probs shape: {reset_probs.shape}, expected shape: {(self.num_operators, bs, seq_len, 2)}'\n",
        "                candidate_scores_to_cache = torch.cat([candidate_scores_to_cache, reset_probs_before_ste[:, :, :, :1].detach().permute(1, 0, 2, 3)], dim=-1)\n",
        "                assert candidate_scores_to_cache.shape == (bs, self.num_operators, seq_len, MERGED_GATE_MLP_NUM_GATES), f'candidate_scores_to_cache.shape: {candidate_scores_to_cache.shape}'\n",
        "                self.cached_candidate_probabilities_for_main_re = candidate_scores_to_cache.cpu()\n",
        "                self.cached_candidate_logits_for_main_re = all_unnormalized_logits.detach().permute(1, 0, 2, 3).cpu()\n",
        "                assert self.cached_candidate_logits_for_main_re.shape == (bs, self.num_operators, seq_len, MERGED_GATE_MLP_NUM_GATES), f'self.cached_candidate_logits_for_main_re shape: {self.cached_candidate_logits_for_main_re.shape}, expected shape: {(bs, self.num_operators, seq_len, 4)}'\n",
        "\n",
        "\n",
        "        # (Optionally combine with lstm outputs as you already do.)\n",
        "        lstm_output_q, lstm_output_k, lstm_output_for_value_context_transform = None, None, None\n",
        "\n",
        "        # RSPE.forward() epilog\n",
        "        return r1_streams_Q, r2_streams_K, r1_streams_Q_prob, r2_streams_K_prob,\\\n",
        "        lstm_output_q, lstm_output_k, lstm_output_for_value_context_transform, {\"gru_embeddings\" : output_embeddings}\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "    def _apply_orthogonal_regularization(self, beta=1e-3):\n",
        "        \"\"\"\n",
        "        Computes an orthogonality penalty for LSTM hidden-to-hidden weight matrices.\n",
        "\n",
        "        Args:\n",
        "            beta (float): Regularization coefficient.\n",
        "\n",
        "        Returns:\n",
        "            orthogonal_loss (Tensor): Scalar loss term to be added to the total loss.\n",
        "        \"\"\"\n",
        "        if not self.use_lstm:\n",
        "            return torch.tensor(0.0, device=device, requires_grad=True)\n",
        "\n",
        "        # Orthog reg. for self.lstm_cells:\n",
        "        ret = torch.tensor(0.0, device=device, requires_grad=True)\n",
        "        # for custom_lstm in self.lstm_cells:\n",
        "        #     ret = ret + custom_lstm._apply_orthogonal_regularization_gru(beta=beta)\n",
        "\n",
        "        # Orthog reg. for self.lstm_out_proj:\n",
        "        lstm_out_proj_wgts = self.lstm_out_proj\n",
        "        assert lstm_out_proj_wgts.shape == (NUM_LSTM_CELLS, self.lstm_hidden_dim, VOCAB_N_DIM)\n",
        "        # self.lstm_out_proj = nn.Parameter(torch.randn(NUM_LSTM_CELLS, self.lstm_hidden_dim, VOCAB_N_DIM))\n",
        "        orthog_loss_lstm_proj = lstm_out_proj_wgts.transpose(1, 2) @ lstm_out_proj_wgts\n",
        "        assert orthog_loss_lstm_proj.shape == (NUM_LSTM_CELLS, VOCAB_N_DIM, VOCAB_N_DIM)\n",
        "        ret = ret + (orthog_loss_lstm_proj - torch.eye(VOCAB_N_DIM, device=device)).pow(2).sum() * (beta)\n",
        "\n",
        "        assert self.W_q_.shape == self.W_k_.shape == (self.num_operators // 2, VOCAB_N_DIM, VOCAB_N_DIM)\n",
        "        orthog_loss_qk = self.W_q_.transpose(1, 2) @ self.W_q_ + self.W_k_.transpose(1, 2) @ self.W_k_\n",
        "        assert orthog_loss_qk.shape == (self.num_operators // 2, VOCAB_N_DIM, VOCAB_N_DIM)\n",
        "        ret = ret + ((orthog_loss_qk - torch.eye(VOCAB_N_DIM, device=device)).pow(2).sum()) * (beta)\n",
        "\n",
        "\n",
        "        return ret\n",
        "\n",
        "def scale_grad_hook(grad, scale=10.0, min_grad=1e-3):\n",
        "    return grad * scale + min_grad\n",
        "\n"
      ],
