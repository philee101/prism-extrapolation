    },
    {
      "cell_type": "code",
      "source": [
        "import math\n",
        "DECODER_LAYER_POST_FF_MHA_MODULE_SOFTCAP_NORM = False # If True, apply a norm to the *outputs* of mha and ff layer individually\n",
        "\n",
        "class DecoderLayer(nn.Module):\n",
        "    def __init__(self, d_model, num_heads, d_ff, dropout=ATTN_FF_OUTPUT_DROPOUT,\n",
        "                 upstream_rotation_matrices=None,\n",
        "                 layer_index=None,\n",
        "                 num_upstream_operators=None,\n",
        "                 model_is_rse=True,\n",
        "                num_purely_content_attn_heads: int = 0,   # [MOD]\n",
        "                 ):\n",
        "\n",
        "        super(DecoderLayer, self).__init__()\n",
        "        self.model_is_rse = model_is_rse\n",
        "        self.num_purely_content_attn_heads = int(num_purely_content_attn_heads)  # [MOD]\n",
        "        print(f'[Decoder layer init], using dropout of {dropout}, num_purely_content_attn_heads = {self.num_purely_content_attn_heads}')\n",
        "\n",
        "        # soft cap: only apply LN to vectors whose L2 norm > threshold\n",
        "        # set to None or <=0 to disable\n",
        "        self.softcap_ln_threshold = float('40')  # e.g., try 20.0 or 40.0; inf disables\n",
        "        self.softcap_ln = nn.LayerNorm(VOCAB_N_DIM, elementwise_affine=False)\n",
        "\n",
        "        if self.model_is_rse:\n",
        "            # positional-only attention\n",
        "            self.self_attn = MultiHeadAttention_ScalarPos(d_model, num_heads,\n",
        "                                                                            head_dim=d_model,\n",
        "                                                                          num_upstream_operators=num_upstream_operators, #upstream_rotation_matrices.shape[0],\n",
        "                                                                            upstream_rotation_matrices=None)\n",
        "\n",
        "            # optional parallel content-only attention\n",
        "            if self.num_purely_content_attn_heads > 0:  # [MOD]\n",
        "                self.content_attn = MultiHeadAttention(\n",
        "                    VOCAB_N_DIM_, self.num_purely_content_attn_heads, head_dim=VOCAB_N_DIM_\n",
        "                )\n",
        "            else:\n",
        "                self.content_attn = None\n",
        "        else:\n",
        "            self.self_attn = MultiHeadAttention(d_model, num_heads, head_dim=d_model)\n",
        "            self.content_attn = None  # [MOD] not used in non-RSE mode\n",
        "\n",
        "        self.layer_index = layer_index\n",
        "\n",
        "        self.norm1 = nn.LayerNorm(VOCAB_N_DIM) if not ReplaceLNWithSmoothCapIfRemoveRSE_LN else SoftCapLNorm()\n",
        "        # if layer_index != NUM_LAYERS -1:\n",
        "        #     d_ff = 0\n",
        "\n",
        "        if d_ff > 0:\n",
        "            self.ff = nn.Sequential(\n",
        "                nn.Linear(VOCAB_N_DIM, d_ff),\n",
        "                nn.GELU(),\n",
        "                nn.Linear(d_ff, VOCAB_N_DIM)\n",
        "            )\n",
        "        else:\n",
        "            self.ff = nn.Identity()\n",
        "        # self.norm2 = nn.LayerNorm(d_model)\n",
        "        self.norm2 = nn.LayerNorm(VOCAB_N_DIM, elementwise_affine=0, bias=1) if not ReplaceLNWithSmoothCapIfRemoveRSE_LN else SoftCapLNorm()\n",
        "        self.norm_pos = nn.LayerNorm(VOCAB_N_DIM)\n",
        "        self.norm_content = nn.LayerNorm(VOCAB_N_DIM)\n",
        "\n",
        "        self.dropout = nn.Dropout(dropout)\n",
        "\n",
        "    def _decoder_layer_apply_softcap_ln(self, x: torch.Tensor) -> torch.Tensor:\n",
        "        \"\"\"\n",
        "        Soft norm cap (differentiable, no hard branch):\n",
        "          - Below threshold -> y ≈ x\n",
        "          - Far above threshold -> y ≈ x * (threshold / ||x||)\n",
        "          - Smooth transition controlled by `softcap_ln_tau`\n",
        "        Keeps direction of x; only scales its magnitude.\n",
        "\n",
        "        Requires on `self` (with fallbacks):\n",
        "          - softcap_ln_threshold: float (e.g., 30.0)\n",
        "          - softcap_ln_tau: float (e.g., 2.0)  # softness of transition\n",
        "          - softcap_ln_sharpness: float (>=1, e.g., 1.0)  # optional gate sharpening\n",
        "        \"\"\"\n",
        "        th = float(getattr(self, \"softcap_ln_threshold\", 40.0))\n",
        "        if th <= 0.0 or math.isinf(th):\n",
        "            return x\n",
        "\n",
        "        tau = float(getattr(self, \"softcap_ln_tau\", 1.0))\n",
        "        tau = 1e-6 if tau <= 0 else tau  # numerical safety\n",
        "        sharp = float(getattr(self, \"softcap_ln_sharpness\", 1.0))\n",
        "\n",
        "        # Per-token L2 norms\n",
        "        norms = x.norm(dim=-1, keepdim=True).clamp_min(1e-12)   # [..., 1]\n",
        "\n",
        "        # Smooth gate in [0,1] that turns on above the threshold\n",
        "        s = (norms - th) / tau\n",
        "        gate = torch.sigmoid(s)\n",
        "        if sharp != 1.0:\n",
        "            gate = gate.pow(sharp)\n",
        "\n",
        "        # Desired scale factor when \"fully capped\": th / ||x||\n",
        "        scale_cap = th / norms\n",
        "\n",
        "        # Smooth blend of scales: 1 (identity) → th/||x||\n",
        "        #   Below th: gate≈0 ⇒ scale≈1\n",
        "        #   Above th: gate≈1 ⇒ scale≈th/||x||\n",
        "        scale = (1.0 - gate) + gate * scale_cap\n",
        "\n",
        "        return x * scale\n",
        "\n",
        "\n",
        "\n",
        "    def clear_cached_self_attn_weights_for_visualization(self):\n",
        "        self.self_attn.attn_weights = []\n",
        "        # self.cached_value_vectors = []\n",
        "        # self.self_attn.segment_boundaries = []\n",
        "        # self.self_attn.cached_value_vectors = []\n",
        "\n",
        "    # Decoder.forward()\n",
        "    # @torch.compile(dynamic=False)\n",
        "    def forward(self, token_stream, position_stream = None,\n",
        "        lstm_output_for_value_context_transform = None,\n",
        "        mask=None, layer_index=None,\n",
        "        clear_self_attn_weights_for_vis=True,\n",
        "        valuesForInputDependentAlphaCoeffs=None,\n",
        "        ):\n",
        "\n",
        "        if layer_index is None:\n",
        "            layer_index = 0\n",
        "        assert self.layer_index == layer_index, f'self.layer_index = {self.layer_index}, layer_index = {layer_index}'\n",
        "\n",
        "        if clear_self_attn_weights_for_vis:\n",
        "            self.clear_cached_self_attn_weights_for_visualization()\n",
        "\n",
        "        x_orig = token_stream\n",
        "\n",
        "        # --- single shared pre-norm for ALL attention paths ---\n",
        "        # (same LayerNorm instance for content & positional attention)\n",
        "        ln_x = self.norm1(token_stream)\n",
        "        # if VERBOSE_LOGGING:\n",
        "        #     print(f'[DecoderLayer index = {self.layer_index}] max norm of ln_x: {torch.norm(ln_x, dim=-1).max()}, min = {ln_x.norm(dim=-1).min()}, mean = {ln_x.norm(dim=-1).mean()}')\n",
        "\n",
        "\n",
        "        if self.model_is_rse:\n",
        "            # Positional-only attention path: Q/K are dummy; V must be normalized via the SAME LN(x)\n",
        "            # NOTE: your surrounding code already creates ln_x = self.norm1(token_stream)\n",
        "            tkn_stream_qk = torch.zeros_like(ln_x)\n",
        "            attn_output_pos = self.self_attn(\n",
        "                tkn_stream_qk, tkn_stream_qk, ln_x if (not removeRSE_LN or ReplaceLNWithSmoothCapIfRemoveRSE_LN) else token_stream,\n",
        "                position_stream, mask,\n",
        "                lstm_output_for_value_context_transform=lstm_output_for_value_context_transform,\n",
        "                valuesForInputDependentAlphaCoeffs=valuesForInputDependentAlphaCoeffs,\n",
        "            )\n",
        "\n",
        "            # Optional parallel content-only attention (Q/K/V all from the SAME LN(x))\n",
        "            if self.content_attn is not None:\n",
        "                tkn_stream_content = ln_x\n",
        "                assert tkn_stream_content.shape[-1] == VOCAB_N_DIM_, \\\n",
        "                    f\"content attn expects width {VOCAB_N_DIM_}, got {tkn_stream_content.shape[-1]}\"\n",
        "                attn_output_content = self.content_attn(\n",
        "                    tkn_stream_content, tkn_stream_content, tkn_stream_content, mask=mask\n",
        "                )\n",
        "\n",
        "                # Keep your existing print (now reflects scaled/capped tensors)\n",
        "                print(f'[decoderLayer index = {self.layer_index}: content vs pos vector norms] '\n",
        "                      f'max pos = {attn_output_pos.norm(dim=-1).max()}, '\n",
        "                      f'max content = {attn_output_content.norm(dim=-1).max()}, '\n",
        "                      f'min pos = {attn_output_pos.norm(dim=-1).min()}, '\n",
        "                      f'min content = {attn_output_content.norm(dim=-1).min()}, '\n",
        "                      f'avg pos = {attn_output_pos.norm(dim=-1).mean()}, '\n",
        "                      f'avg content = {attn_output_content.norm(dim=-1).mean()}')\n",
        "\n",
        "                # --- NEW: soft cap (selective LN only for large norms) per-branch ---\n",
        "                if DECODER_LAYER_POST_FF_MHA_MODULE_SOFTCAP_NORM:\n",
        "                    attn_output_pos     = self._decoder_layer_apply_softcap_ln(attn_output_pos)\n",
        "                    attn_output_content = self._decoder_layer_apply_softcap_ln(attn_output_content)\n",
        "\n",
        "                attn_output = attn_output_pos + attn_output_content\n",
        "            else:\n",
        "                # Feed-forward block (unchanged)\n",
        "                # [9.13.25] <addDecoderLayerSoftCapNormControlForAttnHeads>\n",
        "                if DECODER_LAYER_POST_FF_MHA_MODULE_SOFTCAP_NORM:\n",
        "                    attn_output_pos = self._decoder_layer_apply_softcap_ln(attn_output_pos)\n",
        "                attn_output = attn_output_pos\n",
        "        else:\n",
        "            # Standard content attention path also uses the SAME LN instance\n",
        "            attn_output = self.self_attn(ln_x, ln_x, ln_x, mask=mask)\n",
        "            if DECODER_LAYER_POST_FF_MHA_MODULE_SOFTCAP_NORM:\n",
        "                attn_output = self._apply_decoder_layer_apply_softcap_ln_softcap_ln(attn_output)\n",
        "\n",
        "        attn_output = self.dropout(attn_output)\n",
        "\n",
        "        if sandwichLN:\n",
        "            if VERBOSE_LOGGING:\n",
        "                print(f'[DecoderLayer index = {self.layer_index}, sandwichLN], maxNormOfAttnOutputBeforeRMSNorm = {attn_output.norm(dim=-1).max()}, min = {attn_output.norm(dim=-1).min()}, mean = {attn_output.norm(dim=-1).mean()}')\n",
        "            # Apply rms norm\n",
        "            attn_output = F.rms_norm(attn_output, normalized_shape=attn_output.shape[-1:], eps=1e-8)\n",
        "\n",
        "\n",
        "\n",
        "        if VERBOSE_LOGGING:\n",
        "            print(f'[DecoderLayer index = {self.layer_index}] Avg norm of attn_output: {torch.mean(torch.norm(attn_output, dim=-1))}, min = {attn_output.norm(dim=-1).min()}, max = {attn_output.norm(dim=-1).max()}')\n",
        "\n",
        "        # --- no normalization of the residual stream (pure residual add) ---\n",
        "        if not ResidualStreamLN:\n",
        "            token_stream = attn_output + x_orig\n",
        "        else:\n",
        "            token_stream = attn_output + F.layer_norm(x_orig, x_orig.shape[-1:])\n",
        "\n",
        "\n",
        "        # [9.13.25] <addDecoderLayerSoftCapNormControlForAttnHeads>\n",
        "        # if VERBOSE_LOGGING:\n",
        "        #     print(f'[DecoderLayer index = {self.layer_index}] maxNorm of norm2(token_stream) = {torch.norm(self.norm2(token_stream), dim=-1).max()}, min = {torch.norm(self.norm2(token_stream), dim=-1).min()}, mean = {torch.norm(self.norm2(token_stream), dim=-1).mean()}')\n",
        "        ff_output = self.dropout(self.ff(self.norm2(token_stream)))\n",
        "\n",
        "        if sandwichLN:\n",
        "            # Apply rms norm\n",
        "            if VERBOSE_LOGGING:\n",
        "                print(f'[DecoderLayer index = {self.layer_index}, sandwichLN], maxNormOfFFOutputBeforeRMSNorm = {ff_output.norm(dim=-1).max()}, min = {ff_output.norm(dim=-1).min()}, mean = {ff_output.norm(dim=-1).mean()}')\n",
        "            ff_output = F.rms_norm(ff_output, normalized_shape=ff_output.shape[-1:], eps=1e-8)\n",
        "\n",
        "        elif DECODER_LAYER_POST_FF_MHA_MODULE_SOFTCAP_NORM:\n",
        "            ff_output = self._decoder_layer_apply_softcap_ln(ff_output)\n",
        "\n",
        "\n",
        "        if VERBOSE_LOGGING:\n",
        "            print(f'[DecoderLayer index = {self.layer_index}] Avg norm of ff_output: {torch.mean(torch.norm(ff_output, dim=-1))}, min = {ff_output.norm(dim=-1).min()}, max = {ff_output.norm(dim=-1).max()}')\n",
        "            print(f'[DecoderLayer index = {self.layer_index}] Avg norm of token_stream: {torch.mean(torch.norm(token_stream, dim=-1))}')\n",
        "\n",
        "\n",
        "        return ff_output + token_stream if not ResidualStreamLN else ff_output + F.layer_norm(token_stream, token_stream.shape[-1:])\n"
      ],
      "metadata": {
        "id": "9XlT6DFNjvUE",
        "scrolled": true,
        "trusted": true,
        "execution": {
          "iopub.status.busy": "2025-09-17T19:06:52.165295Z",
          "iopub.execute_input": "2025-09-17T19:06:52.165457Z",
          "iopub.status.idle": "2025-09-17T19:06:52.182242Z",
          "shell.execute_reply.started": "2025-09-17T19:06:52.165442Z",
          "shell.execute_reply": "2025-09-17T19:06:52.181611Z"
        }
