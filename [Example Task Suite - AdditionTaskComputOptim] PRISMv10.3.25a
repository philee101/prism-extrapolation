      "source": [
        "import torch\n",
        "\n",
        "@torch.compile(dynamic=False)  # set False if L, bs, h are fixed across steps\n",
        "def hist_update_v7_fast_bwd_mod_2_noslices_symmetric_narrow_fused(\n",
        "    hist:   torch.Tensor,         # [2*seq_len+1, bs, h]\n",
        "    p_reset: torch.Tensor,        # [bs, h]\n",
        "    p_inc:   torch.Tensor,        # [bs, h]\n",
        "    p_dec:   torch.Tensor,        # [bs, h]\n",
        "    p_keep:  torch.Tensor,        # [bs, h]\n",
        "    eps:     float,\n",
        "    gamma:   torch.Tensor | float,  # scalar or [h]\n",
        "    power:   bool,\n",
        "    seq_len: int,\n",
        "    p_copy:  torch.Tensor | None = None,  # [2*seq_len+2, bs, h] or None\n",
        "):\n",
        "    L, bs, h = hist.shape\n",
        "    mid = seq_len\n",
        "    dt, dev = hist.dtype, hist.device\n",
        "\n",
        "    # ---- weights (no new branches) ----\n",
        "    inv_r  = 1.0 - p_reset\n",
        "    w_inc  = inv_r * p_inc\n",
        "    w_dec  = inv_r * p_dec\n",
        "    w_keep = inv_r * p_keep\n",
        "\n",
        "    # ---- scaled components ----\n",
        "    hist_inc  = hist * w_inc.unsqueeze(0)   # [L,bs,h]\n",
        "    hist_dec  = hist * w_dec.unsqueeze(0)\n",
        "    out       = hist * w_keep.unsqueeze(0)  # start from \"keep\" into a single buffer\n",
        "\n",
        "    # ---- increment branch: shift +1 with last-row carry (all via narrow + add_) ----\n",
        "    if L > 1:\n",
        "        out.narrow(0, 1, L-1).add_( hist_inc.narrow(0, 0, L-1) )   # out[1:] += inc[:-1]\n",
        "    out.narrow(0, L-1, 1).add_( hist_inc.narrow(0, L-1, 1) )       # out[-1] += inc[-1]\n",
        "\n",
        "    # ---- decrement branch: shift -1 with first-row carry ----\n",
        "    if L > 1:\n",
        "        out.narrow(0, 0, L-1).add_( hist_dec.narrow(0, 1, L-1) )   # out[:-1] += dec[1:]\n",
        "    out.narrow(0, 0, 1).add_( hist_dec.narrow(0, 0, 1) )           # out[0]  += dec[0]\n",
        "\n",
        "    # ---- three-way reset spikes (no index tensors) ----\n",
        "    r_m1 = (p_reset * p_dec).unsqueeze(0)   # [1,bs,h]\n",
        "    r_0  = (p_reset * p_keep).unsqueeze(0)\n",
        "    r_p1 = (p_reset * p_inc ).unsqueeze(0)\n",
        "\n",
        "    if mid > 0:\n",
        "        out.narrow(0, mid-1, 1).add_(r_m1)\n",
        "    out.narrow(0, mid,   1).add_(r_0)\n",
        "    if mid + 1 < L:\n",
        "        out.narrow(0, mid+1, 1).add_(r_p1)\n",
        "\n",
        "    # ---- optional position-copying (vectorized; no gathers) ----\n",
        "    if p_copy is not None:\n",
        "        # p_copy: [L+1, bs, h]  (rows 0..L-1 = absolute positions, row L = no-copy)\n",
        "        pos_cols = p_copy.narrow(0, 0, L)       # [L,bs,h]\n",
        "        no_copy  = p_copy.narrow(0, L, 1)       # [1,bs,h]\n",
        "        out.mul_(no_copy).add_(pos_cols)\n",
        "\n",
        "    # ---- sharpening & normalization (out-of-place for autograd sanity) ----\n",
        "    if isinstance(gamma, torch.Tensor):\n",
        "        gamma = gamma.to(device=dev, dtype=dt)\n",
        "    if power:\n",
        "        out = (out + eps).pow(gamma)\n",
        "\n",
        "    # stable normalize along the histogram axis\n",
        "    denom = out.sum(0, keepdim=True).add_(eps)\n",
        "    out = out / denom\n",
        "    return out\n"
      ],
