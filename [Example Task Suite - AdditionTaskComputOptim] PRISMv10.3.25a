    {
      "cell_type": "code",
      "source": [
        "# Enumerate tensors that have grad in rse:\n",
        "for name, param in model_rse.named_parameters():\n",
        "    # if param.requires_grad:\n",
        "    if param.grad is not None:\n",
        "        if 'relative' in name:\n",
        "            print(name, param.data.shape)\n",
        "            print(f'Grad norm for {name}: {param.grad.norm()}')\n",
        "            print(f'mean grad magnitude for {name}: {torch.mean(torch.abs(param.grad))}')\n",
        "            print(f'max grad magnitude for {name}: {torch.max(torch.abs(param.grad))}')\n",
        "            print(f'min grad magnitude for {name}: {torch.min(torch.abs(param.grad))}')\n",
        "            print('---' * 30)\n",
        "\n"
      ],
