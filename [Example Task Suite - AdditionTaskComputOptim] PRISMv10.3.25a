      "cell_type": "code",
      "source": [
        "import torch\n",
        "import torch.nn.functional as F\n",
        "\n",
        "@torch.compile(dynamic=False)\n",
        "def hist_update_v7_fast_bwd_mod_2_noslices_symmetric_depthwise1d(\n",
        "    hist:   torch.Tensor,         # [2*seq_len+1, bs, h]\n",
        "    p_reset: torch.Tensor,        # [bs, h]\n",
        "    p_inc:   torch.Tensor,        # [bs, h]\n",
        "    p_dec:   torch.Tensor,        # [bs, h]\n",
        "    p_keep:  torch.Tensor,        # [bs, h]\n",
        "    eps:     float,\n",
        "    gamma:   torch.Tensor|float,  # scalar or [h]\n",
        "    power:   bool,\n",
        "    seq_len: int,\n",
        "    p_copy:  torch.Tensor|None = None,   # [2*seq_len+2, bs, h] or None\n",
        "    *,\n",
        "    weight_buf: torch.Tensor|None = None,  # optional [bs*h, 1, 3] prealloc\n",
        "):\n",
        "    # shapes / layout\n",
        "    L, bs, h = hist.shape\n",
        "    N = bs * h\n",
        "    mid = seq_len\n",
        "\n",
        "    # ---- per-(b,h) weights ----\n",
        "    inv_r  = 1.0 - p_reset\n",
        "    w_dec  = (inv_r * p_dec).reshape(N)    # [N]\n",
        "    w_keep = (inv_r * p_keep).reshape(N)   # [N]\n",
        "    w_inc  = (inv_r * p_inc ).reshape(N)   # [N]\n",
        "\n",
        "    # depthwise conv expects [B=1, C=N, L]\n",
        "    x = hist.permute(1, 2, 0).reshape(1, N, L).contiguous()\n",
        "\n",
        "    # build grouped kernels: [N, 1, 3]\n",
        "    if weight_buf is None:\n",
        "        W = torch.empty((N, 1, 3), device=hist.device, dtype=hist.dtype)\n",
        "    else:\n",
        "        W = weight_buf\n",
        "    W[:, 0, 0].copy_(w_dec)\n",
        "    W[:, 0, 1].copy_(w_keep)\n",
        "    W[:, 0, 2].copy_(w_inc)\n",
        "\n",
        "    # ---- single cuDNN conv1d (padding=1 implements the 3-tap) ----\n",
        "    y = F.conv1d(x, W, bias=None, stride=1, padding=1, groups=N)  # [1,N,L]\n",
        "\n",
        "    # ---- boundary carries (2 vector adds; O(1) touches) ----\n",
        "    y[..., 0]  = y[..., 0]  + x[..., 0]  * w_dec.view(1, N)\n",
        "    y[..., -1] = y[..., -1] + x[..., -1] * w_inc.view(1, N)\n",
        "\n",
        "    # ---- reset triad (3 O(1) index adds) ----\n",
        "    pr = p_reset\n",
        "    y[..., mid    ] = y[..., mid    ] + (pr * p_keep).reshape(1, N)\n",
        "    if mid + 1 < L:\n",
        "        y[..., mid + 1] = y[..., mid + 1] + (pr * p_inc).reshape(1, N)\n",
        "    if mid - 1 >= 0:\n",
        "        y[..., mid - 1] = y[..., mid - 1] + (pr * p_dec).reshape(1, N)\n",
        "\n",
        "    # ---- optional position copy blend ----\n",
        "    if p_copy is not None:\n",
        "        pos_cols, no_copy = p_copy[:-1], p_copy[-1]                  # [L,bs,h], [bs,h]\n",
        "        pos_cols_ = pos_cols.permute(1, 2, 0).reshape(1, N, L).contiguous()\n",
        "        y = y * no_copy.reshape(1, N, 1) + pos_cols_\n",
        "\n",
        "    # ---- power normalization via softmax(log(.)) (one fused kernel) ----\n",
        "    if power:\n",
        "        z = (y + eps).log()\n",
        "        if isinstance(gamma, torch.Tensor) and gamma.numel() == h:\n",
        "            g_flat = gamma.reshape(1, h).expand(bs, h).reshape(1, N, 1)\n",
        "            z = z * g_flat\n",
        "        else:\n",
        "            z = z * float(gamma)\n",
        "        y = torch.softmax(z, dim=2)  # along L\n",
        "\n",
        "    # back to [L,bs,h]\n",
        "    out = y.reshape(bs, h, L).permute(2, 0, 1).contiguous()\n",
        "    return out\n"
      ],
      "metadata": {
        "id": "uJtff10GjTy1",
        "trusted": true,
        "execution": {
          "iopub.status.busy": "2025-09-17T19:06:51.700072Z",
          "iopub.execute_input": "2025-09-17T19:06:51.700318Z",
          "iopub.status.idle": "2025-09-17T19:06:51.717073Z",
          "shell.execute_reply.started": "2025-09-17T19:06:51.700297Z",
          "shell.execute_reply": "2025-09-17T19:06:51.716419Z"
        }
