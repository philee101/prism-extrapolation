    {
      "cell_type": "code",
      "source": [
        "import torch.nn.functional as F\n",
        "\n",
        "#@torch.compiler.disable()\n",
        "def gumbel_softmax_STE(\n",
        "    logits: torch.Tensor,\n",
        "    tau: float = 10.0,\n",
        "    max_ste=False,\n",
        "    alpha=0.92,\n",
        "    normalize_stddev=False,\n",
        "    dim: int = -1\n",
        ") -> torch.Tensor:\n",
        "    r\"\"\"\n",
        "    Returns a discrete one-hot sample in the forward pass via Gumbel-Softmax,\n",
        "    but in backward pass it passes gradient as though it was the continuous\n",
        "    'softmax((logits + gumbel) / std)' distribution (where std is the stdev).\n",
        "\n",
        "    If max_ste=False, the forward pass is a standard softmax(logits),\n",
        "    but the backward pass flows through the Gumbel-softmax distribution.\n",
        "    If normalize_stddev=False, normalize the mean of the absolute values to equal 1\n",
        "    \"\"\"\n",
        "    # 1) Optionally sample Gumbel noise\n",
        "    #    (Here we set it to zero for demonstration, but you can re-add if desired)\n",
        "    gumbel_noise = 0\n",
        "    # alpha = 1.0\n",
        "\n",
        "    with torch.no_grad():\n",
        "        if normalize_stddev:\n",
        "            # Create a mask for non--inf entries\n",
        "            mask = (logits != float('-inf')).float()\n",
        "\n",
        "            # Number of valid entries per row\n",
        "            n_valid = mask.sum(dim=dim, keepdim=True).clamp_min(1.0)  # avoid div-by-zero\n",
        "\n",
        "            # Replace -inf with 0.0 for the mean/stdev calc\n",
        "            logits_for_stats = logits.masked_fill(logits == float('-inf'), 0.0)\n",
        "\n",
        "            # Compute variance => E[(x - mean)^2] ignoring invalid entries\n",
        "            centered = (logits_for_stats - 0) * mask\n",
        "            if normalize_stddev:\n",
        "                var = (centered * centered).sum(dim=dim, keepdim=True) / n_valid\n",
        "                std = torch.sqrt(var + 1e-9)  # small epsilon to avoid NaNs\n",
        "\n",
        "                # Now we override tau with the computed std\n",
        "                tau = std\n",
        "            else:\n",
        "                pass\n",
        "\n",
        "\n",
        "        # (Optional) debug message\n",
        "        # print(f'[DEBUG] average(std) across batch = {std.mean().item():.3f}')\n",
        "\n",
        "    with torch.no_grad():\n",
        "        if normalize_stddev:\n",
        "\n",
        "            assert len(tau.shape) == len(logits.shape), f'tau.shape: {tau.shape}, logits.shape: {logits.shape}'\n",
        "            assert tau.shape[dim] == 1, f'tau.shape: {tau.shape}, logits.shape: {logits.shape}'\n",
        "            # Assert tau.shape is equal to logits.shape except for axis=<dim>:\n",
        "            tau_shape = list(logits.shape)\n",
        "            tau_shape[dim] = 1\n",
        "            assert tau.shape == tuple(tau_shape), f'tau.shape: {tau.shape}, logits.shape: {logits.shape}'\n",
        "\n",
        "    # 4) Continuous distribution in backward\n",
        "    # y_soft = F.softmax((logits + gumbel_noise) / tau, dim=dim)\n",
        "    y_soft = softmax_lse((logits + gumbel_noise)/tau, dim=dim)\n",
        "    # 5) If we want the forward pass to produce exact one-hots or standard softmax:\n",
        "    if max_ste:\n",
        "        # Hard one-hot in forward, gradient from y_soft\n",
        "        with torch.no_grad():\n",
        "            idx = torch.argmax(y_soft, dim=dim, keepdim=True)\n",
        "            y_hard = torch.zeros_like(logits).scatter_(dim, idx, 1.0)\n",
        "    else:\n",
        "        # Standard softmax in forward pass\n",
        "        # y_hard = F.softmax(logits, dim=dim)\n",
        "        y_hard = softmax_lse(logits, dim=dim)\n",
        "\n",
        "    # 6) Straight-through combo\n",
        "    # forward => y_hard, backward => y_soft\n",
        "\n",
        "    y = alpha * y_hard + (1 - alpha) * y_soft + (y_soft - y_soft.detach())\n",
        "\n",
        "    # Register a hook on the output to print gradient magnitudes during backpropagation.\n",
        "    # def grad_hook(grad):\n",
        "    #     print(f\"[HOOK] Gradients at STE output: mean={grad.abs().mean().item():.4f}, norm={grad.norm().item():.4f}, max={grad.max().item():.4f}, shape={grad.shape}\")\n",
        "    # y.register_hook(grad_hook)\n",
        "\n",
        "    return y\n"
      ],
      "metadata": {
        "id": "SH2PfCphryvh",
        "trusted": true,
        "execution": {
          "iopub.status.busy": "2025-09-17T19:06:51.036774Z",
          "iopub.execute_input": "2025-09-17T19:06:51.037025Z",
          "iopub.status.idle": "2025-09-17T19:06:51.049311Z",
          "shell.execute_reply.started": "2025-09-17T19:06:51.036999Z",
          "shell.execute_reply": "2025-09-17T19:06:51.048698Z"
        }
      },
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "code",
      "source": [
        "import math\n",
        "import torch\n",
        "import torch.nn as nn\n",
        "import torch.nn.functional as F\n",
        "\n",
        "USE_WEIGHTS_FOR_KEEP_GATE = True\n",
        "if USE_WEIGHTS_FOR_KEEP_GATE:\n",
        "    MERGED_GATE_MLP_NUM_GATES = 4  # {inc, dec, keep, reset}\n",
        "else:\n",
        "    MERGED_GATE_MLP_NUM_GATES = 3  # {inc, dec, reset}\n",
        "\n",
        "mgmlp_weight_and_layer_norm_value = 2.5\n",
        "RESET_GATE_NORM = 2.5 if not USE_RESET_GATE_OVERSMOOTHING_FIXES else 3.0\n",
        "mgmlpPerOutputLN = False # If True, always apply a layer norm to the *outputs* of the MLP layers\n",
        "if sandwichLN:\n",
        "    mgmlpPerOutputLN = True\n",
        "    print(f'WARNING: setting mgmlpPerOutputLN = True automatically since sandwichLN = True')\n",
        "\n",
        "MGMLP_LAYER_PER_MLP_OUTPUT_SOFTCAP_POST_NORM = False # If True, apply a norm that only applies beyond a threshold to the *outputs* of the MLP layers\n",
        "if MGMLP_LAYER_PER_MLP_OUTPUT_SOFTCAP_POST_NORM:\n",
        "    assert not mgmlpPerOutputLN, f'{MGMLP_LAYER_PER_MLP_OUTPUT_SOFTCAP_POST_NORM} and {mgmlpPerOutputLN} are mutually exclusive'\n",
        "MGMLP_RESIDUAL_STREAM_LN = False\n",
        "MGMLP_INITIAL_NORM = True\n",
        "USE_SEPARATE_LINEAR_PROJ_FOR_INPT_DPDNT_GAMMA_LATENTS = True\n",
        "\n",
        "class MergedGateMLP_Residual(nn.Module):\n",
        "    \"\"\"\n",
        "    MergedGateMLP computes update logits for 4 discrete actions\n",
        "    (reset, increment, decrement, keep same) with post-LN residual blocks.\n",
        "    \"\"\"\n",
        "    def __init__(self,\n",
        "                 input_dim: int,\n",
        "                 intermediate_dim: int,\n",
        "                 num_operators: int,\n",
        "                 num_layers: int = 5,\n",
        "                 num_shared_layers: int = NUM_SHARED_MGMLP_LAYERS,\n",
        "                 final_gate_bias: float = -0.81,\n",
        "                 fixed_gate_mask: torch.Tensor = None,\n",
        "                 output_value_for_fixed_gates: float = 1.0,\n",
        "                 use_weight_and_final_layer_norm: bool = True):\n",
        "        super().__init__()\n",
        "        assert num_layers >= num_shared_layers, \"num_layers must be >= num_shared_layers\"\n",
        "        assert num_layers > 0\n",
        "\n",
        "        self.input_dim = input_dim\n",
        "        self.intermediate_dim = intermediate_dim\n",
        "        self.num_layers = num_layers\n",
        "        self.num_shared_layers = min(num_shared_layers, num_layers - 1)\n",
        "        self.use_weight_and_final_layer_norm = use_weight_and_final_layer_norm\n",
        "        soft_layer_norm_threshold = 100\n",
        "        self.capped_final_ln = SoftCapLNorm(init_cap=soft_layer_norm_threshold) if ReplaceLNWithSmoothCapIfRemoveRSE_LN else None\n",
        "\n",
        "        # Fixed vs. learnable operators:\n",
        "        if True:\n",
        "          # fixed_gate_mask: [num_operators] bool buffer (already registered)\n",
        "          learnable_idx = (~fixed_gate_mask).nonzero(as_tuple=False).flatten()\n",
        "          fixed_idx     = ( fixed_gate_mask).nonzero(as_tuple=False).flatten()\n",
        "\n",
        "          # For efficiency, avoiding data-dependent for-loops over tensors: Store as buffers so shapes/devices track the module; non-persistent is fine\n",
        "          self.register_buffer(\"learnable_idx\", learnable_idx, persistent=False)\n",
        "          self.register_buffer(\"fixed_idx\",     fixed_idx,     persistent=False)\n",
        "\n",
        "          self.register_buffer('fixed_gate_mask', fixed_gate_mask)\n",
        "          self.output_value_for_fixed_gates = output_value_for_fixed_gates\n",
        "          self.num_fixed = fixed_gate_mask.sum().item()\n",
        "          self.num_learnable = num_operators - self.num_fixed\n",
        "          self.num_operators = num_operators\n",
        "\n",
        "          in_dim = input_dim\n",
        "          # --- Shared Layers + post-LN residual + optional projection ---\n",
        "          self.shared_layers = nn.ModuleList()\n",
        "          self.shared_res_projs = nn.ModuleList()\n",
        "          self.shared_layer_norms = nn.ModuleList()\n",
        "\n",
        "          # Python-native views of the mask (safe to branch on; no tracing)\n",
        "          _mask_bool_list = fixed_gate_mask.to(torch.bool).tolist()  # List[bool] length = num_operators\n",
        "          self._slot_is_fixed = tuple(_mask_bool_list)               # immutable & cheap to iterate\n",
        "          # (num_fixed / num_learnable already computed; keep them)\n",
        "\n",
        "\n",
        "        if removeRSE_LN and ReplaceLNWithSmoothCapIfRemoveRSE_LN:\n",
        "            self.input_softcap_ln = SoftCapLNorm()\n",
        "\n",
        "        for _ in range(self.num_shared_layers):\n",
        "            # the actual feed-forward layer\n",
        "            layer = nn.Linear(in_dim, intermediate_dim)\n",
        "            # nn.init.kaiming_uniform_(layer.weight, mode='fan_in', nonlinearity='leaky_relu')\n",
        "            nn.init.xavier_uniform_(layer.weight)\n",
        "            nn.init.zeros_(layer.bias)\n",
        "            self.shared_layers.append(layer)\n",
        "\n",
        "            # if dims differ, project residual into intermediate_dim\n",
        "            if in_dim != intermediate_dim:\n",
        "                proj = nn.Linear(in_dim, intermediate_dim)\n",
        "                nn.init.xavier_uniform_(proj.weight)\n",
        "                nn.init.zeros_(proj.bias)\n",
        "                assert False, \"Not supported yet\"\n",
        "            else:\n",
        "                proj = nn.Identity()\n",
        "                # proj = nn.Linear(in_dim, intermediate_dim)\n",
        "                # nn.init.xavier_uniform_(proj.weight)\n",
        "                # nn.init.zeros_(proj.bias)\n",
        "\n",
        "            self.shared_res_projs.append(proj)\n",
        "\n",
        "            # post-residual LayerNorm\n",
        "            if removeRSE_LN and ReplaceLNWithSmoothCapIfRemoveRSE_LN:\n",
        "                self.shared_layer_norms.append(SoftCapLNorm(soft_layer_norm_threshold))\n",
        "            else:\n",
        "                self.shared_layer_norms.append(nn.LayerNorm(intermediate_dim))\n",
        "\n",
        "\n",
        "            in_dim = intermediate_dim\n",
        "\n",
        "        # --- Individual Operator-Specific Layers + post-LN residual + Identity proj ---\n",
        "        num_indiv = num_layers - self.num_shared_layers\n",
        "        self.indiv_weights = nn.ParameterList()\n",
        "        self.indiv_biases  = nn.ParameterList()\n",
        "        self.indiv_res_projs = nn.ModuleList()\n",
        "        self.indiv_layer_norms = nn.ModuleList()\n",
        "        for _ in range(num_indiv):\n",
        "            w = nn.Parameter(torch.empty(self.num_learnable, in_dim, intermediate_dim))\n",
        "            b = nn.Parameter(torch.zeros(self.num_learnable, 1, intermediate_dim))\n",
        "            for i in range(self.num_learnable):\n",
        "                # nn.init.kaiming_uniform_(w[i].t(), mode='fan_in', nonlinearity='leaky_relu')\n",
        "                # Use xavier init:\n",
        "                nn.init.xavier_uniform_(w[i].t())\n",
        "            self.indiv_weights.append(w)\n",
        "            self.indiv_biases.append(b)\n",
        "\n",
        "            # individual layers keep the same dim → identity residual proj\n",
        "            if in_dim == intermediate_dim:\n",
        "                self.indiv_res_projs.append(nn.Identity())\n",
        "            else:\n",
        "                # assert False, \"Not supported yet\"\n",
        "                # proj = nn.Linear(in_dim, intermediate_dim)\n",
        "                # nn.init.xavier_uniform_(proj.weight)\n",
        "                # nn.init.zeros_(proj.bias)\n",
        "                self.indiv_res_projs.append(None)\n",
        "\n",
        "            if removeRSE_LN and ReplaceLNWithSmoothCapIfRemoveRSE_LN:\n",
        "                self.indiv_layer_norms.append(SoftCapLNorm(init_cap=soft_layer_norm_threshold))\n",
        "            else:\n",
        "                self.indiv_layer_norms.append(nn.LayerNorm(in_dim, elementwise_affine=False))\n",
        "            in_dim = intermediate_dim\n",
        "\n",
        "            # --- Final & keep gate weights & biases ---\n",
        "            N = self.num_learnable\n",
        "            device = self.device if hasattr(self, \"device\") else None\n",
        "            dtype  = torch.get_default_dtype()\n",
        "\n",
        "            USE_WEIGHTS_FOR_KEEP_GATE = True  # or your flag\n",
        "            assert in_dim >= (4 if USE_WEIGHTS_FOR_KEEP_GATE else 3), \\\n",
        "                \"Need in_dim ≥ number of orthogonal vectors you want.\"\n",
        "\n",
        "            # Candidates\n",
        "            final_wgt_tensor = torch.randn(N, in_dim, 3, device=device, dtype=dtype)\n",
        "\n",
        "            wgt_norm = (1/math.sqrt(in_dim)) if MGMLP_RESIDUAL_STREAM_LN else (1/math.sqrt(in_dim)) # muchSmallerFinalWgtNormMGMLP\n",
        "\n",
        "            if USE_WEIGHTS_FOR_KEEP_GATE:\n",
        "                keep_wgt_tensor  = torch.randn(N, in_dim, 1, device=device, dtype=dtype)\n",
        "\n",
        "                # Stack keep first, then the 3 final vectors -> shape (N, in_dim, 4)\n",
        "                four = torch.cat([keep_wgt_tensor, final_wgt_tensor], dim=-1)\n",
        "\n",
        "                with torch.no_grad():\n",
        "                    # Orthonormal columns via batched QR\n",
        "                    Q, R = torch.linalg.qr(four, mode='reduced')  # Q: (N, in_dim, 4), R: (N, 4, 4)\n",
        "\n",
        "                    # Make diag(R) non-negative to fix column sign ambiguity\n",
        "                    signs = torch.sign(torch.diagonal(R, dim1=-2, dim2=-1)).unsqueeze(-2)  # (N,1,4)\n",
        "                    Q = Q * signs\n",
        "\n",
        "                    # Scale each column to have ||col|| = √in_dim\n",
        "                    Q = Q * wgt_norm\n",
        "\n",
        "                    keep_vec   = Q[..., :1]   # (N, in_dim, 1)\n",
        "                    final_vecs = Q[..., 1:]   # (N, in_dim, 3)\n",
        "\n",
        "                self.keep_weight = nn.Parameter(keep_vec)\n",
        "                # self.keep_weight.requires_grad = False\n",
        "                self.keep_bias   = nn.Parameter(torch.zeros(N, 1, 1, device=device, dtype=dtype))\n",
        "                self.final_weight = nn.Parameter(final_vecs)\n",
        "                # self.final_weight.requires_grad = False\n",
        "                self.final_bias   = nn.Parameter(torch.zeros(N, 1, 3, device=device, dtype=dtype))\n",
        "\n",
        "            else:\n",
        "                with torch.no_grad():\n",
        "                    # Only orthogonalize the 3 final columns\n",
        "                    Q, R = torch.linalg.qr(final_wgt_tensor, mode='reduced')  # (N, in_dim, 3)\n",
        "                    signs = torch.sign(torch.diagonal(R, dim1=-2, dim2=-1)).unsqueeze(-2)  # (N,1,3)\n",
        "                    Q = Q * signs\n",
        "                    Q = Q * wgt_norm\n",
        "\n",
        "                self.final_weight = nn.Parameter(Q)\n",
        "                self.final_bias   = nn.Parameter(torch.zeros(N, 1, 3, device=Q.device, dtype=Q.dtype))\n",
        "\n",
        "\n",
        "\n",
        "        assert len(self.indiv_weights) == len(self.indiv_biases) == len(self.indiv_res_projs) == len(self.indiv_layer_norms), f'{len(self.indiv_weights)}, {len(self.indiv_biases)}, {len(self.indiv_res_projs)}, {len(self.indiv_layer_norms)}'\n",
        "        assert len(list(zip(self.indiv_weights,\n",
        "                                  self.indiv_biases,\n",
        "                                  self.indiv_res_projs,\n",
        "                                  self.indiv_layer_norms))) == num_indiv, f'{len(self.indiv_weights)}, {len(self.indiv_biases)}, {len(self.indiv_res_projs)}, {len(self.indiv_layer_norms)}'\n",
        "\n",
        "        # initialize reset-gate bias\n",
        "        with torch.no_grad():\n",
        "            # if not MGMLP_RESIDUAL_STREAM_LN:\n",
        "            #     self.final_bias[:, :, -1].fill_(-100.0) # Disable\n",
        "            #     print(f'[\\n\\n\\n --- \\n WARNING: EXPERIMENTAL] reset bias is disabled if MGMLP_RESIDUAL_STREAM_LN = {MGMLP_RESIDUAL_STREAM_LN} \\n --- \\n\\n\\n')\n",
        "            #     self.final_bias.requires_grad = False\n",
        "            # else:\n",
        "            self.final_bias[:, :, -1].fill_(-3.2 if USE_RESET_GATE_OVERSMOOTHING_FIXES else -3.2)\n",
        "\n",
        "        if MGMLP_LAYER_PER_MLP_OUTPUT_SOFTCAP_POST_NORM:\n",
        "            self.softcap_per_mlp_post_ln = SoftCapLNorm(init_cap=(self.intermediate_dim ** 0.5) * 5)\n",
        "\n",
        "        if USE_SEPARATE_LINEAR_PROJ_FOR_INPT_DPDNT_GAMMA_LATENTS:\n",
        "            # self.separate_linear_proj_gamma_latent = nn.Parameter(self.num_operators, self.input_dim, self.intermediate_dim)\n",
        "            self.separate_linear_proj_gamma_latent = nn.Parameter(torch.empty(self.num_operators, self.input_dim, self.intermediate_dim))\n",
        "            for i in range(self.num_operators):\n",
        "                nn.init.xavier_uniform_(self.separate_linear_proj_gamma_latent[i].T)\n",
        "            self.separate_linear_bias_gamma_latent = nn.Parameter(torch.zeros(self.num_operators, 1, self.intermediate_dim))\n",
        "            nn.init.zeros_(self.separate_linear_bias_gamma_latent)\n",
        "        else:\n",
        "            self.separate_linear_proj_gamma_latent = None\n",
        "            self.separate_linear_bias_gamma_latent = None\n",
        "\n",
        "\n",
        "        self.latest_scalar_outputs = [] # For debugging nonly\n",
        "\n",
        "    # @torch.compile(dynamic=False)\n",
        "    def forward(self, embeddings: torch.Tensor) -> torch.Tensor:\n",
        "        # bs, num_ops, seq_len, _ = embeddings.shape\n",
        "        bs, seq_len, _ = embeddings.shape\n",
        "\n",
        "        x = embeddings\n",
        "        initial_inputs = x\n",
        "\n",
        "        if not RSE_LSTM_USE_RESIDUAL_CONNECTION or not MGMLP_INITIAL_NORM:\n",
        "            x = x\n",
        "        # el\n",
        "        elif removeRSE_LN and ReplaceLNWithSmoothCapIfRemoveRSE_LN:\n",
        "            x = self.input_softcap_ln(x)\n",
        "        elif not removeRSE_LN:\n",
        "            x = F.layer_norm(x, normalized_shape=x.shape[-1:])\n",
        "\n",
        "        # --- Shared blocks ---\n",
        "        for layer, proj, ln in zip(self.shared_layers,\n",
        "                                   self.shared_res_projs,\n",
        "                                   self.shared_layer_norms):\n",
        "            residual = x\n",
        "            x_ln = ln(x) if RSE_LSTM_USE_RESIDUAL_CONNECTION else x\n",
        "            y = layer(x_ln if not removeRSE_LN else x)\n",
        "\n",
        "            y = F.gelu(y)\n",
        "            if proj is not None:\n",
        "                residual = proj(residual)\n",
        "            if ReplaceLNWithSmoothCapIfRemoveRSE_LN:\n",
        "                y = ln(y)\n",
        "            elif residual.shape[-1] != y.shape[-1]:\n",
        "                x = F.layer_norm(y, normalized_shape=y.shape[-1:])\n",
        "            elif MGMLP_RESIDUAL_STREAM_LN:\n",
        "                x = F.layer_norm(residual, normalized_shape=residual.shape[-1:]) + y\n",
        "            else:\n",
        "                x = residual + y\n",
        "\n",
        "\n",
        "        # --- Individual blocks ---\n",
        "        layer_idx = 0\n",
        "        DEBUG_ADDED_Y = True\n",
        "        if VERBOSE_LOGGING:\n",
        "            print(f'[MGMLP] MGMLP_INITIAL_NORM mean = {x.norm(dim=-1).mean().item():.4f}, std = {x.std().item():.4f}, min = {x.norm(dim=-1).min().item():.4f}, max = {x.norm(dim=-1).max().item():.4f}')\n",
        "\n",
        "\n",
        "        # for w, b, proj, ln in zip(self.indiv_weights,\n",
        "        #                           self.indiv_biases,\n",
        "        #                           self.indiv_res_projs,\n",
        "        #                           self.indiv_layer_norms):\n",
        "        L = len(self.indiv_weights)\n",
        "        for layer_idx in range(L):\n",
        "            w   = self.indiv_weights[layer_idx]\n",
        "            b   = self.indiv_biases[layer_idx]\n",
        "            proj= self.indiv_res_projs[layer_idx]\n",
        "            ln  = self.indiv_layer_norms[layer_idx]\n",
        "\n",
        "            residual = x\n",
        "            x_ln = ln(x) if not removeRSE_LN and (RSE_LSTM_USE_RESIDUAL_CONNECTION or layer_idx > 0) else x\n",
        "            if layer_idx == 0:\n",
        "                y = torch.einsum(\"bsd,ndf->nbsf\", x_ln,\n",
        "                                w) + b.unsqueeze(-2)\n",
        "\n",
        "            else:\n",
        "                y = torch.einsum(\"nbsd,ndf->nbsf\", x_ln,\n",
        "                                w) + b.unsqueeze(-2)\n",
        "            y = F.gelu(y)\n",
        "            if proj is not None:\n",
        "                residual = proj(residual)\n",
        "            if DEBUG_ADDED_Y and VERBOSE_LOGGING:\n",
        "                print(f'[MGMLP_RES] layer idx {layer_idx}, max norm of mlp(x) = {y.norm(dim=-1).max().item():.4f}, mean norm = {y.norm(dim=-1).mean().item():.4f}, min = {y.norm(dim=-1).min().item():.4f}, median norm = {torch.median(y.norm(dim=-1)).item():.4f}, shape = {y.shape}, std = {y.std().item():.4f}')\n",
        "\n",
        "            if (residual.shape[-1] != y.shape[-1]):\n",
        "                x = F.layer_norm(y, normalized_shape=y.shape[-1:]) if not removeRSE_LN and MGMLP_RESIDUAL_STREAM_LN else y\n",
        "            elif residual.shape[-1] == y.shape[-1]:\n",
        "                if removeRSE_LN:\n",
        "                    y = y;\n",
        "                elif MGMLP_LAYER_PER_MLP_OUTPUT_SOFTCAP_POST_NORM:\n",
        "                    y = self.softcap_per_mlp_post_ln(y)\n",
        "                elif mgmlpPerOutputLN:\n",
        "                    y = F.layer_norm(y, normalized_shape=y.shape[-1:])\n",
        "                x = residual + y if not MGMLP_RESIDUAL_STREAM_LN else F.layer_norm(residual, normalized_shape=residual.shape[-1:]) + y\n",
        "\n",
        "            layer_idx += 1\n",
        "\n",
        "        latentFor_gamma_proj = x\n",
        "        # print(f'[MGMLP] x latent shape = {x.shape}, num layers = {layer_idx}')\n",
        "\n",
        "        # --- Final gate computation ---\n",
        "        final_w = self.final_weight\n",
        "        keep_w  = getattr(self, 'keep_weight', None)\n",
        "        final_w_inc, final_w_dec, final_w_reset = final_w.unbind(-1)\n",
        "        x_for_reset = x\n",
        "\n",
        "        if self.use_weight_and_final_layer_norm and MGMLP_RESIDUAL_STREAM_LN:\n",
        "\n",
        "\n",
        "            # normalize final weights\n",
        "            wgt_norm = True\n",
        "\n",
        "            if wgt_norm:\n",
        "\n",
        "                final_w_inc = mgmlp_weight_and_layer_norm_value * final_w_inc / final_w_inc.norm(dim=1, keepdim=True).clamp(min=1e-8)\n",
        "                final_w_dec = mgmlp_weight_and_layer_norm_value * final_w_dec / final_w_dec.norm(dim=1, keepdim=True).clamp(min=1e-8)\n",
        "                final_w_reset = RESET_GATE_NORM * final_w_reset / final_w_reset.norm(dim=1, keepdim=True).clamp(min=1e-8)\n",
        "\n",
        "                if keep_w is not None:\n",
        "                    kw = mgmlp_weight_and_layer_norm_value * keep_w / keep_w.norm(dim=1, keepdim=True).clamp(min=1e-8)\n",
        "                    keep_w = kw\n",
        "\n",
        "            PRINT_X_NORM_STATISTICS = True\n",
        "            if PRINT_X_NORM_STATISTICS and VERBOSE_LOGGING:\n",
        "                print(f'[MGMLP_RES] max norm of x final = {x.norm(dim=-1).max().item():.4f}, mean norm of x = {x.norm(dim=-1).mean().item():.4f}, min norm of x = {x.norm(dim=-1).min().item():.4f}, median norm of x = {torch.median(x.norm(dim=-1)).item():.4f}, shape of x = {x.shape}')\n",
        "\n",
        "            # normalize activations\n",
        "            if ReplaceLNWithSmoothCapIfRemoveRSE_LN:\n",
        "                x = self.capped_final_ln(x)\n",
        "            else:\n",
        "                x = x - x.mean(dim=-1, keepdim=True)\n",
        "                x = mgmlp_weight_and_layer_norm_value * x / x.norm(dim=-1, keepdim=True).clamp(min=1e-8)\n",
        "                x_for_reset = RESET_GATE_NORM * x / x.norm(dim=-1, keepdim=True).clamp(min=1e-8)\n",
        "\n",
        "        # compute inc/dec/reset logits\n",
        "        final_bias_inc, final_bias_dec, final_bias_reset = self.final_bias.unbind(-1)\n",
        "        out_inc = torch.einsum(\"nbsd,nd->nbs\", x, final_w_inc) + final_bias_inc.unsqueeze(-1)\n",
        "        out_dec = torch.einsum(\"nbsd,nd->nbs\", x, final_w_dec) + final_bias_dec.unsqueeze(-1)\n",
        "        out_reset = torch.einsum(\"nbsd,nd->nbs\", x_for_reset, final_w_reset) + final_bias_reset.unsqueeze(-1)\n",
        "\n",
        "        # compute keep-logit and stack into 4-way output\n",
        "        if keep_w is not None:\n",
        "            keep_l = torch.einsum(\"nbsd,ndg->nbsg\", x, keep_w) + self.keep_bias.unsqueeze(-2)\n",
        "            # inc, dec, reset = out3.unbind(-1)\n",
        "            keep = keep_l.squeeze(-1)\n",
        "            # out = torch.stack((inc, dec, keep, reset), dim=-1)\n",
        "            out = torch.stack((out_inc, out_dec, keep, out_reset), dim=-1)\n",
        "        else:\n",
        "            raise NotImplementedError(\"Keep-gate weights disabled when they should not be\")\n",
        "\n",
        "        # re-insert fixed operators\n",
        "\n",
