      "cell_type": "markdown",
      "source": [
        "## Evaluate on Addition + CoT"
      ],
      "metadata": {
        "id": "4dOD2hu_D0NZ"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "def evaluate_extrapolation_Addition_CoT(min_digits=5, max_digits=5,\n",
        "                                         for_model='baseline',\n",
        "                                         printOutputsAndTargets=False,\n",
        "                       examples_per_sequence=1,\n",
        "                       visualize_attn_weights=False\n",
        "                       , train_set=False, n_total_examples=100, seed=None,\n",
        "                                        batch_size=1):\n",
        "    if seed is not None:\n",
        "        set_purely_random_seed(seed)\n",
        "    else:\n",
        "        set_purely_random_seed()\n",
        "\n",
        "    global MODEL_EVALUATE_MODE\n",
        "    MODEL_EVALUATE_MODE = True\n",
        "\n",
        "    print('---' * 10)\n",
        "    print(f'Evaluating on extrapolation_len={min_digits}->{max_digits}, model={for_model}')\n",
        "    print('---' * 10)\n",
        "    test_loader =  _create_dataset(for_mode='addition', examples_per_sequence=1, num_total_examples=n_total_examples,\n",
        "                                batch_size=batch_size,\n",
        "                                   min_seq_len_for_dataset=1, max_seq_len_for_dataset=5,\n",
        "                                min_digits_mult=min_digits, max_digits_mult=max_digits)\n",
        "    if for_model == 'rse':\n",
        "        if model_baseline is not None:\n",
        "            model_baseline.to('cpu')\n",
        "        model_rse.to(device)\n",
        "        # acc = evaluate(model_rse, test_loader, criterion, device,\n",
        "                      #  printOutputsAndTargets=printOutputsAndTargets,\n",
        "                      #  visualize_attn_example_index=0 if visualize_attn_weights else None,\n",
        "                      #  visualize_attn_layer_skip=1,\n",
        "\n",
        "                      #  )\n",
        "        acc = evaluate_multibatch(model_rse, test_loader, criterion, device,\n",
        "                printOutputsAndTargets=printOutputsAndTargets,\n",
        "                visualize_attn_example_index=0 if visualize_attn_weights else None,\n",
        "                visualize_attn_layer_skip=1,\n",
        "\n",
        "                )\n",
        "        print(f'accuracy for rse: {acc}')\n",
        "    else:\n",
        "        if model_rse is not None:\n",
        "            model_rse.to('cpu')\n",
        "        model_baseline.to(device)\n",
        "        acc = evaluate(model_to_use, test_loader, criterion, device,\n",
        "                       printOutputsAndTargets=printOutputsAndTargets,\n",
        "                       visualize_attn_example_index=0 if visualize_attn_weights else None,\n",
        "                       visualize_attn_layer_skip=1,\n",
        "\n",
        "                       )\n",
        "    print(f'accuracy for baseline: {acc}')\n",
        "    print('---' * 10)\n",
        "    print(f'Done Evaluating on extrapolation_len={min_digits}->{max_digits}, model={for_model}')\n",
        "    print('---' * 10)\n",
        "\n"
      ],
