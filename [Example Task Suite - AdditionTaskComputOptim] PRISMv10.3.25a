    {
      "cell_type": "code",
      "source": [
        "@torch.compile(dynamic=False)\n",
        "def hist_update_v7_fast_bwd_mod_2(\n",
        "    hist:   torch.Tensor,         # [P, bs, h]\n",
        "    p_reset:torch.Tensor,         # [bs, h]\n",
        "    p_inc:  torch.Tensor,\n",
        "    p_dec:  torch.Tensor,\n",
        "    p_keep: torch.Tensor,\n",
        "    p_copy: torch.Tensor|None,    # [P+1, bs, h]  or  [bs, h, P+1]\n",
        "    eps:    float,\n",
        "    gamma:  torch.Tensor|float,   # scalar or [h]  (broadcast ok)\n",
        "    power:  bool = True,\n",
        "):\n",
        "    \"\"\"\n",
        "    Forward-only functional histogram update.\n",
        "\n",
        "    Implements optimisation #4:\n",
        "      • the three branches {keep, inc-shift, dec-shift} are accumulated\n",
        "        in ONE tensor (`out`) instead of materialising two roll buffers.\n",
        "    \"\"\"\n",
        "    P, bs, h = hist.shape\n",
        "    one      = hist.new_tensor(1.)\n",
        "\n",
        "    # ----------------------------------------------------------------- weights\n",
        "    inv_r   = one - p_reset\n",
        "    w_inc   = inv_r * p_inc\n",
        "    w_dec   = inv_r * p_dec\n",
        "    w_keep  = inv_r * p_keep\n",
        "\n",
        "    hist_inc  = hist * w_inc .unsqueeze(0)     # [P,bs,h]\n",
        "    hist_dec  = hist * w_dec .unsqueeze(0)\n",
        "    hist_keep = hist * w_keep.unsqueeze(0)\n",
        "\n",
        "    # ----------------------------------------------------------------- CORE\n",
        "    # start with the keep-branch, then add the two shifted branches in-place\n",
        "    out = hist_keep.clone(memory_format=torch.contiguous_format)  # → [P,bs,h]\n",
        "\n",
        "    # ---- increment branch: t  → t+1, clamp overflow to last row\n",
        "    out[1:] += hist_inc[:-1]          # normal shift\n",
        "    out[-1] += hist_inc[-1]           # overflow stays at last row\n",
        "\n",
        "    # ---- decrement branch: t  → t-1, clamp underflow to row-0\n",
        "    out[:-1] += hist_dec[1:]          # normal shift\n",
        "    out[0]   += hist_dec[0]           # underflow stays at row-0\n",
        "\n",
        "    # ----------------------------------------------------------------- reset\n",
        "    total = hist.sum(0)                                   # [bs,h]\n",
        "    out[0] += total * p_reset * (p_dec + p_keep)\n",
        "    out[1] += total * p_reset * p_inc\n",
        "\n",
        "    # ----------------------------------------------------------------- copy\n",
        "    if p_copy is not None and Position_Copying_Enabled:\n",
        "        if p_copy.shape[0] != P + 1:                      # allow [bs,h,P+1]\n",
        "            p_copy = p_copy.permute(2, 0, 1).contiguous() # → [P+1,bs,h]\n",
        "        pos_cols, no_copy = p_copy[:-1], p_copy[-1]       # [P,bs,h]  [bs,h]\n",
        "        out = out * no_copy.unsqueeze(0) + total.unsqueeze(0) * pos_cols\n",
        "\n",
        "    # ----------------------------------------------------------------- sharpen\n",
        "    if power:\n",
        "        out = (out + eps).pow(gamma)\n",
        "    out = (out + eps) / (out.sum(0, keepdim=True) + eps)\n",
        "\n",
        "    return out\n"
      ],
      "metadata": {
        "id": "fq7xQalRWBlb",
        "trusted": true,
        "execution": {
          "iopub.status.busy": "2025-09-17T19:06:51.203343Z",
          "iopub.execute_input": "2025-09-17T19:06:51.203543Z",
          "iopub.status.idle": "2025-09-17T19:06:51.219290Z",
          "shell.execute_reply.started": "2025-09-17T19:06:51.203527Z",
          "shell.execute_reply": "2025-09-17T19:06:51.218689Z"
        }
      },
      "outputs": [],
      "execution_count": null
