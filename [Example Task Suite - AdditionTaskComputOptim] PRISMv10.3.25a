        "    assert NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE % 2 == 0, f'NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE ({NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE}) must be divisible by 2'\n",
        "    NUM_FIXED_KEY_RE = (NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE // 2) * percentageFixedKeyRE\n",
        "    NUM_FIXED_KEY_RE = int(NUM_FIXED_KEY_RE)\n",
        "    assert NUM_FIXED_KEY_RE > 0, f'percentageFixedKeyRE: NUM_FIXED_KEY_RE ({NUM_FIXED_KEY_RE}) must be > 0 after rounding'\n",
        "    print(f'percentageFixedKeyRE: {percentageFixedKeyRE}, NUM_FIXED_KEY_RE: {NUM_FIXED_KEY_RE}')\n",
