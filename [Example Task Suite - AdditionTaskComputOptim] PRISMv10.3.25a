        "\n",
        "if model_rse is not None:\n",
        "    for op_idx in range(0, NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE // 2):\n",
        "        show_hist_heatmap(model_rse.relative_encodings[3],\n",
        "                          op_idx=op_idx,\n",
        "                          log_scale=0,\n",
        "                          for_queries=1)\n",
        "import numpy as np\n",
        "import torch\n",
        "import matplotlib.pyplot as plt\n",
        "from pathlib import Path\n",
        "\n",
        "@torch.no_grad()\n",
        "def show_hist_heatmap(rpe_module,\n",
        "                      op_idx: int = 0,\n",
        "                      for_queries: bool = True,\n",
        "                      log_scale: bool = True,\n",
        "                      downsample: int = 1,\n",
        "                      dpi: int = 50,\n",
        "                      max_ticks: int = 20,\n",
        "                      save_png: Path | None = None):\n",
        "    \"\"\"\n",
        "    Render a horizontal heatmap of the cached histogram of one operator.\n",
        "\n",
        "    Args\n",
        "    ----\n",
        "    rpe_module : RelativePositionEncoding instance (must have cached_hists_q_fordebug / k_fordebug)\n",
        "    op_idx     : which operator (0 … h-1) to show.\n",
        "    for_queries: plot query‐side vs key‐side cached hist.\n",
        "    log_scale  : log10‐scale the counts for contrast.\n",
        "    downsample : integer factor ≥1 to subsample both axes before plotting.\n",
        "    dpi        : figure DPI (lower → faster).\n",
        "    max_ticks  : max number of ticks on each axis.\n",
        "    save_png   : if given, also write out a .png at 150 dpi.\n",
        "    \"\"\"\n",
        "    if rpe_module is None:\n",
        "        return\n",
        "    # 1) grab your list-of-Tensors\n",
        "    lst = (rpe_module.cached_hists_q_fordebug\n",
        "           if for_queries\n",
        "           else rpe_module.cached_hists_k_fordebug)\n",
        "    try:\n",
        "        if type(lst) == torch.Tensor:\n",
        "            assert lst.shape[0] > 0, \"Run forward pass so cached_hists_*_fordebug is filled.\"\n",
        "        else:\n",
        "            assert type(lst) == list\n",
        "            assert lst and len(lst) > 0, \"Run forward pass so cached_hists_*_fordebug is filled.\"\n",
        "    except AssertionError as e:\n",
        "        print(e)\n",
        "        return\n",
        "\n",
        "    # 2) one stack + cpu + numpy + optional log\n",
        "    if type(lst) == list:\n",
        "        hists = torch.stack(lst, dim=1).cpu().numpy()  # [P, T, bs, half_ops]\n",
        "    else:\n",
        "        hists = lst.cpu().numpy()\n",
        "    P, T, bs, half_ops = hists.shape\n",
        "    arr = hists[:, :, 0, op_idx]                   # [P, T]\n",
        "    if log_scale:\n",
        "        arr = np.log10(np.clip(arr, 1e-20, None))\n",
        "\n",
        "    # 3) transpose so shape = [T, P]\n",
        "    mat = arr.T\n",
        "\n",
        "    # 4) downsample if requested\n",
        "    if downsample > 1:\n",
        "        mat = mat[::downsample, ::downsample]\n",
        "\n",
        "    t_ds, p_ds = mat.shape\n",
        "\n",
        "    # 5) build tick values *after* downsampling\n",
        "    #    original position values\n",
        "    if hasattr(rpe_module, \"relative_positions\"):\n",
        "        pos_vals = np.asarray(rpe_module.relative_positions, dtype=float)\n",
        "        if pos_vals.shape[0] != P:\n",
        "            pos_vals = np.arange(P)\n",
        "    else:\n",
        "        pos_vals = np.arange(P)\n",
        "    pos_vals = pos_vals[::downsample]\n",
        "\n",
        "    #    original time values\n",
        "    time_vals = np.arange(T)[::downsample]\n",
        "\n",
        "    #    pick ticks so we never exceed max_ticks\n",
        "    def pick_ticks(n, vals):\n",
        "        step = max(1, n // max_ticks)\n",
        "        idx = np.arange(n)[::step]\n",
        "        labels = [f\"{v:.0f}\" for v in vals[::step]]\n",
        "        return idx, labels\n",
        "\n",
        "    xticks, xlabels = pick_ticks(p_ds, pos_vals)\n",
        "    yticks, ylabels = pick_ticks(t_ds, time_vals)\n",
        "\n",
        "    # 6) plot\n",
        "    fig, ax = plt.subplots(figsize=(p_ds/6, t_ds/8 + 1), dpi=dpi)\n",
        "    im = ax.imshow(\n",
        "        mat,\n",
        "        aspect=\"auto\",\n",
        "        origin=\"lower\",\n",
        "        interpolation=\"nearest\",\n",
        "        rasterized=True  # if SVG/PDF, this layer will be bitmap\n",
        "    )\n",
        "    fig.colorbar(im, ax=ax, fraction=0.02)\n",
        "\n",
        "    ax.set_xlabel(\"relative position j\")\n",
        "    ax.set_ylabel(\"time-step t\")\n",
        "    ax.set_title(f\"Histogram heat-map – operator {op_idx}\")\n",
        "\n",
        "    ax.set_xticks(xticks)\n",
        "    ax.set_xticklabels(xlabels, rotation=45, ha=\"right\")\n",
        "    ax.set_yticks(yticks)\n",
        "    ax.set_yticklabels(ylabels)\n",
        "\n",
        "    plt.tight_layout()\n",
        "\n",
        "    if save_png:\n",
        "        plt.savefig(save_png, dpi=150, bbox_inches=\"tight\")\n",
        "    plt.show()\n",
        "\n",
        "\n",
        "if model_rse is not None:\n",
        "    for op_idx in range(0, NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE // 2):\n",
        "        show_hist_heatmap(model_rse.relative_encodings[0],\n",
        "                          op_idx=op_idx,\n",
        "                          log_scale=0,\n",
        "                          for_queries=0)\n",
        "### Faster Plotting (TODO)\n",
        "### Print _theta_gamma for SharpenHistUpdate\n",
        "for r in model_rse.relative_encodings:\n",
        "    if r is not None:\n",
        "        # print(f'_theta_gamma = {r._theta_gamma}')\n",
        "        # Also print _current_gamma\n",
        "        torch.set_printoptions(precision=3)\n",
        "\n",
        "        print(f'_current_gamma() = {r._current_gamma(keys=False, half_ops=NUM_OPERATORS_PER_RELATIVE_ENCODING_MODULE//2)}')\n",
        "\n",
        "        print(f'_theta_gamma = {r._theta_gamma}')\n",
        "# RelativePositionCopying - visualize_cached_attention\n",
        "if model_rse is not None and hasattr(model_rse.relative_encodings[0], 'cached_attention_matrices'):\n",
        "    for i,rse in enumerate(model_rse.relative_encodings):\n",
        "\n",
        "        # print(model_rse.relative_encodings[0].cached_attention_matrices.shape) # Expected Shape: torch.Size([1, num operators/2, seq_len, seq_len+1])\n",
        "        # cam = model_rse.relative_encodings[0].cached_attention_matrices\n",
        "        if rse is None:\n",
        "            continue\n",
        "        cam = rse.cached_attention_matrices\n",
        "        print('===' * 30)\n",
        "        print('===' + f'RSE layer {i+1}' + '===')\n",
        "        print('===' * 30)\n",
        "        total_count_max = 0\n",
        "        total_count_gr_than_06 = 0\n",
        "        # print the first matrix:\n",
        "        # print(model_rse.relative_encodings[0].cached_attention_matrices[0, 0])\n",
        "        for op_idx in range(cam.shape[1]):\n",
        "            print(f'---' * 10)\n",
        "            print(f'Operator {op_idx}')\n",
        "            # print(cam[0, op_idx])\n",
        "            prob_hist = cam[0, op_idx]\n",
        "            seq_len = prob_hist.shape[0]\n",
        "            assert prob_hist.shape == (seq_len, seq_len + 1)\n",
        "            # prob_hist = prob_hist[:,:-1]\n",
        "            # assert prob_hist.shape == (seq_len, seq_len)\n",
        "            print(f'prob_hist.shape = {prob_hist.shape}')\n",
        "\n",
