    {
      "cell_type": "markdown",
      "source": [
        "# Print all tensor sizes for attributes, not just params, of model_rse recursively\n",
        "## Loop across attributes:"
      ],
      "metadata": {
        "id": "ZcpdXfJJFHs8"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "\n",
        "total_num_params = 0\n",
        "total_tensor_size = 0\n",
        "for module in model_to_use.modules():\n",
        "    for attr_name in dir(module):\n",
        "        attr = getattr(module, attr_name)\n",
        "        if torch.is_tensor(attr):\n",
        "            print(f\"Module: {type(module)}, Attribute: {attr_name}, Tensor Size:\\n\\t\\t{attr.size()}\")\n",
        "            if isinstance(attr, torch.nn.Parameter):\n",
        "                total_num_params += attr.numel()\n",
        "            total_tensor_size += attr.numel()\n",
        "        # ModuleLists and ModuleDict:\n",
        "        elif isinstance(attr, torch.nn.ModuleList) or isinstance(attr, torch.nn.ModuleDict):\n",
        "            print(f'Module: {type(module)}, Attribute: {attr_name}, ModuleList or ModuleDict: {type(attr)}')\n",
        "            for sub_module in attr:\n",
        "                for sub_attr_name in dir(sub_module):\n",
        "                    sub_attr = getattr(sub_module, sub_attr_name)\n",
        "                    if torch.is_tensor(sub_attr):\n",
        "                        print(f\"Module: {type(module)}, Attribute: {attr_name}, Sub-Module: {type(sub_module)}, Sub-Attribute: {sub_attr_name}, Tensor Size:\\n\\t\\t{sub_attr.size()}\")\n",
        "                        if isinstance(sub_attr, torch.nn.Parameter):\n",
        "                            total_num_params += sub_attr.numel()\n",
        "                        total_tensor_size += sub_attr.numel()\n",
        "print('---' * 10)\n",
        "\n",
        "print('---' * 10)\n",
        "print('---' * 100)\n",
        "print(f'Summary: total_num_params = {total_num_params}, total_tensor_size = {total_tensor_size}')"
      ],
      "metadata": {
        "id": "uChpEqH0Ft8K",
        "scrolled": true,
        "trusted": true
      },
      "outputs": [],
      "execution_count": null
