    {
      "cell_type": "markdown",
      "source": [
        "# Absolute Sinusoidal Positional Encoding"
      ],
      "metadata": {
        "id": "mxmJ-fBu-n9w"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "\n",
        "import torch\n",
        "import torch.nn as nn\n",
        "import numpy as np\n",
        "\n",
        "# Positional Encoding for Baseline Transformer\n",
        "class PositionalEncoding(nn.Module):\n",
        "    def __init__(self, d_model, max_len=MAX_SEQ_LEN):\n",
        "        super(PositionalEncoding, self).__init__()\n",
        "\n",
        "        max_len = max_len + SINUSOIDAL_ENC_SEQ_LENGTH_PADDING\n",
        "        self.encoding = positional_encoding_1d(d_model, max_len, use_asymptotically_correct_approx=False)\n",
        "\n",
        "\n",
        "        assert self.encoding.shape == (max_len, d_model)\n",
        "        self.encoding = self.encoding.unsqueeze(0)\n",
        "\n",
        "\n",
        "\n",
        "    # def forward(self, x, pos_x_shift=0):\n",
        "    #     seq_len = x.size(1)\n",
        "\n",
        "    #     return self.encoding[:, pos_x_shift:pos_x_shift+seq_len, :].to(x.device)\n",
        "    def forward(self, x, pos_x_shift=None):\n",
        "        \"\"\"\n",
        "        Forward pass for Positional Encoding with per-sequence shifts.\n",
        "\n",
        "        Args:\n",
        "            x (Tensor): Input tensor of shape [batch_size, seq_len].\n",
        "            pos_x_shift (Tensor): LongTensor of shape [batch_size] containing shifts for each sequence in the batch.\n",
        "\n",
        "        Returns:\n",
        "            Tensor: Positional encoding with shifts applied, shape [batch_size, seq_len, d_model].\n",
        "        \"\"\"\n",
        "        batch_size, seq_len = x.size()\n",
        "        encoding = self.encoding  # Extract the maximum required slice\n",
        "        assert TRAIN_BASELINE_TRANSFORMER, f'TRAIN_BASELINE_TRANSFORMER must be True for PositionalEncoding'\n",
        "\n",
        "        if pos_x_shift is None:\n",
        "            return encoding[:, :seq_len, :].to(x.device)\n",
        "\n",
        "        # print(f'Encoding shape: {encoding.shape}')\n",
        "\n",
        "        # Encoding shape: torch.Size([1, 14, 256])\n",
        "        # pos_x_shift shape: torch.Size([50])\n",
        "\n",
        "        # Create a shifted encoding for each sequence in the batch\n",
        "\n",
        "        shifted_encodings = torch.zeros((batch_size, seq_len, self.encoding.size(-1)), device=x.device)\n",
        "        with torch.no_grad():\n",
        "            # print(f'pos_x_shift shape: {pos_x_shift.shape}')\n",
        "            for i in range(batch_size):\n",
        "                shift = pos_x_shift[i].item()  # Extract shift value for the i-th sequence\n",
        "                assert shift + seq_len <= encoding.size(1), f\"Shift {shift} + sequence length {seq_len} exceeds encoding length {encoding.size(1)}\"\n",
        "                shifted_encodings[i] = encoding[0, shift:shift + seq_len, :]\n",
        "\n",
        "        return shifted_encodings\n",
        "\n"
      ],
      "metadata": {
        "id": "nMpnW0hevV5x",
        "scrolled": true,
        "trusted": true,
