      "cell_type": "code",
      "source": [
        "import torch\n",
        "\n",
        "@torch.compile(dynamic=False)\n",
        "def hist_update_v7_fast_bwd_mod_2_noslices_symmetric_padstrided_fma(\n",
        "    hist:   torch.Tensor,         # [2*seq_len+1, bs, h]\n",
        "    p_reset: torch.Tensor,        # [bs, h]\n",
        "    p_inc:   torch.Tensor,        # [bs, h]\n",
        "    p_dec:   torch.Tensor,        # [bs, h]\n",
        "    p_keep:  torch.Tensor,        # [bs, h]\n",
        "    eps:     float,\n",
        "    gamma:   torch.Tensor|float,  # scalar or [h]\n",
        "    power:   bool,\n",
        "    seq_len: int,\n",
        "    p_copy:  torch.Tensor|None = None,   # [2*seq_len+2, bs, h] or None\n",
        "):\n",
        "    L, bs, h = hist.shape\n",
        "    mid = seq_len\n",
        "\n",
        "    # per-(b,h) gates (no indexing on L)\n",
        "    inv_r  = 1.0 - p_reset\n",
        "    w_inc  = inv_r * p_inc\n",
        "    w_dec  = inv_r * p_dec\n",
        "    w_keep = inv_r * p_keep\n",
        "\n",
        "    # ---- zero-padded staging: one write + 2 boundary carries ----\n",
        "    pad = hist.new_zeros((L + 2, bs, h))\n",
        "    pad.narrow(0, 1, L).copy_(hist)          # hist → pad[1:1+L]\n",
        "    pad[0].add_(hist[0])                     # dec carry (unweighted)\n",
        "    pad[L + 1].add_(hist[L - 1])             # inc carry (unweighted)\n",
        "\n",
        "    # three neighbor views (no data movement)\n",
        "    prev = pad.narrow(0, 0, L)               # hist[i-1] (0 at i=0 + dec carry)\n",
        "    curr = pad.narrow(0, 1, L)               # hist[i]\n",
        "    nxt  = pad.narrow(0, 2, L)               # hist[i+1] (0 at i=L-1 + inc carry)\n",
        "\n",
        "    # broadcast weights once\n",
        "    w_dec_u  = w_dec.unsqueeze(0)            # [1,bs,h]\n",
        "    w_keep_u = w_keep.unsqueeze(0)\n",
        "    w_inc_u  = w_inc.unsqueeze(0)\n",
        "\n",
        "    # ---- fused 3-tap mix with FMAs (one big elementwise kernel under Inductor) ----\n",
        "    out = curr * w_keep_u\n",
        "    out = out.addcmul(prev, w_dec_u, value=1.0)\n",
        "    out = out.addcmul(nxt,  w_inc_u, value=1.0)\n",
        "\n",
        "    # ---- reset triad (three fixed rows; tiny) ----\n",
        "    pr = p_reset\n",
        "    out[mid    ].add_(pr * p_keep)\n",
        "    if mid + 1 < L: out[mid + 1].add_(pr * p_inc)\n",
        "    if mid - 1 >= 0: out[mid - 1].add_(pr * p_dec)\n",
        "\n",
        "    # ---- optional copy blend (rowwise) ----\n",
        "    if p_copy is not None:\n",
        "        pos_cols, no_copy = p_copy.split([L, 1], dim=0)  # views\n",
        "        out = out * no_copy + pos_cols\n",
        "\n",
        "    # ---- γ-sharpen (fast per-head path) ----\n",
        "    if power:\n",
        "        if isinstance(gamma, torch.Tensor) and gamma.numel() == h:\n",
        "            g_flat = gamma.to(device=hist.device, dtype=hist.dtype).repeat(bs)   # [bs*h]\n",
        "            outf = out.view(L, bs * h)\n",
        "            outf.add_(eps).pow_(g_flat.unsqueeze(0))  # broadcast along L\n",
        "            out = outf.view(L, bs, h)\n",
        "        else:\n",
        "            out = (out + eps).pow(float(gamma))\n",
        "\n",
        "    # ---- normalize ----\n",
        "    denom = out.sum(0, keepdim=True).add_(eps)\n",
        "    out = out / denom\n",
        "    return out\n"
      ],
