        "import torch\n",
        "\n",
        "import torch\n",
        "import torch.nn.functional as F\n",
        "\n",
        "@torch.compile(dynamic=False)\n",
        "def hist_update_v7_fast_bwd_mod_2_noslices_symmetric_conv1d_groups(\n",
        "    hist:   torch.Tensor,         # [2*seq_len+1, bs, h]\n",
        "    p_reset: torch.Tensor,        # [bs, h]\n",
        "    p_inc:   torch.Tensor,        # [bs, h]\n",
        "    p_dec:   torch.Tensor,        # [bs, h]\n",
        "    p_keep:  torch.Tensor,        # [bs, h]\n",
        "    eps:     float,\n",
        "    gamma:   torch.Tensor|float,  # scalar or [h]\n",
        "    power:   bool,\n",
        "    seq_len: int,\n",
        "    p_copy:  torch.Tensor|None = None,   # [2*seq_len+2, bs, h] or None\n",
        "):\n",
        "    # Shapes / aliases\n",
        "    L, bs, h = hist.shape\n",
        "    mid = seq_len\n",
        "\n",
        "    # ---- gate weights (per (b,h)) ----\n",
        "    inv_r  = 1.0 - p_reset\n",
        "    w_inc  = inv_r * p_inc           # [bs,h]\n",
        "    w_dec  = inv_r * p_dec           # [bs,h]\n",
        "    w_keep = inv_r * p_keep          # [bs,h]\n",
        "\n",
        "    # ---- build one 3-tap kernel per channel and run a single conv1d ----\n",
        "    # input -> [1, bs*h, L], weight -> [bs*h, 1, 3], groups=bs*h, padding=1 (zero-pad)\n",
        "    x = hist.permute(1, 2, 0).reshape(1, bs * h, L).contiguous()\n",
        "    w = torch.stack((w_inc, w_keep, w_dec), dim=-1).reshape(bs * h, 1, 3).contiguous()\n",
        "    y = F.conv1d(x, w, bias=None, stride=1, padding=1, groups=bs * h)  # [1, bs*h, L]\n",
        "    out = y.view(bs, h, L).permute(2, 0, 1).contiguous()               # -> [L, bs, h]\n",
        "\n",
        "    # ---- boundary \"carry\" corrections (constant-row updates; no index tensors) ----\n",
        "    out[-1] = out[-1] + (hist[-1] * w_inc)\n",
        "    out[ 0] = out[ 0] + (hist[ 0] * w_dec)\n",
        "\n",
        "    # ---- reset triad (three fixed rows) ----\n",
        "    pr = p_reset\n",
        "    out[mid    ] = out[mid    ] + (pr * p_keep)\n",
        "    if mid + 1 < L: out[mid + 1] = out[mid + 1] + (pr * p_inc)\n",
        "    if mid - 1 >= 0: out[mid - 1] = out[mid - 1] + (pr * p_dec)\n",
        "\n",
        "    # ---- optional position-copy (rowwise blend) ----\n",
        "    if p_copy is not None:\n",
        "        pos_cols, no_copy = p_copy.split([L, 1], dim=0)  # views\n",
        "        out = out * no_copy + pos_cols\n",
        "\n",
        "    # ---- gamma sharpen (fast per-head path) ----\n",
        "    if power:\n",
        "        if isinstance(gamma, torch.Tensor) and gamma.numel() == h:\n",
        "            g_flat = gamma.to(device=hist.device, dtype=hist.dtype).repeat(bs)   # [bs*h]\n",
        "            outf = out.view(L, bs * h).contiguous()\n",
        "            outf.add_(eps)\n",
        "            outf.pow_(g_flat.unsqueeze(0))   # broadcast along L\n",
        "            out = outf.view(L, bs, h)\n",
        "        else:\n",
        "            out = (out + eps).pow(float(gamma))\n",
        "\n",
        "    # ---- normalize ----\n",
        "    denom = out.sum(0, keepdim=True).add_(eps)\n",
        "    out = out / denom\n",
        "    return out\n"
      ],
