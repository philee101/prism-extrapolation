    {
      "cell_type": "markdown",
      "source": [
        "## SCAN train start"
      ],
      "metadata": {
        "id": "G_DGt6LXmcvi"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "def test_extrapolation_SCAN(extrapolation_len=2, for_model='baseline', printOutputsAndTargets=False,\n",
        "                       examples_per_sequence=1,\n",
        "                       visualize_attn_weights=False\n",
        "                       , train_set=False, n_total_examples=100,\n",
        "                            stratify_by_length=False,\n",
        "                            random_seed=3\n",
        "                       ):\n",
        "    set_purely_random_seed()\n",
        "\n",
        "    test_dataset = _create_dataset(\"scan_dataset\", num_total_examples=n_total_examples,\n",
        "\n",
        "                                  examples_per_sequence=examples_per_sequence,\n",
        "                                  max_seq_len_for_dataset=99999,\n",
        "                                   min_seq_len_for_dataset=extrapolation_len,\n",
        "                                   stratify_by_length=stratify_by_length,\n",
        "                                   scan_file_path='tasks_test_length_dl.txt' if not train_set else 'tasks_train_length_dl.txt',\n",
        "                                   random_seed=random_seed\n",
        "                                  )\n",
        "\n",
        "\"\"\"\n",
        "Pseudocode to retrieve dataset\n",
        "print('-----------------------------------------------------------------')\n",
        "print('Previewing SCAN dataset:')\n",
        "print('-----------------------------------------------------------------')\n",
        "train_dataset = _create_dataset(for_mode='scan_dataset', examples_per_sequence=1, num_total_examples=200,\n",
        "                                batch_size=30,\n",
        "                                min_seq_len_for_dataset=2, max_seq_len_for_dataset=500,\n",
        "\n",
        "\n",
        "                                scan_file_path='tasks_test_length_dl.txt')\n",
        "\n",
        "                                # scan_file_path='tasks_train_length_dl.txt')\n",
        "dataloader = DataLoader(train_dataset)\n",
        "\n",
        "print('dataset length ', len(train_dataset))\n",
        "for j, batch in enumerate(dataloader):\n",
        "    print('---' * 5)\n",
        "    for i, _ in enumerate(batch):\n",
        "        print(f'Batch {i}, example index {j}:')\n",
        "        batch = batch.squeeze(0)\n",
        "\n",
        "        print(f'batch shape = {batch.shape}')\n",
        "        print(decode_problem(batch.numpy()[0]))\n",
        "\"\"\"\n",
        "\n",
        "\n",
        "    test_loader = DataLoader(test_dataset, batch_size=1, shuffle=False)\n",
        "    assert   for_model in ['baseline', 'rse']\n",
        "\n",
        "    print('---' * 10)\n",
        "    print(f'Evaluating on extrapolation_len={extrapolation_len}, model={for_model}')\n",
        "    print('---' * 10)\n",
        "\n",
        "    if for_model == 'rse':\n",
        "        if model_baseline is not None:\n",
        "            model_baseline.to('cpu')\n",
        "        model_rse.to(device)\n",
        "        acc = evaluate(model_rse, test_loader, criterion, device,\n",
        "                       printOutputsAndTargets=printOutputsAndTargets,\n",
        "                       visualize_attn_example_index=0 if visualize_attn_weights else None,\n",
        "                       visualize_attn_layer_skip=1,\n",
        "\n",
        "                       )\n",
        "        print(f'accuracy for rse: {acc}')\n",
        "    else:\n",
        "        if model_rse is not None:\n",
        "            model_rse.to('cpu')\n",
        "        model_baseline.to(device)\n",
        "        # print(f'accuracy for baseline: {evaluate(model_baseline, test_loader, criterion, device, printOutputsAndTargets=printOutputsAndTargets)}')\n",
        "        acc = evaluate(model_baseline, test_loader, criterion, device, printOutputsAndTargets=printOutputsAndTargets)\n",
        "\n",
        "    print('---' * 10)\n",
        "    print(f'Done Evaluating on extrapolation_len={extrapolation_len}, model={for_model}')\n",
        "    print('---' * 10)\n",
        "    return acc"
      ],
      "metadata": {
        "id": "jHZbySKS4X-Q",
        "scrolled": true,
        "trusted": true
      },
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "code",
      "source": [
        "import datetime\n",
        "gc.collect( )\n",
        "torch.cuda.empty_cache()\n",
        "BATCH_SIZE  = 35\n",
        "\n",
        "max_seq_len  = 9999\n",
        "idx =   0\n",
        "while  True:\n",
        "      continue_training(num_epochs=1, optimizers_dict=optimizers_dict,\n",
        "\n",
        "\n",
        "                          max_seq_len_for_dataset=9999,\n",
        "                             examples_per_sequence=1, task='scan_dataset',\n",
        "                        min_seq_len_for_dataset=1)\n",
        "      idx +=  1\n",
        "      # Evaluate after every N steps:\n",
        "      if idx % 1000 == 0:\n",
        "          print('Evaluating...')\n",
        "          #   acc = test_extrapolation_SCAN(extrapolation_len=9999, for_model='rse', printOutputsAndTargets=True, visualize_attn_weights=0, n_total_examples=1000)\n",
        "          # acc = test_extrapolation_SCAN(extrapolation_len=9999,\n",
        "          #                               for_model='rse' if model_to_use.model_is_rse else 'baseline',\n",
        "          #                               printOutputsAndTargets=True, visualize_attn_weights=0, n_total_examples=100)\n",
        "          acc = test_extrapolation_SCAN(extrapolation_len=1,\n",
        "                        for_model='rse' if model_to_use.model_is_rse else 'baseline',\n",
        "                        printOutputsAndTargets=True, n_total_examples=100, visualize_attn_weights=0,\n",
        "                        train_set=False, random_seed=None)\n",
        "          best_results_scan[idx] = acc\n",
        "          print(f'Final acc={acc}, best acc={max(best_results_scan.values())}')\n",
        "          # Save ckp t indexed by accuracy\n",
        "\n",
        "          current_Time = datetime.datetime.now().strftime(\"%Y-%m-%d_%H-%M-%S\")\n",
        "          # save_ckpt(f'[SCAN] Model RSE iterIdx={idx}, acc={acc}.pth', for_model=model_to_use)\n",
        "          save_ckpt(f'[SCAN] Model RSE iterIdx={idx}, acc={acc}, {current_Time}.pth', for_model=model_to_use)\n",
        "\n"
      ],
      "metadata": {
        "id": "cwvHYl4u1cdc",
        "trusted": true
      },
      "outputs": [],
      "execution_count": null
    },
