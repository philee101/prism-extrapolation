    {
      "cell_type": "markdown",
      "source": [
        "## Run 5 digit addition with Profiler"
      ],
      "metadata": {
        "id": "MctGcgYcDQKI"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "save_ckpt(base_name='rse_before_running_profiler.pth', for_model=model_to_use)"
      ],
      "metadata": {
        "id": "JBAnsjwuChng",
        "trusted": true
      },
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "code",
      "source": [
        "gc.collect()\n",
        "torch.cuda.empty_cache()"
      ],
      "metadata": {
        "id": "yPT5-08K4WF8",
        "trusted": true
      },
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "code",
      "source": [],
      "metadata": {
        "id": "1Gyz6xhFjSn7",
        "trusted": true
      },
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "code",
      "source": [
        "from torch.profiler import profile, record_function, ProfilerActivity, schedule, tensorboard_trace_handler\n",
        "\n",
        "debug_profile = True\n",
        "# if you only want to profile for a few iterations:\n",
        "if debug_profile:\n",
        "    prof = profile(\n",
        "        activities=[ProfilerActivity.CPU, ProfilerActivity.CUDA],\n",
        "        # schedule=schedule(wait=1, warmup=1, active=3, repeat=1),\n",
        "        on_trace_ready=tensorboard_trace_handler(\"./runs/test\"),\n",
        "        record_shapes=True,\n",
        "        profile_memory=True,\n",
        "        with_stack=False,\n",
        "    )\n",
        "    prof.__enter__()\n",
        "\n",
        "for i in range(5):\n",
        "    print(ALLOW_X_SHIFT)\n",
        "    ALLOW_X_SHIFT = DEFAULT_ALLOWS_X_SHIFT\n",
        "    BATCH_SIZE    = 20\n",
        "    continue_training(num_epochs=1, optimizers_dict=optimizers_dict,\n",
        "                              min_seq_len_for_dataset=1,\n",
        "                      max_seq_len_for_dataset=9999,\n",
        "                                dataset_init_seed=None ,\n",
        "\n",
        "                      num_examples_per_batched_data = 1, #int(N_TOTAL_SAMPLES / BATCH_SIZE), print_losses_every_iter=None,\n",
        "                              task='addition',\n",
        "                                examples_per_sequence=1,\n",
        "                              turn_off_aux_losses=False, # Set this to True only when debugging gradients for token losses\n",
        "                              min_digits_arithmetic=1,\n",
        "                              max_digits_arithmetic=3\n",
        "\n",
        "                              )\n",
        "    if debug_profile:\n",
        "        prof.step()\n"
      ],
      "metadata": {
        "id": "Q5Su2sgPDA_-",
        "trusted": true
      },
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "code",
      "source": [
        "# stop profiling after a few steps to keep overhead down\n",
        "if debug_profile:\n",
        "    prof.__exit__(None, None, None)\n",
        "    # print a top-10 hot-spot table\n",
        "    print(prof.key_averages().table(\n",
        "        sort_by=\"cuda_time_total\", row_limit=50,\n",
        "\n",
        "    ))\n",
        "    debug_profile = False  # turn it off for the rest of training"
      ],
      "metadata": {
        "id": "FX9L-zkfDS5c",
        "trusted": true
      },
      "outputs": [],
      "execution_count": null
    },
