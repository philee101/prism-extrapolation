    {
      "cell_type": "code",
      "source": [
        "asymptotically_correct_pe_approx = None"
      ],
      "metadata": {
        "id": "XHrplxQZoewI",
        "trusted": true,
        "execution": {
          "iopub.status.busy": "2025-09-17T19:06:50.715734Z",
          "iopub.execute_input": "2025-09-17T19:06:50.715898Z",
          "iopub.status.idle": "2025-09-17T19:06:50.729561Z",
          "shell.execute_reply.started": "2025-09-17T19:06:50.715884Z",
          "shell.execute_reply": "2025-09-17T19:06:50.729011Z"
