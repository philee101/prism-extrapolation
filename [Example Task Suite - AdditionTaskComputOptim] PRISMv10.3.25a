    {
      "cell_type": "code",
      "source": [
        "import torch\n",
        "\n",
        "@torch.compile(dynamic=False)\n",
        "def hist_update_v7_fast_bwd_mod_2_noslices_expr_rewrite_with_streams(\n",
        "    hist: torch.Tensor,         # [P, bs, h]\n",
        "    p_reset: torch.Tensor,      # [bs, h]\n",
        "    p_inc: torch.Tensor,        # [bs, h]\n",
        "    p_dec: torch.Tensor,        # [bs, h]\n",
        "    p_keep: torch.Tensor,       # [bs, h]\n",
        "    p_copy: torch.Tensor|None,  # [P+1, bs, h] or [bs, h, P+1]\n",
        "    eps: float,\n",
        "    gamma: torch.Tensor|float,  # scalar or [h] (broadcast ok)\n",
        "    power: bool = True,\n",
        "):\n",
        "\n",
        "    P, bs, h = hist.shape\n",
        "    one = 1.0\n",
        "\n",
        "    # ---------- weights ----------------------------------------------------\n",
        "    inv_r = one - p_reset\n",
        "    w_inc = inv_r * p_inc\n",
        "    w_dec = inv_r * p_dec\n",
        "    w_keep = inv_r * p_keep\n",
        "\n",
        "    # Create CUDA streams for parallelizing the calculation of hist_inc, hist_dec, hist_keep\n",
        "    stream_1 = torch.cuda.Stream()\n",
        "    stream_2 = torch.cuda.Stream()\n",
        "    stream_3 = torch.cuda.Stream()\n",
        "\n",
        "    # Create events to synchronize\n",
        "    event_1 = torch.cuda.Event()\n",
        "    event_2 = torch.cuda.Event()\n",
        "    event_3 = torch.cuda.Event()\n",
        "\n",
        "    # ---------- Compute hist_inc, hist_dec, hist_keep in parallel using streams ----------\n",
        "    with torch.cuda.stream(stream_1):\n",
        "        hist_inc = hist * w_inc      # [P, bs, h]\n",
        "        event_1.record()\n",
        "\n",
        "    with torch.cuda.stream(stream_2):\n",
        "        hist_dec = hist * w_dec      # [P, bs, h]\n",
        "        event_2.record()\n",
        "\n",
        "    with torch.cuda.stream(stream_3):\n",
        "        hist_keep = hist * w_keep    # [P, bs, h]\n",
        "        event_3.record()\n",
        "\n",
        "    # Wait for streams to complete before proceeding to the next step\n",
        "    event_1.synchronize()\n",
        "    event_2.synchronize()\n",
        "    event_3.synchronize()\n",
        "\n",
        "    # Build INC & DEC shifts and reset branches in parallel using streams\n",
        "    zero_row = torch.zeros(1, bs, h, device=hist.device, dtype=hist.dtype)\n",
        "    total = 1.0  # hist.sum(0) [bs, h]\n",
        "\n",
        "    # Create new streams for shifting and reset block computation\n",
        "    stream_4 = torch.cuda.Stream()\n",
        "    stream_5 = torch.cuda.Stream()\n",
        "\n",
        "    # Create events for the new streams\n",
        "    event_4 = torch.cuda.Event()\n",
        "    event_5 = torch.cuda.Event()\n",
        "\n",
        "    # Use stream_4 for inc_shift and dec_shift\n",
        "    with torch.cuda.stream(stream_4):\n",
        "        inc_shift = torch.cat([zero_row, hist_inc[:-1]], dim=0) + torch.cat([torch.zeros_like(hist_inc[:-1]), hist_inc[-1:]], dim=0)\n",
        "        dec_shift = torch.cat([hist_dec[1:], zero_row], dim=0) + torch.cat([hist_dec[:1], torch.zeros_like(hist_dec[1:])], dim=0)\n",
        "        event_4.record()\n",
        "\n",
        "    # Use stream_5 for reset block (can run in parallel with stream_4)\n",
        "    with torch.cuda.stream(stream_5):\n",
        "        reset_block = torch.cat([\n",
        "            (total * p_reset * (p_dec + p_keep)).unsqueeze(0),  # row-0\n",
        "            (total * p_reset * p_inc).unsqueeze(0),  # row-1\n",
        "            torch.zeros(P - 2, bs, h, device=hist.device, dtype=hist.dtype)\n",
        "        ], dim=0)\n",
        "        event_5.record()\n",
        "\n",
        "    # Wait for streams to complete before proceeding to the next step\n",
        "    event_4.synchronize()\n",
        "    event_5.synchronize()\n",
        "\n",
        "    # Use stream_6 for final accumulation\n",
        "    stream_6 = torch.cuda.Stream()\n",
        "    event_6 = torch.cuda.Event()\n",
        "\n",
        "    with torch.cuda.stream(stream_6):\n",
        "        out = hist_keep + inc_shift + dec_shift + reset_block\n",
        "\n",
        "        # Sharpen + Renormalize\n",
        "        # Avoid division by zero by ensuring the denominator is not zero\n",
        "        sum_out = out.sum(0, keepdim=True).add_(eps)  # Add eps to prevent zero division\n",
        "        out = (out + eps).div_(sum_out)\n",
        "\n",
        "        # Sharpen + Renormalize\n",
        "        # if power:\n",
        "        #     out = out.pow_(gamma)\n",
        "\n",
        "        event_6.record()\n",
        "\n",
        "    # Ensure all streams are synchronized before returning the result\n",
        "    event_6.synchronize()\n",
        "\n",
        "    return out\n"
      ],
      "metadata": {
        "id": "WvcC_Jn3FWeK",
        "trusted": true,
