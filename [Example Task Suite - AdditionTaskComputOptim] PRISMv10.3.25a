    {
      "cell_type": "code",
      "source": [
        "import os\n",
        "def save_ckpt(base_name='model_ckpt', for_model=None):\n",
        "\n",
        "    # os.chdir('/kaggle/working/')\n",
        "    # os.chdir('/content/')\n",
        "    # name = f'{base_name}_rse_state_dict.pth'\n",
        "    assert for_model is not None\n",
        "    is_rse = for_model.model_is_rse\n",
        "    name = base_name\n",
        "    # if is_rse:\n",
        "    #     name = f'{base_name}_rse_state_dict.pth'\n",
        "    # else:\n",
        "    #     name = f'{base_name}_baseline_state_dict.pth'\n",
        "    torch.save(for_model.state_dict(), name)\n",
        "\n",
        "\n",
        "    cwd = os.getcwd()\n",
        "    # return full path:\n",
        "    path = os.path.join(cwd, name)\n",
        "    print(f'Saved to {path}, file size in MB = {os.path.getsize(path)/1024/1024}')\n",
        "    return path\n",
        "\n",
        "\n",
        "\n",
        "def load_ckpt(file_path, for_model):\n",
        "    # os.chdir('/content/')\n",
        "    is_rse = for_model.model_is_rse\n",
        "    if is_rse:\n",
        "        sd = torch.load(file_path, map_location=device,\n",
        "                                             weights_only=True,\n",
        "                        )\n",
        "\n",
        "        mk, uk = for_model.load_state_dict(sd,\n",
        "                                  strict=False)\n",
        "\n",
        "        print(f'loading from {file_path} for model with rse=True')\n",
        "        for_model.model_is_rse = True\n",
        "        # print(f'mk = {mk}, uk = {uk}')\n",
