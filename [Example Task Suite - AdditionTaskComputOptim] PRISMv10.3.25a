    {
      "cell_type": "markdown",
      "source": [
        "# Relative Sinusoidal Positional Encoding (RSE)"
      ],
      "metadata": {
        "id": "9FQk3MPerh3h"
      }
    },
    {
      "cell_type": "markdown",
      "source": [
        "## CustomGRU"
      ],
      "metadata": {
        "id": "18UAv2XSeW74"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import torch\n",
        "import torch.nn.functional as F\n",
        "from torch import Tensor\n",
        "from typing import Optional, Tuple\n",
        "\n",
        "@torch.jit.script\n",
        "def custom_gru_cell_static_forward(\n",
        "        x: Tensor,\n",
        "        hx: Optional[Tensor],\n",
        "        hidden_size: int,\n",
        "        weight_ih: Tensor,\n",
        "        weight_hh1: Tensor,\n",
        "        weight_hh2: Tensor,\n",
        "        weight_hh3: Tensor,\n",
        "        bias_ih: Optional[Tensor],\n",
        "        bias_hh: Optional[Tensor],\n",
        "    ) -> Tuple[Tensor, Tensor]:\n",
        "    \"\"\"\n",
        "    A JIT-able static forward for a single GRUCell whose hidden→hidden\n",
        "    weight is split into three H×H blocks (already orthonormal).\n",
        "    \"\"\"\n",
        "    # 1) initialize hidden if needed\n",
        "    if hx is None:\n",
        "        # (batch, H)\n",
        "        hx = x.new_zeros(x.size(0), hidden_size)\n",
        "\n",
        "    # 2) compute input→gates\n",
        "    #    (batch, 3H) = F.linear(x, weight_ih, bias_ih)\n",
        "    gi = F.linear(x, weight_ih, bias_ih)\n",
        "\n",
        "    # 3) build hidden→gates weight by concatenating the three orthonormal blocks\n",
        "    #    weight_hh1/2/3: each (H, H)\n",
        "    #    W_hh: (3H, H)\n",
        "    W_hh = torch.cat([weight_hh1, weight_hh2, weight_hh3], dim=0)\n",
        "\n",
        "    # 4) compute hidden→gates\n",
        "    gh = F.linear(hx, W_hh, bias_hh)\n",
        "\n",
        "    # 5) split into reset, update, and new gates\n",
        "    i_r, i_z, i_n = gi.chunk(3, dim=1)\n",
        "    h_r, h_z, h_n = gh.chunk(3, dim=1)\n",
        "\n",
        "    # 6) gate activations\n",
        "    r = torch.sigmoid(i_r + h_r)\n",
        "    z = torch.sigmoid(i_z + h_z)\n",
        "    n = torch.tanh(i_n + r * h_n)\n",
        "\n",
        "    # 7) final hidden state\n",
        "    h_new = (1.0 - z) * n + z * hx\n",
        "\n",
        "    return h_new, h_new\n"
      ],
      "metadata": {
        "id": "SXDuLtVseX2y",
        "scrolled": true,
        "trusted": true,
        "execution": {
          "iopub.status.busy": "2025-09-17T19:06:50.949613Z",
          "iopub.execute_input": "2025-09-17T19:06:50.949862Z",
          "iopub.status.idle": "2025-09-17T19:06:50.956662Z",
          "shell.execute_reply.started": "2025-09-17T19:06:50.949835Z",
          "shell.execute_reply": "2025-09-17T19:06:50.955891Z"
        }
      },
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "code",
      "source": [
        "import torch\n",
        "import torch.nn as nn\n",
        "from typing import Tuple, Optional\n",
        "\n",
        "class RMSNorm(nn.Module):\n",
        "    \"\"\"\n",
        "    RMSNorm as in https://arxiv.org/abs/1910.07467 (no bias).\n",
        "    Normalizes over the last dimension.\n",
        "    y = x / rms(x) * weight\n",
        "    \"\"\"\n",
        "    def __init__(self, dim: int, eps: float = 1e-6):\n",
        "        super().__init__()\n",
        "        self.weight = nn.Parameter(torch.ones(dim))\n",
        "        self.eps = eps\n",
        "\n",
        "    def forward(self, x: torch.Tensor) -> torch.Tensor:\n",
        "        # x: [..., dim]\n",
        "        rms = x.pow(2).mean(dim=-1, keepdim=True).add(self.eps).sqrt()\n",
        "        return (x / rms) * self.weight\n",
        "\n",
        "\n",
        "class RMSNormLSTMCell(nn.Module):\n",
        "    \"\"\"\n",
        "    LSTM cell with optional RMSNorm on:\n",
        "      - the concatenated gate preactivations (Wx x + Wh h + b),\n",
        "      - and/or the cell state c_t before tanh (like LN-LSTM variants).\n",
        "    Gate order used: (i, f, g, o) to match PyTorch convention.\n",
        "    \"\"\"\n",
        "    def __init__(\n",
        "        self,\n",
        "        input_size: int,\n",
        "        hidden_size: int,\n",
        "        bias: bool = True,\n",
        "        norm_on_gates: bool = True,\n",
        "        norm_on_cell: bool = False,\n",
        "        eps: float = 1e-6,\n",
        "    ):\n",
        "        super().__init__()\n",
        "        self.input_size = input_size\n",
        "        self.hidden_size = hidden_size\n",
        "        self.bias = bias\n",
        "        self.norm_on_gates = norm_on_gates\n",
        "        self.norm_on_cell = norm_on_cell\n",
        "\n",
        "        self.W_x = nn.Linear(input_size, 4 * hidden_size, bias=bias)\n",
        "        # No bias here (we keep bias in W_x so there is a single bias vector like the fused kernels)\n",
        "        self.W_h = nn.Linear(hidden_size, 4 * hidden_size, bias=False)\n",
        "\n",
        "        if norm_on_gates:\n",
        "            # One RMSNorm across the concatenated 4H gate preacts (simple, effective)\n",
        "            self.rms_gates = RMSNorm(4 * hidden_size, eps=eps)\n",
        "        else:\n",
        "            self.rms_gates = None\n",
        "\n",
        "        if norm_on_cell:\n",
        "            # Optional RMSNorm on the cell state before tanh\n",
        "            self.rms_cell = RMSNorm(hidden_size, eps=eps)\n",
        "        else:\n",
        "            self.rms_cell = None\n",
        "\n",
        "        # Recommended: initialize forget gate bias positive (chrono or fixed)\n",
        "        # Here: add +1.0 to the forget gate bias for longer initial memory\n",
        "        with torch.no_grad():\n",
        "            # Bias lives in W_x.bias as a 4H vector: [i, f, g, o]\n",
        "            if bias:\n",
        "                self.W_x.bias[self.hidden_size:2*self.hidden_size].add_(1.0)\n",
        "\n",
        "    @torch.compile(dynamic=False)\n",
        "    def forward(\n",
        "        self,\n",
        "        x_t: torch.Tensor,                # [B, input_size]\n",
        "        state: Tuple[torch.Tensor, torch.Tensor],  # (h_{t-1}, c_{t-1}), each [B, H]\n",
        "    ) -> Tuple[torch.Tensor, Tuple[torch.Tensor, torch.Tensor]]:\n",
        "        h_prev, c_prev = state  # [B, H], [B, H]\n",
        "\n",
        "        gates = self.W_x(x_t) + self.W_h(h_prev)  # [B, 4H]\n",
        "        if self.rms_gates is not None:\n",
        "            gates = self.rms_gates(gates)\n",
        "\n",
        "        i, f, g, o = gates.chunk(4, dim=-1)\n",
        "        i = torch.sigmoid(i)\n",
        "        f = torch.sigmoid(f)\n",
        "        o = torch.sigmoid(o)\n",
        "        g = torch.tanh(g)\n",
        "\n",
        "        c_t = f * c_prev + i * g\n",
        "        if self.rms_cell is not None:\n",
        "            # Normalize the cell before exposure\n",
        "            c_hat = self.rms_cell(c_t)\n",
        "            h_t = o * torch.tanh(c_hat)\n",
        "        else:\n",
        "            h_t = o * torch.tanh(c_t)\n",
        "\n",
        "        return h_t, (h_t, c_t)\n",
        "\n",
        "\n",
        "class RMSNormLSTM(nn.Module):\n",
        "    \"\"\"\n",
        "    A minimal LSTM stack (single direction) built from RMSNormLSTMCell.\n",
        "    Matches the (batch_first=True) API of nn.LSTM for inputs/outputs:\n",
        "      - input:  [B, T, D]\n",
        "      - output: output sequence [B, T, H], (h_n, c_n) where h_n/c_n are [num_layers, B, H]\n",
        "    Includes dropout between layers (like nn.LSTM) if num_layers > 1.\n",
        "    \"\"\"\n",
        "    def __init__(\n",
        "        self,\n",
        "        input_size: int,\n",
        "        hidden_size: int,\n",
        "        num_layers: int = 1,\n",
        "        bias: bool = True,\n",
        "        batch_first: bool = True,\n",
        "        dropout: float = 0.0,\n",
        "        norm_on_gates: bool = True,\n",
        "        norm_on_cell: bool = False,\n",
        "        eps: float = 1e-6,\n",
        "    ):\n",
        "        super().__init__()\n",
        "        assert batch_first, \"This implementation assumes batch_first=True.\"\n",
        "        self.input_size = input_size\n",
        "        self.hidden_size = hidden_size\n",
        "        self.num_layers = num_layers\n",
        "        self.batch_first = batch_first\n",
        "        self.dropout = dropout if num_layers > 1 else 0.0\n",
        "\n",
        "        layers = []\n",
        "        for layer_idx in range(num_layers):\n",
        "            in_dim = input_size if layer_idx == 0 else hidden_size\n",
        "            layers.append(\n",
        "                RMSNormLSTMCell(\n",
        "                    input_size=in_dim,\n",
        "                    hidden_size=hidden_size,\n",
        "                    bias=bias,\n",
        "                    norm_on_gates=norm_on_gates,\n",
        "                    norm_on_cell=norm_on_cell,\n",
        "                    eps=eps,\n",
        "                )\n",
        "            )\n",
        "        self.layers = nn.ModuleList(layers)\n",
        "        self.drop = nn.Dropout(self.dropout)\n",
        "\n",
        "    @torch.compile(dynamic=False)\n",
        "    def forward(\n",
        "        self,\n",
        "        x: torch.Tensor,                               # [B, T, D]\n",
        "        hx: Optional[Tuple[torch.Tensor, torch.Tensor]] = None,  # ([L, B, H], [L, B, H])\n",
        "    ) -> Tuple[torch.Tensor, Tuple[torch.Tensor, torch.Tensor]]:\n",
        "        B, T, _ = x.shape\n",
        "        if hx is None:\n",
        "            h0 = x.new_zeros(self.num_layers, B, self.hidden_size)\n",
        "            c0 = x.new_zeros(self.num_layers, B, self.hidden_size)\n",
        "        else:\n",
        "            h0, c0 = hx\n",
        "            assert h0.shape == (self.num_layers, B, self.hidden_size)\n",
        "            assert c0.shape == (self.num_layers, B, self.hidden_size)\n",
        "\n",
        "        hs_out = []\n",
        "        h_n = []\n",
        "        c_n = []\n",
        "\n",
        "        inp = x\n",
        "        for layer_idx, cell in enumerate(self.layers):\n",
        "            h_prev = h0[layer_idx]\n",
        "            c_prev = c0[layer_idx]\n",
        "            layer_outputs = []\n",
        "\n",
        "            for t in range(T):\n",
        "                h_prev, (h_prev, c_prev) = cell(inp[:, t, :], (h_prev, c_prev))\n",
        "                layer_outputs.append(h_prev)\n",
        "\n",
        "            h_seq = torch.stack(layer_outputs, dim=1)  # [B, T, H]\n",
        "            hs_out.append(h_seq)\n",
        "            h_n.append(h_prev)\n",
        "            c_n.append(c_prev)\n",
        "\n",
        "            if layer_idx < self.num_layers - 1 and self.dropout > 0:\n",
        "                inp = self.drop(h_seq)\n",
        "            else:\n",
        "                inp = h_seq\n",
        "\n",
        "        output = hs_out[-1]\n",
        "        h_n = torch.stack(h_n, dim=0)  # [L, B, H]\n",
        "        c_n = torch.stack(c_n, dim=0)  # [L, B, H]\n",
        "        return output, (h_n, c_n)\n"
      ],
      "metadata": {
