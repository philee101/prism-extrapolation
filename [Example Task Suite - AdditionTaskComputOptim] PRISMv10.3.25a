    {
      "cell_type": "code",
      "source": [
        "from re import L\n"
      ],
      "metadata": {
        "id": "MDrhe1wBZls_",
        "scrolled": true,
        "trusted": true,
        "execution": {
          "iopub.status.busy": "2025-09-17T19:06:59.371393Z",
