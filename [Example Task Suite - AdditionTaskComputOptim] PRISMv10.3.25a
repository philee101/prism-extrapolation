      "source": [
        "import torch\n",
        "import torch.nn.functional as F\n",
        "\n",
        "@torch.compile(dynamic=False)\n",
        "def hist_update_v7_fast_bwd_mod_2_noslices_symmetric_conv_new(\n",
        "    hist:   torch.Tensor,         # [2*seq_len+1, bs, h]\n",
        "    p_reset: torch.Tensor,        # [bs, h]\n",
        "    p_inc:   torch.Tensor,        # [bs, h]\n",
        "    p_dec:   torch.Tensor,        # [bs, h]\n",
        "    p_keep:  torch.Tensor,        # [bs, h]\n",
        "    eps:     float,\n",
        "    gamma:   torch.Tensor | float,  # scalar or [h]\n",
        "    power:   bool,\n",
        "    seq_len: int,\n",
        "    p_copy:  torch.Tensor | None = None,  # [2*seq_len+2, bs, h] or None\n",
        "):\n",
        "    L, bs, h = hist.shape\n",
        "    mid = seq_len\n",
        "    dev = hist.device\n",
        "    dtype = hist.dtype\n",
        "\n",
        "    # weights per (b,h) channel   (inv_r = 1 - p_reset)\n",
        "    inv_r = (1.0 - p_reset)\n",
        "    w_inc, w_keep, w_dec = inv_r * p_inc, inv_r * p_keep, inv_r * p_dec     # [bs,h] each\n",
        "\n",
        "    # ---------------------------------------------\n",
        "    # depth-wise 1D conv (groups = bs*h), replicate pad for exact clamped edges\n",
        "    # ---------------------------------------------\n",
        "    # input: (N=1, C=bs*h, L)\n",
        "    x = hist.permute(1, 2, 0).contiguous().view(1, bs * h, L)\n",
        "    x = F.pad(x, (1, 1), mode=\"replicate\")  # replicate = clamp-at-edges\n",
        "\n",
        "    # kernel per-channel: [-1, 0, +1] → [w_inc, w_keep, w_dec]\n",
        "    k = torch.stack([w_inc, w_keep, w_dec], dim=-1).reshape(bs * h, 1, 3).to(dtype)\n",
        "\n",
        "    y = F.conv1d(x, k, bias=None, stride=1, padding=0, groups=bs * h)  # (1, C, L)\n",
        "    out = y.view(bs, h, L).permute(2, 0, 1).contiguous()               # → [L, bs, h]\n",
        "\n",
        "    # ---------------------------------------------\n",
        "    # Reset triad (pre-pow, index_add_ is fine here)\n",
        "    # ---------------------------------------------\n",
        "    reset_idx  = torch.tensor((mid - 1, mid, mid + 1), device=dev)\n",
        "    reset_rows = torch.stack((p_reset * p_dec,   # −1 bin\n",
        "                              p_reset * p_keep,  #  0 bin\n",
        "                              p_reset * p_inc),  # +1 bin\n",
        "                             dim=0)              # [3, bs, h]\n",
        "    out = out.index_add(0, reset_idx, reset_rows)\n",
        "\n",
        "    # ---------------------------------------------\n",
        "    # Optional position copying (kept out-of-place)\n",
        "    # ---------------------------------------------\n",
        "    if p_copy is not None:\n",
        "        # split once; avoids select/gather on the hot path\n",
        "        pos_cols, no_copy = torch.split(p_copy, [L, 1], dim=0)  # [L,bs,h], [1,bs,h]\n",
        "        out = out * no_copy.squeeze(0) + pos_cols\n",
        "\n",
        "    # ---------------------------------------------\n",
        "    # Optional sharpening then normalize (out-of-place)\n",
        "    # ---------------------------------------------\n",
        "    if power:\n",
        "        out = (out + eps).pow(gamma)\n",
        "\n",
        "    out = out / (out.sum(0, keepdim=True) + eps)\n",
        "    return out\n"
      ],
