    {
      "cell_type": "code",
      "source": [
        "\n",
        "def _create_dataset(for_mode,\n",
        "                     max_seq_len_for_dataset=None,\n",
        "                    min_seq_len_for_dataset=None,\n",
        "                    examples_per_sequence=None,\n",
        "                    num_total_examples=10,\n",
        "                    max_digits_mult=5,\n",
        "                    min_digits_mult=2,\n",
        "                    batch_size=1,\n",
        "                    scan_file_path=None,\n",
        "                    # --- NEW CODE for stratify by length for dataset mode=='scan_dataset' ---\n",
        "                    stratify_by_length=False,\n",
        "                    # --- NEW ARGS for breadth-first traversal\n",
        "                    args_for_breadth_first={'max_depth': 2, 'max_children': 3},\n",
        "                    random_seed=None, hold_n_for_repeat_n_copy=3):\n",
        "\n",
        "  if random_seed is not None:\n",
        "      torch.manual_seed(random_seed)\n",
        "      np.random.seed(random_seed)\n",
        "      random.seed(random_seed)\n",
        "\n",
        "\n",
        "\n",
        "  if for_mode == 'multiplication' or for_mode == 'addition':\n",
        "      epb = 1\n",
        "      if examples_per_sequence is not None:\n",
        "          epb = examples_per_sequence\n",
        "      train_dataset_multiplication = ArithmeticDatasetWithBatching(num_total_examples,\n",
        "                                                                  max_digits=max_digits_mult,\n",
        "                                                                  min_digits=min_digits_mult, mode=for_mode,\n",
        "                                                      examples_per_sequence=epb, max_seq_len=None, min_seq_len=None,\n",
        "                                                                  batch_size=batch_size,\n",
        "                                                                   n_filler_for_hold_n=N_FILLER_FOR_HOLD_N,)\n",
        "      return train_dataset_multiplication\n",
        "  else:\n",
        "  # for_mode == 'token_copy' or for_mode == 'reverse' or for_mode == 'scan_dataset':\n",
        "      epb = np.random.randint(1,examples_per_sequence+1)\n",
        "      if examples_per_sequence is not None:\n",
        "          epb = examples_per_sequence\n",
        "\n",
        "      if max_seq_len_for_dataset is None:\n",
        "          max_seq_len_for_dataset = 30\n",
        "\n",
        "\n",
        "\n",
        "      train_dataset_token_copy = ArithmeticDatasetWithBatching(num_total_examples,\n",
        "                                                              max_digits=None,min_digits=None, mode=for_mode, examples_per_sequence=epb,\n",
        "                        max_seq_len=max_seq_len_for_dataset,\n",
        "                                                               min_seq_len=min_seq_len_for_dataset,\n",
        "                                                              batch_size=batch_size, scan_file_path=scan_file_path,\n",
        "                                                              stratify_by_length=stratify_by_length,\n",
        "                                                               max_children_for_bft=args_for_breadth_first['max_children'],\n",
        "                                                               max_depth_for_bft=args_for_breadth_first['max_depth'],\n",
        "                                                               min_depth_for_bft=args_for_breadth_first['min_depth'] if 'min_depth' in args_for_breadth_first else 0\n",
        "                                                               , hold_n=hold_n_for_repeat_n_copy,\n",
        "                                                               n_filler_for_hold_n=N_FILLER_FOR_HOLD_N,)\n",
        "\n",
        "\n",
        "      if examples_per_sequence is not None:\n",
        "        train_dataset_token_copy.examples_per_sequence = examples_per_sequence\n",
        "        train_dataset_token_copy.shuffle_problems_and_generate_batches()\n",
        "\n",
        "      return train_dataset_token_copy\n",
        "\n",
        "  # else:\n",
        "  #   raise Exception('Unknown mode')\n",
        "\n"
      ],
