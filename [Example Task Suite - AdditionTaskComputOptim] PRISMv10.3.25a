    },
    {
      "cell_type": "code",
      "source": [
        "# General Losses dict structure:\n",
        "# Allows to Retrieve for each of train/val:\n",
        "    # - Each list is A list of tuples\n",
        "    # - Losses: indexes the iteration index of each epoch, along with the loss, of the form [(iteration index, epoch, loss)]\n",
        "    # - extra_info_*: a list of tuples where each tuples contains an extra\n",
        "    #   info dictionary. Of the same length as train_losses_*, though also of the form\n",
        "    #   also as [(<iteration index>, <dictionary at iteration index>)]\n",
        "# Init empty list\n",
        "losses_dict_mult = {\n",
        "    'train_losses_rse': [],\n",
        "    'val_losses_rse': [],\n",
        "    'train_losses_baseline': [],\n",
        "    'val_losses_baseline': [],\n",
        "    'wall_clock_time_rse': [],\n",
        "    'wall_clock_time_baseline': [],\n",
        "    'extra_info_rse' : [],\n",
        "    'extra_info_ baseline' : []\n",
        "    }"
      ],
      "metadata": {
        "id": "e84CvSzozzzH",
        "scrolled": true,
        "trusted": true
      },
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "code",
      "source": [
        "global continue_training_mult_num_invocations\n",
        "continue_training_mult_num_invocations = 0"
      ],
      "metadata": {
        "id": "mktuCPC8YDTq",
        "scrolled": true,
        "trusted": true
      },
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "code",
      "source": [],
      "metadata": {
        "id": "EL9Wqr10AAOW",
        "scrolled": true,
        "trusted": true
      },
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "code",
      "source": [
        "import gc\n",
        "\n",
        "def continue_training_mult(max_iterations=5, num_epochs=1, optimizers_dict={},\n",
        "                      num_batches_per_epoch=50 if BATCH_SIZE == 1 else 1,\n",
        "                           min_digits=3, max_digits=5,\n",
        "                           task='multiplication',\n",
        "                           min_seq_len_for_dataset=1,\n",
        "                           max_seq_len_for_dataset=20,\n",
        "                           examples_per_sequence=1,\n",
        "                           losses_dict=None,\n",
        "                           ):\n",
        "\n",
        "    global continue_training_mult_num_invocations,MODEL_EVALUATE_MODE\n",
        "    MODEL_EVALUATE_MODE = False\n",
        "    print(f'continue_training_mult_num_invocations = {continue_training_mult_num_invocations}')\n",
        "    # gc.collect()\n",
        "    # torch.cuda.empty_cache()\n",
        "    # clear_cached_sigmoid_activation_values(model_rse)\n",
        "\n",
        "\n",
        "    if losses_dict is None:\n",
        "        losses_dict = losses_dict_mult\n",
        "\n",
        "    for epoch in range(num_epochs):\n",
        "        continue_training_mult_num_invocations += 1\n",
        "\n",
        "        # gc.collect()\n",
        "        # torch.cuda.empty_cache()\n",
        "        clear_cached_sigmoid_activation_values(model_rse)\n",
        "        print('---' * 20)\n",
        "        print(f\"Epoch {epoch+1}/{num_epochs}\")\n",
        "\n",
        "        # Rotated Adam model\n",
        "        print('---' * 10)\n",
        "        print(\"[Multiplication Task] Training RSE model with Adam optimizer...\")\n",
        "        if model_baseline is not None:\n",
        "            model_baseline.to('cpu')\n",
        "        model_rse.to(device)\n",
        "        optim_rse = optimizers_dict.get('rse', None); assert optim_rse is not None, \"optim_rse is None\"\n",
        "        # if num_batches_per_epoch > 1:\n",
        "        #     print(f'[mult train] \"num_batches_per_epoch\" of 1 chosen')\n",
        "        #     num_batches_per_epoch = 1\n",
        "\n",
        "        #   losses_dict={}, max_iterations=None, print_losses_every_iter=False, model_type='RSE'):\n",
        "        batch_sz = BATCH_SIZE\n",
        "\n",
        "        set_purely_random_seed()\n",
        "        # dataset_ = _create_dataset(task, min_digits_mult=min_digits, max_digits_mult=max_digits,\n",
        "        #                                    max_seq_len_for_dataset=max_seq_len_for_dataset,\n",
        "        #                                             min_seq_len_for_dataset=min_seq_len_for_dataset,\n",
        "        #                                             examples_per_sequence=examples_per_sequence,\n",
        "        #                                     num_total_examples = num_batches_per_epoch * batch_sz,\n",
        "        #                                     batch_size=batch_sz,\n",
        "        #                                     )\n",
        "        dataset_ = _create_dataset(for_mode='multiplication',\n",
        "                                examples_per_sequence=1,\n",
        "                                num_total_examples=num_batches_per_epoch * batch_sz,\n",
        "                                batch_size=batch_sz,\n",
        "                                min_digits_mult=min_digits,\n",
        "                                max_digits_mult=max_digits,)\n",
        "\n",
        "\n",
        "        if model_to_use.model_is_rse:\n",
        "\n",
        "\n",
        "            results = train_with_enhanced_logging(model_rse, train_dataset=dataset_,\n",
        "                                                        optimizer=optim_rse,\n",
        "                                                          latest_epoch_index=epoch,\n",
        "                                                          learning_rate=None,\n",
        "                                                          losses_dict=losses_dict, model_type='rse',\n",
        "                                                  print_losses_every_iter=None)\n",
        "            token_loss = results[1]\n",
        "            # print(f\"[Model: {'rse'}] Token Loss: {token_loss:.10f}\")\n",
        "            # Print epoch completed:\n",
        "            print('---' * 20)\n",
        "            print(f\"[Model: {'RSE'}], Task: {task}, Epoch {epoch + 1} Completed]: Token Loss: {token_loss:.10f}, max_seq_len_for_dataset = {max_seq_len_for_dataset}\")\n",
        "            print('---' * 20)\n",
        "\n",
        "\n",
        "            # print(\"Evaluating RSE model...\")\n",
        "            # val_loss_RSE = evaluate(model_RSE, valid_loader, losses_dict, model_type='rotated_adam')\n",
        "            if (epoch % 1000 == 0 and epoch > 0) or continue_training_mult_num_invocations % 500 == 0 and model_rse is not None:\n",
        "                print('Autosaving...')\n",
        "                remove_old_autosaved_files_earlier_than(hours_to_keep=10, in_directory=None)\n",
        "                saveCkptForMostRecentEpoch(losses_dict, for_model=model_rse, save_file_base_name='mult_rse')\n",
        "\n",
        "\n",
        "            # if epoch % 10 == 0:\n",
        "\n",
        "\n",
        "        # gc.collect()\n",
        "        # torch.cuda.empty_cache()\n",
        "\n",
        "        if model_baseline is not None:\n",
        "\n",
        "            # Baseline model\n",
        "            optim_baseline = optimizers_dict.get('baseline', None); assert optim_baseline is not None, \"optim_baseline is None\"\n",
        "            print(\"Training Baseline model with Adam optimizer...\")\n",
        "            if model_rse is not None:\n",
        "                model_rse.to('cpu')\n",
        "            model_baseline.to(device)\n",
        "\n",
        "            results = train_with_enhanced_logging(model_baseline, train_dataset=dataset_,\n",
        "                                                        optimizer=optim_baseline,\n",
        "                                                        latest_epoch_index=epoch,\n",
        "                                                        learning_rate=LEARNING_RATE,\n",
        "                                                        losses_dict=losses_dict,\n",
        "                                                  model_type='baseline',\n",
        "                                                  print_losses_every_iter=None)\n",
        "            token_loss = results[1]\n",
        "            print(f\"[Model: {'Baseline'}, Epoch {epoch + 1} Completed]: Token Loss: {token_loss:.15f}, max_seq_len_for_dataset = {max_seq_len_for_dataset}\")\n",
        "\n",
        "            if (epoch % 1000 == 0 and epoch > 0) or continue_training_mult_num_invocations % 500 == 0:\n",
        "                remove_old_autosaved_files_earlier_than(hours_to_keep=0.5, in_directory=None)\n",
        "                saveCkptForMostRecentEpoch(losses_dict, for_model=model_to_use, save_file_base_name='mult_rse')\n",
        "\n",
        "                print('---' * 3)\n",
        "\n",
        "        if (continue_training_mult_num_invocations % 1200 == 0):\n",
        "\n",
        "            plotAll(losses_dict)\n",
        "\n",
        "        if continue_training_mult_num_invocations % 205 == 0:\n",
        "              clear_output(wait=True)  # Clears the previous output\n",
        "\n",
        "\n",
        "    print(\"Training completed.\")\n"
      ],
      "metadata": {
        "id": "pJdqhMhUHyr3",
        "scrolled": true,
        "trusted": true
      },
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "markdown",
      "source": [
        "## evalOODOnMultiplication()"
      ],
      "metadata": {
        "id": "CswwIm9-3Fua"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "\n",
        "def run_mult_eval(num_batches, min_digits, max_digits, examples_per_sequence=1, for_model=None,\n",
        "                  printOutputsAndTargets=False):\n",
        "\n",
        "  set_purely_random_seed()\n",
        "  assert for_model is not None, \"model is None\"\n",
        "  test_dataset = _create_dataset(\"multiplication\",\n",
        "                                 min_digits_mult=min_digits, max_digits_mult=max_digits,\n",
        "                                  examples_per_sequence=examples_per_sequence,\n",
        "                                  batch_size=1,\n",
        "                                  num_total_examples=num_batches)\n",
        "\n",
        "\n",
        "  test_loader = DataLoader(test_dataset, batch_size=1, shuffle=False)\n",
        "  print('accuracy:')\n",
        "  return evaluate(for_model, test_loader, criterion, device, printOutputsAndTargets=printOutputsAndTargets,\n",
        "          visualize_attn_example_index=None)\n",
        "\n",
        "\n",
        "def evalOODOnMultiplication(maxTrainProblemSizeForLog,\\\n",
        "    ranges_to_evaluate=[(9,9), (10,10), (11,11), (12,12), (13,13), (14,14), (15,15), (16,16), (17,17)],\n",
        "                            for_model=None,\n",
        "                            best_accuracies_for_range={},\n",
        "                            printOutputsAndTargets=False,\n",
        "                            ):\n",
        "  global MODEL_EVALUATE_MODE\n",
        "  MODEL_EVALUATE_MODE = True\n",
        "\n",
        "  set_purely_random_seed()\n",
        "  assert for_model is not None, \"model is None\"\n",
        "  # gc.collect()\n",
        "  # torch.cuda.empty_cache()\n",
        "\n",
        "\n",
        "  print('---' * 50)\n",
        "  print(\"evalOODOnMultiplication()...\")\n",
        "  print('---' * 50)\n",
        "  # torch.cuda.empty_cache()\n",
        "  # gc.collect()\n",
        "  for rng in ranges_to_evaluate:\n",
        "      print('---' * 20)\n",
        "      # print(f\"Evaluating multiplication in range {str(rng)}\")\n",
        "      print(f'[Model = {\"RSE\" if for_model.model_is_rse else \"Baseline\"}]')\n",
        "      print(f\"Max train problem size so far was {maxTrainProblemSizeForLog}\")\n",
        "      print('---' * 10)\n",
        "      print(f'Running mult eval for range {str(rng)}...')\n",
        "      print('---' * 10)\n",
        "      acc = run_mult_eval(num_batches=100,\n",
        "                          min_digits=rng[0], max_digits=rng[1],\n",
        "                          examples_per_sequence=1, for_model=for_model,\n",
        "                          printOutputsAndTargets=printOutputsAndTargets)\n",
        "\n",
        "      print(f\"Accuracy for range {str(rng)}: {acc}\")\n",
        "      existing = best_accuracies_for_range.get(rng)\n",
        "      # If accuracy is less than 1%, break early:\n",
        "      if acc < 1.0:\n",
        "        print(f\"Accuracy for range {str(rng)} is less than 1%, breaking early...\")\n",
        "        break\n",
        "      if existing is None:\n",
        "          best_accuracies_for_range[rng] = acc\n",
        "      else:\n",
        "        best_accuracies_for_range[rng] = max(existing, acc)\n",
        "      if existing is None or acc > existing:\n",
        "        # save(f\"best_accuracies_for_range{str(rng)}, maxTrainProblemSize={maxTrainProblemSizeForLog}\\\n",
        "        #                                  ={acc}.pth\")\n",
        "        model_type = 'rse' if for_model.model_is_rse else 'baseline'\n",
        "        base_name = f\"[{model_type}] best_accuracies_for_range{str(rng)}={acc}, maxTrainProblemSize={maxTrainProblemSizeForLog}\"\n",
        "\n",
        "\n",
        "        save_ckpt(base_name=base_name, for_model=for_model)\n",
        "        print(f\"Best accuracy for range {str(rng)}: {best_accuracies_for_range[rng]}\")\n",
        "  print(f'Best accuracies for all ranges: {best_accuracies_for_range}')\n",
        "  print('---' * 50)"
      ],
      "metadata": {
        "id": "b-_NVkwG3JZj",
        "scrolled": true,
        "trusted": true
      },
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "code",
      "source": [
        "def eval_ood_for_model(model_, best_accs, ranges_to_evaluate=None, max_digits_mult=None, device=device,\n",
        "                       printOutputsAndTargets=False):\n",
        "\n",
        "    assert max_digits_mult is not None, \"max_digits_mult is None\"\n",
        "    if ranges_to_evaluate is None:\n",
        "        ranges_to_evaluate=[(i,i) for i in range(3, 9999)]\n",
        "    model_to_move_to_cpu = model_rse if not model_.model_is_rse else model_baseline\n",
        "    if model_to_move_to_cpu is not None:\n",
        "        model_to_move_to_cpu.to('cpu')\n",
        "    model_.to(device)\n",
        "    evalOODOnMultiplication(maxTrainProblemSizeForLog=max_digits_mult,\n",
        "                      ranges_to_evaluate=ranges_to_evaluate,\n",
        "                            best_accuracies_for_range=best_accs,\n",
        "                      for_model=model_,\n",
        "                            printOutputsAndTargets=printOutputsAndTargets)"
      ],
      "metadata": {
        "id": "BySQhRBX8Qb5",
        "scrolled": true,
        "trusted": true
      },
      "outputs": [],
      "execution_count": null
    },
