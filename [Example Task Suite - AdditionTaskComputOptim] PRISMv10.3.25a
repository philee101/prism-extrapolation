    },
    {
      "cell_type": "code",
      "source": [],
      "metadata": {
        "id": "is1D68mf5fpW",
        "trusted": true
      },
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "code",
      "source": [
        "def soft_cap_smooth(x, cap, beta):\n",
        "    # c = (1/beta) * log(1 + exp(-beta*cap)) = softplus(-cap, beta)\n",
        "    c = F.softplus(-cap, beta=beta, threshold=20.0)\n",
        "    y = x - F.softplus(x - cap, beta=beta, threshold=20.0) + c  # ensures y(0)=0\n",
        "    scale = cap / (cap + c)  # ensures y(∞) = cap\n",
        "    return scale * y"
      ],
      "metadata": {
        "id": "fdce_vU5jeTC",
        "trusted": true
      },
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "code",
      "source": [
        "# torch.set_printoptions(precision=15)\n",
        "# soft_maximum_for_alpha_coeffs(torch.tensor(2, dtype=torch.float32), torch.tensor(capAlphaCoeffs), beta=torch.tensor(POSITION_SOFTMAX_TEMP))"
      ],
      "metadata": {
        "id": "FkrBoF96X2gH"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [],
      "metadata": {
        "id": "BfIOlZxyVs30"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "import torch\n",
        "import torch.nn as nn\n",
        "import numpy as np\n",
        "\n",
        "\n",
        "\n",
        "MHA_USE_OUTPUT_LNORM = False\n",
        "SOFTMAX_TEMP_SCALING_FACTOR = 1.0 # 27.5\n",
        "# OPERATOR_Q_K_MSG_PASSING_IS_ONE_TO_ONE_MAPPING = False\n",
        "OPERATOR_Q_K_MSG_PASSING_IS_ONE_TO_ONE_MAPPING = False\n",
        "NORMALIZE_ALIGNMENT_WEIGHTS_USING_SOFTMAX = False\n",
        "USE_HIGH_DIMENSIONAL_OUTPUT_PROJECTION = False\n",
        "MHA_VALUE_TRANSFORM_ENABLED = False\n",
        "\n",
        "COEFFS_Q_MULTIPLIER = 1.0\n",
        "MHA_NORM_REGULARIZATION_ON_ATTN_SCORES_ENABLED = False # If true, applies activation norm on self-attn scores for values above a certain threshold and effectively dampens coeffs_q\n",
        "NEGATIVE_COEFFS_ALLOWED = False\n",
        "POST_QK_SCALING_FACTORS_MULTIPLIER = 1\n",
        "MHA_RELEVANCE_ENCODING_OUTPUT_DIM = LSTM_OUTPUT_QK_N_DIM\n",
        "\n",
        "ABLATE_MHA_ATTN_CALC = False\n",
        "TIME_ATTN_SCORES_BLOCK = ENABLE_CUDA_SYNCHRONIZE_TIMING_STATISTICS\n",
        "ABSOLUTE_POS_ATTN_BIAS = False\n",
        "USE_LEARNABLE_ZEROTH_PE_MHA = False\n",
        "LOG_INPUT_DEPENDENT_ALPHA_COEFF_STATS = True and VERBOSE_LOGGING\n",
        "USE_SOFTPLUS_FOR_ALPHA_COEFFS = False # Otherwise use absolute values, motivation - prevent vanishing/small gradients fo rx < 0\n",
        "\n",
        "def soft_maximum_for_alpha_coeffs(x: torch.Tensor, cap: float, beta: float = 1.0) -> torch.Tensor:\n",
        "    \"\"\"\n",
        "    Smoothly saturates at `cap` from below; equals x when x << cap and ~cap when x >> cap.\n",
        "    Uses softplus: soft_cap(x) = cap - softplus(cap - x, beta).\n",
        "    \"\"\"\n",
        "    return cap - F.softplus(cap - x, beta=beta, threshold=1.0)\n",
        "\n",
        "\n",
        "def scaled_xavier_init(module):\n",
        "    \"\"\"\n",
        "    Simple utility for custom initialization if needed.\n",
        "    \"\"\"\n",
        "    if isinstance(module , nn.Linear):\n",
        "        nn.init.xavier_uniform_(module.weight)\n",
        "        if module.bias is not None:\n",
        "            nn.init.constant_(module.bias, 0.0)\n",
        "\n",
        "class CustomLayerNorm(nn.Module):\n",
        "    def __init__(self, eps=1e-8):\n",
        "        super().__init__()\n",
        "        self.eps = eps\n",
        "\n",
        "    def forward(self, x):\n",
        "      # assert x.shape == pos_q.shape == pos_k.shape == (batch_size, self.num_heads,\n",
        "      #                                             num_operators_per_head + (1 if CONCAT_ABS_POSITION_ENCODINGS else 0),\n",
        "      #                                             seq_len, self.d_model), f'pos_q.shape = {pos_q.shape}, pos_k.shape = {pos_k.shape}, seq_len = {seq_len}, expected = {(batch_size, self.num_heads, num_operators_per_head, seq_len, self.d_model)}'\n",
        "#\n",
        "        # x is assumed to have shape [B, *, O, S, d_model]\n",
        "        # We want to normalize over dims 2 (O) and 4 (d_model)\n",
        "        mu = x.mean(dim=(2, 4), keepdim=True)\n",
        "        sigma = x.std(dim=(2, 4), keepdim=True)\n",
        "        # print(f'[CustomLN] sigmaAvg: {sigma.mean()}, sigmaMin: {sigma.min()}, sigmaMax: {sigma.max()}')\n",
        "        # Expected: [CustomLN] sigmaAvg: 0.5243927240371704, sigmaMin: 0.45587408542633057, sigmaMax: 0.5747336745262146\n",
        "\n",
        "        return (x - mu) / (sigma + self.eps)\n",
        "\n",
        "# In your attention forward (after v = v_linear(x) and reshape [B,T,H,D]):\n",
        "def norm_rms(x, cap, eps=1e-6):\n",
        "    # x: [..., D]\n",
        "    rms = x.pow(2).mean(dim=-1, keepdim=True).sqrt()\n",
        "    scale = (cap / (rms + eps))#.clamp(max=1.0)\n",
        "    return x * scale\n",
        "\n",
        "class MultiHeadAttention_ScalarPos(nn.Module):\n",
        "    # <MHA.init()>\n",
        "    def __init__(self, d_model, num_heads, head_dim=None,\n",
        "                 num_upstream_operators=None, upstream_rotation_matrices=None,\n",
        "\n",
        "                 ):\n",
        "        \"\"\"\n",
        "        Args:\n",
        "            d_model (int): Model dimension.f\n",
        "            num_heads (int): Number of self-attention heads.\n",
        "            head_dim (int, optional): Dimension per head. If None, head_dim = d_model // num_heads.\n",
        "            num_upstream_operators (int): Total number of upstream RPSE operators.\n",
        "            upstream_rotation_matrices (Tensor): [num_upstream_operators, d_model, d_model]\n",
        "        \"\"\"\n",
        "\n",
        "        super(MultiHeadAttention_ScalarPos, self).__init__()\n",
        "        if head_dim is None:\n",
        "            assert d_model % num_heads == 0, \"d_model must be divisible by num_heads\"\n",
        "            head_dim = d_model // num_heads\n",
        "            self.has_custom_head_dim = False\n",
        "        else:\n",
        "            self.has_custom_head_dim = True\n",
        "\n",
        "\n",
        "\n",
        "        self.custom_ln = CustomLayerNorm()\n",
        "        self.d_model = d_model\n",
        "        self.num_heads = num_heads\n",
        "        self.head_dim = head_dim\n",
        "        self.num_upstream_operators = num_upstream_operators\n",
        "\n",
        "        # In the RPSE case we do not use learned q_linear and k_linear.\n",
        "\n",
        "        self.q_linear = nn.Identity()\n",
        "        self.k_linear = nn.Identity()\n",
        "\n",
        "        # For values, we always use a learned projection.\n",
        "        # self.v_linear = nn.Linear(d_model, num_heads * head_dim)\n",
        "\n",
        "        if not VALUE_VECTORS_USE_HEAD_DIM_CONCATENATION_TO_MATCH_VOCAB_DIM:\n",
        "            self.v_linear = nn.Linear(VOCAB_N_DIM_, num_heads * VOCAB_N_DIM)\n",
        "        else:\n",
        "            self.v_linear = nn.Linear(VOCAB_N_DIM, VOCAB_N_DIM)\n",
        "            assert VOCAB_N_DIM_ % num_heads == 0, f'VOCAB_N_DIM: {VOCAB_N_DIM}, num_heads: {num_heads}'\n",
        "        self.v_linear.apply(scaled_xavier_init)\n",
        "\n",
        "        #\n",
        "        # --- Output projection parameters: Two cases ---\n",
        "        #\n",
        "        # Case 1: Standard MHA output projection by-head: [num_heads, head_dim, d_model].\n",
        "        # Case 2: High-dimensional approach (flattened heads): [num_heads * head_dim, d_model].\n",
        "        #\n",
        "        if USE_HIGH_DIMENSIONAL_OUTPUT_PROJECTION:\n",
        "            # (TODO) If True, the output projection has shape [num_heads * head_dim, d_model]\n",
        "            # and acts on all heads at once. No per-head summation is performed.\n",
        "            assert not VALUE_VECTORS_USE_HEAD_DIM_CONCATENATION_TO_MATCH_VOCAB_DIM\n",
        "\n",
        "            self.head_projections = nn.Parameter(\n",
        "                torch.empty(num_heads * VOCAB_N_DIM, VOCAB_N_DIM_)\n",
        "            )\n",
        "            nn.init.xavier_uniform_(self.head_projections.T)\n",
        "            self.head_proj_bias = nn.Parameter(torch.zeros(VOCAB_N_DIM_))\n",
        "        # elif VALUE_VECTORS_USE_HEAD_DIM_CONCATENATION_TO_MATCH_VOCAB_DIM:\n",
        "            # self.head_projections = nn.Parameter(torch.empty(num_heads, VOCAB_N_DIM, VOCAB_N_DIM // num_heads))\n",
        "        elif VALUE_VECTORS_USE_HEAD_DIM_CONCATENATION_TO_MATCH_VOCAB_DIM:\n",
        "            self.head_projections = nn.Parameter(torch.empty(VOCAB_N_DIM, VOCAB_N_DIM))\n",
        "            nn.init.xavier_uniform_(self.head_projections.T)\n",
        "            self.head_proj_bias = nn.Parameter(torch.zeros(VOCAB_N_DIM))\n",
        "\n",
        "        else:\n",
        "            # The typical approach: separate projection for each head, then sum over heads.\n",
        "            self.head_projections = nn.Parameter(torch.empty(num_heads, VOCAB_N_DIM, VOCAB_N_DIM))\n",
        "            # Xavier init\n",
        "            for i in range(num_heads):\n",
        "                nn.init.xavier_uniform_(self.head_projections[i])\n",
        "\n",
        "            self.head_proj_bias = nn.Parameter(torch.zeros(num_heads, VOCAB_N_DIM))\n",
        "\n",
        "        if RelativeEncodingLSTMHiddenOutputsRelevanceEncoding_IS_ENABLED:\n",
        "            self.alignment_matrices_Q = nn.Parameter(torch.empty(num_upstream_operators // 2, LSTM_OUTPUT_QK_N_DIM, MHA_RELEVANCE_ENCODING_OUTPUT_DIM))\n",
        "            self.alignment_matrices_K = nn.Parameter(torch.empty(num_upstream_operators // 2, LSTM_OUTPUT_QK_N_DIM, MHA_RELEVANCE_ENCODING_OUTPUT_DIM))\n",
        "            self.alignMatrixBiasQ = nn.Parameter(torch.zeros(num_upstream_operators // 2, MHA_RELEVANCE_ENCODING_OUTPUT_DIM))\n",
        "            self.alignMatrixBiasK = nn.Parameter(torch.zeros(num_upstream_operators // 2, MHA_RELEVANCE_ENCODING_OUTPUT_DIM))\n",
        "\n",
        "\n",
        "            for i in range(self.num_upstream_operators // 2):\n",
        "                nn.init.xavier_uniform_(self.alignment_matrices_Q[i].T)\n",
        "                nn.init.xavier_uniform_(self.alignment_matrices_K[i].T)\n",
        "\n",
        "        # MARK: Direct Sum of RPE into separate streams of num_operators:\n",
        "        # Initialize the learned coefficients for the positional encoding.\n",
        "        # Previously we had half_ops = num_upstream_operators // 2.\n",
        "        # Now, we want one extra channel for the absolute encoding.\n",
        "        # half_ops = num_upstream_operators // 2\n",
        "        # new_half_ops = half_ops + 1  # extra absolute channel\n",
        "\n",
        "        assert (self.num_upstream_operators // 2) % self.num_heads == 0, f'self.num_upstream_operators // 2: {self.num_upstream_operators // 2}, self.num_heads: {self.num_heads}'\n",
        "        num_operators_per_head = self.num_ops_per_head()\n",
        "        new_half_ops = num_operators_per_head\n",
        "\n",
        "        std_dev = 10.0\n",
        "        pos_coeffs_Q = nn.Parameter(torch.abs(torch.randn(num_heads, new_half_ops))) * std_dev\n",
        "        # DIVIDE by sum:\n",
        "        # pos_coeffs_Q.data.div_(pos_coeffs_Q.sum(dim=-1, keepdim=True) + 1e-8)\n",
        "        # NORMALIZE USING SOFTMAX:\n",
        "        # pos_coeffs_Q.data = torch.softmax(pos_coeffs_Q.data, dim=-1)\n",
        "        # Divide by COEFFS_Q_MULTIPLIER:\n",
        "        pos_coeffs_Q.data = pos_coeffs_Q.data / COEFFS_Q_MULTIPLIER\n",
        "        # self.pos_coeffs_Q = pos_coeffs_Q.to(device)\n",
        "        self.pos_coeffs_Q = nn.Parameter(pos_coeffs_Q.to(device))\n",
        "        if CONCAT_ABS_POSITION_ENCODINGS:\n",
        "            # Set last coefficient equal to 0.05:\n",
        "            pos_coeffs_Q.data[:, -1] = 0.05\n",
        "        self.pos_coeffs_K = nn.Parameter(torch.abs(torch.randn(num_heads, new_half_ops))) * std_dev\n",
        "        # NORMALIZE USING SOFTMAX:\n",
        "        # self.pos_coeffs_K.data = torch.softmax(self.pos_coeffs_K.data, dim=-1)\n",
        "\n",
        "        # Exp scaling factors:\n",
        "        # self.post_scaling_factors_QK = nn.Parameter(torch.ones(num_heads, new_half_ops) / POST_QK_SCALING_FACTORS_MULTIPLIER)\n",
        "        post_scaling_factors_QK = (torch.randn(num_heads, self.num_ops_per_head(base_ops_only=False)) * 1.0)\n",
        "        # Normalize to init_norm norm:\n",
        "        init_norm = 0.01 / POST_QK_SCALING_FACTORS_MULTIPLIER\n",
        "        post_scaling_factors_QK = (post_scaling_factors_QK / (post_scaling_factors_QK.norm(p=2, dim=-1, keepdim=True) + 1e-8)) * init_norm\n",
        "\n",
        "\n",
        "        if CONCAT_ABS_POSITION_ENCODINGS:\n",
        "            # Set last coefficient equal to 0.01:\n",
        "            if hasattr(self, 'post_scaling_factors_QK'):\n",
        "                post_scaling_factors_QK.data[:, -1] = 0.000 / POST_QK_SCALING_FACTORS_MULTIPLIER\n",
        "\n",
        "\n",
        "        # <Input-Dependent Gamma+Alpha coefficients>\n",
        "        # -- new: projection from pooled context → H*O raw logits--\n",
        "        num_ops = self.num_ops_per_head(base_ops_only=False)\n",
        "        self.post_scale_proj = nn.Linear(VOCAB_N_DIM, num_heads * num_ops)\n",
        "        nn.init.xavier_uniform_(self.post_scale_proj.weight)\n",
        "        nn.init.zeros_(self.post_scale_proj.bias)\n",
        "        self._num_heads_times_ops = self.post_scale_proj.out_features  # = H * O\n",
        "\n",
        "        self.post_scaling_factors_QK = nn.Parameter(post_scaling_factors_QK / POST_QK_SCALING_FACTORS_MULTIPLIER)\n",
        "\n",
        "\n",
        "        self.max_len = MAX_SEQ_LEN  # or another maximum length\n",
        "        abs_enc = positional_encoding_1d(self.d_model, MAX_SEQ_LEN + SINUSOIDAL_ENC_SEQ_LENGTH_PADDING,\n",
        "                                         use_asymptotically_correct_approx=True)  # [max_len, d_model]\n",
        "        # self.abs_enc = abs_enc.to(device)\n",
        "        self.abs_enc = abs_enc.to(device)\n",
        "\n",
        "        if Input_Dependent_Alpha_Coeffs:\n",
        "\n",
        "            input_dim_for_alpha_proj = VOCAB_N_DIM\n",
        "            # total number of α’s we need = H * O\n",
        "            total_alpha = self._num_heads_times_ops\n",
        "\n",
        "            # a single‐layer MLP that takes [bs, H*value_dim] → [bs, H*O]\n",
        "            # self.alpha_proj = nn.Linear(self.num_heads * value_dim, total_alpha)\n",
        "            # self._alpha_proj = nn.Linear(value_dim, total_alpha)\n",
        "\n",
        "            parameter_tensor_for_alpha_proj = torch.randn(input_dim_for_alpha_proj, total_alpha)\n",
        "            # Normalize to norm 1/sqrt(<input_dim_for_alpha_proj>):\n",
        "            for i in range(total_alpha):\n",
        "                parameter_tensor_for_alpha_proj[:, i] = parameter_tensor_for_alpha_proj[:, i] / (torch.norm(parameter_tensor_for_alpha_proj[:, i]))\n",
        "                parameter_tensor_for_alpha_proj[:, i] /= (input_dim_for_alpha_proj ** 0.5)\n",
        "                assert torch.allclose(torch.norm(parameter_tensor_for_alpha_proj[:, i]), 1/(input_dim_for_alpha_proj ** 0.5) * torch.ones_like(parameter_tensor_for_alpha_proj[:, i])), \\\n",
        "                    f'torch.norm(parameter_tensor_for_alpha_proj[:, i]) = {torch.norm(parameter_tensor_for_alpha_proj[:, i])}, expected = {1/(input_dim_for_alpha_proj ** 0.5) * torch.ones_like(parameter_tensor_for_alpha_proj[:, i])}'\n",
        "\n",
        "            self._alpha_proj = nn.Parameter(parameter_tensor_for_alpha_proj)\n",
        "            alpha_proj_bias = torch.rand(total_alpha) * 1e-3\n",
        "            self._alpha_proj_bias = nn.Parameter(alpha_proj_bias)\n",
        "            self._input_proj_for_alpha_proj = nn.Linear(input_dim_for_alpha_proj, input_dim_for_alpha_proj, bias=True)\n",
        "\n",
        "\n",
        "\n",
        "        # MARK: scalar posEnc via curveFit of SPE innerProd responseFunction\n",
        "\n",
        "\n",
        "\n",
        "        # Additional learnable temperature for final attention softmax per head.\n",
        "\n",
        "        # For potential visualization:\n",
        "        self.attn_weights = []\n",
        "        # self.output_lnorm = nn.LayerNorm(normalized_shape=d_model, elementwise_affine=False, bias=False)\n",
        "        self.output_lnorm = nn.LayerNorm(VOCAB_N_DIM_)\n",
        "\n",
        "        # MARK: v_linear+lstmContextTransform\n",
        "        # self.value_context_transform_map = nn.Linear(VOCAB_N_DIM * 2, VOCAB_N_DIM)\n",
        "        if MHA_VALUE_TRANSFORM_ENABLED:\n",
        "            self.value_context_transform_map = nn.Parameter(torch.empty(self.num_heads, VOCAB_N_DIM * 2, VOCAB_N_DIM))\n",
        "            for i in range(self.num_heads):\n",
        "                nn.init.xavier_uniform_(self.value_context_transform_map[i].T)\n",
        "\n",
        "            self.l_prenorm_for_value_context_transform = nn.LayerNorm(VOCAB_N_DIM * 2)\n",
        "            self.value_context_transform_bias = nn.Parameter(torch.zeros(self.num_heads, VOCAB_N_DIM))\n",
        "        # self.value_context_transform_map.apply(scaled_xavier_init)\n",
        "        self.cached_scores_for_norm_reg = None\n",
        "\n",
        "        if copyRelViaAbsPos:\n",
        "            # One per operator\n",
        "            # self.coeffsForAttenBias = nn.Parameter(torch.ones(self.num_ops_per_head(base_ops_only=True)))\n",
        "            # assert attentional_bias.shape == (batch_size, self.num_heads, seq_len, seq_len), f'attentional_bias.shape = {attentional_bias.shape}, expected = (batch_size, self.num_heads, seq_len, seq_len)'\n",
        "            self.coeffsForAttenBias_ = nn.Parameter(torch.ones(self.num_heads, self.num_ops_per_head(base_ops_only=True)))\n",
        "\n",
        "\n",
        "        # --- distance-based negative bias ---------------------------------\n",
        "        # maps token embedding → one scalar coeff per head\n",
        "        if ABSOLUTE_POS_ATTN_BIAS:\n",
        "            # self.dist_bias_proj__ = nn.Linear(VOCAB_N_DIM, self.num_heads)\n",
        "            # fan_in = VOCAB_N_DIM\n",
        "            # nn.init.normal_(self.dist_bias_proj__.weight, mean=0.0,\n",
        "            #     std=1.0 / math.sqrt(fan_in))\n",
        "\n",
        "            # nn.init.zeros_(self.dist_bias_proj__.bias)\n",
        "            # self.dist_logit = nn.Parameter(torch.randn(num_heads) * 1e-2)\n",
        "\n",
        "            # --- distance-bias parameters (per head) -------------------------------\n",
        "            bias_dim   = 1920                          # D\n",
        "\n",
        "\n",
        "            target_std = 0.0045                                  # desired σ(dot)\n",
        "\n",
        "            # For u,v ~ 𝒩(0, σ²)  ⇒  Var(u·v) = D · σ⁴\n",
        "            # Choose σ so that √Var(u·v) = target_std  independent of D:\n",
        "            #     σ = (target_std² / D) ** 0.25  = √target_std · D^{-¼}\n",
        "            # v0.9998: Increase <target_std> by 25 for <lower coeff forDistBias>\n",
        "            scale = (target_std ** 0.5) / (bias_dim ** 0.25) * 30  # == 0.2236 · D^{-¼}\n",
        "\n",
        "            self.attn_dist_bias_u_ = nn.Parameter(\n",
        "                torch.randn(self.num_heads, bias_dim) * scale\n",
        "            )\n",
        "            self.attn_dist_bias_v_ = nn.Parameter(\n",
        "                torch.randn(self.num_heads, bias_dim) * scale\n",
        "            )\n",
        "\n",
        "            # NEW: scale vectors (one more pair per head)\n",
        "            #     Init with N(0,0.05) so that the *resulting* scale has stdev ≈ 0.05.\n",
        "            # self.attn_dist_scale_u = nn.Parameter(torch.randn(self.num_heads, bias_dim) * 0.05)\n",
        "            # self.attn_dist_scale_v = nn.Parameter(torch.randn(self.num_heads, bias_dim) * 0.05)\n",
        "            self.attn_dist_scale_u_ = nn.Parameter(torch.randn(self.num_heads, bias_dim) * scale)\n",
        "            self.attn_dist_scale_v_ = nn.Parameter(torch.randn(self.num_heads, bias_dim) * scale)\n",
        "\n",
        "\n",
        "        # --- per-head learnable \"zeroth-PE\" bias (positive scalar per head) ----------\n",
        "        # bias_h = softplus( <u_h> · <v_h> ), where u_h, v_h are vectors (size d_model)\n",
        "        import torch.nn.functional as F  # add at file top if not present\n",
        "\n",
        "        if USE_LEARNABLE_ZEROTH_PE_MHA:\n",
        "          self._zeroth_pe_bias_u = nn.Parameter(torch.zeros(self.num_heads, self.d_model))\n",
        "          self._zeroth_pe_bias_v = nn.Parameter(torch.zeros(self.num_heads, self.d_model))\n",
        "\n",
        "          # <RSEv0.99999c-FIXED>\n",
        "          # ---- in __init__ ----\n",
        "          # Per-head alpha for the zeroth-PE bias (static case)\n",
        "          # self.alpha_z0_head = nn.Parameter(torch.ones(self.num_heads))\n",
        "          self.alpha_z0_head_ = nn.Parameter(torch.ones(self.num_heads) * (self.d_model ** 0.5))\n",
        "\n",
        "\n",
        "          with torch.no_grad():\n",
        "              H, D = self.num_heads, self.d_model\n",
        "\n",
        "              # target: softplus(dot) ≈ sqrt(D)\n",
        "              # target_bias = (float(D) ** 0.5)\n",
        "              # target_preact = float(torch.log(torch.expm1(torch.tensor(target_bias))))  # softplus^{-1}\n",
        "              target_preact = float(D)\n",
        "\n",
        "              # 1) independent random directions (breaks symmetry)\n",
        "              # choose a moderate scale so the corrective alpha isn't huge\n",
        "              scale = 1.0 / (D ** 0.5)  # unit-variance per dot ~ O(1)\n",
        "              u = torch.randn(H, D, device=self._zeroth_pe_bias_u.device, dtype=self._zeroth_pe_bias_u.dtype) * scale\n",
        "              v = torch.randn(H, D, device=self._zeroth_pe_bias_v.device, dtype=self._zeroth_pe_bias_v.dtype) * scale\n",
        "\n",
        "              # 2) minimally adjust v along u to hit the target dot for each head\n",
        "              pre0 = (u * v).sum(dim=1, keepdim=True)                      # [H,1]\n",
        "              u_norm2 = (u * u).sum(dim=1, keepdim=True).clamp_min(1e-12)  # [H,1]\n",
        "              alpha = (target_preact - pre0) / u_norm2                     # [H,1]\n",
        "              v = v + alpha * u                                            # new dot(u,v) == target_preact\n",
        "\n",
        "              # (optional) tiny jitter to avoid exact colinearity if you like\n",
        "              v = v + 1e-4 * torch.randn_like(v)\n",
        "\n",
        "              # 3) assign\n",
        "              self._zeroth_pe_bias_u.copy_(u)\n",
        "              self._zeroth_pe_bias_v.copy_(v)\n",
        "\n",
        "\n",
        "    def num_ops_per_head(self, base_ops_only=False):\n",
        "        return num_ops_per_head(num_ops_per_layer=self.num_upstream_operators, base_ops_only=base_ops_only,\n",
        "                                num_heads=self.num_heads)\n",
        "\n",
        "\n",
        "    def get_zeroth_pe_bias_per_head(self):\n",
        "        num_heads = self.num_heads\n",
        "        device = self._zeroth_pe_bias_u.device\n",
        "        return torch.ones(num_heads, ).to(device)\n",
        "        # \"\"\"\n",
        "        # Returns a length-H vector of positive scalars:\n",
        "        #     bias_h = softplus( sum_d u[h,d] * v[h,d] )\n",
        "        # \"\"\"\n",
        "        # pre = (self._zeroth_pe_bias_u * self._zeroth_pe_bias_v).sum(dim=-1)  # [H]\n",
        "\n",
        "        # # return torch.abs(pre)\n",
        "\n",
        "        # # <sqrtFix>:\n",
        "        # return torch.abs(pre) / (float(self._zeroth_pe_bias_u.shape[-1]) ** 0.5)\n",
        "\n",
        "    def mha_compute_norm_reg_loss_for_lstm_inputs(self, lambda_reg=5e-2, norm_threshold=(MHA_RELEVANCE_ENCODING_OUTPUT_DIM ** 0.5) // 1):\n",
        "        \"\"\"\n",
        "        Computes a regularization loss based on the average L2 norm of aligned_Q_lstm and aligned_K_lstm.\n",
        "\n",
        "        Args:\n",
        "          aligned_Q_lstm (Tensor): Shape [batch_size, num_ops, seq_len, d_model].\n",
        "          aligned_K_lstm (Tensor): Same shape as aligned_Q_lstm.\n",
        "          lambda_reg (float): Regularization strength.\n",
        "\n",
        "        Returns:\n",
        "          reg_loss (Tensor): A scalar loss term.\n",
        "        \"\"\"\n",
        "        # Compute the per-element (per token) L2 norm along the last dimension,\n",
        "        # then take the average over batch, operators and time.\n",
        "        aligned_Q_lstm, aligned_K_lstm = self.latest_aligned_qk_lstm_tensors\n",
        "        bs, seq_len = aligned_Q_lstm.shape[0], aligned_Q_lstm.shape[-2]\n",
        "        num_ops = aligned_Q_lstm.shape[2]\n",
        "        # assert aligned_Q_lstm.shape == aligned_K_lstm.shape == (bs, self.num_upstream_operators, seq_len, self.d_model)\n",
        "        assert aligned_Q_lstm.shape == aligned_K_lstm.shape == (bs, self.num_heads, num_ops, seq_len, MHA_RELEVANCE_ENCODING_OUTPUT_DIM), f'aligned_Q_lstm.shape = {aligned_Q_lstm.shape}, aligned_K_lstm.shape = {aligned_K_lstm.shape}'\n",
        "\n",
        "        norm_Q = aligned_Q_lstm.norm(p=2, dim=-1, keepdim=True)\n",
        "        norm_K = aligned_K_lstm.norm(p=2, dim=-1, keepdim=True)\n",
        "        loss = torch.relu(norm_Q - norm_threshold) + torch.relu(norm_K - norm_threshold)\n",
        "        loss = loss.mean()\n",
        "        self.latest_norm_reg_loss = loss\n",
        "\n",
        "        # loss = torch.relu(avg_norm_Q - norm_threshold) + torch.relu(avg_norm_K - norm_threshold)\n",
        "        # return lambda_reg * (avg_norm_Q + avg_norm_K)\n",
        "        return lambda_reg * loss\n",
        "\n",
        "    def mha_compute_minimum_scaling_factors_QK_loss(self, lambda_reg=5e-2, max_norm=20):\n",
        "        \"\"\"\n",
        "        Computes a regularization loss based on the average L2 norm of aligned_Q_lstm and aligned_K_lstm.\n",
        "\n",
        "        \"\"\"\n",
        "        scaling_Factors_QK = self.post_scaling_factors_QK\n",
        "        assert scaling_Factors_QK.shape == (self.num_heads, self.num_ops_per_head())\n",
        "\n",
        "        min_norm = 0.5 / POST_QK_SCALING_FACTORS_MULTIPLIER\n",
        "        max_norm = max_norm #/ POST_QK_SCALING_FACTORS_MULTIPLIER\n",
        "        scaling_Factors_QK_norm = (scaling_Factors_QK * POST_QK_SCALING_FACTORS_MULTIPLIER).norm(p=2, dim=-1, keepdim=True)\n",
        "        assert scaling_Factors_QK_norm.shape == (self.num_heads, 1)\n",
        "        # loss = torch.relu(min_norm - scaling_Factors_QK_norm)\n",
        "        # loss = torch.pow(loss, 2)\n",
        "        # loss = loss.sum()\n",
        "        loss = torch.tensor(0.0, requires_grad=True, device=device)\n",
        "        loss_max = torch.relu(scaling_Factors_QK_norm - max_norm)\n",
        "        loss_max = torch.pow(loss_max, 2)\n",
        "        # loss_max = loss_max.mean()\n",
        "        loss_max = loss_max.sum()\n",
        "        loss = loss + loss_max\n",
        "        # self.latest_min_scaling_factors_QK_loss = loss\n",
        "        return lambda_reg * loss\n",
        "\n",
        "    def mha_apply_scores_matrix_norm_reg_naive(self, lambda_reg=1e-2, threshold=30.0):\n",
        "        \"\"\"\n",
        "        Apply activation norm regularization on dot product attn scores for values above a certain threshold.\n",
        "        \"\"\"\n",
        "        assert MHA_NORM_REGULARIZATION_ON_ATTN_SCORES_ENABLED, f'MHA_NORM_REGULARIZATION_ON_ATTN_SCORES_ENABLED = {MHA_NORM_REGULARIZATION_ON_ATTN_SCORES_ENABLED}'\n",
        "        if self.cached_scores_for_norm_reg is None:\n",
        "            return torch.tensor(0.0, requires_grad=True, device=device)\n",
        "        else:\n",
        "            bs, seq_len = self.cached_scores_for_norm_reg.shape[0], self.cached_scores_for_norm_reg.shape[2]\n",
        "            assert self.cached_scores_for_norm_reg.shape == (bs, self.num_heads, seq_len, seq_len)\n",
        "            # Find abs values above threshold:\n",
        "            loss = torch.relu(torch.abs(self.cached_scores_for_norm_reg) - threshold) * lambda_reg\n",
        "            self.cached_scores_for_norm_reg = None\n",
        "            return loss.sum()\n",
        "\n",
        "    def mha_apply_activation_norm_reg_simple(self, lambda_reg=1e-2, threshold=30.0):\n",
        "        \"\"\"\n",
        "        Apply activation norm regularization on dot product attn scores for values above a certain threshold.\n",
        "        \"\"\"\n",
        "        assert MHA_NORM_REGULARIZATION_ON_ATTN_SCORES_ENABLED, f'MHA_NORM_REGULARIZATION_ON_ATTN_SCORES_ENABLED = {MHA_NORM_REGULARIZATION_ON_ATTN_SCORES_ENABLED}'\n",
        "        # Use relu to find the l2 loss:\n",
        "        if self.cached_scores_for_norm_reg is None:\n",
        "            return torch.tensor(0.0, requires_grad=True, device=device)\n",
        "        else:\n",
        "            bs, seq_len = self.cached_scores_for_norm_reg.shape[0], self.cached_scores_for_norm_reg.shape[2]\n",
        "            assert self.cached_scores_for_norm_reg.shape == (bs, self.num_heads, seq_len, seq_len)\n",
        "            # Mean center self.cached_scores_for_norm_reg:\n",
        "            cs = self.cached_scores_for_norm_reg\n",
        "            # cs = cs.view(bs, self.num_heads, -1)\n",
        "            # assert cs.shape == (bs, self.num_heads, seq_len * seq_len), f'cs.shape = {cs.shape}, seq_len = {seq_len}, expected = {(bs, self.num_heads, seq_len * seq_len)}'\n",
        "\n",
        "            # cs_mean = cs.mean(dim=-1, keepdim=True)\n",
        "            # Take the mean over the non-upper triangular elems:\n",
        "            # cs is your cached scores tensor with shape [B, H, S, S]\n",
        "            B, H, S, _ = cs.shape  # cs: [B, H, S, S]\n",
        "            mask = torch.tril(torch.ones(S, S, device=cs.device, dtype=cs.dtype))  # shape: [S, S]\n",
        "            # Expand mask for broadcasting:\n",
        "            mask = mask.unsqueeze(0).unsqueeze(0)  # shape: [1, 1, S, S]\n",
        "\n",
        "            # Multiply to zero out upper-triangular elements\n",
        "            masked_cs = cs * mask  # [B, H, S, S]\n",
        "\n",
        "            # Sum each row (along the last dimension)\n",
        "            row_sums = masked_cs.sum(dim=-1)  # shape: [B, H, S]\n",
        "\n",
        "            # For each row i, the number of valid elements is (i+1):\n",
        "            row_counts = mask.squeeze(0).squeeze(0).sum(dim=-1)  # shape: [S]\n",
        "            assert row_sums.shape == (bs, self.num_heads, seq_len), f'row_sums.shape = {row_sums.shape}, expected = (bs, self.num_heads, seq_len)'\n",
        "\n",
        "            # Now divide each row by its count. We need to reshape row_counts to [1, 1, S]:\n",
        "            row_means = row_sums / row_counts.unsqueeze(0).unsqueeze(0)\n",
        "            assert row_means.shape == (bs, self.num_heads, seq_len), f'row_means.shape = {row_means.shape}, expected = (bs, self.num_heads, seq_len)'\n",
        "\n",
        "            orig_shape = cs.shape\n",
        "            cs = cs - row_means.unsqueeze(-2)\n",
        "            assert cs.shape == orig_shape == (bs, self.num_heads, seq_len, seq_len)\n",
        "\n",
        "\n",
        "            # threshold = 30\n",
        "            # loss = torch.relu(self.cached_scores_for_norm_reg - threshold) * lambda_reg\n",
        "            # Use abs value on scores:\n",
        "            # loss = torch.relu(torch.abs(self.cached_scores_for_norm_reg) - threshold) * lambda_reg\n",
        "            loss = torch.relu(torch.abs(cs) - threshold) * lambda_reg\n",
        "\n",
        "            self.cached_scores_for_norm_reg = None\n",
        "            return loss.mean()\n",
        "\n",
        "    # @torch.compile(dynamic=False)\n",
        "    def _findPositionScores_Unoptimized(\n",
        "        self,\n",
        "        enc_q,\n",
        "        enc_k,\n",
        "        valuesForInputDependentAlphaCoeffs=None,\n",
        "        p0_q_h=None,   # [B, H, S] or None\n",
        "        p0_k_h=None    # [B, H, S] or None\n",
        "    ):\n",
        "        B, H, O = enc_q.shape[0], self.num_heads, self.num_ops_per_head(base_ops_only=False)\n",
        "        S = enc_q.shape[-2]\n",
        "        d = self.d_model\n",
        "        assert enc_q.shape == enc_k.shape == (B, H, O, S, d), f'enc_q.shape = {enc_q.shape}, enc_k.shape = {enc_k.shape}, expected = (B, H, O, S, d) = {(B, H, O, S, d)}'\n",
        "\n",
        "        # (1) base per-operator dot products\n",
        "        scores = torch.einsum(\"bhoid,bhojd->bhoij\", enc_q, enc_k)\n",
        "        total_enc_per_head = O\n",
        "\n",
        "        assert valuesForInputDependentAlphaCoeffs is not None, \"valuesForInputDependentAlphaCoeffs is None\"\n",
        "\n",
        "        # (2) per-operator alpha scaling (UNCHANGED behavior)\n",
        "        #     - dynamic path: softplus(raw) per-token, per-operator, then broadcast and multiply\n",
        "        #     - static path: abs(post_scaling_factors_QK) per-operator, no averaging\n",
        "        scores_for_norm_reg = None\n",
        "        raw_alpha_logits = None  # keep raw (non-softplus) ONLY for the dynamic zeroth-PE path\n",
        "        if VERBOSE_LOGGING:\n",
        "            assert scores.shape == (B, H, O, S, S), f'scores.shape = {scores.shape}, expected = (B, H, O, S, S)'\n",
        "\n",
        "        if Input_Dependent_Alpha_Coeffs or hasattr(self, 'post_scaling_factors_QK'):\n",
        "            ABLATE_ABSOLUTE_POS_EMBED_COEFF = False\n",
        "\n",
        "            if Input_Dependent_Alpha_Coeffs:\n",
        "                bs = valuesForInputDependentAlphaCoeffs.shape[0]\n",
        "                assert valuesForInputDependentAlphaCoeffs.shape == (bs, S, VOCAB_N_DIM)\n",
        "                # raw = self._alpha_proj(valuesForInputDependentAlphaCoeffs)                 # [B, S, H*O]\n",
        "                # alpha_proj shape -> (input_dim_for_alpha_proj, total_alpha)\n",
        "\n",
        "                valuesForInputDependentAlphaCoeffs = valuesForInputDependentAlphaCoeffs / valuesForInputDependentAlphaCoeffs.norm(dim=-1, keepdim=True)\n",
        "                valuesForInputDependentAlphaCoeffs = self._input_proj_for_alpha_proj(valuesForInputDependentAlphaCoeffs)\n",
        "                assert self._alpha_proj.shape == (VOCAB_N_DIM, self._num_heads_times_ops), f'alpha_proj.shape = {alpha_proj.shape}, expected = (VOCAB_N_DIM, self._num_heads_times_ops)'\n",
        "\n",
        "                raw = torch.einsum(\"bsd,da->bsa\", valuesForInputDependentAlphaCoeffs, self._alpha_proj)  # [B, S, H*O]\n",
        "                assert self._alpha_proj_bias.shape == (self._num_heads_times_ops,)\n",
        "                raw = raw + self._alpha_proj_bias\n",
        "\n",
        "                # raw_alpha_logits = raw                                                     # raw (non-exponentiated)\n",
        "                O_chk = self._num_heads_times_ops // self.num_heads\n",
        "                assert raw.shape == (B, S, self._num_heads_times_ops) and O_chk == total_enc_per_head\n",
        "\n",
        "                # raw = torch.abs(raw)\n",
        "                if USE_SOFTPLUS_FOR_ALPHA_COEFFS:\n",
        "                    dyn_scales = torch.nn.functional.softplus(raw).view(B, S, H, O_chk)       # [B,S,H,O]\n",
        "                else:\n",
        "                    dyn_scales = torch.abs(raw).view(B, S, H, O_chk)                           # [B,S,H,O]\n",
        "                scaling_f = dyn_scales.unsqueeze(-1).permute(0, 2, 3, 1, 4)               # [B,H,O,S,1]\n",
        "                if VERBOSE_LOGGING:\n",
        "                    assert scaling_f.shape == (B, H, O, S, 1), f'scaling_f.shape = {scaling_f.shape}, expected = (B, H, O, S, 1)'\n",
        "                    assert O_chk == O, f'O_chk = {O_chk}, O = {O}'\n",
        "                if LOG_INPUT_DEPENDENT_ALPHA_COEFF_STATS:\n",
        "                    print(f'[MHA Input_Dependent_Alpha_Coeffs] max alphaCoeff={torch.max(raw)}, avg={torch.mean(raw)}, min={torch.min(raw)}, std={torch.std(raw)}')\n",
        "\n",
        "                min_scale = 0.001; dyn_scales = dyn_scales + min_scale\n",
        "\n",
        "            else:\n",
        "                # STATIC alphas: exact previous behavior — per-operator, abs(), no averaging\n",
        "                post_scaling_factors_QK_unsq = self.post_scaling_factors_QK.unsqueeze(-1).unsqueeze(-1)  # [H,O,1,1]\n",
        "                if not NEGATIVE_COEFFS_ALLOWED:\n",
        "                    post_scaling_factors_QK_unsq = torch.abs(post_scaling_factors_QK_unsq)\n",
        "                post_scaling_factors_QK_unsq = post_scaling_factors_QK_unsq * POST_QK_SCALING_FACTORS_MULTIPLIER\n",
        "                scaling_f = post_scaling_factors_QK_unsq.unsqueeze(0)                      # [1,H,O,1,1]\n",
        "\n",
        "            # multiply per-operator, then (optionally) keep a copy for norm reg\n",
        "            scores = scores * scaling_f                                                    # [B,H,O,S,S] × [...]\n",
        "            if MHA_NORM_REGULARIZATION_ON_ATTN_SCORES_ENABLED:\n",
        "                scores_for_norm_reg = scores * scaling_f if Input_Dependent_Alpha_Coeffs else scores.clone()\n",
        "        else:\n",
        "            scores_for_norm_reg = None\n",
        "\n",
        "        # (3) sum over operators (UNCHANGED)\n",
        "        assert scores.shape == (B, H, O, S, S)\n",
        "        scores = torch.sum(scores, dim=2)  # -> [B, H, S, S]\n",
        "        if MHA_NORM_REGULARIZATION_ON_ATTN_SCORES_ENABLED and (scores_for_norm_reg is not None):\n",
        "            scores_for_norm_reg = torch.sum(scores_for_norm_reg, dim=2)\n",
        "\n",
        "        # (4) zeroth-PE bias (with ALPHA COUPLING), added BEFORE normalization\n",
        "        #     delta_z0 = b(h) * [ alpha_row(B,H,S)*p0_q(B,H,S) (broadcast over j)\n",
        "        #                        + alpha_col(B,H,S)*p0_k(B,H,S) (broadcast over i) ]\n",
        "        if USE_LEARNABLE_ZEROTH_PE_MHA and (p0_q_h is not None) and (p0_k_h is not None):\n",
        "            # per-head nonnegative magnitude from u·v (kept like before)\n",
        "            b_per_head = self.get_zeroth_pe_bias_per_head().to(scores.dtype)              # [H] ≥ 0\n",
        "            b_broadcast = b_per_head.view(1, H, 1, 1)                                     # [1,H,1,1]\n",
        "\n",
        "            # --- alpha coupling for zeroth-PE (NO averaging over operators) -----------\n",
        "            if Input_Dependent_Alpha_Coeffs and hasattr(self, \"_alpha_proj_z0\"):\n",
        "                # raw, non-exponentiated per-token per-head alpha\n",
        "                raw_z0 = self._alpha_proj_z0(valuesForInputDependentAlphaCoeffs)          # [B, S, H]\n",
        "                # reshape to row/col forms\n",
        "                alpha_row = raw_z0.permute(0, 2, 1).unsqueeze(-1)                         # [B,H,S,1]\n",
        "                alpha_col = raw_z0.permute(0, 2, 1).unsqueeze(-2)                         # [B,H,1,S]\n",
        "            else:\n",
        "                # STATIC per-head alpha, ABS unless negatives allowed\n",
        "                alpha_h = self.alpha_z0_head_\n",
        "                if not NEGATIVE_COEFFS_ALLOWED:\n",
        "                    alpha_h = torch.abs(alpha_h)\n",
        "                zeroth_pe_quadratic_term_setting = False\n",
        "                alpha_row = alpha_h.view(1, H, 1, 1).expand(B, H, S, 1) ** (0.5 if not zeroth_pe_quadratic_term_setting else 1.0)                   # [B,H,S,1]\n",
        "                alpha_col = alpha_h.view(1, H, 1, 1).expand(B, H, 1, S) ** (0.5 if not zeroth_pe_quadratic_term_setting else 1.0)                   # [B,H,1,S]\n",
        "\n",
        "            # p0 probs to row/col\n",
        "            row = p0_q_h.unsqueeze(-1)                                                    # [B,H,S,1]\n",
        "            col = p0_k_h.unsqueeze(-2)                                                    # [B,H,1,S]\n",
        "\n",
        "            delta_z0 = b_broadcast * (alpha_row * row + alpha_col * col)                  # [B,H,S,S]\n",
        "\n",
        "            print(f'[MHA get_zeroth_pe_bias_per_head] max delta_z0 = {torch.max(delta_z0)}, avg delta_z0 = {torch.mean(delta_z0)}, min delta_z0 = {torch.min(delta_z0)}, min col = {torch.min(col)}, max col = {torch.max(col)}, avg col = {torch.mean(col)}, min row = {torch.min(row)}, max row = {torch.max(row)}, avg row = {torch.mean(row)}')\n",
        "            scores = scores + delta_z0\n",
        "\n",
        "        # (5) final normalization by √(O*d + d_model)  (bias channel included)\n",
        "\n",
        "        # new_dim = (total_enc_per_head * d + self.d_model)\n",
        "        new_dim = (total_enc_per_head * (PE_VECTOR_NORM_FOR_INNER_PROD_POSITION_SCORES ** 2)) + self.d_model\n",
        "        scores = scores / (new_dim ** 0.5)\n",
        "\n",
        "\n",
        "        scores = scores * POSITION_SOFTMAX_TEMP\n",
        "        position_scores = scores\n",
        "\n",
        "        # if MHA_NORM_REGULARIZATION_ON_ATTN_SCORES_ENABLED and scores_for_norm_reg is not None:\n",
        "        #     scores_for_norm_reg = scores_for_norm_reg / (new_dim ** 0.5)\n",
        "\n",
        "        return scores, position_scores, None\n",
        "\n",
        "\n",
        "\n",
        "    # MHA.forward()\n",
        "    # @torch.compile(dynamic=False)\n",
        "    def forward(self, query, key, value, position_stream=None, mask=None,\n",
        "                lstm_output_for_value_context_transform=None, valuesForInputDependentAlphaCoeffs=None):\n",
        "\n",
        "\n",
        "        batch_size = query.size(0)\n",
        "        seq_len = query.size(1)\n",
        "        Q_exp, K_exp = None, None\n",
        "        assert query.shape == (batch_size, seq_len, VOCAB_N_DIM_), f'query.shape = {query.shape}, key.shape = {key.shape}, value.shape = {value.shape}'\n",
        "\n",
        "\n",
        "        # if USE_LEARNABLE_ZEROTH_PE_MHA: # sanity checks\n",
        "            # --- debug: compact per-head list of zeroth-PE biases ------------------------\n",
        "            # if not hasattr(self, \"_printed_zeroth_head_bias\") or self._printed_zeroth_head_bias < 3:\n",
        "            #     b = self.get_zeroth_pe_bias_per_head().detach().cpu().tolist()\n",
        "            #     print(\"[zeroth-PE per-head bias] \" + \", \".join(f\"h{h}:{v:.3f}\" for h, v in enumerate(b))\n",
        "            #           + f\"  (√D={self.d_model**0.5:.3f})\")\n",
        "            #     self._printed_zeroth_head_bias = getattr(self, \"_printed_zeroth_head_bias\", 0) + 1\n",
        "\n",
        "\n",
        "        scores = None\n",
        "        lstm_output_q = None; lstm_output_k = None\n",
        "\n",
        "        assert position_stream is not None, \"Model RSE MHA: Position stream must be provided for this configuration.\"\n",
        "        num_operators_per_head = self.num_ops_per_head(base_ops_only=True)\n",
        "\n",
        "        V = self.v_linear(value)\n",
        "\n",
        "\n",
        "\n",
        "        if not VALUE_VECTORS_USE_HEAD_DIM_CONCATENATION_TO_MATCH_VOCAB_DIM:\n",
        "            V = V.view(batch_size, seq_len, self.num_heads, VOCAB_N_DIM).transpose(1, 2)\n",
        "        else:\n",
        "            V = V.view(batch_size, seq_len, self.num_heads, VOCAB_N_DIM // self.num_heads).transpose(1, 2)\n",
        "\n",
        "        \"\"\"\n",
        "        valueVectorLNorm:\n",
        "        apply norm_rms with signature (x, cap, eps=1e-6):\n",
        "        \"\"\"\n",
        "        if VALUE_VECTOR_LNORM:\n",
        "            D_head = V.size(-1)\n",
        "            value_cap = 1.0\n",
        "            V = norm_rms(V, value_cap)\n",
        "\n",
        "        if ABLATE_MHA_ATTN_CALC:\n",
        "            attn = torch.randn(batch_size, self.num_heads, seq_len, seq_len, device=query.device)\n",
        "            assert attn.shape == (batch_size, self.num_heads, seq_len, seq_len), f'attn.shape = {attn.shape}'\n",
        "            scores = attn\n",
        "\n",
        "        elif USE_SINUSOIDAL_PE:\n",
        "            attentional_bias = None\n",
        "\n",
        "            # make sure all previous GPU work is done:\n",
        "\n",
        "            if TIME_ATTN_SCORES_BLOCK:\n",
        "                self._pos_score_start = torch.cuda.Event(enable_timing=True)\n",
        "                self._pos_score_end   = torch.cuda.Event(enable_timing=True)\n",
        "                torch.cuda.synchronize()\n",
        "                # record the start:\n",
        "                self._pos_score_start.record()\n",
        "\n",
        "            attentional_bias = None\n",
        "            assert position_stream is not None, \"Position stream needed\"\n",
        "            vec_q, vec_k, *_ = position_stream\n",
        "\n",
        "            # compute scores (now includes zeroth-PE bias and uses sqrt(O*d + d_model))\n",
        "            p0_q_h = None; p0_k_h = None\n",
        "            if USE_LEARNABLE_ZEROTH_PE_MHA:\n",
        "                if isinstance(position_stream, (tuple, list)) and len(position_stream) >= 4:\n",
        "                    _, _, p0_q_h, p0_k_h, *rest = position_stream\n",
        "            scores, position_scores, *_ = self._findPositionScores_Unoptimized(\n",
        "                vec_q, vec_k,\n",
        "                valuesForInputDependentAlphaCoeffs=valuesForInputDependentAlphaCoeffs,\n",
        "                p0_q_h=p0_q_h, p0_k_h=p0_k_h\n",
        "            )\n",
        "\n",
        "            #################################################################################\n",
        "\n",
        "\n",
        "            # if MHA_NORM_REGULARIZATION_ON_ATTN_SCORES_ENABLED: # If true, applies activation norm on self-attn scores for values above a certain threshold and effectively dampens coeffs_q\n",
        "\n",
        "            #     self.cached_scores_for_norm_reg = scores_for_norm_reg.tril(diagonal=0)\n",
        "            #     assert self.cached_scores_for_norm_reg.shape == (batch_size, self.num_heads, seq_len, seq_len)\n",
        "            #     # Mask out the upper triangular part to 0:\n",
        "            #     self.cached_scores_for_norm_reg = self.cached_scores_for_norm_reg.tril(diagonal=0)\n",
        "            #     assert self.cached_scores_for_norm_reg.shape == (batch_size, self.num_heads, seq_len, seq_len)\n",
        "\n",
        "\n",
        "            # # We set Q_exp and K_exp based on the weighted positional streams \"implicitly\"\n",
        "            # # (or they can be computed via a similar einsum if needed for downstream fusion).\n",
        "            # Q_exp = None\n",
        "            # K_exp = None\n",
        "\n",
        "\n",
        "        if self.has_custom_head_dim:\n",
        "            # Means head_dim was custom-set, so d_model = head_dim * ???  (or a special config)\n",
        "            assert self.d_model == self.head_dim, (\n",
        "                f\"d_model ({self.d_model}) != head_dim ({self.head_dim}) \"\n",
        "                \"in the custom configuration!\"\n",
        "            )\n",
        "\n",
        "        # Project values: [B, S, num_heads * head_dim] -> reshape -> [B, num_heads, S, head_dim]\n",
        "        assert value.shape == (batch_size, seq_len, VOCAB_N_DIM), f'Expected shape {batch_size, seq_len, VOCAB_N_DIM}, got {value.shape}'\n",
        "        # print(f'v_linear shape == {self.v_linear.in_features}, out_features == {self.v_linear.out_features}')\n",
        "        # v_linear shape == 256, out_features == 64\n",
        "\n",
        "\n",
        "        if not VALUE_VECTORS_USE_HEAD_DIM_CONCATENATION_TO_MATCH_VOCAB_DIM:\n",
        "            assert V.shape == (batch_size, self.num_heads, seq_len, VOCAB_N_DIM)\n",
        "        else:\n",
        "            assert V.shape == (batch_size, self.num_heads, seq_len, VOCAB_N_DIM // self.num_heads)\n",
        "\n",
        "        aligned_Q_lstm, aligned_K_lstm = None, None\n",
        "        if RelativeEncodingLSTMHiddenOutputsRelevanceEncoding_IS_ENABLED:\n",
        "            assert self.alignment_matrices_Q.shape == self.alignment_matrices_K.shape == \\\n",
        "            (self.num_upstream_operators // 2, LSTM_OUTPUT_QK_N_DIM, MHA_RELEVANCE_ENCODING_OUTPUT_DIM)\n",
        "            lstm_output_q_dim = lstm_output_q.shape[-1]\n",
        "            # print(f'lstm output q shape = {lstm_output_q.shape}')\n",
        "            assert lstm_output_q.shape == lstm_output_k.shape == (batch_size, self.num_upstream_operators // 2, seq_len, lstm_output_q_dim), f'lstm_output_q.shape = {lstm_output_q.shape}, lstm_output_k.shape = {lstm_output_k.shape}'\n",
        "            print(f'[MHA] Avg lstm_output_q norm = {lstm_output_q.norm(dim=-1).mean()}, Avg lstm_output_k norm = {lstm_output_k.norm(dim=-1).mean()}, Max lstm_output_q norm = {lstm_output_q.norm(dim=-1).max()}, Max lstm_output_k norm = {lstm_output_k.norm(dim=-1).max()}')\n",
        "            # print(f'[MHA] Avg lstm_output_q norm = {torch.mean(torch.norm(lstm_output_q, dim=-1))}, Avg lstm_output_k norm = {torch.mean(torch.norm(lstm_output_k, dim=-1))}, Max lstm_output_q norm = {torch.max(torch.norm(lstm_output_q, dim=-1))}, Max lstm_output_k norm = {torch.max(torch.norm(lstm_output_k, dim=-1))}')\n",
        "            aligned_Q_lstm = torch.einsum(\"bnsd,nde->bnse\", lstm_output_q, self.alignment_matrices_Q)\n",
        "            aligned_K_lstm = torch.einsum(\"bnsd,nde->bnse\", lstm_output_k, self.alignment_matrices_K)\n",
        "            aligned_Q_lstm_for_norm_reg = torch.einsum(\"bnsd,nde->bnse\", lstm_output_q.detach(), self.alignment_matrices_Q)\n",
        "            aligned_K_lstm_for_norm_reg = torch.einsum(\"bnsd,nde->bnse\", lstm_output_k.detach(), self.alignment_matrices_K)\n",
        "\n",
        "            assert aligned_Q_lstm.shape == aligned_K_lstm.shape == (batch_size, self.num_upstream_operators // 2, seq_len, MHA_RELEVANCE_ENCODING_OUTPUT_DIM), f'aligned_Q_lstm.shape = {aligned_Q_lstm.shape}, aligned_K_lstm.shape = {aligned_K_lstm.shape}'\n",
        "\n",
        "            aligned_Q_lstm = aligned_Q_lstm + self.alignMatrixBiasQ.unsqueeze(-2)\n",
        "            aligned_K_lstm = aligned_K_lstm + self.alignMatrixBiasK.unsqueeze(-2)\n",
        "            aligned_Q_lstm_for_norm_reg = aligned_Q_lstm_for_norm_reg + self.alignMatrixBiasQ.unsqueeze(-2)\n",
        "            aligned_K_lstm_for_norm_reg = aligned_K_lstm_for_norm_reg + self.alignMatrixBiasK.unsqueeze(-2)\n",
        "\n",
        "\n",
        "        # --- Combine the position-based streams (from the concatenated einsum) with the LSTM-based streams ---\n",
        "        # Here, assume the \"virtual\" Q_exp and K_exp computed from positions are represented implicitly via 'scores'\n",
        "        # and we add the LSTM contributions:\n",
        "        if aligned_Q_lstm is not None and RelativeEncodingLSTMHiddenOutputsRelevanceEncoding_IS_ENABLED:\n",
        "            # For later processing, one could add these to a \"combined\" Q stream.\n",
        "            # For example, if you had computed Q_concat from weighted_pos_q by a different einsum,\n",
        "            # you might set:\n",
        "            #   final_Q = Q_concat + aligned_Q_lstm\n",
        "            # In our case, since the dot-product scores already come from weighted_pos_q and weighted_pos_k,\n",
        "            # we incorporate the LSTM contributions by adding their dot-product scores.\n",
        "            # scores_lstm = torch.einsum(\"bhse,bhse->bhij\", aligned_Q_lstm, aligned_K_lstm)\n",
        "\n",
        "            # coeffs: H, half_ops\n",
        "\n",
        "\n",
        "            # coeffs_K = torch.ones_like(coeffs_Q) #(self.pos_coeffs_K)\n",
        "            assert coeffs_Q.shape == (1, self.num_heads, num_operators_per_head + (1 if CONCAT_ABS_POSITION_ENCODINGS else 0), 1, 1), f'coeffs_Q.shape = {coeffs_Q.shape}'\n",
        "            coeffs_Q = coeffs_Q.squeeze(0).squeeze(-1).squeeze(-1)\n",
        "            assert coeffs_Q.shape == (self.num_heads, num_operators_per_head + (1 if CONCAT_ABS_POSITION_ENCODINGS else 0)), f'coeffs_Q.shape = {coeffs_Q.shape}'\n",
        "            coeffs_K = torch.ones_like(coeffs_Q)\n",
        "\n",
        "\n",
        "\n",
        "            ####################################################################################\n",
        "            ####################################################################################\n",
        "\n",
        "\n",
        "\n",
        "            print(f'[MHA, pre] Avg aligned_Q_lstm norm = {aligned_Q_lstm.norm(dim=-1).mean()}, Avg aligned_K_lstm norm = {aligned_K_lstm.norm(dim=-1).mean()}, Max aligned_Q_lstm norm = {aligned_Q_lstm.norm(dim=-1).max()}, Max aligned_K_lstm norm = {aligned_K_lstm.norm(dim=-1).max()}')\n",
        "\n",
        "            assert aligned_Q_lstm.shape == aligned_K_lstm.shape == (batch_size, self.num_upstream_operators // 2, seq_len, MHA_RELEVANCE_ENCODING_OUTPUT_DIM), f'aligned_Q_lstm.shape = {aligned_Q_lstm.shape}, aligned_K_lstm.shape = {aligned_K_lstm.shape}'\n",
        "            aligned_Q_lstm = aligned_Q_lstm.view(batch_size, self.num_heads, num_operators_per_head, seq_len, MHA_RELEVANCE_ENCODING_OUTPUT_DIM)\n",
        "            aligned_K_lstm = aligned_K_lstm.view(batch_size, self.num_heads, num_operators_per_head, seq_len, MHA_RELEVANCE_ENCODING_OUTPUT_DIM)\n",
        "            aligned_Q_lstm_for_norm_reg = aligned_Q_lstm_for_norm_reg.view(batch_size, self.num_heads, num_operators_per_head, seq_len, MHA_RELEVANCE_ENCODING_OUTPUT_DIM)\n",
        "            aligned_K_lstm_for_norm_reg = aligned_K_lstm_for_norm_reg.view(batch_size, self.num_heads, num_operators_per_head, seq_len, MHA_RELEVANCE_ENCODING_OUTPUT_DIM)\n",
        "            self.latest_aligned_qk_lstm_tensors = (aligned_Q_lstm_for_norm_reg, aligned_K_lstm_for_norm_reg)\n",
        "\n",
        "            # print(f'coeffs_Q[:,:-1].shape = {coeffs_Q[:,:-1].shape}')\n",
        "            if not RelativeEncodingLSTMHiddenOutputsRelevanceEncoding_IS_ENABLED:\n",
        "                aligned_Q_lstm = torch.einsum('bhnsd,hn->bhsd', aligned_Q_lstm, coeffs_Q[:,:])#(-1 if CONCAT_ABS_POSITION_ENCODINGS else 0)])\n",
        "                aligned_K_lstm = torch.einsum('bhnsd,hn->bhsd', aligned_K_lstm, coeffs_K[:,:])#(-1 if CONCAT_ABS_POSITION_ENCODINGS else 0)])\n",
        "            else:\n",
        "                aligned_Q_lstm = torch.einsum('bhnsd,hn->bhsd', aligned_Q_lstm, coeffs_Q[:,:(-1 if CONCAT_ABS_POSITION_ENCODINGS else 0)])\n",
        "                aligned_K_lstm = torch.einsum('bhnsd,hn->bhsd', aligned_K_lstm, coeffs_K[:,:(-1 if CONCAT_ABS_POSITION_ENCODINGS else 0)])\n",
        "\n",
        "            assert aligned_Q_lstm.shape == aligned_K_lstm.shape == (batch_size, self.num_heads, seq_len, MHA_RELEVANCE_ENCODING_OUTPUT_DIM), f'aligned_Q_lstm.shape = {aligned_Q_lstm.shape}, aligned_K_lstm.shape = {aligned_K_lstm.shape}'\n",
        "\n",
        "\n",
        "            print(f'[MHA] Avg aligned_Q_lstm norm = {aligned_Q_lstm.norm(dim=-1).mean()}, Avg aligned_K_lstm norm = {aligned_K_lstm.norm(dim=-1).mean()}, Max aligned_Q_lstm norm = {aligned_Q_lstm.norm(dim=-1).max()}, Max aligned_K_lstm norm = {aligned_K_lstm.norm(dim=-1).max()}')\n",
        "            scores_lstm = torch.einsum(\"bhse,bhte->bhst\", aligned_Q_lstm, aligned_K_lstm)\n",
        "            scores_lstm = scores_lstm / np.sqrt(MHA_RELEVANCE_ENCODING_OUTPUT_DIM)\n",
        "\n",
        "            lambda_lstm_scores = 0.5 #0.01\n",
        "            if MHA_NORM_REGULARIZATION_ON_ATTN_SCORES_ENABLED:\n",
        "\n",
        "\n",
        "                assert self.cached_scores_for_norm_reg.shape == scores.shape == (batch_size, self.num_heads, seq_len, seq_len)\n",
        "                self.cached_scores_for_norm_reg = scores_lstm.tril(diagonal=0) * lambda_lstm_scores + self.cached_scores_for_norm_reg\n",
        "                # Mask out the upper triangular part to 0:\n",
        "                self.cached_scores_for_norm_reg = self.cached_scores_for_norm_reg.tril(diagonal=0)\n",
        "\n",
        "            scores = scores + lambda_lstm_scores * scores_lstm  # or apply another combination strategy\n",
        "\n",
        "        assert scores is not None\n",
        "\n",
        "        if ABSOLUTE_POS_ATTN_BIAS:\n",
        "            # ---- per-head coefficient -------------------------------------------\n",
        "            coeff_raw = (self.attn_dist_bias_u_ * self.attn_dist_bias_v_).sum(dim=-1)    # [H]\n",
        "            # <FlexLogAttnDistBias>:\n",
        "            # v0.9998: Decrease <coeff> by 25 for <lower coeff forDistBias>\n",
        "            coeff     = 1.5 * torch.abs(coeff_raw)                                          # [-1,1]\n",
        "\n",
        "            # ---- per-head scale --------------------------------------------------\n",
        "            # dot product of the new (u,v) pair – gives one *raw* scale per head\n",
        "            # scale_raw = (self.attn_dist_scale_u_ * self.attn_dist_scale_v_).sum(dim=-1)  # [H]\n",
        "\n",
        "            # squash and bound to ±0.05  ⇒  initial std ≈ 0.05\n",
        "            # <FlexLogAttnDistBias>:\n",
        "            scale = 1.0 #150 * torch.abs((scale_raw))                                       # [-0.05,0.05]\n",
        "\n",
        "            # ---- combine & build bias matrix ------------------------------------\n",
        "            # b = torch.abs(scale * coeff)                                               # [H]  ≥ 0\n",
        "\n",
        "            # idx   = torch.arange(seq_len, device=query.device)\n",
        "            # dist  = (idx[None, :] - idx[:, None]).abs().float()                        # [S,S]\n",
        "\n",
        "            # bias  = -(b.view(1, self.num_heads, 1, 1) * dist)                          # [1,H,S,S]\n",
        "            #                                                # broadcast over B\n",
        "\n",
        "            # indexedValues = [f'head {h}: {b[h]}' for h in range(self.num_heads)]\n",
        "\n",
        "            # ---- logarithmic distance-bias matrix --------------------------------\n",
        "            # <LogAttnDistBias>:\n",
        "            b = torch.abs(scale * coeff)                                              # [H] ≥ 0\n",
        "\n",
        "            idx        = torch.arange(seq_len, device=query.device)\n",
        "            dist_linear = (idx[None, :] - idx[:, None]).abs().float()                 # |i-j|\n",
        "            dist        = torch.log1p(dist_linear)                                    # log(1+|i-j|)\n",
        "\n",
        "            bias = -(b.view(1, self.num_heads, 1, 1) * dist)                          # [1,H,S,S]\n",
        "            scores = scores + bias\n",
        "            position_scores = position_scores + bias      # keep in sync if you log it elsewhere\n",
        "\n",
        "            print(f'[MHA dist bias] avg = {b.mean()}, max = {b.max()}, min = {b.min()}' +  f' log transformed dist max = {bias.max()}, min = {bias.min()}, mean = {bias.mean()}')\n",
        "            # scores = scores + bias                                             # broadcast over B\n",
        "            # position_scores = position_scores + bias\n",
        "\n",
        "\n",
        "        assert mask is not None\n",
        "        if mask is not None:\n",
        "            scores = scores.masked_fill(mask == 1, float('-inf'))\n",
        "\n",
        "            # Example of diagonal masking, etc.\n",
        "            # diag_mask = torch.eye(seq_len, device=scores.device).unsqueeze(0).unsqueeze(0)\n",
        "            # diag_mask[:, :, 0, 0] = 0  # keep first token's self-attn\n",
        "            # scores = scores.masked_fill(diag_mask == 1, float('-inf'))\n",
        "\n",
        "        USE_SOFTMAX_STE = False\n",
        "\n",
        "        if USE_SOFTMAX_STE:\n",
        "            # attn = SoftmaxSTE.apply(scores)\n",
        "            attn = gumbel_softmax_STE(scores, tau=7.0, alpha=0.99)\n",
        "        else:\n",
        "            attn = torch.softmax(scores, dim=-1)\n",
        "\n",
        "        assert attn.shape == (batch_size, self.num_heads, seq_len, seq_len), f'Expected shape {batch_size, self.num_heads, seq_len, seq_len}, got {attn.shape}'\n",
        "\n",
        "        # if mha_attnProbMaxThreshold is not None:\n",
        "        #     # if any of the attn prob > mha_attnProbMaxThreshold, clip the max and renormalize the row of the attn matrix:\n",
        "        #         thr = float(mha_attnProbMaxThreshold)\n",
        "        #     if not (thr < 1.0):\n",
        "        #         raise ValueError(\"mha_attnProbMaxThreshold must be < 1.0\")\n",
        "        #     thr_t = torch.as_tensor(thr, dtype=attn.dtype, device=attn.device)\n",
        "\n",
        "        #     # Per-row maximum and which rows need clipping\n",
        "        #     row_max, _ = attn.max(dim=-1, keepdim=True)                             # [B,H,S,1]\n",
        "        #     rows_need_clip = row_max > thr_t                                        # [B,H,S,1]\n",
        "\n",
        "        #     if rows_need_clip.any():\n",
        "        #         # Mask of the maximum entries in each row (ties included), restricted to rows needing clip\n",
        "        #         is_row_max = (attn >= row_max)                                      # [B,H,S,S]\n",
        "        #         clip_mask = is_row_max & rows_need_clip                             # broadcast\n",
        "\n",
        "        #         # 1) Clip only the maximum entries to the threshold\n",
        "        #         clipped = torch.where(clip_mask, thr_t, attn)\n",
        "\n",
        "        #         # 2) Renormalize the affected rows so they sum to 1 along the last dim\n",
        "        #         row_sum = clipped.sum(dim=-1, keepdim=True)                         # [B,H,S,1]\n",
        "\n",
        "        #         # If the sum is (numerically) zero (e.g., thr==0 and all mass was on the max), fall back to uniform\n",
        "        #         zero_sum = row_sum <= 1e-12\n",
        "        #         if zero_sum.any():\n",
        "        #             uniform_row = torch.full_like(clipped, 1.0 / clipped.size(-1))\n",
        "        #             clipped = torch.where(zero_sum, uniform_row, clipped)\n",
        "        #             row_sum = clipped.sum(dim=-1, keepdim=True)\n",
        "\n",
        "        #         # Apply renormalization only to rows that were clipped\n",
        "        #         attn = torch.where(rows_need_clip, clipped / row_sum.clamp_min(1e-12), attn)\n",
        "\n",
        "        #     # (Optional) sanity check: rows should still sum to ~1\n",
        "        #     # assert torch.allclose(attn.sum(dim=-1), torch.ones_like(attn[..., 0]), atol=1e-5)\n",
        "\n",
        "        \"\"\" mha_attnProbMinThreshold -> if > 0, add to all prob of the non-masked semifinal attention probs, divided by seq len, and renormalize \"\"\"\n",
        "        if mha_attnProbMinThreshold is not None and mha_attnProbMinThreshold > 0:\n",
        "            thr = float(mha_attnProbMinThreshold)\n",
        "            thr_t = torch.as_tensor(thr, dtype=attn.dtype, device=attn.device)\n",
        "\n",
        "            # Unmasked positions (broadcasts if mask is broadcastable)\n",
        "            valid = (mask != 1)  # True where we keep attention\n",
        "\n",
        "            # Count non-zero entries per row among unmasked keys\n",
        "            nz = valid & (attn != 0)\n",
        "            cnt_nz = nz.sum(dim=-1, keepdim=True)                  # [B,H,S,1]\n",
        "            cnt_valid = valid.sum(dim=-1, keepdim=True)            # [B,H,S,1]\n",
        "            rows_no_nz = (cnt_nz == 0)\n",
        "\n",
        "            # Per-row additive amount = threshold / (# non-zero); fallback to / (# valid) if no non-zeros\n",
        "            cnt_nz_safe = cnt_nz.clamp_min(1)\n",
        "            cnt_valid_safe = cnt_valid.clamp_min(1)\n",
        "            delta_nz = thr_t / cnt_nz_safe\n",
        "            delta_valid = thr_t / cnt_valid_safe\n",
        "            delta = torch.where(rows_no_nz, delta_valid, delta_nz)  # [B,H,S,1]\n",
        "\n",
        "            # Add to non-zero entries (or to all valid if no non-zeros in the row)\n",
        "            add_mask = torch.where(rows_no_nz, valid, nz)           # [B,H,S,S]\n",
        "            attn = attn + delta * add_mask.to(attn.dtype)\n",
        "\n",
        "            # Mask out invalid entries and renormalize rows\n",
        "            attn = attn.masked_fill(~valid, 0.0)\n",
        "            attn = attn / attn.sum(dim=-1, keepdim=True).clamp_min(1e-12)\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "        output = torch.matmul(attn, V)  # [B, H, S, head_dim]\n",
        "        assert output.shape == (batch_size, self.num_heads, seq_len, (VOCAB_N_DIM_ // self.num_heads) if VALUE_VECTORS_USE_HEAD_DIM_CONCATENATION_TO_MATCH_VOCAB_DIM else VOCAB_N_DIM_)\n",
        "\n",
        "        # if self.value_context_transform_map is not None and lstm_output_for_value_context_transform is not None:\n",
        "        if MHA_VALUE_TRANSFORM_ENABLED and self.value_context_transform_map is not None and lstm_output_for_value_context_transform is not None:\n",
        "            assert lstm_output_for_value_context_transform.shape == (batch_size, seq_len, VOCAB_N_DIM)\n",
        "\n",
        "            # output = self.value_context_transform_map(output)\n",
        "            assert output.shape == (batch_size, self.num_heads, seq_len, VOCAB_N_DIM)\n",
        "\n",
        "            lstm_output_for_value_context_transform = lstm_output_for_value_context_transform.unsqueeze(1)\n",
        "            assert lstm_output_for_value_context_transform.shape == (batch_size, 1, seq_len, VOCAB_N_DIM)\n",
        "            lstm_output_for_value_context_transform = lstm_output_for_value_context_transform.expand(\n",
        "                batch_size, self.num_heads, seq_len, VOCAB_N_DIM\n",
        "            )\n",
        "            cat_tensors = torch.cat((output, lstm_output_for_value_context_transform), dim=-1)\n",
        "            assert cat_tensors.shape == (batch_size, self.num_heads, seq_len, VOCAB_N_DIM * 2)\n",
        "            cat_tensors = self.l_prenorm_for_value_context_transform(cat_tensors)\n",
        "            # output = self.value_context_transform_map(cat_tensors)\n",
        "            assert self.value_context_transform_map.shape == (self.num_heads, VOCAB_N_DIM * 2, VOCAB_N_DIM)\n",
        "            output = torch.einsum(\"bhsd,hdo->bhso\", cat_tensors, self.value_context_transform_map)\n",
        "            assert output.shape == (batch_size, self.num_heads, seq_len, VOCAB_N_DIM)\n",
        "            bias = self.value_context_transform_bias.unsqueeze(0).unsqueeze(-2)\n",
        "            assert bias.shape ==   (1,          self.num_heads,    1,    VOCAB_N_DIM)\n",
        "            output = output + bias\n",
        "\n",
        "\n",
        "        # For debugging/visualization if not training\n",
        "        if not self.training:\n",
        "            self.attn_weights.append(attn.detach().cpu().numpy())\n",
        "            # neg_inf_mask = scores == float('-inf')\n",
        "            # self.attn_weights.append(scores.masked_fill(neg_inf_mask, 0).detach().cpu().numpy())\n",
        "            # Mask out upper triangular part of position_scores:\n",
        "            position_scores = position_scores.tril(diagonal=0)\n",
        "            self.attn_weights.append(position_scores.detach().cpu().numpy())\n",
        "            if RelativeEncodingLSTMHiddenOutputsRelevanceEncoding_IS_ENABLED:\n",
        "                self.attn_weights.append(scores_lstm.detach().cpu().numpy())\n",
        "\n",
        "\n",
        "        #\n",
        "        # --- Final output projection ---\n",
        "        #\n",
        "        if USE_HIGH_DIMENSIONAL_OUTPUT_PROJECTION:\n",
        "            assert not VALUE_VECTORS_USE_HEAD_DIM_CONCATENATION_TO_MATCH_VOCAB_DIM\n",
        "            assert output.shape == (batch_size, self.num_heads, seq_len, VOCAB_N_DIM_), f'Expected shape {batch_size, self.num_heads, seq_len, self.head_dim}, got {output.shape}'\n",
        "\n",
        "            # Flatten all heads into one vector of size (num_heads * head_dim)\n",
        "            # output shape is [B, H, S, head_dim] -> permute to [B, S, H, head_dim]\n",
        "            output = output.permute(0, 2, 1, 3).contiguous()  # [B, S, H, head_dim]\n",
        "            assert output.shape == (batch_size, seq_len, self.num_heads, VOCAB_N_DIM_)\n",
        "            output = output.view(batch_size, seq_len, self.num_heads * VOCAB_N_DIM_)  # flatten H dimension\n",
        "            # Multiply by single large projection [num_heads * head_dim, d_model]\n",
        "            # assert self.head_projections.shape == (self.num_heads * VOCAB_N_DIM, VOCAB_N_DIM)\n",
        "            output = output @ self.head_projections  # => [B, S, d_model]\n",
        "            output = output + self.head_proj_bias  # shape [B, S, d_model]\n",
        "\n",
        "\n",
        "            # Optionally apply layer norm\n",
        "            if MHA_USE_OUTPUT_LNORM:\n",
        "                output = self.output_lnorm(output)\n",
        "\n",
        "        else:\n",
        "            # Original approach: project each head (H of them) and sum\n",
        "            # head_projections: [num_heads, head_dim, d_model]\n",
        "            if VALUE_VECTORS_USE_HEAD_DIM_CONCATENATION_TO_MATCH_VOCAB_DIM:\n",
        "                # Concatenate:\n",
        "                assert output.shape == (batch_size, self.num_heads, seq_len, (VOCAB_N_DIM // self.num_heads))\n",
        "                output = output.permute(0, 2, 1, 3).contiguous()\n",
        "                assert output.shape == (batch_size, seq_len, self.num_heads, VOCAB_N_DIM // self.num_heads)\n",
        "                output = output.view(batch_size, seq_len, VOCAB_N_DIM)\n",
        "                # Apply head_projctions\n",
        "                # self.head_projections = nn.Parameter(torch.empty(num_heads, VOCAB_N_DIM, VOCAB_N_DIM))\n",
        "                assert self.head_projections.shape == (VOCAB_N_DIM, VOCAB_N_DIM)\n",
        "                output = torch.einsum(\"bsd,de->bse\", output, self.head_projections)\n",
        "                assert output.shape == (batch_size, seq_len, VOCAB_N_DIM) , f'Expected shape {batch_size, seq_len, VOCAB_N_DIM}, got {output.shape}'\n",
        "                # Add bias\n",
        "                assert self.head_proj_bias.shape == (VOCAB_N_DIM,)\n",
        "                output = output + self.head_proj_bias\n",
        "            else:\n",
        "\n",
        "                ABLATE_MHA_OUTPUT_BIAS = False\n",
        "                if ABLATE_MHA_OUTPUT_BIAS:\n",
        "                    output = torch.einsum(\"bnsd,nde->bse\", output, self.head_projections)\n",
        "                else:\n",
        "                    output = torch.einsum(\"bnsd,nde->bnse\", output, self.head_projections)\n",
        "                    assert output.shape == (batch_size, self.num_heads, seq_len, VOCAB_N_DIM if not VALUE_VECTORS_USE_HEAD_DIM_CONCATENATION_TO_MATCH_VOCAB_DIM else VOCAB_N_DIM // self.num_heads)\n",
        "                    assert self.head_proj_bias.shape == (self.num_heads, VOCAB_N_DIM), f'Expected shape {self.num_heads, VOCAB_N_DIM}, got {self.head_proj_bias.shape}'\n",
        "                    output = output + self.head_proj_bias.unsqueeze(-2)\n",
        "\n",
        "                    # shape now [B, num_heads, S, d_model]\n",
        "                    # sum across heads\n",
        "                    if not VALUE_VECTORS_USE_HEAD_DIM_CONCATENATION_TO_MATCH_VOCAB_DIM:\n",
        "                        output = output.sum(dim=1)  # => [B, S, d_model]\n",
        "\n",
        "            # Possibly divide output if you're used to scaling after summation\n",
        "            if not MHA_USE_OUTPUT_LNORM:\n",
        "                pass\n",
        "                # assert False, f'mha_use_output_lnorm = {MHA_USE_OUTPUT_LNORM}'\n",
        "                # output = output / (self.num_heads * 1.5)\n",
        "\n",
        "            elif MHA_USE_OUTPUT_LNORM:\n",
        "                output = self.output_lnorm(output)\n",
        "\n",
        "        return output\n"
      ],
      "metadata": {
