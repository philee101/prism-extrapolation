    {
      "cell_type": "code",
      "source": [
        "from packaging import version\n",
        "import subprocess, sys\n",
        "\n",
        "# parse your current torch version\n",
        "if version.parse(torch.__version__) < version.parse(\"2.1.0\"):\n",
        "    print(f\"Upgrading torch (found {torch.__version__} < 2.1.0)…\")\n",
        "    # install the nightly 2.1+ build with cu117\n",
        "    subprocess.check_call([\n",
        "        sys.executable, \"-m\", \"pip\", \"install\", \"--pre\", \"--upgrade\",\n",
        "        \"torch\", \"torchvision\",\n",
        "        \"--extra-index-url\", \"https://download.pytorch.org/whl/nightly/cu117\"\n",
        "    ])\n",
        "    # after this cell you’ll need to restart the runtime\n",
        "else:\n",
        "    print(f\"torch {torch.__version__} ≥ 2.1.0, skipping install.\")"
      ],
      "metadata": {
        "id": "ZW2WkhndZYRg",
        "trusted": true,
        "execution": {
          "iopub.status.busy": "2025-09-17T19:06:50.264175Z",
          "iopub.execute_input": "2025-09-17T19:06:50.264824Z",
          "iopub.status.idle": "2025-09-17T19:06:50.276723Z",
          "shell.execute_reply.started": "2025-09-17T19:06:50.264803Z",
          "shell.execute_reply": "2025-09-17T19:06:50.276165Z"
        }
      },
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "code",
      "source": [
        "\n",
        "# Print cudnn benchmark:\n",
        "print(torch.backends.cudnn.benchmark)\n",
        "print(torch.backends.cudnn.deterministic)\n",
        "print(torch.backends.cuda.matmul.allow_tf32)\n",
        "print(torch.backends.cudnn.allow_tf32)\n",
        "\n",
        "# Let CuDNN pick the best convolution (and other) algorithms for your exact tensor sizes:\n",
        "torch.backends.cudnn.benchmark = True\n",
        "# Disable the slower, “deterministic” fallback paths:\n",
        "torch.backends.cudnn.deterministic = False\n",
        "torch.backends.cuda.matmul.allow_tf32 = True\n",
        "torch.backends.cudnn.allow_tf32  = True\n",
        "# Set matmul precision:\n",
        "torch.set_float32_matmul_precision('high')\n",
        "\n",
        "torch._dynamo.config.cache_size_limit = 100000000000"
      ],
