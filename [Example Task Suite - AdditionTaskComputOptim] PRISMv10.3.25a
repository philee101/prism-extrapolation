      "cell_type": "markdown",
      "source": [
        "## Clear cached _sigmoid_activation_values_for_logging"
      ],
      "metadata": {
        "id": "YvNRqDDu_Wo9"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Print cached sigmoid activation values\n",
        "def clear_cached_sigmoid_activation_values(model):\n",
        "    if model is None or not model.model_is_rse:\n",
        "        return\n",
        "    for module in model.modules():\n",
        "        if hasattr(module, 'output_gate_sigmoid_activation_values_for_logging'):\n",
        "            # print Length of list:\n",
        "            print(f'len(module.output_gate_sigmoid_activation_values_for_logging) = {len(module.output_gate_sigmoid_activation_values_for_logging)}')\n",
        "            module.output_gate_sigmoid_activation_values_for_logging.clear()\n",
        "\n",
        "        if hasattr(module, 'reset_gate_sigmoid_activation_values_for_logging'):\n",
        "            print(f'len(module.reset_gate_sigmoid_activation_values_for_logging) = {len(module.reset_gate_sigmoid_activation_values_for_logging)}')\n",
        "            module.reset_gate_sigmoid_activation_values_for_logging.clear()\n",
        "\n",
        "        if hasattr(module, 'decrement_gate_sigmoid_activation_values_for_logging'):\n",
        "            print(f'len(module.decrement_gate_sigmoid_activation_values_for_logging) = {len(module.decrement_gate_sigmoid_activation_values_for_logging)}')\n",
        "            module.decrement_gate_sigmoid_activation_values_for_logging.clear()\n",
        "\n",
        "if model_rse is not None:\n",
        "    clear_cached_sigmoid_activation_values(model_rse)\n",
        "\n"
      ],
      "metadata": {
        "id": "iq_KMEYOY5JA",
        "scrolled": true,
        "trusted": true,
        "execution": {
