    {
      "cell_type": "code",
      "source": [
        "@torch.compile(dynamic=False)\n",
        "def hist_update_v7_fast_bwd_mod_3_noslices(\n",
        "    hist, p_reset, p_inc, p_dec, p_keep,\n",
        "    p_copy, eps, gamma, power=True,\n",
        "    row0=None, rowN=None            # static 1-element index tensors\n",
        "):\n",
        "    P, bs, h = hist.shape\n",
        "    one = hist.new_tensor(1.)\n",
        "\n",
        "    # ---------------------------------------------------------------- Wgts\n",
        "    inv_r = one - p_reset\n",
        "    w_k, w_i, w_d = (inv_r * p_keep,\n",
        "                     inv_r * p_inc,\n",
        "                     inv_r * p_dec)\n",
        "\n",
        "    # ---------------------------------------------------------------- base (keep + inc + dec) in one buffer\n",
        "    out = hist.mul(w_k.unsqueeze(0))             # keep\n",
        "\n",
        "    out.addcmul_(hist, w_i.unsqueeze(0))         # +inc\n",
        "    out.addcmul_(hist, w_d.unsqueeze(0))         # +dec\n",
        "\n",
        "    # -- INC shift (t→t+1)\n",
        "    out[1:] += hist.mul(w_i.unsqueeze(0))[:-1]\n",
        "    if rowN is None:                            # create once if absent\n",
        "        rowN = torch.as_tensor([P-1], device=hist.device)\n",
        "    out.index_add_(0, rowN, hist.mul(w_i.unsqueeze(0))[-1:])\n",
        "\n",
        "    # -- DEC shift (t→t-1)\n",
        "    out[:-1] += hist.mul(w_d.unsqueeze(0))[1:]\n",
        "    if row0 is None:\n",
        "        row0 = torch.zeros(1, dtype=torch.long, device=hist.device)\n",
        "    out.index_add_(0, row0, hist.mul(w_d.unsqueeze(0))[:1])\n",
        "\n",
        "    # ---------------------------------------------------------------- reset\n",
        "    total = hist.sum(0)                          # [bs,h]\n",
        "    out[0] += total * p_reset * (p_dec + p_keep)\n",
        "    out[1] += total * p_reset * p_inc\n",
        "\n",
        "    # ---------------------------------------------------------------- copy\n",
        "    if p_copy is not None and Position_Copying_Enabled:\n",
        "        if p_copy.shape[0] != P + 1:\n",
        "            p_copy = p_copy.permute(2, 0, 1).contiguous()\n",
        "        pos_cols, no_copy = p_copy[:-1], p_copy[-1]\n",
        "        out = out.mul(no_copy.unsqueeze(0)).add_(total.unsqueeze(0) * pos_cols)\n",
        "\n",
        "    # ---------------------------------------------------------------- sharp\n",
        "    # --- sharpen ---------------------------------------------------------\n",
        "    if power:\n",
        "        out.add_(eps).pow_(gamma)            # single in-place chain\n",
        "\n",
        "    # --- normalise (alloc ≪ 1 µs) ----------------------------------------\n",
        "    denom = out.sum(0, keepdim=True).add_(eps)      # [1,bs,h]\n",
        "    out   = out / denom                             # NOT div_  → new tensor\n",
        "    return out\n"
      ],
