      "source": [
        "def scaled_xavier_init(m):\n",
        "    if isinstance(m, nn.Linear):\n",
        "        gain = 1.0 / np.sqrt(2)  # Scaling factor to stabilize large inputs\n",
        "        nn.init.xavier_uniform_(m.weight, gain=gain)\n",
        "        if m.bias is not None:\n",
        "            nn.init.zeros_(m.bias)\n",
        "\n"
      ],
      "metadata": {
        "id": "5t3s2XfM9JuT",
        "scrolled": true,
