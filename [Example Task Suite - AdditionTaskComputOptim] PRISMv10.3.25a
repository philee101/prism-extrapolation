    {
      "cell_type": "code",
      "source": [
        "# For <removeRSE_LN>=1 and <ReplaceLNWithSmoothCap>=1 only\n",
        "\n",
        "import torch\n",
        "import torch.nn as nn\n",
        "import torch.nn.functional as F\n",
        "\n",
        "import math\n",
        "import torch\n",
        "import torch.nn as nn\n",
        "import torch.nn.functional as F\n",
        "\n",
        "class SoftCapLNorm(nn.Module):\n",
        "\n",
        "    \"\"\"\n",
        "    Gemma-style soft cap with a learnable cap 'c' (scalar or per-feature).\n",
        "\n",
        "    y = x * (tanh(||x||/c) * c / ||x||), where the norm is over `dim`.\n",
        "\n",
        "    Args:\n",
        "        dim:   dimension over which to compute the vector norm (e.g., -1).\n",
        "        per_feature: if True, use a separate cap for each feature on `dim`.\n",
        "                     Requires `feature_size` when True.\n",
        "        feature_size: size of the `dim` dimension when per_feature=True.\n",
        "        init_cap: initial cap value c0 (>0).\n",
        "        min_cap:  lower bound added to softplus so c >= min_cap.\n",
        "        eps:      small constant to avoid division by zero.\n",
        "    \"\"\"\n",
        "    def __init__(self, init_cap=VOCAB_N_DIM ** 0.5 * 8.5,\n",
        "                 k=5.0, eps=1e-8):\n",
        "        super().__init__(); self.init_cap = init_cap; self.k = k; self.eps = eps\n",
        "        self.cap = init_cap\n",
        "    def forward(self, x):\n",
        "        n = x.norm(dim=-1, keepdim=True).clamp_min(self.eps)\n",
        "        # t≈0 when n<<cap (no scaling), t≈1 when n>>cap (scale to cap)\n",
        "        t = torch.sigmoid(self.k*(n - self.cap))\n",
        "        x_cap = x * (self.cap / n)\n",
        "        r = (1 - t) * x + t * x_cap\n",
        "        assert r.shape == x.shape, f'r.shape = {r.shape}, x.shape = {x.shape}'\n",
        "        return r"
      ],
      "metadata": {
        "id": "bxfAlaD2buRl",
        "scrolled": true,
        "trusted": true,
