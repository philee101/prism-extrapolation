    {
      "cell_type": "code",
      "source": [
        "\"\"\"\n",
        "<CONCAT_ABS_POSITION_ENCODINGS>:\n",
        "if set to TRUE, the absolute positional encoding is concatenated to the \"hierarchical\" PE vector at each position and is assigned its own alpha coefficient(s)\n",
        "\"\"\"\n",
        "CONCAT_ABS_POSITION_ENCODINGS = 1\n",
        "\n",
        "\"\"\"\n",
        "Returns the number of concatenated operators per head for the hierarchical PE vector at each position\n",
        "\"\"\"\n",
        "def num_ops_per_head(num_ops_per_layer=NUM_OPERATORS_PER_SA_LAYER,\n",
        "                     num_heads=NUM_HEADS,\n",
        "                     base_ops_only=False):\n",
        "    num_operators_per_head = (num_ops_per_layer // 2) // num_heads\n",
        "\n",
        "    if CONCAT_ABS_POSITION_ENCODINGS and not base_ops_only:\n",
        "        num_operators_per_head += 1\n",
        "    return num_operators_per_head\n",
        "\n",
        "\n",
        "\n",
        "\"\"\"\n",
        "Determine <PE_VECTOR_NORM_FOR_INNER_PROD_POSITION_SCORES>\n",
        "\"\"\"\n",
        "PE_VECTOR_NORM_FOR_INNER_PROD_POSITION_SCORES = 192 ** 0.5 # Also affects the denominator for the qk inner product. Is equal to the maximum inner product of two non-\"hierarchical\" PEs without any temperature scaling.\n",
        "COMBINED_VECTOR_NORM_FOR_CONCAT_PE = ((PE_VECTOR_NORM_FOR_INNER_PROD_POSITION_SCORES ** 2) * num_ops_per_head(base_ops_only=True)) ** 0.5\n",
        "print(f'PE_VECTOR_NORM_FOR_INNER_PROD_POSITION_SCORES = {PE_VECTOR_NORM_FOR_INNER_PROD_POSITION_SCORES}, COMBINED_VECTOR_NORM_FOR_CONCAT_PE = {COMBINED_VECTOR_NORM_FOR_CONCAT_PE}')\n",
        "\n",
        "\"\"\"\n",
        "More HParams\n",
        "\"\"\"\n",
        "\n",
        "PE_MAX_TEMPERATURE_SCALING_TARGET_FOR_CAP_ALPHA_COEFFS = None #315 / PE_VECTOR_NORM_FOR_INNER_PROD_POSITION_SCORES\n",
        "print(f'PE_MAX_TEMPERATURE_SCALING_TARGET_FOR_CAP_ALPHA_COEFFS = {PE_MAX_TEMPERATURE_SCALING_TARGET_FOR_CAP_ALPHA_COEFFS}')\n",
        "if PE_MAX_TEMPERATURE_SCALING_TARGET_FOR_CAP_ALPHA_COEFFS is not None:\n",
        "    capAlphaCoeffs = PE_MAX_TEMPERATURE_SCALING_TARGET_FOR_CAP_ALPHA_COEFFS / POSITION_SOFTMAX_TEMP\n",
        "else:\n",
        "    capAlphaCoeffs = None\n",
        "\n",
        "print(f'capAlphaCoeffs = {capAlphaCoeffs}')\n",
        "Input_Dependent_Alpha_Coeffs = True\n",
        "if Input_Dependent_Alpha_Coeffs:\n",
        "    assert capAlphaCoeffs is None, \"capAlphaCoeffs must be None if Input_Dependent_Alpha_Coeffs is True\"\n",
        "\n",
        "mha_attnProbMaxThreshold = None #0.99\n",
        "mha_attnProbMinThreshold = 0.01 # If > 0, add to all prob of the non-masked semifinal attention probs and renormalize\n",
        "POSITION_SOFTMAX_TEMP = 2.5 # Base temperature scaling"
      ],
      "metadata": {
        "id": "Q6IrUhE7iOv_"
